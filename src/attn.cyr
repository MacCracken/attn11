# attn11 — causal multi-head self-attention (forward + backward)
#
# Source: Vaswani et al. (2017), "Attention Is All You Need", arXiv:1706.03762 —
# scaled dot-product attention score = (Q·K)/sqrt(hd), softmax, multi-head split.
# Grouped-query attention (nkv < nh): Ainslie et al. (2023), arXiv:2305.13245;
# multi-query (nkv = 1): Shazeer (2019), arXiv:1911.02150. See docs/sources.md.
#
# Single sequence of length T, embedding width C, nh query heads, head dim
# hd = C/nh, and nkv K/V heads (nkv divides nh; nkv == nh is classic MHA).
# Q/O projections are C x C; K/V projections are C x Ckv where Ckv = nkv*hd —
# each group of gsz = nh/nkv query heads shares one K/V head. Biases optional.
# Query heads occupy contiguous column blocks [h*hd, (h+1)*hd) of the (T,C)
# Q/concat tensors; K/V head g occupies [g*hd, (g+1)*hd) of the (T,Ckv) K/V.
#
# All forward caches and backward temporaries live in one pre-allocated arena
# (shapes are fixed across a training run, so we never alloc per step). Layout:
#   Qc              : T*C
#   Kc Vc           : T*Ckv each
#   Pc              : nh*T*T   (attention probabilities, causal-masked)
#   concat          : T*C      (pre-Wo head concatenation)
#   dconcat dQ      : T*C each (backward temporaries)
#   dK dV           : T*Ckv each
#   dxq dxk dxv     : T*C each
#   dprow           : T        (one softmax-row gradient scratch)

fn attn_arena_size(T, C, nh, nkv): i64 {
    var Ckv = nkv * (C / nh);
    # + 2*(C/nh)^2 for the gated-linear core's running S / reverse dS scratch
    # (M14; tiny, reused per-head; unused by the softmax/MLA paths).
    return 7 * T * C + 4 * T * Ckv + nh * T * T + T + 2 * (C / nh) * (C / nh);
}

# arena sub-pointers (deterministic given dims; Ckv = nkv * (C/nh))
fn _at_Qc(ar): i64 { return ar; }
fn _at_Kc(ar, T, C): i64 { return ar + (T * C) * 8; }
fn _at_Vc(ar, T, C, Ckv): i64 { return ar + (T * C + T * Ckv) * 8; }
fn _at_Pc(ar, T, C, Ckv): i64 { return ar + (T * C + 2 * T * Ckv) * 8; }
fn _at_concat(ar, T, C, nh, Ckv): i64 { return ar + (T * C + 2 * T * Ckv + nh * T * T) * 8; }
fn _at_dconcat(ar, T, C, nh, Ckv): i64 { return ar + (2 * T * C + 2 * T * Ckv + nh * T * T) * 8; }
fn _at_dQ(ar, T, C, nh, Ckv): i64 { return ar + (3 * T * C + 2 * T * Ckv + nh * T * T) * 8; }
fn _at_dK(ar, T, C, nh, Ckv): i64 { return ar + (4 * T * C + 2 * T * Ckv + nh * T * T) * 8; }
fn _at_dV(ar, T, C, nh, Ckv): i64 { return ar + (4 * T * C + 3 * T * Ckv + nh * T * T) * 8; }
fn _at_dxq(ar, T, C, nh, Ckv): i64 { return ar + (4 * T * C + 4 * T * Ckv + nh * T * T) * 8; }
fn _at_dxk(ar, T, C, nh, Ckv): i64 { return ar + (5 * T * C + 4 * T * Ckv + nh * T * T) * 8; }
fn _at_dxv(ar, T, C, nh, Ckv): i64 { return ar + (6 * T * C + 4 * T * Ckv + nh * T * T) * 8; }
fn _at_dprow(ar, T, C, nh, Ckv): i64 { return ar + (7 * T * C + 4 * T * Ckv + nh * T * T) * 8; }
# gated-linear scratch (M14): running state S and reverse accumulator dS, each
# (C/nh)^2, after dprow (the last softmax-path region).
fn _at_linS(ar, T, C, nh, Ckv): i64 { return ar + (7 * T * C + 4 * T * Ckv + nh * T * T + T) * 8; }
fn _at_lindS(ar, T, C, nh, Ckv): i64 { return _at_linS(ar, T, C, nh, Ckv) + (C / nh) * (C / nh) * 8; }

# ---- shared attention core (post-projection) --------------------------------
# Given Qc(T,C), Kc(T,Ckv), Vc(T,Ckv) it fills Pc(nh,T,T) and concat(T,C): causal
# scaled-dot-product, each query head h attending its shared K/V head
# kvb = (h/gsz)*hd. ONE source of truth for the per-head softmax/PV arithmetic —
# attn_fwd (MHA/GQA) calls it after the Q/K/V projections, and MLA calls it with
# nkv = nh / Ckv = C over up-projected full K/V, so the kernel never diverges
# (docs/architecture/003).
fn attn_core_fwd(Qc, Kc, Vc, Pc, concat, T, C, nh, nkv): i64 {
#ifndef CYRIUS_TARGET_AGNOS
    # GPU fused attention (causal MHA) under --gpu-tc; self-falls-back to CPU (GQA,
    # non-tileable T, or no device → -1). Causal only (g_bidir==0). TOLERANCE: in-shader exp.
    if (g_gpu_tc == 1) {
        if (g_bidir == 0) {
            if (gpu_attn_core(Qc, Kc, Vc, Pc, concat, T, C, nh, nkv) == 0) { return 0; }
        }
    }
#endif
    var hd = C / nh;
    var Ckv = nkv * hd;
    var gsz = nh / nkv;             # query heads per K/V head (GQA group size)
    var hd4 = hd - (hd % 4);        # head dim is contiguous -> 4-wide vector body
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd)));
    var acc[32];                    # 4-lane dot accumulator
    var pv[32];                     # 4-lane broadcast buffer

    # zero the full probability buffer (upper triangle stays 0)
    t_zero(Pc, nh * T * T);

    var h = 0;
    while (h < nh) {
        var base = h * hd;          # this query head's block in Q/concat
        var kvb = (h / gsz) * hd;   # its shared K/V head's block in Kc/Vc
        var i = 0;
        while (i < T) {
            var prow = Pc + (h * T + i) * T * 8;
            # CAUSAL (g_bidir == 0, today): query i attends keys j = 0..i.
            # BIDIRECTIONAL (g_bidir == 1, M15 diffusion): j = 0..T-1 (the full
            # square; Pc is already nh*T*T, so the off-diagonal is just filled in).
            # g_bidir is 1 only for MHA-diffusion (the loader/CLI reject mla/lin/ssm
            # + diffusion), so MLA — which also calls this core — stays causal.
            var jhi = i;
            if (g_bidir == 1) { jhi = T - 1; }
            # raw scores for j = 0..jhi
            var qbase = Qc + (i * C + base) * 8;
            var j = 0;
            while (j <= jhi) {
                var kbase = Kc + (j * Ckv + kvb) * 8;
                store64(&acc, f64_from(0)); store64(&acc + 8, f64_from(0));
                store64(&acc + 16, f64_from(0)); store64(&acc + 24, f64_from(0));
                var d = 0;
                while (d < hd4) {
                    f64v_fmadd(&acc, qbase + d * 8, kbase + d * 8, &acc, 4);
                    d = d + 4;
                }
                var dot = f64_add(f64_add(load64(&acc), load64(&acc + 8)),
                                  f64_add(load64(&acc + 16), load64(&acc + 24)));
                while (d < hd) {
                    dot = f64_add(dot, f64_mul(load64(qbase + d * 8), load64(kbase + d * 8)));
                    d = d + 1;
                }
                store64(prow + j * 8, f64_mul(dot, scale));
                j = j + 1;
            }
            # softmax over j = 0..jhi
            var mx = load64(prow);
            j = 1;
            while (j <= jhi) {
                var s = load64(prow + j * 8);
                if (f64_gt(s, mx) == 1) { mx = s; }
                j = j + 1;
            }
            var sum = f64_from(0);
            j = 0;
            while (j <= jhi) {
                var e = f64_exp(f64_sub(load64(prow + j * 8), mx));
                store64(prow + j * 8, e);
                sum = f64_add(sum, e);
                j = j + 1;
            }
            var inv = f64_div(f64_from(1), sum);
            j = 0;
            while (j <= jhi) { store64(prow + j * 8, f64_mul(load64(prow + j * 8), inv)); j = j + 1; }
            # concat[i, base+d] = sum_j P[i,j] * V[j, kvb+d]  (axpy over the
            # contiguous head dim d, broadcasting the scalar P[i,j] over j)
            var cbase = concat + (i * C + base) * 8;
            var dz = 0;
            while (dz < hd) { store64(cbase + dz * 8, f64_from(0)); dz = dz + 1; }
            j = 0;
            while (j <= jhi) {
                var pij = load64(prow + j * 8);
                store64(&pv, pij); store64(&pv + 8, pij);
                store64(&pv + 16, pij); store64(&pv + 24, pij);
                var vbase = Vc + (j * Ckv + kvb) * 8;
                var d = 0;
                while (d < hd4) {
                    f64v_fmadd(cbase + d * 8, &pv, vbase + d * 8, cbase + d * 8, 4);
                    d = d + 4;
                }
                while (d < hd) {
                    store64(cbase + d * 8, f64_add(load64(cbase + d * 8),
                                                   f64_mul(pij, load64(vbase + d * 8))));
                    d = d + 1;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        h = h + 1;
    }
    return 0;
}

# ---- rotary positional embedding (RoPE, coupled; ADR 0007 / M12 increment 4) -
# Source: Su et al. (2021), "RoFormer", arXiv:2104.09864. A position-dependent
# rotation applied to Q and K AFTER projection, BEFORE the score — so the score
# (R_m q)·(R_n k) depends only on the relative offset m-n. Parameter-free, so the
# only new gradient is the rotation's backward. attn11 uses the ORIGINAL
# interleaved convention: dimension pairs (2k, 2k+1) within each head rotate by
# angle m·θ_k, θ_k = base^(-2k/hd), base 10000 — so hd must be EVEN (gated in
# model_config_ok). The angle depends on (position, k, hd) only, not the head
# index, so all heads share it.
#
# PORTABLE TRIG: f64_sin/f64_cos are x86-only builtins (aarch64 has no native
# trig and v5.6.0 doesn't polyfill it, like the inverse-trig family — ganita
# note). We never need a general sin/cos: θ_k = base^(-2k/hd) ∈ (0, 1] rad and
# the multiplier m is an integer, so (1) cos θ_k / sin θ_k come from a Maclaurin
# series with NO range reduction (θ ≤ 1), then (2) (cos mθ, sin mθ) =
# (cos θ + i sin θ)^m by binary exponentiation. Pure f64 add/mul/div + f64_sqrt
# + f64_pow (all aarch64-polyfilled), deterministic on both arches. Because the
# rotation for absolute position m is computed DIRECTLY from m (not via a
# row-to-row recurrence), position m yields identical bits in the batch and the
# single-row cached paths, preserving bit-identity (docs/architecture/003).
fn ROPE_BASE(): i64 { return f64_from(10000); }

# Maclaurin cos/sin of theta ∈ (0,1] -> unit (cos,sin) into cout/sout. Series
# through θ^16 (cos) / θ^17 (sin) give ~1e-15 at θ=1; the result is renormalised
# to exactly unit magnitude so powering it cannot drift the magnitude.
fn _rope_unit_cossin(theta, cout, sout): i64 {
    var t2 = f64_mul(theta, theta);
    var one = f64_from(1);
    # sin(t) = t·(1 - t²/6(1 - t²/20(1 - t²/42(1 - t²/72(1 - t²/110(1 - t²/156(1 - t²/210(1 - t²/272))))))))
    var sp = f64_sub(one, f64_div(t2, f64_from(272)));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(210)), sp));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(156)), sp));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(110)), sp));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(72)), sp));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(42)), sp));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(20)), sp));
    sp = f64_sub(one, f64_mul(f64_div(t2, f64_from(6)), sp));
    var sv = f64_mul(theta, sp);
    # cos(t) = 1 - t²/2(1 - t²/12(1 - t²/30(1 - t²/56(1 - t²/90(1 - t²/132(1 - t²/182(1 - t²/240)))))))
    var cp = f64_sub(one, f64_div(t2, f64_from(240)));
    cp = f64_sub(one, f64_mul(f64_div(t2, f64_from(182)), cp));
    cp = f64_sub(one, f64_mul(f64_div(t2, f64_from(132)), cp));
    cp = f64_sub(one, f64_mul(f64_div(t2, f64_from(90)), cp));
    cp = f64_sub(one, f64_mul(f64_div(t2, f64_from(56)), cp));
    cp = f64_sub(one, f64_mul(f64_div(t2, f64_from(30)), cp));
    cp = f64_sub(one, f64_mul(f64_div(t2, f64_from(12)), cp));
    var cv = f64_sub(one, f64_mul(f64_div(t2, f64_from(2)), cp));
    var nrm = f64_div(one, f64_sqrt(f64_add(f64_mul(cv, cv), f64_mul(sv, sv))));
    store64(cout, f64_mul(cv, nrm));
    store64(sout, f64_mul(sv, nrm));
    return 0;
}

# (cos mθ, sin mθ) = (c0 + i·s0)^m by binary exponentiation, into cout/sout.
# m == 0 -> (1, 0). Complex multiply (a+ib)(c+id) = (ac-bd) + i(ad+bc).
fn _rope_pow(c0, s0, m, cout, sout): i64 {
    var rc = f64_from(1); var rs = f64_from(0);   # identity
    var bc = c0; var bs = s0;                     # running base
    var e = m;
    while (e > 0) {
        if ((e % 2) == 1) {
            var nrc = f64_sub(f64_mul(rc, bc), f64_mul(rs, bs));
            var nrs = f64_add(f64_mul(rc, bs), f64_mul(rs, bc));
            rc = nrc; rs = nrs;
        }
        var sbc = f64_sub(f64_mul(bc, bc), f64_mul(bs, bs));
        var sbs = f64_add(f64_mul(bc, bs), f64_mul(bs, bc));
        bc = sbc; bs = sbs;
        e = e / 2;
    }
    store64(cout, rc); store64(sout, rs);
    return 0;
}

# Rotate X(rows, width) in place: each row r is at absolute position pos0+r, each
# head occupies a contiguous hd = width/num_heads block, each (2k,2k+1) pair
# rotates by (pos0+r)·θ_k. Used for Q (width=C, heads=nh) and K (width=Ckv,
# heads=nkv) — both with the same hd, hence the same θ_k.
fn rope_apply_fwd(X, rows, pos0, width, num_heads): i64 {
    var hd = width / num_heads;
    var hdp = hd / 2;
    var base = ROPE_BASE();
    var cs[32];                     # [c0, s0, c, s] scratch
    var k = 0;
    while (k < hdp) {
        # θ_k = base^(-(2k)/hd); base rotation (cos θ_k, sin θ_k) once per k
        var ex = f64_div(f64_from(0 - (2 * k)), f64_from(hd));
        var th = f64_pow(base, ex);
        _rope_unit_cossin(th, &cs, &cs + 8);
        var r = 0;
        while (r < rows) {
            _rope_pow(load64(&cs), load64(&cs + 8), pos0 + r, &cs + 16, &cs + 24);
            var c = load64(&cs + 16); var s = load64(&cs + 24);
            var h = 0;
            while (h < num_heads) {
                var p = X + (r * width + h * hd + 2 * k) * 8;
                var x0 = load64(p); var x1 = load64(p + 8);
                store64(p,     f64_sub(f64_mul(x0, c), f64_mul(x1, s)));
                store64(p + 8, f64_add(f64_mul(x0, s), f64_mul(x1, c)));
                h = h + 1;
            }
            r = r + 1;
        }
        k = k + 1;
    }
    return 0;
}

# Backward of rope_apply_fwd: the rotation is linear and orthogonal, so the
# gradient w.r.t. the pre-rotation input is the TRANSPOSE rotation R(-angle).
# y0 = x0·c - x1·s, y1 = x0·s + x1·c  =>  dx0 = dy0·c + dy1·s, dx1 = dy1·c - dy0·s.
# In place: dX (= dY on entry) becomes dX (the pre-rotation gradient). Uses the
# SAME cos/sin path as the forward, so the rotation values match bit-for-bit.
fn rope_apply_bwd(dX, rows, pos0, width, num_heads): i64 {
    var hd = width / num_heads;
    var hdp = hd / 2;
    var base = ROPE_BASE();
    var cs[32];                     # [c0, s0, c, s] scratch
    var k = 0;
    while (k < hdp) {
        var ex = f64_div(f64_from(0 - (2 * k)), f64_from(hd));
        var th = f64_pow(base, ex);
        _rope_unit_cossin(th, &cs, &cs + 8);
        var r = 0;
        while (r < rows) {
            _rope_pow(load64(&cs), load64(&cs + 8), pos0 + r, &cs + 16, &cs + 24);
            var c = load64(&cs + 16); var s = load64(&cs + 24);
            var h = 0;
            while (h < num_heads) {
                var p = dX + (r * width + h * hd + 2 * k) * 8;
                var d0 = load64(p); var d1 = load64(p + 8);
                store64(p,     f64_add(f64_mul(d0, c), f64_mul(d1, s)));
                store64(p + 8, f64_sub(f64_mul(d1, c), f64_mul(d0, s)));
                h = h + 1;
            }
            r = r + 1;
        }
        k = k + 1;
    }
    return 0;
}

# ---- forward (MHA / GQA) ----------------------------------------------------
# x(T,C) -> out(T,C). Projects Q/K/V, runs the shared core, applies Wo. Fills
# caches in `ar` for the backward pass. Bias pointers bq/bk/bv/bo may be 0.
# pos_kind: 0 = learned-abs positions applied at the embedding (no rotation here);
# 1 = coupled RoPE (rotate Q/K by absolute position before the score).
fn attn_fwd(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, ar, T, C, nh, nkv, pos_kind): i64 {
    var Ckv = nkv * (C / nh);
    var Qc = _at_Qc(ar);
    var Kc = _at_Kc(ar, T, C);
    var Vc = _at_Vc(ar, T, C, Ckv);
    var Pc = _at_Pc(ar, T, C, Ckv);
    var concat = _at_concat(ar, T, C, nh, Ckv);
    qlinear_fwd(x, Wq, bq, Qc, T, C, C);
    qlinear_fwd(x, Wk, bk, Kc, T, C, Ckv);
    qlinear_fwd(x, Wv, bv, Vc, T, C, Ckv);
    if (pos_kind == 1) {                # coupled RoPE: rotate Q/K (not V) in place
        rope_apply_fwd(Qc, T, 0, C, nh);
        rope_apply_fwd(Kc, T, 0, Ckv, nkv);
    }
    attn_core_fwd(Qc, Kc, Vc, Pc, concat, T, C, nh, nkv);
    qlinear_fwd(concat, Wo, bo, out, T, C, C);
    return 0;
}

# ---- shared single-row attention core (post-projection) ---------------------
# Given the query row q_row(C) at window position `pos` and the K/V caches
# Kc/Vc ((>=pos+1, Ckv), holding positions 0..pos), fill concat_row(C): the
# per-head causal softmax/PV for ONE query attending cache rows 0..pos. The
# single-row mirror of attn_core_fwd — ONE source of truth for the cached
# per-head arithmetic (docs/architecture/003): attn_fwd_row (MHA/GQA) calls it
# after projecting K/V into the cache; attn_mla_fwd_row calls it with nkv = nh /
# Ckv = C over up-projected full K/V. prow: caller scratch (>= pos+1 f64).
fn attn_core_fwd_row(q_row, Kc, Vc, prow, concat_row, pos, C, nh, nkv): i64 {
    var hd = C / nh;
    var Ckv = nkv * hd;
    var gsz = nh / nkv;
    var hd4 = hd - (hd % 4);
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd)));
    var acc[32];                    # 4-lane dot accumulator
    var pv[32];                     # 4-lane broadcast buffer
    var h = 0;
    while (h < nh) {
        var base = h * hd;          # this query head's block in q_row/concat_row
        var kvb = (h / gsz) * hd;   # its shared K/V head's block in Kc/Vc
        # raw scores for cache rows j = 0..pos
        var qbase = q_row + base * 8;
        var j = 0;
        while (j <= pos) {
            var kbase = Kc + (j * Ckv + kvb) * 8;
            store64(&acc, f64_from(0)); store64(&acc + 8, f64_from(0));
            store64(&acc + 16, f64_from(0)); store64(&acc + 24, f64_from(0));
            var d = 0;
            while (d < hd4) {
                f64v_fmadd(&acc, qbase + d * 8, kbase + d * 8, &acc, 4);
                d = d + 4;
            }
            var dot = f64_add(f64_add(load64(&acc), load64(&acc + 8)),
                              f64_add(load64(&acc + 16), load64(&acc + 24)));
            while (d < hd) {
                dot = f64_add(dot, f64_mul(load64(qbase + d * 8), load64(kbase + d * 8)));
                d = d + 1;
            }
            store64(prow + j * 8, f64_mul(dot, scale));
            j = j + 1;
        }
        # softmax over j = 0..pos
        var mx = load64(prow);
        j = 1;
        while (j <= pos) {
            var s = load64(prow + j * 8);
            if (f64_gt(s, mx) == 1) { mx = s; }
            j = j + 1;
        }
        var sum = f64_from(0);
        j = 0;
        while (j <= pos) {
            var e = f64_exp(f64_sub(load64(prow + j * 8), mx));
            store64(prow + j * 8, e);
            sum = f64_add(sum, e);
            j = j + 1;
        }
        var inv = f64_div(f64_from(1), sum);
        j = 0;
        while (j <= pos) { store64(prow + j * 8, f64_mul(load64(prow + j * 8), inv)); j = j + 1; }
        # concat_row[base+d] = sum_j P[j] * V[j, kvb+d]
        var cbase = concat_row + base * 8;
        var dz = 0;
        while (dz < hd) { store64(cbase + dz * 8, f64_from(0)); dz = dz + 1; }
        j = 0;
        while (j <= pos) {
            var pij = load64(prow + j * 8);
            store64(&pv, pij); store64(&pv + 8, pij);
            store64(&pv + 16, pij); store64(&pv + 24, pij);
            var vbase = Vc + (j * Ckv + kvb) * 8;
            var d = 0;
            while (d < hd4) {
                f64v_fmadd(cbase + d * 8, &pv, vbase + d * 8, cbase + d * 8, 4);
                d = d + 4;
            }
            while (d < hd) {
                store64(cbase + d * 8, f64_add(load64(cbase + d * 8),
                                               f64_mul(pij, load64(vbase + d * 8))));
                d = d + 1;
            }
            j = j + 1;
        }
        h = h + 1;
    }
    return 0;
}

# ---- cached single-row forward, MHA/GQA (inference) --------------------------
# E1 (KV-cached generation): process ONE new position `pos` — x_row(1,C) ->
# out_row(1,C) — appending this position's K/V rows to the caller-owned caches
# Kc/Vc ((T,Ckv), must already hold positions 0..pos-1) and attending over
# cache rows 0..pos. Source: Pope et al. (2022), arXiv:2211.05102 (KV-cache
# inference); see docs/sources.md. Generation-only: writes no backward caches.
# prow: caller scratch (>= pos+1 f64); concat_row/q_row: C-f64 scratch.
#
# ARITHMETIC CONTRACT: bit-identical per row to attn_fwd — same kernels, same
# accumulation order (linear_fwd rows are independent, so a 1-row call matches
# row `pos` of a T-row call bit-for-bit). With coupled RoPE (pos_kind == 1) the
# query row and the newly-appended K row are rotated by absolute position `pos`
# (cached K rows 0..pos-1 were rotated when they were appended), matching the
# uncached path's per-row rotation. Pinned by the cached-vs-uncached generation
# tests in tests/attn11.tcyr.
fn attn_fwd_row(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x_row, out_row,
                Kc, Vc, prow, concat_row, q_row, pos, C, nh, nkv, pos_kind): i64 {
    var Ckv = nkv * (C / nh);
    qlinear_fwd(x_row, Wq, bq, q_row, 1, C, C);
    qlinear_fwd(x_row, Wk, bk, Kc + pos * Ckv * 8, 1, C, Ckv);
    qlinear_fwd(x_row, Wv, bv, Vc + pos * Ckv * 8, 1, C, Ckv);
    if (pos_kind == 1) {                # coupled RoPE: rotate this row's Q and K
        rope_apply_fwd(q_row, 1, pos, C, nh);
        rope_apply_fwd(Kc + pos * Ckv * 8, 1, pos, Ckv, nkv);
    }
    attn_core_fwd_row(q_row, Kc, Vc, prow, concat_row, pos, C, nh, nkv);
    qlinear_fwd(concat_row, Wo, bo, out_row, 1, C, C);
    return 0;
}

# ---- cached single-row forward, MLA (inference, M12.2) -----------------------
# The latent KV-cache decode (ADR 0007): the persistent per-token cache is the
# low-rank latent `c` (d_c per token), NOT full per-head K/V. Process position
# `pos`: down-project x_row -> c_row, APPEND it to the caller-owned latent cache
# c_cache ((T,d_c), holding latents 0..pos-1), then up-project the full cached
# latent block 0..pos to per-head K/V into the transient scratch Kc/Vc ((T,C))
# and run the shared single-row core (full heads, Ckv == C). The K/V scratch is
# decode working set, re-derived from the latents each step (Wuk/Wuv are fixed
# during generation) — it is not persisted, so the stored cache stays d_c-wide.
#
# ARITHMETIC CONTRACT: bit-identical per row to attn_mla_fwd. linear_fwd rows
# are independent, so the 1-row down-projection at `pos` and the (pos+1)-row
# up-projection match rows `pos` / `0..pos` of the uncached T-row path bit-for-
# bit, and the core mirrors attn_core_fwd. Pinned by the MLA cached-vs-uncached
# generation tests in tests/attn11.tcyr.
fn attn_mla_fwd_row(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x_row, out_row,
                    c_cache, Kc, Vc, prow, concat_row, q_row, pos, C, nh, d_c): i64 {
    var n = pos + 1;
    linear_fwd(x_row, Wq, bq, q_row, 1, C, C);                    # Q = x @ Wq
    linear_fwd(x_row, Wdkv, 0, c_cache + pos * d_c * 8, 1, C, d_c); # c = x @ W_DKV (append)
    linear_fwd(c_cache, Wuk, buk, Kc, n, d_c, C);                 # K = c @ W_UK (up, all rows)
    linear_fwd(c_cache, Wuv, buv, Vc, n, d_c, C);                 # V = c @ W_UV (up, all rows)
    attn_core_fwd_row(q_row, Kc, Vc, prow, concat_row, pos, C, nh, nh);
    linear_fwd(concat_row, Wo, bo, out_row, 1, C, C);
    return 0;
}

# ---- shared attention core backward (post-projection) -----------------------
# dconcat(T,C) + the forward caches -> dQ(T,C), dK(T,Ckv), dV(T,Ckv) (incl. the
# softmax backward). The mirror of attn_core_fwd; with nkv < nh the gsz query
# heads of a group all accumulate into the same dK/dV columns — the head loop is
# sequential, so the accumulation order is deterministic. Shared by attn_bwd
# (MHA/GQA) and the MLA backward.
fn attn_core_bwd(Qc, Kc, Vc, Pc, dconcat, dQ, dK, dV, dprow, T, C, nh, nkv): i64 {
#ifndef CYRIUS_TARGET_AGNOS
    # GPU attention backward (causal MHA) under --gpu-tc; self-falls-back (GQA, T>32, bidir, no
    # device). TOLERANCE (P carries the in-shader-exp tolerance + sequential vs tree dots).
    if (g_gpu_tc == 1) {
        if (g_bidir == 0) {
            if (gpu_attn_core_bwd(Qc, Kc, Vc, Pc, dconcat, dQ, dK, dV, dprow, T, C, nh, nkv) == 0) { return 0; }
        }
    }
#endif
    var hd = C / nh;
    var Ckv = nkv * hd;
    var gsz = nh / nkv;
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd)));
    var hd4 = hd - (hd % 4);
    var bb[32];                     # 4-lane broadcast buffer
    var dacc[32];                   # 4-lane dot accumulator

    t_zero(dQ, T * C);
    t_zero(dK, T * Ckv);
    t_zero(dV, T * Ckv);

    var h = 0;
    while (h < nh) {
        var base = h * hd;
        var kvb = (h / gsz) * hd;
        var i = 0;
        while (i < T) {
            var prow = Pc + (h * T + i) * T * 8;
            # dP[i,j] = sum_d dconcat[i,base+d]*V[j,kvb+d]  (dot over d)
            # dV[j,kvb+d] += P[i,j]*dconcat[i,base+d]       (axpy over d)
            var dcbase = dconcat + (i * C + base) * 8;
            # CAUSAL: j = 0..i. BIDIRECTIONAL (g_bidir==1, diffusion): j = 0..T-1 —
            # mirroring attn_core_fwd. The dotPdP softmax sum below MUST use the SAME
            # jhi range as the forward normalized over, else the off-diagonal
            # (future-position) gradient terms come out wrong (M15 grad-check pins).
            var jhi = i;
            if (g_bidir == 1) { jhi = T - 1; }
            var j = 0;
            while (j <= jhi) {
                var pij = load64(prow + j * 8);
                store64(&bb, pij); store64(&bb + 8, pij);
                store64(&bb + 16, pij); store64(&bb + 24, pij);
                store64(&dacc, f64_from(0)); store64(&dacc + 8, f64_from(0));
                store64(&dacc + 16, f64_from(0)); store64(&dacc + 24, f64_from(0));
                var vbase = Vc + (j * Ckv + kvb) * 8;
                var dvbase = dV + (j * Ckv + kvb) * 8;
                var d = 0;
                while (d < hd4) {
                    f64v_fmadd(dvbase + d * 8, &bb, dcbase + d * 8, dvbase + d * 8, 4);
                    f64v_fmadd(&dacc, dcbase + d * 8, vbase + d * 8, &dacc, 4);
                    d = d + 4;
                }
                var dpj = f64_add(f64_add(load64(&dacc), load64(&dacc + 8)),
                                  f64_add(load64(&dacc + 16), load64(&dacc + 24)));
                while (d < hd) {
                    var dc = load64(dcbase + d * 8);
                    dpj = f64_add(dpj, f64_mul(dc, load64(vbase + d * 8)));
                    store64(dvbase + d * 8, f64_add(load64(dvbase + d * 8), f64_mul(pij, dc)));
                    d = d + 1;
                }
                store64(dprow + j * 8, dpj);
                j = j + 1;
            }
            # softmax backward: dscore[j] = P[j]*(dP[j] - sum_k P[k]*dP[k])
            var dotPdP = f64_from(0);
            j = 0;
            while (j <= jhi) {
                dotPdP = f64_add(dotPdP, f64_mul(load64(prow + j * 8), load64(dprow + j * 8)));
                j = j + 1;
            }
            var dqbase = dQ + (i * C + base) * 8;
            var qbase2 = Qc + (i * C + base) * 8;
            j = 0;
            while (j <= jhi) {
                var ds = f64_mul(load64(prow + j * 8), f64_sub(load64(dprow + j * 8), dotPdP));
                var sds = f64_mul(scale, ds);
                # dQ[i,base+d] += sds*K[j,kvb+d]; dK[j,kvb+d] += sds*Q[i,base+d]
                store64(&bb, sds); store64(&bb + 8, sds);
                store64(&bb + 16, sds); store64(&bb + 24, sds);
                var kbase = Kc + (j * Ckv + kvb) * 8;
                var dkbase = dK + (j * Ckv + kvb) * 8;
                var d = 0;
                while (d < hd4) {
                    f64v_fmadd(dqbase + d * 8, &bb, kbase + d * 8, dqbase + d * 8, 4);
                    f64v_fmadd(dkbase + d * 8, &bb, qbase2 + d * 8, dkbase + d * 8, 4);
                    d = d + 4;
                }
                while (d < hd) {
                    store64(dqbase + d * 8, f64_add(load64(dqbase + d * 8),
                                                    f64_mul(sds, load64(kbase + d * 8))));
                    store64(dkbase + d * 8, f64_add(load64(dkbase + d * 8),
                                                    f64_mul(sds, load64(qbase2 + d * 8))));
                    d = d + 1;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        h = h + 1;
    }

    return 0;
}

# ---- backward (MHA / GQA) ---------------------------------------------------
# dout(T,C) -> dx(T,C); accumulate dWq..dWo and (if non-0) dbq..dbo. Back through
# Wo, the shared core, then the Q/K/V projections. Uses caches from attn_fwd.
fn attn_bwd(Wq, Wk, Wv, Wo, x, dout, dx,
            dWq, dbq, dWk, dbk, dWv, dbv, dWo, dbo, ar, T, C, nh, nkv, pos_kind): i64 {
    var Ckv = nkv * (C / nh);
    var Qc = _at_Qc(ar);
    var Kc = _at_Kc(ar, T, C);
    var Vc = _at_Vc(ar, T, C, Ckv);
    var Pc = _at_Pc(ar, T, C, Ckv);
    var concat = _at_concat(ar, T, C, nh, Ckv);
    var dconcat = _at_dconcat(ar, T, C, nh, Ckv);
    var dQ = _at_dQ(ar, T, C, nh, Ckv);
    var dK = _at_dK(ar, T, C, nh, Ckv);
    var dV = _at_dV(ar, T, C, nh, Ckv);
    var dxq = _at_dxq(ar, T, C, nh, Ckv);
    var dxk = _at_dxk(ar, T, C, nh, Ckv);
    var dxv = _at_dxv(ar, T, C, nh, Ckv);
    var dprow = _at_dprow(ar, T, C, nh, Ckv);
    # 1. out = concat @ Wo
    qlinear_bwd(concat, Wo, dout, dconcat, dWo, dbo, T, C, C);
    # 2-4. attention core: dconcat -> dQ, dK, dV (incl. softmax backward). Qc/Kc
    # in the arena are the ROTATED forward values (RoPE rewrote them in place), so
    # dQ/dK come out w.r.t. the rotated Q/K.
    attn_core_bwd(Qc, Kc, Vc, Pc, dconcat, dQ, dK, dV, dprow, T, C, nh, nkv);
    if (pos_kind == 1) {               # undo the rotation: dQ/dK -> pre-rotation grad
        rope_apply_bwd(dQ, T, 0, C, nh);
        rope_apply_bwd(dK, T, 0, Ckv, nkv);
    }
    # 5. back through Q=x@Wq, K=x@Wk, V=x@Wv; accumulate dx
    qlinear_bwd(x, Wq, dQ, dxq, dWq, dbq, T, C, C);
    qlinear_bwd(x, Wk, dK, dxk, dWk, dbk, T, C, Ckv);
    qlinear_bwd(x, Wv, dV, dxv, dWv, dbv, T, C, Ckv);
    var idx = 0;
    while (idx < T * C) {
        store64(dx + idx * 8, f64_add(f64_add(load64(dxq + idx * 8), load64(dxk + idx * 8)),
                                      load64(dxv + idx * 8)));
        idx = idx + 1;
    }
    return 0;
}

# ---- forward (MLA) ----------------------------------------------------------
# Multi-head latent attention (ADR 0007). K/V are NOT projected from x directly;
# instead x is down-projected to a low-rank latent c (C -> d_c), which is
# up-projected to full per-head K and V (d_c -> C). c is the caller-owned
# per-layer buffer (T*d_c) that the cache would store; here it also feeds the
# backward. nkv == nh (full heads); Ckv == C. Reuses attn_core_fwd, so the
# softmax/PV kernel is identical to MHA. Biases: bq on Q, buk/buv on the up-K/V
# (size C), bo on Wo; the down-projection W_DKV is bias-free.
fn attn_mla_fwd(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, ar, c, T, C, nh, d_c): i64 {
    var Qc = _at_Qc(ar);
    var Kc = _at_Kc(ar, T, C);
    var Vc = _at_Vc(ar, T, C, C);
    var Pc = _at_Pc(ar, T, C, C);
    var concat = _at_concat(ar, T, C, nh, C);
    linear_fwd(x, Wq, bq, Qc, T, C, C);            # Q = x @ Wq
    linear_fwd(x, Wdkv, 0, c, T, C, d_c);          # c = x @ W_DKV   (down-project, no bias)
    linear_fwd(c, Wuk, buk, Kc, T, d_c, C);        # K = c @ W_UK    (up-project)
    linear_fwd(c, Wuv, buv, Vc, T, d_c, C);        # V = c @ W_UV
    attn_core_fwd(Qc, Kc, Vc, Pc, concat, T, C, nh, nh);
    linear_fwd(concat, Wo, bo, out, T, C, C);
    return 0;
}

# ---- backward (MLA) ---------------------------------------------------------
# Mirror of attn_mla_fwd. dlat1/dlat2 are caller-owned T*d_c scratch; the dxk
# arena slot (free in MLA) holds dx-from-c. Every step is matmul-backward
# (linear_bwd) over the same caches, so the new gradient composes from already
# grad-checked ops (no novel hand-derived math).
fn attn_mla_bwd(Wq, Wdkv, Wuk, Wuv, Wo, x, dout, dx,
                dWq, dbq, dWdkv, dWuk, dbuk, dWuv, dbuv, dWo, dbo,
                ar, c, dlat1, dlat2, T, C, nh, d_c): i64 {
    var Qc = _at_Qc(ar);
    var Kc = _at_Kc(ar, T, C);
    var Vc = _at_Vc(ar, T, C, C);
    var Pc = _at_Pc(ar, T, C, C);
    var concat = _at_concat(ar, T, C, nh, C);
    var dconcat = _at_dconcat(ar, T, C, nh, C);
    var dQ = _at_dQ(ar, T, C, nh, C);
    var dK = _at_dK(ar, T, C, nh, C);
    var dV = _at_dV(ar, T, C, nh, C);
    var dxq = _at_dxq(ar, T, C, nh, C);
    var dxc = _at_dxk(ar, T, C, nh, C);            # reuse the dxk slot (T*C) for dx-from-c
    var dprow = _at_dprow(ar, T, C, nh, C);
    # 1. out = concat @ Wo
    linear_bwd(concat, Wo, dout, dconcat, dWo, dbo, T, C, C);
    # 2. core: dconcat -> dQ, dK, dV (incl. softmax backward)
    attn_core_bwd(Qc, Kc, Vc, Pc, dconcat, dQ, dK, dV, dprow, T, C, nh, nh);
    # 3. up-projections K=c@W_UK, V=c@W_UV -> dW_UK/dW_UV, dbk/dbv, and dc (latent)
    linear_bwd(c, Wuk, dK, dlat1, dWuk, dbuk, T, d_c, C);
    linear_bwd(c, Wuv, dV, dlat2, dWuv, dbuv, T, d_c, C);
    var idx = 0;
    while (idx < T * d_c) {                        # dc = dc_from_K + dc_from_V
        store64(dlat1 + idx * 8, f64_add(load64(dlat1 + idx * 8), load64(dlat2 + idx * 8)));
        idx = idx + 1;
    }
    # 4. down-projection c=x@W_DKV -> dW_DKV (no bias) and dx-from-c
    linear_bwd(x, Wdkv, dlat1, dxc, dWdkv, 0, T, C, d_c);
    # 5. query Q=x@Wq -> dWq, dbq, dx-from-q
    linear_bwd(x, Wq, dQ, dxq, dWq, dbq, T, C, C);
    # 6. dx = dx-from-q + dx-from-c
    idx = 0;
    while (idx < T * C) {
        store64(dx + idx * 8, f64_add(load64(dxq + idx * 8), load64(dxc + idx * 8)));
        idx = idx + 1;
    }
    return 0;
}

# ---- decoupled-RoPE attention core (MLA, M12 increment 5; ADR 0007) ----------
# DeepSeek-V2 decoupled RoPE (arXiv:2405.04434): the score splits into a CONTENT
# term over the compressed per-head K (Qc·Kc, dim hd) plus a POSITION term over a
# separate rope channel (Qr·Kr, dim d_rope), summed and scaled by
# 1/sqrt(hd + d_rope). The rope channel carries position OUTSIDE the latent —
# Qr is per-head (nh blocks of d_rope), Kr is SHARED across heads (one d_rope row
# per token) and computed from x directly — so the latent stays absorbable and
# the cache stays small (latent d_c + the shared d_rope, vs full K/V). V is
# content-only (no rope part), so the PV step is unchanged. Scalar dots (d_rope
# and hd are small); its own kernel because the two-term score + different scale
# differ from attn_core. Qr/Kr arrive ALREADY rotated (RoPE applied before this).
fn attn_dec_core_fwd(Qc, Kc, Vc, Qr, Kr, Pc, concat, T, C, nh, d_rope): i64 {
    var hd = C / nh;
    var dr = nh * d_rope;                # Qr row stride (per-head rope blocks)
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd + d_rope)));
    t_zero(Pc, nh * T * T);
    var h = 0;
    while (h < nh) {
        var base = h * hd;               # content block in Qc/Kc/concat
        var rbase = h * d_rope;          # this head's rope block in Qr (Kr is shared)
        var i = 0;
        while (i < T) {
            var prow = Pc + (h * T + i) * T * 8;
            var qb = Qc + (i * C + base) * 8;
            var qrb = Qr + (i * dr + rbase) * 8;
            var j = 0;
            while (j <= i) {
                var dot = f64_from(0);
                var kb = Kc + (j * C + base) * 8;
                var d = 0;
                while (d < hd) { dot = f64_add(dot, f64_mul(load64(qb + d * 8), load64(kb + d * 8))); d = d + 1; }
                var krb = Kr + (j * d_rope) * 8;
                var e = 0;
                while (e < d_rope) { dot = f64_add(dot, f64_mul(load64(qrb + e * 8), load64(krb + e * 8))); e = e + 1; }
                store64(prow + j * 8, f64_mul(dot, scale));
                j = j + 1;
            }
            # softmax over j = 0..i
            var mx = load64(prow);
            j = 1;
            while (j <= i) { var s = load64(prow + j * 8); if (f64_gt(s, mx) == 1) { mx = s; } j = j + 1; }
            var sum = f64_from(0);
            j = 0;
            while (j <= i) {
                var ex = f64_exp(f64_sub(load64(prow + j * 8), mx));
                store64(prow + j * 8, ex); sum = f64_add(sum, ex); j = j + 1;
            }
            var inv = f64_div(f64_from(1), sum);
            j = 0;
            while (j <= i) { store64(prow + j * 8, f64_mul(load64(prow + j * 8), inv)); j = j + 1; }
            # concat[i,base+d] = sum_j P[i,j] * Vc[j,base+d]   (content-only V)
            var cb = concat + (i * C + base) * 8;
            var dz = 0;
            while (dz < hd) { store64(cb + dz * 8, f64_from(0)); dz = dz + 1; }
            j = 0;
            while (j <= i) {
                var pij = load64(prow + j * 8);
                var vb = Vc + (j * C + base) * 8;
                var d = 0;
                while (d < hd) {
                    store64(cb + d * 8, f64_add(load64(cb + d * 8), f64_mul(pij, load64(vb + d * 8))));
                    d = d + 1;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        h = h + 1;
    }
    return 0;
}

# Backward of attn_dec_core_fwd. dconcat -> dQc/dKc/dVc (content) + dQr/dKr (rope).
# dKr accumulates ACROSS heads (the rope key is shared) — the head loop is
# sequential, so the order is deterministic. Mirror of the forward; the only new
# terms vs attn_core_bwd are the rope dot's contributions to dQr/dKr.
fn attn_dec_core_bwd(Qc, Kc, Vc, Qr, Kr, Pc, dconcat, dQc, dKc, dVc, dQr, dKr, dprow, T, C, nh, d_rope): i64 {
    var hd = C / nh;
    var dr = nh * d_rope;
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd + d_rope)));
    t_zero(dQc, T * C);
    t_zero(dKc, T * C);
    t_zero(dVc, T * C);
    t_zero(dQr, T * dr);
    t_zero(dKr, T * d_rope);
    var h = 0;
    while (h < nh) {
        var base = h * hd;
        var rbase = h * d_rope;
        var i = 0;
        while (i < T) {
            var prow = Pc + (h * T + i) * T * 8;
            var dcb = dconcat + (i * C + base) * 8;
            # dP[i,j] = sum_d dconcat[i,base+d]*Vc[j,base+d]; dVc[j,base+d] += P[i,j]*dconcat[i,base+d]
            var j = 0;
            while (j <= i) {
                var pij = load64(prow + j * 8);
                var vb = Vc + (j * C + base) * 8;
                var dvb = dVc + (j * C + base) * 8;
                var dpj = f64_from(0);
                var d = 0;
                while (d < hd) {
                    var dcd = load64(dcb + d * 8);
                    dpj = f64_add(dpj, f64_mul(dcd, load64(vb + d * 8)));
                    store64(dvb + d * 8, f64_add(load64(dvb + d * 8), f64_mul(pij, dcd)));
                    d = d + 1;
                }
                store64(dprow + j * 8, dpj);
                j = j + 1;
            }
            # softmax backward: dscore[j] = P[j]*(dP[j] - sum_k P[k]*dP[k])
            var dotPdP = f64_from(0);
            j = 0;
            while (j <= i) {
                dotPdP = f64_add(dotPdP, f64_mul(load64(prow + j * 8), load64(dprow + j * 8)));
                j = j + 1;
            }
            var dqb = dQc + (i * C + base) * 8;
            var qb = Qc + (i * C + base) * 8;
            var dqrb = dQr + (i * dr + rbase) * 8;
            var qrb = Qr + (i * dr + rbase) * 8;
            j = 0;
            while (j <= i) {
                var ds = f64_mul(scale, f64_mul(load64(prow + j * 8), f64_sub(load64(dprow + j * 8), dotPdP)));
                # content: dQc[i,base+d] += ds*Kc[j,base+d]; dKc[j,base+d] += ds*Qc[i,base+d]
                var kb = Kc + (j * C + base) * 8;
                var dkb = dKc + (j * C + base) * 8;
                var d = 0;
                while (d < hd) {
                    store64(dqb + d * 8, f64_add(load64(dqb + d * 8), f64_mul(ds, load64(kb + d * 8))));
                    store64(dkb + d * 8, f64_add(load64(dkb + d * 8), f64_mul(ds, load64(qb + d * 8))));
                    d = d + 1;
                }
                # rope: dQr[i,rbase+e] += ds*Kr[j,e]; dKr[j,e] += ds*Qr[i,rbase+e]  (dKr shared)
                var krb = Kr + (j * d_rope) * 8;
                var dkrb = dKr + (j * d_rope) * 8;
                var e = 0;
                while (e < d_rope) {
                    store64(dqrb + e * 8, f64_add(load64(dqrb + e * 8), f64_mul(ds, load64(krb + e * 8))));
                    store64(dkrb + e * 8, f64_add(load64(dkrb + e * 8), f64_mul(ds, load64(qrb + e * 8))));
                    e = e + 1;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        h = h + 1;
    }
    return 0;
}

# ---- forward (MLA + decoupled RoPE) -----------------------------------------
# Content path is MLA (down C->d_c, up d_c->C, full heads); the rope path adds
# Qr = RoPE(x @ W_QR)  (C -> nh*d_rope, per-head) and the SHARED
# Kr = RoPE(x @ W_KR)  (C -> d_rope) computed from x directly. W_QR/W_KR are
# bias-free. c (latent) and kr (rope key) are the caller-owned cache buffers.
fn attn_mla_dec_fwd(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo,
                    x, out, ar, c, qr, kr, T, C, nh, d_c, d_rope): i64 {
    var Qc = _at_Qc(ar);
    var Kc = _at_Kc(ar, T, C);
    var Vc = _at_Vc(ar, T, C, C);
    var Pc = _at_Pc(ar, T, C, C);
    var concat = _at_concat(ar, T, C, nh, C);
    linear_fwd(x, Wq, bq, Qc, T, C, C);            # content query
    linear_fwd(x, Wdkv, 0, c, T, C, d_c);          # latent
    linear_fwd(c, Wuk, buk, Kc, T, d_c, C);        # content key (up)
    linear_fwd(c, Wuv, buv, Vc, T, d_c, C);        # value (up)
    linear_fwd(x, Wqr, 0, qr, T, C, nh * d_rope);  # rope query (per-head)
    linear_fwd(x, Wkr, 0, kr, T, C, d_rope);       # rope key (shared)
    rope_apply_fwd(qr, T, 0, nh * d_rope, nh);     # rotate each head's d_rope block
    rope_apply_fwd(kr, T, 0, d_rope, 1);           # rotate the shared d_rope block
    attn_dec_core_fwd(Qc, Kc, Vc, qr, kr, Pc, concat, T, C, nh, d_rope);
    linear_fwd(concat, Wo, bo, out, T, C, C);
    return 0;
}

# ---- backward (MLA + decoupled RoPE) ----------------------------------------
# Mirror of attn_mla_dec_fwd. dlat1/dlat2: T*d_c scratch; dqr: T*nh*d_rope; dkr:
# T*d_rope. dx = dx_q + dx_c + dx_qr + dx_kr. Every step is matmul-backward over
# the caches; the only hand-derived piece is attn_dec_core_bwd.
fn attn_mla_dec_bwd(Wq, Wdkv, Wuk, Wuv, Wqr, Wkr, Wo, x, dout, dx,
                    dWq, dbq, dWdkv, dWuk, dbuk, dWuv, dbuv, dWqr, dWkr, dWo, dbo,
                    ar, c, qr, kr, dlat1, dlat2, dqr, dkr, T, C, nh, d_c, d_rope): i64 {
    var Qc = _at_Qc(ar);
    var Kc = _at_Kc(ar, T, C);
    var Vc = _at_Vc(ar, T, C, C);
    var Pc = _at_Pc(ar, T, C, C);
    var concat = _at_concat(ar, T, C, nh, C);
    var dconcat = _at_dconcat(ar, T, C, nh, C);
    var dQc = _at_dQ(ar, T, C, nh, C);
    var dKc = _at_dK(ar, T, C, nh, C);
    var dVc = _at_dV(ar, T, C, nh, C);
    var dxq = _at_dxq(ar, T, C, nh, C);
    var dxk = _at_dxk(ar, T, C, nh, C);
    var dxv = _at_dxv(ar, T, C, nh, C);
    var dprow = _at_dprow(ar, T, C, nh, C);
    # 1. out = concat @ Wo
    linear_bwd(concat, Wo, dout, dconcat, dWo, dbo, T, C, C);
    # 2. decoupled core: dconcat -> dQc/dKc/dVc (content) + dqr/dkr (rope)
    attn_dec_core_bwd(Qc, Kc, Vc, qr, kr, Pc, dconcat, dQc, dKc, dVc, dqr, dkr, dprow, T, C, nh, d_rope);
    # 3. undo the rope rotation on the rope-path gradients
    rope_apply_bwd(dqr, T, 0, nh * d_rope, nh);
    rope_apply_bwd(dkr, T, 0, d_rope, 1);
    # 4. up-projections K=c@W_UK, V=c@W_UV -> dW_UK/dW_UV, dbuk/dbuv, dc
    linear_bwd(c, Wuk, dKc, dlat1, dWuk, dbuk, T, d_c, C);
    linear_bwd(c, Wuv, dVc, dlat2, dWuv, dbuv, T, d_c, C);
    var idx = 0;
    while (idx < T * d_c) {                        # dc = dc_from_K + dc_from_V
        store64(dlat1 + idx * 8, f64_add(load64(dlat1 + idx * 8), load64(dlat2 + idx * 8)));
        idx = idx + 1;
    }
    # 5. down-projection c=x@W_DKV -> dW_DKV, dx-from-c
    linear_bwd(x, Wdkv, dlat1, dxk, dWdkv, 0, T, C, d_c);
    # 6. content query Qc=x@Wq -> dWq, dbq, dx-from-q
    linear_bwd(x, Wq, dQc, dxq, dWq, dbq, T, C, C);
    # 7. rope query Qr=x@Wqr -> dWqr, dx-from-qr
    linear_bwd(x, Wqr, dqr, dxv, dWqr, 0, T, C, nh * d_rope);
    # 8. dx = dx_q + dx_c + dx_qr
    idx = 0;
    while (idx < T * C) {
        store64(dx + idx * 8, f64_add(f64_add(load64(dxq + idx * 8), load64(dxk + idx * 8)), load64(dxv + idx * 8)));
        idx = idx + 1;
    }
    # 9. rope key Kr=x@Wkr -> dWkr, dx-from-kr (reuse dxq); dx += dx_kr
    linear_bwd(x, Wkr, dkr, dxq, dWkr, 0, T, C, d_rope);
    idx = 0;
    while (idx < T * C) {
        store64(dx + idx * 8, f64_add(load64(dx + idx * 8), load64(dxq + idx * 8)));
        idx = idx + 1;
    }
    return 0;
}

# ---- decoupled single-row attention core (cached decode) --------------------
# The single-row mirror of attn_dec_core_fwd: ONE query (content q_row + rope
# qr_row) attends cache rows 0..pos using content Kc/Vc + the shared rope key Kr
# (one d_rope row per token). Same two-term score / scale as the batch core, so
# decode is bit-identical to the uncached reference per row.
fn attn_dec_core_fwd_row(q_row, Kc, Vc, qr_row, Kr, prow, concat_row, pos, C, nh, d_rope): i64 {
    var hd = C / nh;
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd + d_rope)));
    var h = 0;
    while (h < nh) {
        var base = h * hd;
        var rbase = h * d_rope;
        var qb = q_row + base * 8;
        var qrb = qr_row + rbase * 8;
        var j = 0;
        while (j <= pos) {
            var dot = f64_from(0);
            var kb = Kc + (j * C + base) * 8;
            var d = 0;
            while (d < hd) { dot = f64_add(dot, f64_mul(load64(qb + d * 8), load64(kb + d * 8))); d = d + 1; }
            var krb = Kr + (j * d_rope) * 8;
            var e = 0;
            while (e < d_rope) { dot = f64_add(dot, f64_mul(load64(qrb + e * 8), load64(krb + e * 8))); e = e + 1; }
            store64(prow + j * 8, f64_mul(dot, scale));
            j = j + 1;
        }
        var mx = load64(prow);
        j = 1;
        while (j <= pos) { var s = load64(prow + j * 8); if (f64_gt(s, mx) == 1) { mx = s; } j = j + 1; }
        var sum = f64_from(0);
        j = 0;
        while (j <= pos) {
            var ex = f64_exp(f64_sub(load64(prow + j * 8), mx));
            store64(prow + j * 8, ex); sum = f64_add(sum, ex); j = j + 1;
        }
        var inv = f64_div(f64_from(1), sum);
        j = 0;
        while (j <= pos) { store64(prow + j * 8, f64_mul(load64(prow + j * 8), inv)); j = j + 1; }
        var cb = concat_row + base * 8;
        var dz = 0;
        while (dz < hd) { store64(cb + dz * 8, f64_from(0)); dz = dz + 1; }
        j = 0;
        while (j <= pos) {
            var pij = load64(prow + j * 8);
            var vb = Vc + (j * C + base) * 8;
            var d = 0;
            while (d < hd) {
                store64(cb + d * 8, f64_add(load64(cb + d * 8), f64_mul(pij, load64(vb + d * 8))));
                d = d + 1;
            }
            j = j + 1;
        }
        h = h + 1;
    }
    return 0;
}

# ---- cached single-row forward, MLA + decoupled RoPE (inference, M12 incr 5) -
# The persistent cache stores the latent c (d_c) AND the shared rope key kr
# (d_rope) per token. Process position `pos`: append c and the rotated kr, build
# the content query q_row + rotated rope query qr_row, up-project the cached
# latents 0..pos to K/V scratch, then run the decoupled single-row core. Each
# rotation is computed DIRECTLY from the absolute position, so a decoded row is
# bit-identical to the uncached reference (docs/architecture/003, /005).
fn attn_mla_dec_fwd_row(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x_row, out_row,
                        c_cache, kr_cache, Kc, Vc, qr_row, prow, concat_row, q_row, pos, C, nh, d_c, d_rope): i64 {
    var n = pos + 1;
    var dr = nh * d_rope;
    linear_fwd(x_row, Wq, bq, q_row, 1, C, C);                       # content query
    linear_fwd(x_row, Wdkv, 0, c_cache + pos * d_c * 8, 1, C, d_c);  # latent append
    linear_fwd(x_row, Wqr, 0, qr_row, 1, C, dr);                     # rope query
    linear_fwd(x_row, Wkr, 0, kr_cache + pos * d_rope * 8, 1, C, d_rope);  # rope key append
    rope_apply_fwd(qr_row, 1, pos, dr, nh);                          # rotate query by pos
    rope_apply_fwd(kr_cache + pos * d_rope * 8, 1, pos, d_rope, 1);  # rotate this key row by pos
    linear_fwd(c_cache, Wuk, buk, Kc, n, d_c, C);                   # up-project latents 0..pos -> Kc
    linear_fwd(c_cache, Wuv, buv, Vc, n, d_c, C);                   # -> Vc
    attn_dec_core_fwd_row(q_row, Kc, Vc, qr_row, kr_cache, prow, concat_row, pos, C, nh, d_rope);
    linear_fwd(concat_row, Wo, bo, out_row, 1, C, C);
    return 0;
}
