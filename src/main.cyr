# attn11 — main entry point.
# A from-scratch GPT-style transformer, trained, in Cyrius.
# Stdlib (alloc/fmt/string/io/args/math/...) auto-included via cyrius.cyml.
#
# Usage:
#   attn11                          train on the embedded corpus, then sample
#   attn11 --corpus PATH            train on a corpus file (O_NOFOLLOW, 64 MB cap)
#   attn11 --stdin                  train on a corpus read from stdin
#   attn11 --steps N                set total training steps (schedule horizon)
#   attn11 --save PATH              write a checkpoint after training
#   attn11 --load PATH              resume from a checkpoint (with --corpus or
#                                   --stream-corpus to continue training; alone for
#                                   --gen-only)
#   attn11 --gen-only               skip training, just sample from the model
#   attn11 --preset                 ctx 64 / d_model 64 / 8 heads / 4 layers
#                                   (the scale preset; default stays ctx 16)
#   attn11 --d-model N              override d_model / width (1..4096; divisible by heads)
#   attn11 --ctx N                  override context length T (1..8192)
#   attn11 --heads N                override attention heads (must divide d_model)
#   attn11 --kv-heads N             override K/V heads (must divide heads;
#                                   < heads = GQA, 1 = MQA; default = heads)
#   attn11 --layers N               override transformer blocks
#   attn11 --attn-every K           hybrid mixer (M14 rung c): a full-attention
#                                   (MHA) block every K-th layer, the --attn-kind
#                                   base (mha/lin) elsewhere — the survey's
#                                   "few attention layers among many cheap" lever
#   attn11 --experts N              MoE: N experts per block (1 = dense baseline;
#                                   the dense MLP becomes a top-K-routed mixture)
#   attn11 --expert-topk K          active experts per token (default 2; 1..N)
#   attn11 --bpe K                  learn K BPE merges over the corpus before
#                                   training (1..512; byte-level is the default;
#                                   ignored under --load — the checkpoint
#                                   carries its own tokenizer)
#   attn11 --eval                   after training/save: one deterministic pass
#                                   over the corpus, prints CE/token and
#                                   bits-per-byte (tokenizer-comparable)
#   attn11 --eval-corpus PATH       held-out eval: re-encode a DISJOINT corpus
#                                   through the loaded tokenizer and score
#                                   bits/byte on it (the generalization metric;
#                                   no vocab-order check; combines with --eval)
#   attn11 --encode-shard PATH      pre-encode the corpus to a token-shard file
#                                   (header + tokenizer + packed ids), then exit
#   attn11 --stream-encode          with --corpus FILE + --encode-shard: encode a
#                                   LARGE file (incl. --bpe) to a shard in bounded
#                                   RAM (GB-scale; not capped at 64 MB), then exit
#   attn11 --stream-corpus PATH     train/eval from a token-shard WITHOUT loading
#                                   it into RAM (windows by offset; GB-scale path)
#   attn11 --ternary                BitNet-style ternary weights {-1,0,+1} with a
#                                   straight-through estimator (mha + dense + AR;
#                                   master weights stay f64, fake-quant matmul)
#   attn11 --gpu                    run matmul + layernorm + the Adam step on the GPU (M18;
#                                   native-AMD f64 SPIR-V via mabda, BIT-EXACT vs the CPU oracle —
#                                   a --gpu checkpoint is byte-identical; auto CPU fallback)
#   attn11 --gpu-tc                 also run GELU + LM head + attention + the GELU/linear/attention
#                                   BACKWARD on the GPU (implies --gpu) — so the full training step
#                                   (fwd+bwd+Adam) runs on-device. TOLERANCE (in-shader f64 exp ≠ x86
#                                   exp; sequential vs SIMD-tree dot) — ~1e-13-close, not byte-identical
#   attn11 --help, -h               show usage and exit
#   attn11 --version                print the version and exit
#
# Config flags (--preset/--heads/--kv-heads/--layers) apply to a FRESH model
# only; with --load the checkpoint's config wins. Later flags override earlier
# ones (so `--preset --heads 4` is the preset at 4 heads). Invalid combinations
# (heads not dividing d_model, kv-heads not dividing heads) abort cleanly in
# model_init.

# The GPU backend (rosnet's [lib.gpu] bundle, 1.10.0 / ADR 0017) rides mabda's native-AMD DRM path —
# Linux-only. cyrius auto-prepends a declared dep's `modules` on EVERY target (incl. --agnos), so on
# AGNOS BOTH rosnet-gpu and mabda are prepended (a dep module can't be #ifndef-guarded out). The GPU
# path is still DEAD on AGNOS — no `--gpu` flag, `g_gpu` unsettable, every `gpu_*` CALL #ifndef-guarded
# in src/ — but the prepended bundles must still *compile*. mabda references SYS_IOCTL (DRM ioctls)
# which the AGNOS ring-3 syscall peer omits, so provide the one missing constant for AGNOS to let the
# dead code type-check. (On Linux the stdlib syscalls peer owns SYS_IOCTL — this #ifdef avoids a dup.)
#ifdef CYRIUS_TARGET_AGNOS
var SYS_IOCTL = 16;
#endif

include "lib/tyche.cyr"          # extracted PRNG (rng_*, _rng_state)
include "lib/rosnet.cyr"         # extracted tensor/BLAS-1/matmul (+ gradient)
# M19 1.10.0 (ADR 0017): the GPU backend was extracted whole to rosnet's [lib.gpu] profile
# (dist/rosnet-gpu.cyr) — it + mabda are auto-prepended from [deps] on all targets; AGNOS keeps the
# gpu_* CALLS #ifndef-guarded so the bundle type-checks as dead code there (the SYS_IOCTL stub above).
include "src/tensor.cyr"
include "src/fileio.cyr"
include "lib/akshara.cyr"      # tokenizer data layer — extracted to the akshara lib (M1)
include "src/ops.cyr"
include "src/attn.cyr"
include "src/attn_linear.cyr"
include "src/attn_ssm.cyr"
include "src/model.cyr"
include "src/train.cyr"
include "src/persist.cyr"
include "src/stream.cyr"

# ---- hyperparameters -------------------------------------------------------
fn CFG_C(): i64 { return 32; }       # d_model
fn CFG_T(): i64 { return 16; }       # context length
fn CFG_NH(): i64 { return 4; }       # attention heads (head dim = C/NH)
fn CFG_NL(): i64 { return 3; }       # transformer blocks
fn CFG_SEED(): i64 { return 1337; }
fn CFG_STEPS(): i64 { return 2000; }
fn CFG_BATCH(): i64 { return 16; }
fn CFG_LOG(): i64 { return 250; }
fn CFG_WARMUP(): i64 { return 100; }
fn CFG_LR(): i64 { return f64_div(f64_from(3), f64_from(1000)); }      # base 3e-3
fn CFG_MINLR(): i64 { return f64_div(f64_from(3), f64_from(10000)); }  # min 3e-4
fn CFG_CLIP(): i64 { return f64_from(1); }                            # global-norm 1.0
fn CFG_ATTN_BIAS(): i64 { return 1; }                                 # Q/K/V/O biases
fn CFG_DROPOUT(): i64 { return f64_from(0); }                         # residual dropout (off; tiny corpus)

fn _atoi(s): i64 {
    if (s == 0) { return 0; }   # a value flag given as the last arg: argv() OOB
    var v = 0; var i = 0; var neg = 0;
    if (load8(s) == 45) { neg = 1; i = 1; }
    while (load8(s + i) != 0) {
        var c = load8(s + i);
        # saturate at ~1e9 (> any real --steps or model dim, << i64 overflow):
        # a garbage-huge arg can no longer wrap mod 2^64 to a plausible small or
        # negative value. Downstream caps (model_config_ok, --bpe 1..512) then
        # reject the saturated value cleanly (M8 audit 2026-06-11).
        if ((c >= 48) && (c <= 57)) {
            if (v < 1000000000) { v = v * 10 + (c - 48); }
        }
        i = i + 1;
    }
    if (neg == 1) { return 0 - v; }
    return v;
}

# Kept in sync with the VERSION file (CI's docs job gates the match).
fn CFG_VERSION(): i64 { return "1.11.1"; }

fn usage(): i64 {
    puts("attn11 — a from-scratch GPT-style transformer, trained, in Cyrius\n");
    puts("usage: attn11 [flags]   (no flags: train on the embedded corpus, then sample)\n");
    puts("  --corpus PATH   train on a corpus file (O_NOFOLLOW, 64 MB cap)\n");
    puts("  --stdin         train on a corpus read from stdin\n");
    puts("  --steps N       total training steps (also the LR-schedule horizon)\n");
    puts("  --save PATH     write a crash-atomic checkpoint after training\n");
    puts("  --load PATH     resume from a checkpoint (+ --corpus or --stream-corpus to continue)\n");
    puts("  --gen-only      skip training, just sample\n");
    puts("  --preset        ctx 64 / d_model 64 / 8 heads / 4 layers\n");
    puts("  --d-model N     override d_model (width; 1..4096; must be divisible by heads)\n");
    puts("  --ctx N         override context length T (1..8192)\n");
    puts("  --heads N       attention heads (must divide d_model)\n");
    puts("  --kv-heads N    K/V heads (must divide heads; 1 = MQA; default = heads)\n");
    puts("  --layers N      transformer blocks (1..128)\n");
    puts("  --attn-kind K   mixer: mha (default), mla (latent KV), lin (gated linear), ssm (selective SSM)\n");
    puts("  --latent-dim N  MLA latent width / SSM state size (1..d_model; MLA default d_model/2, SSM 16)\n");
    puts("  --attn-every K  hybrid: a full-attention (MHA) block every K-th layer, --attn-kind base elsewhere\n");
    puts("  --pos-kind K    positions: learned (default), rope (coupled, mha/gqa), or rope-decoupled (mla)\n");
    puts("  --rope-dim N    decoupled-RoPE channel width d_rope (even, 2..d_model; default ~hd/2)\n");
    puts("  --experts N     MoE: N experts per block (1=dense; >1 enables top-K routing, 1..256)\n");
    puts("  --mtp N         multi-token prediction: N-1 aux heads predict t+2..t+N (1=off; 1..8)\n");
    puts("  --expert-topk K active experts per token (default 2; 1..N)\n");
    puts("  --bpe K         learn K BPE merges first (1..512; byte-level is the default)\n");
    puts("  --eval          print CE/token + bits-per-byte after training/save\n");
    puts("  --eval-corpus P held-out eval on a disjoint corpus via the loaded tokenizer\n");
    puts("  --encode-shard P pre-encode the corpus to a token-shard file, then exit\n");
    puts("  --stream-encode  with --corpus FILE + --encode-shard: encode a large file (incl. --bpe) in bounded RAM\n");
    puts("  --stream-corpus P train/eval from a token-shard without loading it into RAM\n");
    puts("  --objective O   training objective: ar (default) or diffusion (masked, bidirectional)\n");
    puts("  --ternary       BitNet-style ternary weights {-1,0,+1} (mha + dense + ar; STE backward)\n");
    puts("  --decode-steps N   diffusion decode iterations (default = ctx)\n");
    puts("  --decode-schedule S  diffusion unmask schedule: cosine (default) or linear\n");
    puts("  --gpu           forward matmul + layernorm on the GPU (native-AMD f64, bit-exact; CPU fallback)\n");
    puts("  --gpu-tc        also run GELU + head + attention on the GPU (implies --gpu; tolerance)\n");
    puts("  --help, -h      show this help and exit\n");
    puts("  --version       print the version and exit\n");
    return 0;
}

# Consume a value-flag's argument: returns argv(idx), or prints an error + usage
# and exits if the flag was the last arg (no value). Keeps the parse loop short.
fn _av(idx, flag): i64 {
    if (idx >= argc()) { puts("attn11: "); puts(flag); puts(" needs a value\n"); usage(); sys_exit(1); }
    return argv(idx);
}

fn main(): i64 {
    alloc_init();
    args_init();

    # ---- parse args ----
    var corpus_path = 0; var use_stdin = 0; var load_path = 0; var save_path = 0;
    var steps = CFG_STEPS(); var gen_only = 0;
    # fresh-model config (ignored under --load: the checkpoint's config wins).
    # cfg_nkv == 0 means "follow cfg_nh" (full MHA), resolved after parsing so
    # --preset/--heads never clobber an explicit --kv-heads.
    var cfg_c = CFG_C(); var cfg_t = CFG_T(); var cfg_nh = CFG_NH();
    var cfg_nl = CFG_NL(); var cfg_nkv = 0;
    var cfg_attn_kind = 0; var cfg_latent_dim = 0;   # mla off; d_c resolved post-parse
    var cfg_pos_kind = 0;                            # 0 = learned-abs, 1 = coupled RoPE, 2 = decoupled
    var cfg_rope_dim = 0;                            # d_rope; resolved post-parse for rope-decoupled
    var cfg_num_experts = 1;                         # 1 = dense (default); --experts N enables MoE
    var cfg_expert_topk = 0;                         # 0 = "default" -> min(2, N), resolved post-parse
    var cfg_attn_every = 0;                          # M14 rung c: MHA every K-th layer (0 = uniform)
    var cfg_hybrid = 0;                              # set post-parse if the per-layer kinds are mixed
    var lkinds[1024];                                # per-layer mixer kinds (128 i64 = max --layers)
    var use_bpe = 0; var bpe_k = 0; var do_eval = 0; var eval_corpus_path = 0;
    var encode_shard_path = 0; var stream_corpus_path = 0;   # 1.6.x token-shard streaming
    var stream_encode = 0;                                   # 1.6.4: stream --encode-shard (GB-scale, incl. BPE)
    var cfg_objective = 0;                           # M15: 0 = AR (default), 1 = masked diffusion
    var cfg_mtp = 1;                                 # X043: --mtp N>1 = multi-token prediction (N-1 aux heads)
    var cfg_decode_steps = 0;                        # diffusion decode iterations (0 = default, resolved post-parse)
    var cfg_decode_sched = 0;                        # diffusion decode schedule: 0 = cosine (default), 1 = linear
    var cfg_ternary = 0;                             # M16 (E6): 1 = BitNet-style ternary weights
    var i = 1;
    while (i < argc()) {
        var a = argv(i);
        if ((streq(a, "--help") == 1) || (streq(a, "-h") == 1)) { usage(); return 0; }
        elif (streq(a, "--version") == 1) { puts("attn11 "); puts(CFG_VERSION()); _putc(10); return 0; }
        elif (streq(a, "--corpus") == 1) { i = i + 1; corpus_path = _av(i, a); }
        elif (streq(a, "--stdin") == 1) { use_stdin = 1; }
        elif (streq(a, "--load") == 1) { i = i + 1; load_path = _av(i, a); }
        elif (streq(a, "--save") == 1) { i = i + 1; save_path = _av(i, a); }
        elif (streq(a, "--steps") == 1) { i = i + 1; steps = _atoi(_av(i, a)); }
        elif (streq(a, "--gen-only") == 1) { gen_only = 1; }
        #ifndef CYRIUS_TARGET_AGNOS
        elif (streq(a, "--gpu") == 1) { g_gpu = 1; }
        elif (streq(a, "--gpu-tc") == 1) { g_gpu = 1; g_gpu_tc = 1; }
        #endif
        elif (streq(a, "--preset") == 1) { cfg_c = 64; cfg_t = 64; cfg_nh = 8; cfg_nl = 4; }
        elif (streq(a, "--d-model") == 1) { i = i + 1; cfg_c = _atoi(_av(i, a)); }
        elif (streq(a, "--ctx") == 1) { i = i + 1; cfg_t = _atoi(_av(i, a)); }
        elif (streq(a, "--heads") == 1) { i = i + 1; cfg_nh = _atoi(_av(i, a)); }
        elif (streq(a, "--kv-heads") == 1) { i = i + 1; cfg_nkv = _atoi(_av(i, a)); }
        elif (streq(a, "--layers") == 1) { i = i + 1; cfg_nl = _atoi(_av(i, a)); }
        elif (streq(a, "--attn-kind") == 1) {
            i = i + 1; var ak = _av(i, a);
            if (streq(ak, "mha") == 1) { cfg_attn_kind = 0; }
            elif (streq(ak, "mla") == 1) { cfg_attn_kind = 1; }
            elif (streq(ak, "lin") == 1) { cfg_attn_kind = 2; }
            elif (streq(ak, "ssm") == 1) { cfg_attn_kind = 3; }
            else { puts("attn11: --attn-kind must be mha, mla, lin, or ssm\n"); return 1; }
        }
        elif (streq(a, "--latent-dim") == 1) { i = i + 1; cfg_latent_dim = _atoi(_av(i, a)); }
        elif (streq(a, "--pos-kind") == 1) {
            i = i + 1; var pk = _av(i, a);
            if (streq(pk, "learned") == 1) { cfg_pos_kind = 0; }
            elif (streq(pk, "rope") == 1) { cfg_pos_kind = 1; }
            elif (streq(pk, "rope-decoupled") == 1) { cfg_pos_kind = 2; }
            else { puts("attn11: --pos-kind must be learned, rope, or rope-decoupled\n"); return 1; }
        }
        elif (streq(a, "--rope-dim") == 1) { i = i + 1; cfg_rope_dim = _atoi(_av(i, a)); }
        elif (streq(a, "--attn-every") == 1) { i = i + 1; cfg_attn_every = _atoi(_av(i, a)); }
        elif (streq(a, "--experts") == 1) { i = i + 1; cfg_num_experts = _atoi(_av(i, a)); }
        elif (streq(a, "--mtp") == 1) { i = i + 1; cfg_mtp = _atoi(_av(i, a)); }
        elif (streq(a, "--expert-topk") == 1) { i = i + 1; cfg_expert_topk = _atoi(_av(i, a)); }
        elif (streq(a, "--bpe") == 1) { use_bpe = 1; i = i + 1; bpe_k = _atoi(_av(i, a)); }
        elif (streq(a, "--eval") == 1) { do_eval = 1; }
        elif (streq(a, "--eval-corpus") == 1) { i = i + 1; eval_corpus_path = _av(i, a); }
        elif (streq(a, "--encode-shard") == 1) { i = i + 1; encode_shard_path = _av(i, a); }
        elif (streq(a, "--stream-corpus") == 1) { i = i + 1; stream_corpus_path = _av(i, a); }
        elif (streq(a, "--stream-encode") == 1) { stream_encode = 1; }
        elif (streq(a, "--objective") == 1) {
            i = i + 1; var ob = _av(i, a);
            if (streq(ob, "ar") == 1) { cfg_objective = 0; }
            elif (streq(ob, "diffusion") == 1) { cfg_objective = 1; }
            else { puts("attn11: --objective must be ar or diffusion\n"); return 1; }
        }
        elif (streq(a, "--ternary") == 1) { cfg_ternary = 1; }
        elif (streq(a, "--decode-steps") == 1) { i = i + 1; cfg_decode_steps = _atoi(_av(i, a)); }
        elif (streq(a, "--decode-schedule") == 1) {
            i = i + 1; var ds = _av(i, a);
            if (streq(ds, "cosine") == 1) { cfg_decode_sched = 0; }
            elif (streq(ds, "linear") == 1) { cfg_decode_sched = 1; }
            else { puts("attn11: --decode-schedule must be cosine or linear\n"); return 1; }
        }
        else { puts("attn11: unknown argument "); puts(a); _putc(10); usage(); return 1; }
        i = i + 1;
    }
    # M18: report GPU status once when --gpu is requested (the matmul backend lazily
    # brings the device up on first use; this is just a user-facing probe). A missing
    # device is non-fatal — qlinear_fwd self-falls-back to the CPU oracle. (Linux-only;
    # --gpu isn't a recognized flag on AGNOS, so g_gpu cannot be set there.)
    #ifndef CYRIUS_TARGET_AGNOS
    if (g_gpu == 1) { gpu_probe(); }
    #endif
    if (cfg_nkv == 0) { cfg_nkv = cfg_nh; }
    # MLA uses full heads (the cache compression is the latent, not head-sharing);
    # force nkv = nh and default d_c to C/2 (~4x KV-cache cut vs MHA's 2*Ckv) when
    # --latent-dim is unspecified. Resolved post-parse so --preset's C is final.
    if (cfg_attn_kind == 1) {
        cfg_nkv = cfg_nh;
        if (cfg_latent_dim == 0) {
            cfg_latent_dim = cfg_c / 2;
            if (cfg_latent_dim < 1) { cfg_latent_dim = 1; }
        }
    }
    # Gated linear attention (M14): full K/V, learned-abs positions (the pos-kind
    # checks below reject RoPE on it). model_config_ok_moe is the backstop.
    if (cfg_attn_kind == 2) { cfg_nkv = cfg_nh; }
    # Selective SSM (M14 rung b): full heads; --latent-dim is the state size N
    # (default 16, capped at d_model). model_config_ok_moe is the backstop.
    if (cfg_attn_kind == 3) {
        cfg_nkv = cfg_nh;
        if (cfg_latent_dim == 0) { cfg_latent_dim = 16; if (cfg_latent_dim > cfg_c) { cfg_latent_dim = cfg_c; } }
    }
    # Coupled RoPE (1.2.2) ships on dense MHA/GQA with an even head dim. Surface a
    # clear CLI error before model_init (model_config_ok_arch is the backstop).
    # Ignored under --load — the checkpoint's descriptor wins.
    if ((cfg_pos_kind == 1) && (load_path == 0)) {
        if (cfg_attn_kind != 0) {
            puts("attn11: --pos-kind rope requires --attn-kind mha (decoupled RoPE for MLA is a later release)\n");
            return 1;
        }
        if (((cfg_c / cfg_nh) % 2) != 0) {
            puts("attn11: --pos-kind rope needs an even head dim (d_model / heads)\n");
            return 1;
        }
    }
    # Decoupled RoPE (1.2.3) is MLA-only with a separate EVEN d_rope channel. Default
    # d_rope to the even part of hd/2 (DeepSeek uses d_rope < d_head); --rope-dim
    # overrides. Resolved post-parse so --preset's C/heads are final.
    if ((cfg_pos_kind == 2) && (load_path == 0)) {
        if (cfg_attn_kind != 1) {
            puts("attn11: --pos-kind rope-decoupled requires --attn-kind mla\n");
            return 1;
        }
        if (cfg_rope_dim == 0) {
            var hd = cfg_c / cfg_nh;
            var dr = hd / 2;
            dr = dr - (dr % 2);                       # round down to even
            if (dr < 2) { dr = 2; }
            cfg_rope_dim = dr;
        }
        if (((cfg_rope_dim % 2) != 0) || (cfg_rope_dim < 2) || (cfg_rope_dim > cfg_c)) {
            puts("attn11: --rope-dim must be even, 2..d_model\n");
            return 1;
        }
    }
    # --rope-dim only applies to decoupled RoPE; a clean CLI error beats letting
    # model_init's config gate sys_exit with a generic message (the fresh path).
    if ((cfg_rope_dim != 0) && (cfg_pos_kind != 2) && (load_path == 0)) {
        puts("attn11: --rope-dim requires --pos-kind rope-decoupled\n");
        return 1;
    }
    # MoE (M13): --experts N (1 = dense; >1 routes the MLP through N experts) and
    # --expert-topk K (default 2, capped at N). Ignored under --load (the
    # checkpoint's descriptor wins); model_config_ok_moe is the backstop (caps N
    # at 256, requires 1 <= K <= N). Resolved post-parse so --preset's C is final.
    if (load_path == 0) {
        if (cfg_num_experts < 1) { puts("attn11: --experts must be >= 1 (1 = dense)\n"); return 1; }
        if (cfg_num_experts > 1) {
            if (cfg_expert_topk == 0) {
                cfg_expert_topk = 2;
                if (cfg_expert_topk > cfg_num_experts) { cfg_expert_topk = cfg_num_experts; }
            }
            if ((cfg_expert_topk < 1) || (cfg_expert_topk > cfg_num_experts)) {
                puts("attn11: --expert-topk must be 1..--experts\n");
                return 1;
            }
        } else {
            if (cfg_expert_topk > 1) { puts("attn11: --expert-topk needs --experts > 1\n"); return 1; }
            cfg_expert_topk = 1;
        }
    }
    # Per-layer mixer HYBRID (M14 rung c+d): --attn-every K places a full-attention
    # (MHA) block at every K-th layer (L % K == 0, so layer 0 is attention) and the
    # --attn-kind base elsewhere — the survey's "few attention layers among many
    # cheap ones" lever. Any base {mha, lin, mla, ssm} (rung d pads the K/V region to
    # the max kind size, so the stride stays uniform). Ignored under --load (the
    # checkpoint's per-layer pattern wins). model_config_ok/_hybrid_kinds_ok are the
    # backstops. If the pattern collapses to one kind (K=1 → all MHA), it falls back
    # to uniform MHA (resetting the latent, since MHA carries none) — no v6, no hybrid.
    if ((cfg_attn_every > 0) && (load_path == 0)) {
        if (cfg_pos_kind != 0) {
            puts("attn11: --attn-every requires learned-abs positions (no RoPE in a hybrid)\n");
            return 1;
        }
        # Bound cfg_nl to the lkinds[1024] capacity (128 i64 = model_config_ok's NL
        # cap) BEFORE the loop indexes it — an unvalidated --layers (the NL cap lives
        # in model_init, which runs LATER) would otherwise overflow the stack buffer
        # (the M7 --layers OOB lesson; a hostile `--layers N --attn-every K` SIGSEGV).
        if ((cfg_nl < 1) || (cfg_nl > 128)) {
            puts("attn11: --layers must be 1..128 (the transformer-block cap)\n");
            return 1;
        }
        var hl = 0;
        while (hl < cfg_nl) {
            var hk = cfg_attn_kind;
            if ((hl % cfg_attn_every) == 0) { hk = 0; }       # attention block
            store64(&lkinds + hl * 8, hk);
            if (hk != load64(&lkinds)) { cfg_hybrid = 1; }    # differs from layer 0 → mixed
            hl = hl + 1;
        }
        if (cfg_hybrid == 0) { cfg_attn_kind = load64(&lkinds); cfg_latent_dim = 0; }   # collapsed → uniform MHA
    }
    # M15 masked-diffusion (E5). v1.5.0 scope: MHA (kind 0) + learned-abs + dense +
    # uniform — lin/ssm are causal recurrences with no bidirectional form; mla/moe/
    # rope-diffusion are additive fast-follows. Ignored under --load (the
    # checkpoint's objective wins); model_init_full's backstop + the loader
    # re-validate. Resolve the decode-step default (~ctx) post-parse so --preset's T
    # is final.
    if ((cfg_objective == 1) && (load_path == 0)) {
        if (cfg_attn_kind != 0) {
            puts("attn11: --objective diffusion requires --attn-kind mha (lin/ssm are causal; mla is a fast-follow)\n");
            return 1;
        }
        if (cfg_pos_kind != 0) {
            puts("attn11: --objective diffusion requires learned-abs positions (RoPE-diffusion is a fast-follow)\n");
            return 1;
        }
        if (cfg_num_experts != 1) {
            puts("attn11: --objective diffusion requires a dense MLP (--experts 1; MoE-diffusion is a fast-follow)\n");
            return 1;
        }
        if (cfg_attn_every > 0) {
            puts("attn11: --objective diffusion does not support --attn-every (uniform MHA only)\n");
            return 1;
        }
        if ((cfg_decode_steps < 1) || (cfg_decode_steps > cfg_t)) { cfg_decode_steps = cfg_t; }
    }
    if ((cfg_decode_steps != 0) && (cfg_objective != 1) && (load_path == 0)) {
        puts("attn11: --decode-steps / --decode-schedule require --objective diffusion\n");
        return 1;
    }
    # M16 ternary (E6, ADR 0014). v1.6.0 scope: MHA + dense MLP + uniform + AR +
    # learned-abs (the other axes are documented fast-follows). Surface a clear CLI
    # error before model_init (model_init_full's g_ternary backstop is the
    # secondary gate). Ignored under --load — the checkpoint's ternary flag wins.
    if ((cfg_ternary == 1) && (load_path == 0)) {
        if (cfg_attn_kind != 0) {
            puts("attn11: --ternary requires --attn-kind mha (mla/lin/ssm ternary are fast-follows)\n"); return 1;
        }
        if (cfg_pos_kind != 0) {
            puts("attn11: --ternary requires learned-abs positions (RoPE-ternary is a fast-follow)\n"); return 1;
        }
        if (cfg_num_experts != 1) {
            puts("attn11: --ternary requires a dense MLP (--experts 1; MoE-ternary is a fast-follow)\n"); return 1;
        }
        if (cfg_attn_every > 0) {
            puts("attn11: --ternary does not support --attn-every (uniform MHA only)\n"); return 1;
        }
        if (cfg_objective != 0) {
            puts("attn11: --ternary requires --objective ar (diffusion-ternary is a fast-follow)\n"); return 1;
        }
    }
    # K is the experiment's key variable — a silent default would hide it
    if ((use_bpe == 1) && ((bpe_k < 1) || (bpe_k > BPE_MAX_MERGES()))) {
        puts("attn11: --bpe needs a merge count in 1..512\n");
        return 1;
    }
    # Streaming token-shard ingestion (1.6.x). --stream-corpus is a self-contained
    # corpus + tokenizer (a pre-encoded shard), so it is mutually exclusive with
    # the other corpus sources and with --bpe (the shard carries its own tokenizer).
    # --load + --stream-corpus IS supported (resume-from-stream, 1.6.3): the shard
    # supplies the corpus, the checkpoint the weights; the loader hard-rejects (-15)
    # if the shard's vocab does not match the checkpoint's, so a successful resume
    # is consistent.
    if (stream_corpus_path != 0) {
        if ((corpus_path != 0) || (use_stdin == 1)) {
            puts("attn11: --stream-corpus conflicts with --corpus/--stdin\n"); return 1;
        }
        if (use_bpe == 1) {
            puts("attn11: --bpe conflicts with --stream-corpus (the shard carries its tokenizer)\n"); return 1;
        }
        if (encode_shard_path != 0) {
            puts("attn11: --stream-corpus and --encode-shard are mutually exclusive\n"); return 1;
        }
    }
    # --encode-shard writes a token-shard from an in-memory corpus, then exits (a
    # one-shot pre-encode). It needs a corpus source and no checkpoint.
    if ((encode_shard_path != 0) && (load_path != 0)) {
        puts("attn11: --encode-shard cannot be combined with --load\n"); return 1;
    }

    # ---- streaming encode (1.6.4): pre-encode a large corpus FILE in bounded RAM ----
    # --stream-encode turns --encode-shard into the GB-scale producer: it reads the
    # --corpus FILE in chunks (never loading it whole), learns the tokenizer from a
    # bounded prefix, and streams a shard — so a BPE shard can come from a corpus
    # larger than the 64 MB in-RAM cap. One-shot: it writes the shard and exits.
    if (stream_encode == 1) {
        if (encode_shard_path == 0) { puts("attn11: --stream-encode requires --encode-shard PATH\n"); return 1; }
        if (corpus_path == 0) { puts("attn11: --stream-encode requires --corpus FILE (the input)\n"); return 1; }
        if (use_stdin == 1) { puts("attn11: --stream-encode reads a seekable file, not --stdin\n"); return 1; }
        if (load_path != 0) { puts("attn11: --stream-encode cannot be combined with --load\n"); return 1; }
        if (stream_corpus_path != 0) { puts("attn11: --stream-encode excludes --stream-corpus\n"); return 1; }
        var lk = 0; if (use_bpe == 1) { lk = bpe_k; }
        var sr = shard_stream_encode(corpus_path, encode_shard_path, lk);
        if (sr < 0) { puts("attn11: stream-encode failed (code "); fmt_int(sr); puts(")\n"); return 1; }
        puts("attn11: stream-encoded token-shard "); puts(encode_shard_path);
        puts(" (tokens "); fmt_int(sr);
        if (use_bpe == 1) { puts(", bpe merges "); fmt_int(g_bpe_nmerges); }
        puts(")\n");
        return 0;
    }

    # ---- corpus ----
    # Token-store width (1.5.3): g_data packs one byte/token for byte-level
    # (vocab <= 256) and two for BPE (vocab <= 768). Set BEFORE the corpus load
    # (corpus_set reads g_data_w to size + fill the packed buffer). On --load the
    # checkpoint may carry a BPE tokenizer — its corpus rebuild re-encodes through
    # the loaded merges (ids up to 766) — so size wide regardless of --bpe.
    g_data_w = 1;
    if (use_bpe == 1) { g_data_w = 2; }
    if (load_path != 0) { g_data_w = 2; }
    var V = 0;
    if (stream_corpus_path != 0) {
        # streaming (1.6.x): the shard sets g_data_w / g_datalen / the tokenizer and
        # leaves the tokens on disk (gd_ld streams them); RAM stays O(model + chunk).
        V = shard_open(stream_corpus_path);
        if (V < 0) { puts("attn11: stream-corpus open failed (code "); fmt_int(V); puts(")\n"); return 1; }
    } else {
        if (use_stdin == 1) { V = corpus_load_stdin(); }
        elif (corpus_path != 0) { V = corpus_load_file(corpus_path); }
        elif (load_path == 0) { V = build_corpus(); }    # default embedded corpus
        if (V < 0) { puts("attn11: corpus load failed (code "); fmt_int(V); puts(")\n"); return 1; }
    }

    # ---- BPE (opt-in; a loaded checkpoint's tokenizer always wins) ----
    # Runs AFTER the corpus is loaded and BEFORE model_init: the model's
    # embedding/logits sizes depend on the post-merge V.
    if (use_bpe == 1) {
        if (load_path != 0) {
            puts("attn11: --bpe ignored; the checkpoint carries its tokenizer\n");
        } else {
            V = bpe_learn(bpe_k);
            if (V < 0) { puts("attn11: bpe merge training failed (code "); fmt_int(V); puts(")\n"); return 1; }
        }
    }

    # ---- encode-shard (1.6.x): pre-encode the corpus, then exit ----
    # A one-shot tool mode: the corpus (+ optional --bpe) is loaded and tokenized
    # above; write it as a token-shard (header + tokenizer + packed ids) and stop
    # before any model is built. The shard then feeds --stream-corpus in bounded RAM.
    if (encode_shard_path != 0) {
        var er = shard_save_file(encode_shard_path, V);
        if (er < 0) { puts("attn11: encode-shard failed (code "); fmt_int(er); puts(")\n"); return 1; }
        puts("attn11: wrote token-shard "); puts(encode_shard_path);
        puts(" (tokens "); fmt_int(g_datalen);
        puts(", vocab "); fmt_int(V); puts(")\n");
        return 0;
    }

    # ---- model: fresh or resumed ----
    # M16: set the ternary mode BEFORE model_init (it sizes g_qscratch + runs the
    # backstop). On --load the checkpoint loader overwrites g_ternary with the
    # image's flag (the CLI --ternary is ignored under --load, like every config).
    g_ternary = cfg_ternary;
    # X043: --mtp is a fresh-training config (aux heads are train-time, not
    # serialized), so it can't combine with --load; bound it like the other dims.
    if ((cfg_mtp < 1) || (cfg_mtp > 8)) { puts("attn11: --mtp must be in [1, 8]\n"); return 1; }
    if ((cfg_mtp > 1) && (load_path != 0)) {
        puts("attn11: --mtp applies to fresh training only (not with --load)\n"); return 1;
    }
    if ((cfg_mtp > 1) && (cfg_objective != 0)) {
        puts("attn11: --mtp requires the AR objective (not --objective diffusion)\n"); return 1;
    }
    g_mtp = cfg_mtp;
    if (load_path != 0) {
        # ckpt_load_file hard-rejects (code -15) if a loaded corpus's vocab
        # doesn't match the checkpoint's, so a successful load is consistent.
        var rc = ckpt_load_file(load_path);
        if (rc < 0) { puts("attn11: checkpoint load failed (code "); fmt_int(rc); puts(")\n"); return 1; }
        puts("attn11: resumed from checkpoint at step "); fmt_int(g_step); _putc(10);
    } elif (cfg_objective == 1) {
        # M15 masked-diffusion (uniform MHA + learned-abs + dense; bidirectional)
        model_init_full(V, cfg_c, cfg_t, cfg_nh, cfg_nkv, cfg_nl,
        CFG_ATTN_BIAS(), CFG_DROPOUT(), CFG_SEED(),
        cfg_attn_kind, cfg_latent_dim, cfg_pos_kind, cfg_rope_dim,
        cfg_num_experts, cfg_expert_topk, 0, 1);
    } elif (cfg_hybrid == 1) {
        model_init_full(V, cfg_c, cfg_t, cfg_nh, cfg_nkv, cfg_nl,
        CFG_ATTN_BIAS(), CFG_DROPOUT(), CFG_SEED(),
        cfg_attn_kind, cfg_latent_dim, cfg_pos_kind, cfg_rope_dim,
        cfg_num_experts, cfg_expert_topk, &lkinds, 0);
    } else {
        model_init_moe(V, cfg_c, cfg_t, cfg_nh, cfg_nkv, cfg_nl,
        CFG_ATTN_BIAS(), CFG_DROPOUT(), CFG_SEED(),
        cfg_attn_kind, cfg_latent_dim, cfg_pos_kind, cfg_rope_dim,
        cfg_num_experts, cfg_expert_topk);
    }

    puts("attn11 — transformer training in Cyrius\n");
    puts("  vocab="); fmt_int(g_V);
    puts(" d_model="); fmt_int(g_C);
    puts(" ctx="); fmt_int(g_T);
    puts(" heads="); fmt_int(g_nh);
    puts(" kv_heads="); fmt_int(g_nkv);
    puts(" layers="); fmt_int(g_NL);
    if (g_layer_kind != 0) {
        # per-layer hybrid (M14 rung c): count the MHA (attention) blocks vs the base
        var nm = 0; var hl2 = 0;
        while (hl2 < g_NL) { if (load64(g_layer_kind + hl2 * 8) == 0) { nm = nm + 1; } hl2 = hl2 + 1; }
        puts(" attn=hybrid("); fmt_int(nm); puts("/"); fmt_int(g_NL); puts(" mha, base=");
        if (g_attn_kind == 1) { puts("mla)"); }
        elif (g_attn_kind == 2) { puts("lin)"); }
        elif (g_attn_kind == 3) { puts("ssm)"); }
        else { puts("mha)"); }
    } else {
        if (g_attn_kind == 1) { puts(" attn=mla(d_c="); fmt_int(g_latent_dim); puts(")"); }
        if (g_attn_kind == 2) { puts(" attn=linear"); }
        if (g_attn_kind == 3) { puts(" attn=ssm(N="); fmt_int(g_latent_dim); puts(")"); }
    }
    if (g_pos_kind == 1) { puts(" pos=rope"); }
    if (g_pos_kind == 2) { puts(" pos=rope-decoupled(d_rope="); fmt_int(g_rope_dim); puts(")"); }
    if (g_num_experts > 1) {
        puts(" moe(experts="); fmt_int(g_num_experts); puts(",topk="); fmt_int(g_expert_topk); puts(")");
    }
    if (g_objective == 1) { puts(" objective=diffusion(bidir)"); }
    if (g_ternary == 1) { puts(" weights=ternary{-1,0,+1}"); }
    puts(" params="); fmt_int(g_NP); _putc(10);
    puts("  tokenizer=");
    if (g_bpe_on == 1) { puts("bpe(merges="); fmt_int(g_bpe_nmerges); puts(")"); }
    else { puts("byte"); }
    puts(" corpus tokens="); fmt_int(g_datalen); _putc(10);
    _putc(10);

    # ---- train ----
    if (gen_only == 0) {
        if (((g_stream == 0) && (g_data == 0)) || (g_datalen < g_T + 1)) {
            puts("attn11: no/short corpus (need >= ctx+1 bytes); skipping training\n");
        } else {
            puts("training:\n");
            train(steps, steps, CFG_BATCH(), CFG_LR(), CFG_MINLR(), CFG_WARMUP(), CFG_CLIP(), CFG_LOG());
        }
    }

    # ---- save ----
    # A failed --save sets a non-zero exit (a script's `attn11 --save x && use x`
    # must detect the write failure); eval + samples still print from the
    # in-memory model so output isn't lost.
    var rc = 0;
    if (save_path != 0) {
        var sv = ckpt_save_file(save_path);
        if (sv < 0) { puts("attn11: checkpoint save failed (code "); fmt_int(sv); puts(")\n"); rc = 1; }
        else { puts("attn11: saved checkpoint ("); fmt_int(ckpt_size()); puts(" bytes)\n"); }
    }

    # ---- eval (after save, so the checkpoint is identical with or without) ----
    if ((do_eval == 1) && (g_objective == 1)) {
        # diffusion: the AR next-token CE is the wrong metric for a bidirectional
        # denoiser. Report the masked-CE denoising bits/byte at a mask-ratio grid +
        # the ELBO bound — an UPPER bound on NLL, NOT comparable head-to-head with
        # AR's exact bits/byte (X015 / ADR 0013).
        var noc = ((g_stream == 0) && (g_data == 0)) || (g_datalen < g_T);
        if (noc == 1) { puts("attn11: no/short corpus; skipping eval\n"); }
        else {
            puts("eval (diffusion denoising; ELBO upper bound, not AR's exact NLL):\n");
            eval_diffusion_grid();
        }
    }
    if ((do_eval == 1) && (g_objective != 1)) {
        var et = eval_corpus();
        if (et < 0) { puts("attn11: no/short corpus; skipping eval\n"); }
        else {
            puts("eval: tokens "); fmt_int(g_eval_tokens);
            puts("  bytes "); fmt_int(g_eval_bytes);
            puts("  ce/token "); f_print(f64_div(g_eval_nats, f64_from(g_eval_tokens)), 5);
            puts("  bits/byte "); f_print(eval_bpb(), 5);
            _putc(10);
            # MoE: the density-sweep metrics — total vs per-token-active params
            # and the routing entropy (1 = balanced expert load, 0 = collapse).
            if (g_num_experts > 1) {
                var inactive = g_NL * (g_num_experts - g_expert_topk) * (2 * g_C * g_F + g_F + g_C);
                puts("moe: experts "); fmt_int(g_num_experts);
                puts("  topk "); fmt_int(g_expert_topk);
                puts("  params total "); fmt_int(g_NP);
                puts("  active/token "); fmt_int(g_NP - inactive);
                puts("  route-entropy "); f_print(moe_entropy(), 4);
                _putc(10);
            }
        }
    }

    # ---- held-out eval (X019 follow-on; after own-corpus eval so both print) ----
    # The generalization metric: score the model on a DISJOINT corpus re-encoded
    # through the loaded tokenizer (no vocab-order check). Independent of --eval —
    # works alone or alongside it, and under --gen-only --load (score a saved
    # model on unseen text).
    if (eval_corpus_path != 0) {
        if (g_objective == 1) {
            puts("held-out eval (diffusion denoising; ELBO upper bound; corpus ");
            puts(eval_corpus_path); puts("):\n");
        }
        var hr = eval_corpus_held(eval_corpus_path);
        if (hr < 0) {
            # an explicitly-requested eval that can't run is an error (mirrors
            # --save): a script `attn11 ... --eval-corpus held.txt` must detect a
            # missing/empty/too-short held-out file, not silently exit 0.
            puts("attn11: held-out eval failed (code "); fmt_int(hr); puts(")\n"); rc = 1;
        } elif (g_objective != 1) {
            puts("held-out eval (corpus "); puts(eval_corpus_path); puts("): tokens ");
            fmt_int(g_eval_tokens);
            puts("  bytes "); fmt_int(g_eval_bytes);
            puts("  ce/token "); f_print(f64_div(g_eval_nats, f64_from(g_eval_tokens)), 5);
            puts("  bits/byte "); f_print(eval_bpb(), 5);
            _putc(10);
        }
    }

    # ---- sample ----
    _putc(10);
    if (g_step == 0) { puts("attn11: NOTE model is untrained; sample output is random\n"); }
    if (g_objective == 1) {
        # M15: confidence-ordered iterative unmasking (a diffusion model is
        # bidirectional, so it denoises a whole window — not left-to-right AR).
        if (cfg_decode_steps < 1) { cfg_decode_steps = g_T; }   # resolve for the --load path
        puts("diffusion sample (confidence-ordered unmask):\n");
        gen_diffusion("cyrius ", 7, cfg_decode_steps, cfg_decode_sched, 1);
        gen_diffusion("a transformer ", 14, cfg_decode_steps, cfg_decode_sched, 1);
    } else {
        puts("greedy sample:\n");
        generate("cyrius ", 7, 120, f64_from(0));
        puts("\nsampled (temp 0.8):\n");
        var temp = f64_div(f64_from(8), f64_from(10));
        generate("a transformer ", 14, 120, temp);
    }

    # M18: report GPU engagement so a silent CPU fallback is never mistaken for a GPU run.
    #ifndef CYRIUS_TARGET_AGNOS
    if (g_gpu == 1) {
        if ((gpu_mm_count() > 0) || (gpu_ln_count() > 0) || (gpu_gelu_count() > 0) ||
        (gpu_head_count() > 0) || (gpu_attn_count() > 0) || (gpu_adam_count() > 0) ||
        (gpu_linbwd_count() > 0) || (gpu_headbwd_count() > 0) || (gpu_lnbwd_count() > 0) ||
        (gpu_attnbwd_count() > 0) || (gpu_rope_count() > 0)) {
            puts("GPU: dispatched "); fmt_int(gpu_mm_count()); puts(" matmuls + ");
            fmt_int(gpu_ln_count()); puts(" layernorms");
            if (gpu_adam_count() > 0) { puts(" + "); fmt_int(gpu_adam_count()); puts(" adam steps"); }
            if (gpu_headbwd_count() > 0) { puts(" + "); fmt_int(gpu_headbwd_count()); puts(" head-bwd"); }
            if (gpu_lnbwd_count() > 0) { puts(" + "); fmt_int(gpu_lnbwd_count()); puts(" ln-bwd"); }
            if (gpu_rope_count() > 0) { puts(" + "); fmt_int(gpu_rope_count()); puts(" rope"); }
            puts(" (bit-exact)");
            if (gpu_gelu_count() > 0) { puts(" + "); fmt_int(gpu_gelu_count()); puts(" gelus"); }
            if (gpu_head_count() > 0) { puts(" + "); fmt_int(gpu_head_count()); puts(" heads"); }
            if (gpu_attn_count() > 0) { puts(" + "); fmt_int(gpu_attn_count()); puts(" attention cores"); }
            if (gpu_linbwd_count() > 0) { puts(" + "); fmt_int(gpu_linbwd_count()); puts(" linear-bwd"); }
            if (gpu_attnbwd_count() > 0) { puts(" + "); fmt_int(gpu_attnbwd_count()); puts(" attn-bwd"); }
            if ((gpu_gelu_count() > 0) || (gpu_head_count() > 0) || (gpu_attn_count() > 0) ||
            (gpu_linbwd_count() > 0) || (gpu_attnbwd_count() > 0)) { puts(" (tolerance)"); }
            puts(" on-device\n");
        } else {
            puts("GPU: requested but nothing ran on-device — CPU fallback was used throughout\n");
        }
    }
    #endif

    return rc;
}

# Entry epilogue: `r = main()` must be a STATEMENT, not a `var` initializer —
# on agnos, call initializers run before the compiler-emitted argv init-stack
# capture, so main() would see argc()==0. See docs/architecture/002.
var r = 0;
r = main();
sys_exit(r);
