# attn11 — the model: an N-block GPT with a weight-tied LM head.
#
# Architecture: a pre-norm decoder-only Transformer (Vaswani et al. 2017,
# arXiv:1706.03762; pre-norm placement per Xiong et al. 2020, arXiv:2002.04745;
# GPT-2, Radford et al. 2019). See docs/sources.md for the full citation map.
#
# The model is a singleton, so its tensors live in module globals (far cleaner
# than threading a struct through every call in a language where everything is
# i64).
#
# PARAMETERS are packed into ONE flat vector `g_params`; `g_grads`, `g_adam_m`,
# `g_adam_v` share the identical layout. Layout:
#
#   [ tok_emb (V*C) ][ pos_emb (T*C) ][ block_0 ]...[ block_{NL-1} ][ lnf_g (C) ][ lnf_b (C) ]
#
# Each block is a fixed-size group repeated NL times; layer L's weights are at a
# computed offset (see _blk_base / _o_* helpers). The token embedding is
# weight-tied: it is both the input embedding and the output LM head.

# ---- config ----------------------------------------------------------------
var g_V = 0;    # vocab size
var g_C = 0;    # embedding width (d_model)
var g_T = 0;    # context length
var g_nh = 0;   # number of query heads
var g_nkv = 0;  # number of K/V heads (GQA; nkv divides nh; == nh is full MHA)
var g_F = 0;    # MLP hidden width (= 4*C)
var g_NL = 0;   # number of transformer blocks
var g_NP = 0;   # total parameter count
var g_attn_bias = 0;  # 1 = Q/K/V/O projections carry biases
var g_dropout = 0;    # residual dropout probability (f64 bit pattern; 0 = off)
var g_training = 1;    # dropout active only when training
var g_step = 0;        # completed Adam update count (for resume + checkpoints)

# ---- architecture descriptor (M12 scaffolding; checkpoint v4, ADR 0007) -----
# Reserved opt-in axes, defaulting to the current model so a no-flag run and
# every existing checkpoint stay byte-identical. Only the defaults are accepted
# until MLA / RoPE fill them.
#   g_attn_kind  0 = mha (today)        1 = mla            (reserved)
#   g_pos_kind   0 = learned-abs (today) 1 = rope  2 = rope-decoupled (reserved)
#   g_latent_dim d_c   (MLA latent width; 0 until MLA)
#   g_rope_dim   d_rope (decoupled-RoPE width; 0 until decoupled RoPE)
var g_attn_kind = 0;
var g_pos_kind = 0;
var g_latent_dim = 0;
var g_rope_dim = 0;
# ---- per-layer mixer hybrid (M14 rung c; checkpoint v6, ADR 0011) -----------
# By default every block runs the global g_attn_kind. A HYBRID interleaves mixer
# kinds per layer (the survey's structural lever: a few full-attention layers
# among many cheap recurrent ones). g_layer_kind == 0 means uniform (g_attn_kind
# everywhere — byte-identical to today). When set, it points to NL i64 per-layer
# kinds, read ONLY by _lk(L) in the three dispatch helpers. 1.4.3 (rung c) allowed
# the layout-compatible mix {0 = mha/gqa, 2 = gated-linear}; 1.4.4 (rung d) admits
# any mix of {0,1 = mla,2,3 = ssm} by PADDING each block's K/V region to the max
# _kvw over the present kinds (`_kvw_hyb`) — the per-block stride stays uniform
# (NO per-layer offset refactor), at the cost of a zeroed pad on smaller kinds.
var g_layer_kind = 0;
# layer L's mixer kind: the per-layer array when hybrid, else the global.
fn _lk(L): i64 { if (g_layer_kind == 0) { return g_attn_kind; } return load64(g_layer_kind + L * 8); }
# 1 if ANY block runs mixer kind k — uniform: base == k; hybrid: scan the
# per-layer kinds. Gates the per-kind decode/scratch allocation (LA_c for mla,
# the ssm caches, g_lin_state for lin): a kind's buffers are held when ANY layer
# uses it (allocated for all NL; non-matching layers' slots sit unused — the
# dispatch reads a layer's buffer only when _lk(L) selects that kind).
fn _any_kind(k): i64 {
    if (g_layer_kind == 0) { if (g_attn_kind == k) { return 1; } return 0; }
    var L = 0;
    while (L < g_NL) { if (load64(g_layer_kind + L * 8) == k) { return 1; } L = L + 1; }
    return 0;
}
fn _any_lin(): i64 { return _any_kind(2); }

# ---- MoE descriptor (M13, E8; checkpoint v5) -------------------------------
# The dense GELU MLP becomes N experts + a top-K router. g_num_experts == 1 is
# the dense baseline — byte-identical to today, NO router/gate. g_expert_topk =
# active experts per token. g_aux_alpha = Switch load-balance coefficient (f64
# bit pattern; 0 unless MoE). g_aux_loss carries the last forward's summed aux
# loss (added to the CE loss; also surfaced for logging).
var g_num_experts = 1;
var g_expert_topk = 1;
var g_aux_alpha = 0;
var g_aux_loss = 0;
var g_moe_disp = 0;   # MoE: per-expert dispatch histogram (N counts) for the
                      # utilization metric (routing entropy); accumulated by eval.

# ---- training-objective descriptor (M15, E5; checkpoint v7, ADR 0013) -------
# The default objective is autoregressive next-token CE. g_objective == 1 selects
# masked absorbing-state DIFFUSION: a BIDIRECTIONAL model predicts the original
# bytes at positions corrupted to a learned [MASK] embedding (mask_emb, appended
# after lnf_b — see _o_maskemb). g_objective == 0 is byte-identical to today (the
# AR path is literally unchanged). g_bidir gates the attention causal mask
# (0 = causal, today; 1 = full square) and is set to 1 iff diffusion. g_nmask is
# the masked-position count of the current window — the masked-CE normalizer.
var g_objective = 0;
var g_bidir = 0;
var g_nmask = 0;

# ---- packed parameter vectors ----------------------------------------------
var g_params = 0;
var g_grads = 0;
var g_adam_m = 0;
var g_adam_v = 0;

# ---- parameter layout (element offsets) ------------------------------------
fn _emb_end(): i64 { return g_V * g_C + g_T * g_C; }
# K/V projection width: nkv heads of dim C/nh (== C when nkv == nh; == C for MLA,
# which uses full heads — the cache compression is the latent, not head-sharing).
fn _Ckv(): i64 { return g_nkv * (g_C / g_nh); }
# Size (elements) of the K/V WEIGHT region between Wq and Wo — the ONE place the
# attention variant changes the block layout (ADR 0007). MHA/GQA: Wk(C*Ckv) +
# Wv(C*Ckv). MLA: W_DKV(C*d_c) + W_UK(d_c*C) + W_UV(d_c*C). Everything downstream
# (Wo, ln2, MLP, bias offsets, _blk_base_size, ckpt_expected_np) chains off this
# single helper, so the layout invariant has one source of truth.
# PURE (descriptor-parameterized) per-block weight-region sizes — the SINGLE
# source of the block-layout arithmetic, shared by the offset helpers below (via
# the global wrappers) AND the checkpoint validator (persist.cyr's
# ckpt_expected_np, which sizes a candidate config before any allocation). A new
# mixer axis updates the K/V (or a new) region size in ONE place, not in both
# model.cyr and persist.cyr (the M13/M14 keep-in-sync hazard). 1.4.1.
fn _kvw(C, nh, nkv, ak, dc, pk, dr): i64 {
    if (ak == 1) {                                       # MLA: W_DKV + W_UK + W_UV
        var s = C * dc + 2 * dc * C;
        if (pk == 2) { s = s + C * nh * dr + C * dr; }   # + decoupled-RoPE W_QR/W_KR
        return s;
    }
    if (ak == 3) { return 3 * C * dc + C; }              # SSM (dc = state size N): A + W_B + W_C + D
    return 2 * C * (nkv * (C / nh));                      # MHA/GQA/lin: Wk + Wv (Ckv = nkv*hd)
}
fn _mlpw(C, F, ne): i64 {
    if (ne > 1) { return ne * (2 * C * F + F + C) + C * ne; }   # N experts + router gate
    return 2 * C * F + F + C;                                   # dense Wfc + bfc + Wproj + bproj
}
# Padded block K/V region for a per-layer HYBRID (M14 rung d, ADR 0011): each
# block's K/V region is sized to the MAX _kvw over the kinds PRESENT, so the
# per-block stride stays UNIFORM (no per-layer offset refactor) even when the
# mixed kinds have different region sizes — a layer of a smaller kind tiles its
# own offsets at the shared region base (2C+C²) and leaves a zeroed pad at the end
# (t_alloc zeroes; the pad gets no gradient, so Adam never moves it). {mha,gqa,lin}
# alone share _kvw (max == that size, no pad — rung c's exact layout). All mla/ssm
# layers share the global latent_dim (d_c / state N), so the within-region offset
# helpers stay global-`g_latent_dim`-driven and zero-arg.
fn _kvw_hyb(kinds, NL, C, nh, nkv, dc, pk, dr): i64 {
    var mx = 0;
    var L = 0;
    while (L < NL) {
        var w = _kvw(C, nh, nkv, load64(kinds + L * 8), dc, pk, dr);
        if (w > mx) { mx = w; }
        L = L + 1;
    }
    return mx;
}
fn _kv_weight_size(): i64 {
    if (g_layer_kind != 0) {
        return _kvw_hyb(g_layer_kind, g_NL, g_C, g_nh, g_nkv, g_latent_dim, g_pos_kind, g_rope_dim);
    }
    return _kvw(g_C, g_nh, g_nkv, g_attn_kind, g_latent_dim, g_pos_kind, g_rope_dim);
}
# Size (elements) of the MLP WEIGHT region — the SECOND place an architecture
# axis changes the block layout (M13, E8). Dense: Wfc(C*F) + bfc(F) + Wproj(F*C)
# + bproj(C). MoE (g_num_experts > 1): N experts each the dense quad, packed
# array-of-structs, + the router gate Wg(C*N). Expert 0 starts exactly where the
# dense Wfc does, so the dense _o_Wfc/_o_bfc/_o_Wproj/_o_bproj offsets stay valid
# (they describe expert 0); _o_expert(e)/_o_Wgate index the rest.
fn _moe_estride_blk(): i64 { return _moe_estride(g_C, g_F); }   # per-expert: C*F+F+F*C+C (offset stride)
fn _mlp_weight_size(): i64 { return _mlpw(g_C, g_F, g_num_experts); }
# one block, in elements: ln1(2C) + Wq(C^2) + [K/V weight region] + Wo(C^2) +
# ln2(2C) + [MLP weight region]; plus 2C+2Ckv for attention biases (bq,bk,bv,bo)
# when enabled, appended after the MLP region so the weight offsets below are
# unaffected. For MLA, Ckv == C so the bias region is 4C, same as full MHA.
fn _blk_base_size(): i64 { return 4 * g_C + 2 * g_C * g_C + _kv_weight_size() + _mlp_weight_size(); }
fn _blk(): i64 {
    if (g_attn_bias == 1) { return _blk_base_size() + 2 * g_C + 2 * _Ckv(); }
    return _blk_base_size();
}
fn _blk_base(L): i64 { return _emb_end() + L * _blk(); }

# within-block offsets
fn _o_ln1g(): i64 { return 0; }
fn _o_ln1b(): i64 { return g_C; }
fn _o_Wq(): i64 { return 2 * g_C; }
fn _o_Wk(): i64 { return 2 * g_C + g_C * g_C; }
fn _o_Wv(): i64 { return 2 * g_C + g_C * g_C + g_C * _Ckv(); }
# MLA K/V weight offsets (attn_kind == mla): one down-projection then two
# up-projections occupy the same region MHA's Wk/Wv do.
fn _o_Wdkv(): i64 { return 2 * g_C + g_C * g_C; }                            # C x d_c
fn _o_Wuk(): i64 { return 2 * g_C + g_C * g_C + g_C * g_latent_dim; }        # d_c x C
fn _o_Wuv(): i64 { return 2 * g_C + g_C * g_C + g_C * g_latent_dim + g_latent_dim * g_C; }  # d_c x C
# decoupled-RoPE rope projections (pos_kind == 2), after the up-projections
fn _o_Wqr(): i64 { return _o_Wuv() + g_latent_dim * g_C; }              # C x nh*d_rope
fn _o_Wkr(): i64 { return _o_Wqr() + g_C * g_nh * g_rope_dim; }         # C x d_rope
# SSM (attn_kind == 3) K/V-region offsets: A/W_B/W_C/D (latent_dim = state N);
# Wq doubles as W_dt and Wo as the output projection (the MLA reuse pattern).
fn _o_ssmA(): i64 { return 2 * g_C + g_C * g_C; }                       # C x N (diagonal transition)
fn _o_ssmWB(): i64 { return _o_ssmA() + g_C * g_latent_dim; }          # C x N (B projection)
fn _o_ssmWC(): i64 { return _o_ssmWB() + g_C * g_latent_dim; }         # C x N (C projection)
fn _o_ssmD(): i64 { return _o_ssmWC() + g_C * g_latent_dim; }          # C (skip)
fn _o_Wo(): i64 { return 2 * g_C + g_C * g_C + _kv_weight_size(); }
fn _o_ln2g(): i64 { return _o_Wo() + g_C * g_C; }
fn _o_ln2b(): i64 { return _o_ln2g() + g_C; }
fn _o_Wfc(): i64 { return _o_ln2g() + 2 * g_C; }
fn _o_bfc(): i64 { return _o_Wfc() + g_C * g_F; }
fn _o_Wproj(): i64 { return _o_bfc() + g_F; }
fn _o_bproj(): i64 { return _o_Wproj() + g_F * g_C; }
# MoE MLP offsets (g_num_experts > 1). The MLP region starts where the dense Wfc
# does; expert e is a dense quad at stride _moe_estride_blk(); the gate follows
# all N experts. (_o_expert(0) == _o_Wfc(), so the dense path is unchanged.)
fn _o_mlp(): i64 { return _o_ln2g() + 2 * g_C; }                          # == _o_Wfc()
fn _o_expert(e): i64 { return _o_mlp() + e * _moe_estride_blk(); }        # expert e: Wfc|bfc|Wproj|bproj
fn _o_Wgate(): i64 { return _o_mlp() + g_num_experts * _moe_estride_blk(); }   # router gate: C x N
# attention biases, appended after the base block (only present when enabled)
fn _o_bq(): i64 { return _blk_base_size(); }
fn _o_bk(): i64 { return _blk_base_size() + g_C; }
fn _o_bv(): i64 { return _blk_base_size() + g_C + _Ckv(); }
fn _o_bo(): i64 { return _blk_base_size() + g_C + 2 * _Ckv(); }

# per-layer param / grad sub-pointers
fn PL(L, off): i64 { return g_params + (_blk_base(L) + off) * 8; }
fn GL(L, off): i64 { return g_grads + (_blk_base(L) + off) * 8; }
# attention-bias sub-pointers — return 0 (no bias) when disabled
fn P_bq(L): i64 { if (g_attn_bias == 0) { return 0; } return PL(L, _o_bq()); }
fn P_bk(L): i64 { if (g_attn_bias == 0) { return 0; } return PL(L, _o_bk()); }
fn P_bv(L): i64 { if (g_attn_bias == 0) { return 0; } return PL(L, _o_bv()); }
fn P_bo(L): i64 { if (g_attn_bias == 0) { return 0; } return PL(L, _o_bo()); }
fn G_bq(L): i64 { if (g_attn_bias == 0) { return 0; } return GL(L, _o_bq()); }
fn G_bk(L): i64 { if (g_attn_bias == 0) { return 0; } return GL(L, _o_bk()); }
fn G_bv(L): i64 { if (g_attn_bias == 0) { return 0; } return GL(L, _o_bv()); }
fn G_bo(L): i64 { if (g_attn_bias == 0) { return 0; } return GL(L, _o_bo()); }

# shared param / grad sub-pointers
fn P_tokemb(): i64 { return g_params; }
fn G_tokemb(): i64 { return g_grads; }
fn P_posemb(): i64 { return g_params + (g_V * g_C) * 8; }
fn G_posemb(): i64 { return g_grads + (g_V * g_C) * 8; }
fn P_lnfg(): i64 { return g_params + (_emb_end() + g_NL * _blk()) * 8; }
fn G_lnfg(): i64 { return g_grads + (_emb_end() + g_NL * _blk()) * 8; }
fn P_lnfb(): i64 { return P_lnfg() + g_C * 8; }
fn G_lnfb(): i64 { return G_lnfg() + g_C * 8; }
# ---- diffusion [MASK] embedding (M15, E5) ----------------------------------
# A single learned C-vector, appended to the param block AFTER lnf_b, present
# ONLY when g_objective == 1 (g_NP grows by C only under diffusion, so an AR
# model's layout / draw order / checkpoint stay byte-identical). It is fed as the
# input embedding at masked positions; the weight-tied LM head is untouched
# (still V logits). Its offset is the OLD (AR) g_NP — i.e. just past lnf_b.
fn _o_maskemb(): i64 { return _emb_end() + g_NL * _blk() + 2 * g_C; }
fn P_maskemb(): i64 { return g_params + _o_maskemb() * 8; }
fn G_maskemb(): i64 { return g_grads + _o_maskemb() * 8; }

# ---- shared activation caches ----------------------------------------------
var A_tokens = 0; var A_targets = 0;  # T (integer ids)
var A_mask = 0;   # T: 1 at masked (supervised) positions, 0 at given — diffusion
                  # only (M15). Allocated for all models (tiny, T i64), read only
                  # when g_objective == 1, so an AR run is byte-output-identical.
var A_attn = 0;   # T x C  attention output (forward temp)
var A_mlp = 0;    # T x C  MLP output       (forward temp)
var A_f = 0;      # T x C  final-LN output (head input)
var A_logits = 0; # T x V
var A_probs = 0;  # T x V
var A_meanf = 0; var A_rstdf = 0;     # T

# ---- per-layer activation caches (arrays of pointers) ----------------------
var LA_resid = 0; # (NL+1) pointers, each T*C  (residual stream; [0]=embeddings)
var LA_a = 0;     # NL pointers, each T*C  (ln1 out / attn in)
var LA_xmid = 0;  # NL pointers, each T*C  (xin + attn)
var LA_b = 0;     # NL pointers, each T*C  (ln2 out / mlp in)
var LA_fc = 0;    # NL pointers, each T*F  (pre-GELU)
var LA_g = 0;     # NL pointers, each T*F  (GELU out)
var LA_m1 = 0; var LA_r1 = 0;         # NL pointers, each T
var LA_m2 = 0; var LA_r2 = 0;         # NL pointers, each T
var LA_arena = 0; # NL pointers, each attn_arena_size
var LA_dmask_attn = 0;  # NL pointers, each T*C  (residual dropout mask, attn branch)
var LA_dmask_mlp = 0;   # NL pointers, each T*C  (residual dropout mask, mlp branch)
var LA_c = 0;     # MLA only: NL pointers, each T*d_c (the cached latent c_KV)
var LA_qr = 0;    # decoupled RoPE only: NL pointers, each T*nh*d_rope (rotated rope query)
var LA_kr = 0;    # decoupled RoPE only: NL pointers, each T*d_rope (rotated shared rope key; cached)
# MoE only (g_num_experts > 1): per-layer router/expert caches written by moe_fwd
# for moe_bwd / moe_aux. logits(T*N), sel(T*K i64), gate(T*K), efc/egg(T*K*F).
var LA_mlogits = 0; var LA_msel = 0; var LA_mgate = 0; var LA_mefc = 0; var LA_megg = 0;
var g_moe_sc = 0;    # shared MoE scratch, >= 2*F + 2*C + 3*N + K (fwd/bwd + aux)
var g_moe_dlaux = 0; # shared aux-backward router-gradient scratch, T*N

fn La(arr, L): i64 { return load64(arr + L * 8); }

# ---- gradient temporaries (shared, reused across layers) -------------------
var D_logits = 0; # T x V
var D_f = 0;      # T x C
var D_resid = 0;  # T x C (rolling residual-stream gradient)
var D_xmid = 0;   # T x C
var D_a = 0;      # T x C
var D_b = 0;      # T x C
var D_g = 0;      # T x F
var D_fc = 0;     # T x F
var D_tmp = 0;    # T x C (ln residual-path scratch)
var D_drop = 0;   # T x C (dropout-adjusted branch gradient)
var D_lat1 = 0;   # MLA only: T x d_c (dc from W_UK; accumulates dc from W_UV)
var D_lat2 = 0;   # MLA only: T x d_c (dc from W_UV)
var D_qr = 0;     # decoupled RoPE only: T x nh*d_rope (rope-query gradient)
var D_kr = 0;     # decoupled RoPE only: T x d_rope (shared rope-key gradient)

# ---- KV caches + single-row scratch (inference/generation path, E1) ---------
var KV_K = 0;     # NL pointers, each T x Ckv (per-layer K cache)
var KV_V = 0;     # NL pointers, each T x Ckv (per-layer V cache)
var g_lin_state = 0;  # gated-linear (attn_kind==2) only: NL pointers, each nh*hd^2
                      # — the per-layer retention STATE (the constant-size decode cache)
# selective SSM (attn_kind==3) only. Per-layer forward caches for the backward
# (Δ, B, C, the per-step state h, and the pre-Wo output y); the shared reverse-scan
# scratch; and g_ssm_state, the per-layer C*N decode STATE (constant-size cache).
var LA_ssm_dlt = 0; var LA_ssm_B = 0; var LA_ssm_C = 0; var LA_ssm_h = 0; var LA_ssm_y = 0;
var g_ssm_dy = 0; var g_ssm_dDlt = 0; var g_ssm_dBm = 0; var g_ssm_dCm = 0; var g_ssm_dhc = 0; var g_ssm_sc = 0;
var g_ssm_state = 0;  # NL pointers, each C*N
var R_x = 0;      # C  residual-stream row
var R_a = 0;      # C  ln1 out / attn in
var R_attn = 0;   # C  attention out
var R_xmid = 0;   # C  x + attn
var R_b = 0;      # C  ln2 out / mlp in
var R_fc = 0;     # F  pre-GELU
var R_g = 0;      # F  GELU out
var R_mlp = 0;    # C  mlp out
var R_f = 0;      # C  final-LN out
var R_q = 0;      # C  query row
var R_qr = 0;     # decoupled RoPE only: nh*d_rope  rope-query row scratch
var R_concat = 0; # C  pre-Wo concat row
var R_mean = 0; var R_rstd = 0;       # 1 each
var R_prow = 0;   # T  attention-probability row scratch
var R_logits = 0; # V  the processed position's logits
var G_win = 0;    # T  token ids in the generation window
var G_n = 0;      # tokens currently in the window (== valid cache positions)

# Config invariants. An inconsistent (C, nh, nkv) silently corrupts memory:
# kvb = (h/gsz)*hd walks past the Ckv-wide K/V rows when nkv doesn't divide
# nh, and hd truncates when nh doesn't divide C. The checkpoint loader rejects
# these (-16); the in-process constructor must too.
fn model_config_ok(V, C, T, nh, nkv, NL): i64 {
    return model_config_ok_arch(V, C, T, nh, nkv, NL, 0, 0, 0, 0);   # mha, no latent, learned-abs
}
# attn_kind/d_c/pos_kind/d_rope-aware variant (ADR 0007). model_config_ok delegates
# with the MHA / learned-abs default so existing callers stay unchanged.
fn model_config_ok_arch(V, C, T, nh, nkv, NL, attn_kind, d_c, pos_kind, d_rope): i64 {
    return model_config_ok_moe(V, C, T, nh, nkv, NL, attn_kind, d_c, pos_kind, d_rope, 1, 1);   # dense MLP
}
# MoE-aware variant (M13, E8; checkpoint v5). model_config_ok_arch delegates with
# the dense default (1 expert, top-1) so existing callers stay unchanged.
fn model_config_ok_moe(V, C, T, nh, nkv, NL, attn_kind, d_c, pos_kind, d_rope, num_experts, topk): i64 {
    if ((V < 1) || (C < 1) || (T < 1) || (NL < 1)) { return 0; }
    # Magnitude caps mirror the checkpoint loader's (-4/-5/-7/-8). The fresh
    # path takes CLI-supplied dims (`--layers`, and `--preset`-set C/T) — an
    # unbounded NL makes `NL * _blk()` (and model_alloc_bytes) overflow i64,
    # wrapping to a small positive size that t_alloc accepts, after which the
    # weight-init loops write past the undersized buffer (heap OOB). Capping
    # here keeps every product below the overflow point so the byte-total
    # pre-flight in model_init is meaningful. BPE_VMAX() == 768.
    if ((V > BPE_VMAX()) || (C > 4096) || (T > 8192) || (NL > 128)) { return 0; }
    if ((nh < 1) || (nh > C) || ((C % nh) != 0)) { return 0; }
    if ((nkv < 1) || (nkv > nh) || ((nh % nkv) != 0)) { return 0; }
    # MLA (attn_kind == 1): full heads — the cache compression is the latent, not
    # head-sharing — and a positive low-rank d_c bounded by C (so C*d_c <= C*C,
    # already inside the alloc budget). mha (0) ignores d_c.
    # attn_kind 2 = gated linear attention (M14, E4): a non-softmax sequence mixer
    # over the MHA projection layout — full heads (nkv == nh), no latent (d_c == 0),
    # learned-absolute positions only (RoPE is softmax-only). Parameter-free core.
    # attn_kind 3 = selective SSM (M14 rung b): d_c reused as the state size N
    # (1..C); full heads, learned-abs; reuses Wq (W_dt) + Wo (output proj).
    if ((attn_kind != 0) && (attn_kind != 1) && (attn_kind != 2) && (attn_kind != 3)) { return 0; }
    if ((attn_kind == 1) || (attn_kind == 3)) {
        if (nkv != nh) { return 0; }
        if ((d_c < 1) || (d_c > C)) { return 0; }   # MLA latent / SSM state size
    }
    if (attn_kind == 2) {
        if (nkv != nh) { return 0; }       # full K/V (no GQA in the basic linear mixer)
        if (d_c != 0) { return 0; }        # no latent
        if (pos_kind != 0) { return 0; }   # learned-abs only (RoPE is softmax attention)
    }
    if (attn_kind == 3) {
        if (pos_kind != 0) { return 0; }   # learned-abs only (the scan carries position)
    }
    # pos_kind (ADR 0007 / M12 increment 4): 0 = learned-abs (default), 1 = coupled
    # RoPE. RoPE rotates dimension PAIRS (2k, 2k+1) within each head, so the head
    # dim hd = C/nh must be EVEN; and 1.2.2 ships coupled RoPE on dense MHA/GQA
    # only — MLA + RoPE is the faithful decoupled form (pos_kind 2, a later rung),
    # so reject mla + rope here. pos_kind 2 = decoupled RoPE for MLA (1.2.3, the
    # faithful DeepSeek form): a separate even d_rope channel (W_QR/W_KR), so it
    # requires MLA and an even, in-range d_rope; the content head dim need NOT be
    # even (the rotation lives on the d_rope channel, not the content head).
    if ((pos_kind != 0) && (pos_kind != 1) && (pos_kind != 2)) { return 0; }
    if (pos_kind == 1) {
        if (attn_kind != 0) { return 0; }       # coupled RoPE is MHA/GQA only
        if (((C / nh) % 2) != 0) { return 0; }  # even head dim required
    }
    if (pos_kind == 2) {
        if (attn_kind != 1) { return 0; }       # decoupled RoPE is MLA-only
        if ((d_rope < 2) || (d_rope > C)) { return 0; }
        if ((d_rope % 2) != 0) { return 0; }    # even for the (2k,2k+1) rotation
    }
    # rope_dim is 0 unless decoupled (mirrors d_c == 0 unless MLA)
    if ((pos_kind != 2) && (d_rope != 0)) { return 0; }
    # MoE (M13): num_experts >= 1 (1 = dense). Cap N at 256 (the roadmap's sweep
    # ceiling); the 128 MB alloc pre-flight in model_init bounds the rest (large
    # N at non-trivial C/NL is rejected there, not here). 1 <= topk <= num_experts.
    if ((num_experts < 1) || (num_experts > 256)) { return 0; }
    if ((topk < 1) || (topk > num_experts)) { return 0; }
    return 1;
}
# Per-layer HYBRID validity (M14 rung c+d). `kinds` is NL i64 mixer kinds. Rung d
# (1.4.4) admits ANY mix of {mha/gqa (0), mla (1), lin (2), ssm (3)}: the block K/V
# region is PADDED to the max _kvw over the present kinds (`_kvw_hyb`), so the
# per-block stride stays uniform regardless of which kinds appear — no per-layer
# offset refactor. The cross-cutting constraints are what remains: RoPE is
# softmax/MLA-specific so a hybrid is learned-absolute (pos_kind == 0); mla/ssm/lin
# all need FULL heads (nkv == nh); and the SHARED latent_dim (d_c, used as the MLA
# d_c / SSM state N by every latent layer) must be in [1, C] iff any mla/ssm layer
# is present (else 0). Returns 1 if valid, 0 if not.
fn _hybrid_kinds_ok(kinds, NL, C, nh, nkv, d_c, pos_kind, d_rope): i64 {
    if (pos_kind != 0) { return 0; }       # learned-abs only (no RoPE in a hybrid)
    if (nkv != nh) { return 0; }           # mla/ssm/lin layers require full heads
    var L = 0;
    var needs_latent = 0;
    while (L < NL) {
        var k = load64(kinds + L * 8);
        if ((k != 0) && (k != 1) && (k != 2) && (k != 3)) { return 0; }   # a known kind
        if ((k == 1) || (k == 3)) { needs_latent = 1; }                   # mla / ssm use the latent
        L = L + 1;
    }
    if (needs_latent == 1) { if ((d_c < 1) || (d_c > C)) { return 0; } }
    else { if (d_c != 0) { return 0; } }
    return 1;
}
# Pure kind-presence helpers (the alloc-accounting mirror of model_init's gates):
# does any layer run kind k? _alloc_has handles both the uniform (kinds == 0, all
# layers run attn_kind) and hybrid (scan the per-layer array) cases.
fn _present(kinds, NL, k): i64 {
    var L = 0;
    while (L < NL) { if (load64(kinds + L * 8) == k) { return 1; } L = L + 1; }
    return 0;
}
fn _alloc_has(kinds, NL, attn_kind, k): i64 {
    if (kinds == 0) { if (attn_kind == k) { return 1; } return 0; }
    return _present(kinds, NL, k);
}

# Exact bytes model_init will allocate for a config (NP precomputed by the
# caller). Used by the checkpoint loader to reject configs that would drive
# the allocator past its cap BEFORE any allocation happens. KEEP IN SYNC with
# model_init — test_alloc_accounting pins the two together.
fn model_alloc_bytes(V, C, T, nh, nkv, NL, NP): i64 {
    return model_alloc_bytes_arch(V, C, T, nh, nkv, NL, NP, 0, 0, 0, 0);   # mha
}
# attn_kind/d_c/pos_kind/d_rope-aware variant (ADR 0007). model_alloc_bytes
# delegates with the MHA default so existing callers/tests are unchanged.
fn model_alloc_bytes_arch(V, C, T, nh, nkv, NL, NP, attn_kind, d_c, pos_kind, d_rope): i64 {
    return model_alloc_bytes_moe(V, C, T, nh, nkv, NL, NP, attn_kind, d_c, pos_kind, d_rope, 1, 1);
}
# MoE-aware variant (M13). KEEP IN SYNC with model_init_moe — test_alloc_accounting
# pins the two together (incl. the MoE per-layer router/expert caches + scratch).
fn model_alloc_bytes_moe(V, C, T, nh, nkv, NL, NP, attn_kind, d_c, pos_kind, d_rope, num_experts, topk): i64 {
    return model_alloc_bytes_hyb(V, C, T, nh, nkv, NL, NP, attn_kind, d_c, pos_kind, d_rope, num_experts, topk, 0);
}
# Hybrid-aware (M14 rung c/d). `kinds` = 0 for a uniform model (every layer runs
# attn_kind), else the NL per-layer kind array (also held as g_layer_kind, +NL).
# Each kind's caches are counted when ANY layer uses it (mirrors model_init's
# presence gates) — for a hybrid the per-layer buffers are held for all NL layers.
fn model_alloc_bytes_hyb(V, C, T, nh, nkv, NL, NP, attn_kind, d_c, pos_kind, d_rope,
                         num_experts, topk, kinds): i64 {
    var F = 4 * C;
    var Ckv = nkv * (C / nh);
    var asz = attn_arena_size(T, C, nh, nkv);
    var e = 4 * NP;                                   # params, grads, m, v
    e = e + 3 * T + 3 * T * C + 2 * T * V + 2 * T;    # tokens/targets/mask (M15), A_*, meanf/rstdf
    e = e + (NL + 1) + 14 * NL;                       # pointer arrays (LA_* + KV_K/KV_V)
    e = e + (NL + 1) * T * C;                         # residual stream
    e = e + NL * (5 * T * C + 2 * T * F + 4 * T + asz + 2 * T * Ckv);  # per-layer caches + arena + KV
    e = e + T * V + 7 * T * C + 2 * T * F;            # gradient temporaries
    e = e + 9 * C + 2 * F + 2 + T + V + T;            # single-row scratch + G_win
    # MLA latent buffers (ADR 0007): LA_c pointer array (NL) + per-layer latent c
    # (NL * T*d_c) + the two shared down/up backward temporaries (2 * T*d_c).
    if (_alloc_has(kinds, NL, attn_kind, 1) == 1) { e = e + NL + NL * T * d_c + 2 * T * d_c; }
    # decoupled-RoPE buffers (pos_kind == 2): LA_qr + LA_kr pointer arrays (2*NL) +
    # per-layer rope query/key (NL * (T*nh*d_rope + T*d_rope)) + the two shared
    # backward temporaries D_qr (T*nh*d_rope) + D_kr (T*d_rope).
    if (pos_kind == 2) {
        e = e + 2 * NL + NL * (T * nh * d_rope + T * d_rope) + T * nh * d_rope + T * d_rope;
        e = e + nh * d_rope;   # R_qr single-row scratch
    }
    # gated-linear: the per-layer retention state cache (NL pointers + NL·nh·hd^2).
    # The arena's 2·hd^2 lin scratch is already in `asz` above. Counted when any
    # layer is lin (a uniform lin model OR a hybrid with lin layers).
    if (_alloc_has(kinds, NL, attn_kind, 2) == 1) { e = e + NL + NL * nh * (C / nh) * (C / nh); }
    if (kinds != 0) { e = e + NL; }   # per-layer g_layer_kind array (NL i64), held only by a hybrid
    # selective SSM (d_c = state N): 6 per-layer pointer arrays + per-layer caches
    # (Δ/B/C/h/y + the C*N decode state) + shared reverse scratch. Counted when any
    # layer is ssm.
    if (_alloc_has(kinds, NL, attn_kind, 3) == 1) {
        e = e + 6 * NL;
        e = e + NL * (2 * T * C + 2 * T * d_c + T * C * d_c + C * d_c);
        e = e + 3 * T * C + 2 * T * d_c + C * d_c;
    }
    # MoE buffers (M13, num_experts > 1): 5 per-layer pointer arrays (LA_mlogits/
    # msel/mgate/mefc/megg) + per-layer router/expert caches logits(T*N) +
    # sel/gate(2*T*K) + efc/egg(2*T*K*F) + shared scratch g_moe_sc(2F+2C+3N+K) +
    # the aux router-gradient scratch g_moe_dlaux(T*N).
    if (num_experts > 1) {
        e = e + 5 * NL;
        e = e + NL * (T * num_experts + 2 * T * topk + 2 * T * topk * F);
        e = e + 2 * F + 2 * C + 3 * num_experts + topk;
        e = e + T * num_experts;
        e = e + num_experts;                       # g_moe_disp utilization histogram
    }
    return e * 8;
}

# The model-allocation cap (128 MB), gating model_alloc_bytes for BOTH the
# checkpoint loader (persist.cyr `-18`) and model_init's fresh-path pre-flight.
# Defined here, not in persist.cyr, so every harness that builds a model has it
# (the bench harness includes model.cyr but not persist.cyr).
fn CKPT_MAX_MODEL_BYTES(): i64 { return 134217728; }

# ---- init ------------------------------------------------------------------
# attn_bias: 1 to give Q/K/V/O biases. dropout: residual dropout prob (f64).
# nkv: K/V heads (must divide nh; pass nh for classic multi-head attention).
# model_init builds the default MHA/GQA transformer; model_init_arch (below) adds
# the attn_kind / latent-dim axis (ADR 0007). Existing callers use model_init.
fn model_init(V, C, T, nh, nkv, NL, attn_bias, dropout, seed): i64 {
    return model_init_arch(V, C, T, nh, nkv, NL, attn_bias, dropout, seed, 0, 0, 0, 0);
}
fn model_init_arch(V, C, T, nh, nkv, NL, attn_bias, dropout, seed, attn_kind, d_c, pos_kind, d_rope): i64 {
    return model_init_moe(V, C, T, nh, nkv, NL, attn_bias, dropout, seed, attn_kind, d_c, pos_kind, d_rope, 1, 1);
}
# MoE-aware constructor (M13, E8). model_init_arch delegates with the dense
# default (1 expert) so a no-flag run and every existing caller stay byte-identical.
# model_init_moe is the uniform entry (hybrid_kinds = 0); model_init_full carries
# the M14 rung-c per-layer hybrid array (1.4.3). Existing callers use model_init_moe.
fn model_init_moe(V, C, T, nh, nkv, NL, attn_bias, dropout, seed,
                  attn_kind, d_c, pos_kind, d_rope, num_experts, topk): i64 {
    return model_init_full(V, C, T, nh, nkv, NL, attn_bias, dropout, seed,
                           attn_kind, d_c, pos_kind, d_rope, num_experts, topk, 0, 0);
}
# hybrid_kinds: 0 = uniform (every block runs attn_kind); else a pointer to NL
# i64 per-layer mixer kinds (copied into g_layer_kind). Rung d (1.4.4) admits any
# mix of {mha,mla,lin,ssm} — the K/V region pads to the max _kvw — validated by
# _hybrid_kinds_ok (learned-abs, full heads, a valid shared latent for mla/ssm).
fn model_init_full(V, C, T, nh, nkv, NL, attn_bias, dropout, seed,
                   attn_kind, d_c, pos_kind, d_rope, num_experts, topk, hybrid_kinds, objective): i64 {
    if (model_config_ok_moe(V, C, T, nh, nkv, NL, attn_kind, d_c, pos_kind, d_rope, num_experts, topk) == 0) {
        puts("attn11: model_init: invalid config (need nh | C, nkv | nh, nkv <= nh; ");
        puts("mla: nkv == nh, 1 <= d_c <= C; rope: mha + even hd; rope-decoupled: mla + even d_rope; ");
        puts("moe: 1 <= num_experts <= 256, 1 <= topk <= num_experts)\n");
        sys_exit(1);
    }
    # M15 diffusion backstop (the CLI + checkpoint loader are the primary gates):
    # the masked-diffusion objective is MHA (kind 0) + learned-abs (pos 0) + dense
    # (1 expert) + uniform (no hybrid) for v1.5.0. lin/ssm are causal recurrences
    # (no bidirectional form); mla/moe/rope-diffusion are additive fast-follows.
    if (objective != 0) {
        if ((objective != 1) || (attn_kind != 0) || (pos_kind != 0)
            || (num_experts != 1) || (hybrid_kinds != 0)) {
            puts("attn11: model_init: diffusion objective requires mha + learned-abs + dense + uniform\n");
            sys_exit(1);
        }
    }
    # M16 ternary backstop (E6, ADR 0014). g_ternary is a global set by main()
    # (gated at the CLI) or the checkpoint loader (validated, -49). v1.6.0 scope:
    # mha (kind 0) + learned-abs (pos 0) + dense (1 expert) + uniform (no hybrid)
    # + AR (objective 0). The other axes are documented fast-follows. This is the
    # defense-in-depth gate (the primary gates run before model_init).
    if (g_ternary == 1) {
        if ((attn_kind != 0) || (pos_kind != 0) || (num_experts != 1)
            || (hybrid_kinds != 0) || (objective != 0)) {
            puts("attn11: model_init: ternary requires mha + learned-abs + dense + uniform + ar\n");
            sys_exit(1);
        }
    }
    g_V = V; g_C = C; g_T = T; g_nh = nh; g_nkv = nkv; g_NL = NL; g_F = 4 * C;
    g_attn_bias = attn_bias; g_dropout = dropout; g_training = 1; g_step = 0;
    # architecture descriptor (ADR 0007). g_attn_kind/g_latent_dim/g_pos_kind/
    # g_rope_dim AND g_num_experts must be set BEFORE g_NP, since
    # _blk()->_kv_weight_size()/_mlp_weight_size() read them (MLA adds W_DKV/up,
    # decoupled RoPE adds W_QR/W_KR, MoE swaps the MLP region for N experts + gate).
    g_attn_kind = attn_kind; g_pos_kind = pos_kind; g_latent_dim = d_c; g_rope_dim = d_rope;
    g_num_experts = num_experts; g_expert_topk = topk;
    # M15 objective descriptor (E5). Set BEFORE g_NP — diffusion appends mask_emb
    # (C) to the param block — and BEFORE the g_bidir-reading attention dispatch.
    # g_bidir = 1 iff diffusion (the attention causal mask becomes the full square).
    g_objective = objective;
    g_bidir = 0;
    if (objective == 1) { g_bidir = 1; }
    # per-layer hybrid (M14 rung c): copy the NL kinds into g_layer_kind, or stay
    # uniform (0). Reset FIRST so a re-init (tests build many models) never carries
    # a stale array from a prior hybrid. Set before g_NP/_any_lin reads it.
    g_layer_kind = 0;
    if (hybrid_kinds != 0) {
        if (_hybrid_kinds_ok(hybrid_kinds, NL, C, nh, nkv, d_c, pos_kind, d_rope) == 0) {
            puts("attn11: model_init: invalid hybrid (per-layer kinds in {mha,mla,lin,ssm}; ");
            puts("full heads; learned-abs positions; shared latent in [1,C] iff any mla/ssm)\n");
            sys_exit(1);
        }
        g_layer_kind = t_alloc(NL);
        var lk = 0;
        while (lk < NL) { store64(g_layer_kind + lk * 8, load64(hybrid_kinds + lk * 8)); lk = lk + 1; }
    }
    g_aux_alpha = f64_from(0);
    if (num_experts > 1) { g_aux_alpha = f64_div(f64_from(1), f64_from(100)); }   # Switch α = 0.01
    var F = g_F;
    g_NP = _emb_end() + NL * _blk() + 2 * C;
    # M15: the learned [MASK] embedding (C) is appended after lnf_b, present ONLY
    # under diffusion — so an AR model's g_NP, draw order, Adam state, and v5/v6
    # checkpoints are byte-identical. It rides g_params, so Adam / grad-clip /
    # zero-grads / serialize (all of which iterate g_NP) handle it for free.
    if (objective == 1) { g_NP = g_NP + C; }

    # Pre-allocation cap, mirroring the checkpoint loader's -18 (model_config_ok
    # has already bounded the dims, so this product cannot overflow): a
    # shape-valid config can still imply a model larger than the allocator cap.
    # Reject BEFORE any allocation so a hostile --layers/--preset combination
    # aborts cleanly instead of through an oversized/undersized t_alloc.
    # g_layer_kind (0 = uniform, else the per-layer array) drives the per-kind
    # cache accounting — each present kind's buffers + the NL kind array.
    var abytes = model_alloc_bytes_hyb(V, C, T, nh, nkv, NL, g_NP, attn_kind, d_c, pos_kind, d_rope,
                                       num_experts, topk, g_layer_kind);
    if (abytes > CKPT_MAX_MODEL_BYTES()) {
        puts("attn11: model_init: config exceeds the 128 MB model-allocation cap\n");
        sys_exit(1);
    }

    g_params = t_alloc(g_NP);
    g_grads = t_alloc(g_NP);
    g_adam_m = t_alloc(g_NP);
    g_adam_v = t_alloc(g_NP);
    # M16 (E6): a scratch buffer holding the quantized W_eff of the active matmul.
    # Sized to the largest quantized matrix — C*F (the MLP Wfc/Wproj, F = 4C) >=
    # C*C (the attention Q/K/V/O) — and reused sequentially (only one quantized
    # matmul is live at a time). Allocated ONLY under ternary (g_qscratch stays 0
    # otherwise, and qlinear_* is then a pure passthrough — default byte-identical).
    g_qscratch = 0;
    if (g_ternary == 1) { g_qscratch = t_alloc(g_C * g_F); }

    # initialise weights
    rng_seed(seed);
    var std = f64_div(f64_from(2), f64_from(100));   # 0.02
    # GPT-2 residual-projection scaling: 1/sqrt(2*NL) (Radford et al. 2019, §2.3)
    var rstd = f64_div(std, f64_sqrt(f64_from(2 * NL)));
    t_randn(P_tokemb(), V * C, std);
    t_randn(P_posemb(), T * C, std);
    var Ckv = _Ckv();
    var L = 0;
    while (L < NL) {
        t_fill(PL(L, _o_ln1g()), C, f64_from(1));
        t_fill(PL(L, _o_ln2g()), C, f64_from(1));
        t_randn(PL(L, _o_Wq()), C * C, std);
        # per-layer kind (M14 rung c/d): a hybrid inits each block to ITS OWN kind's
        # K/V weights within the (padded) region; the pad tail stays zero (t_alloc).
        # Uniform model: _lk(L) == attn_kind for every L, so this is unchanged.
        var lkk = _lk(L);
        if (lkk == 1) {
            # MLA: down-projection C->d_c, then two up-projections d_c->C
            t_randn(PL(L, _o_Wdkv()), C * d_c, std);
            t_randn(PL(L, _o_Wuk()), d_c * C, std);
            t_randn(PL(L, _o_Wuv()), d_c * C, std);
            # decoupled RoPE: the rope projections W_QR (C->nh*d_rope) + W_KR (C->d_rope)
            if (pos_kind == 2) {
                t_randn(PL(L, _o_Wqr()), C * nh * d_rope, std);
                t_randn(PL(L, _o_Wkr()), C * d_rope, std);
            }
        } elif (lkk == 3) {
            # SSM (Wq=W_dt above, Wo=output proj below): B/C projections randn; the
            # diagonal A is a fixed negative ramp -(n+1) (S4D-style — a spread of
            # decay rates exp(Δ·A) across state dims); D is the identity skip (=1).
            t_randn(PL(L, _o_ssmWB()), C * d_c, std);
            t_randn(PL(L, _o_ssmWC()), C * d_c, std);
            t_fill(PL(L, _o_ssmD()), C, f64_from(1));
            var ci = 0;
            while (ci < C) {
                var ni = 0;
                while (ni < d_c) {
                    store64(PL(L, _o_ssmA()) + (ci * d_c + ni) * 8, f64_sub(f64_from(0), f64_from(ni + 1)));
                    ni = ni + 1;
                }
                ci = ci + 1;
            }
        } else {
            t_randn(PL(L, _o_Wk()), C * Ckv, std);
            t_randn(PL(L, _o_Wv()), C * Ckv, std);
        }
        t_randn(PL(L, _o_Wo()), C * C, rstd);     # residual projection
        if (num_experts > 1) {
            # N experts, each a dense quad; Wproj is the residual projection (rstd).
            # The router gate gets the standard 0.02 init. Biases (bfc/bproj) zero.
            var ei = 0;
            while (ei < num_experts) {
                t_randn(PL(L, _o_expert(ei)), C * F, std);                 # Wfc_e
                t_randn(PL(L, _o_expert(ei) + C * F + F), F * C, rstd);    # Wproj_e
                ei = ei + 1;
            }
            t_randn(PL(L, _o_Wgate()), C * num_experts, std);             # router gate
        } else {
            t_randn(PL(L, _o_Wfc()), C * F, std);
            t_randn(PL(L, _o_Wproj()), F * C, rstd);  # residual projection
        }
        # biases (bfc, bproj, attn biases) and ln betas already zero
        L = L + 1;
    }
    t_fill(P_lnfg(), C, f64_from(1));
    # M15: the learned [MASK] embedding, inited like the token embedding (0.02).
    # AFTER every other param draw, so an AR run (objective 0, skipped) keeps its
    # exact RNG draw order — byte-identical.
    if (objective == 1) { t_randn(P_maskemb(), C, std); }

    # shared caches
    var TC = T * C; var TV = T * V;
    A_tokens = t_alloc(T); A_targets = t_alloc(T); A_mask = t_alloc(T);
    A_attn = t_alloc(TC); A_mlp = t_alloc(TC); A_f = t_alloc(TC);
    A_logits = t_alloc(TV); A_probs = t_alloc(TV);
    A_meanf = t_alloc(T); A_rstdf = t_alloc(T);

    # per-layer cache arrays
    LA_resid = t_alloc(NL + 1);
    LA_a = t_alloc(NL); LA_xmid = t_alloc(NL); LA_b = t_alloc(NL);
    LA_fc = t_alloc(NL); LA_g = t_alloc(NL);
    LA_m1 = t_alloc(NL); LA_r1 = t_alloc(NL);
    LA_m2 = t_alloc(NL); LA_r2 = t_alloc(NL);
    LA_arena = t_alloc(NL);
    LA_dmask_attn = t_alloc(NL); LA_dmask_mlp = t_alloc(NL);
    # per-kind caches gated on PRESENCE (any layer of that kind), not the base —
    # so a hybrid holds every present kind's caches (M14 rung d).
    var has_mla = _any_kind(1); var has_ssm = _any_kind(3);
    if (has_mla == 1) { LA_c = t_alloc(NL); }
    if (pos_kind == 2) { LA_qr = t_alloc(NL); LA_kr = t_alloc(NL); }
    if (num_experts > 1) {
        LA_mlogits = t_alloc(NL); LA_msel = t_alloc(NL); LA_mgate = t_alloc(NL);
        LA_mefc = t_alloc(NL); LA_megg = t_alloc(NL);
    }
    if (has_ssm == 1) {
        LA_ssm_dlt = t_alloc(NL); LA_ssm_B = t_alloc(NL); LA_ssm_C = t_alloc(NL);
        LA_ssm_h = t_alloc(NL); LA_ssm_y = t_alloc(NL); g_ssm_state = t_alloc(NL);
    }
    var i = 0;
    while (i < NL + 1) { store64(LA_resid + i * 8, t_alloc(TC)); i = i + 1; }
    var TF = T * F; var asz = attn_arena_size(T, C, nh, nkv);
    L = 0;
    while (L < NL) {
        store64(LA_a + L * 8, t_alloc(TC));
        store64(LA_xmid + L * 8, t_alloc(TC));
        store64(LA_b + L * 8, t_alloc(TC));
        store64(LA_fc + L * 8, t_alloc(TF));
        store64(LA_g + L * 8, t_alloc(TF));
        store64(LA_m1 + L * 8, t_alloc(T));
        store64(LA_r1 + L * 8, t_alloc(T));
        store64(LA_m2 + L * 8, t_alloc(T));
        store64(LA_r2 + L * 8, t_alloc(T));
        store64(LA_arena + L * 8, t_alloc(asz));
        store64(LA_dmask_attn + L * 8, t_alloc(TC));
        store64(LA_dmask_mlp + L * 8, t_alloc(TC));
        if (has_mla == 1) { store64(LA_c + L * 8, t_alloc(T * d_c)); }
        if (pos_kind == 2) {
            store64(LA_qr + L * 8, t_alloc(T * nh * d_rope));
            store64(LA_kr + L * 8, t_alloc(T * d_rope));
        }
        if (num_experts > 1) {
            store64(LA_mlogits + L * 8, t_alloc(T * num_experts));
            store64(LA_msel + L * 8, t_alloc(T * topk));
            store64(LA_mgate + L * 8, t_alloc(T * topk));
            store64(LA_mefc + L * 8, t_alloc(T * topk * F));
            store64(LA_megg + L * 8, t_alloc(T * topk * F));
        }
        if (has_ssm == 1) {
            store64(LA_ssm_dlt + L * 8, t_alloc(TC));
            store64(LA_ssm_B + L * 8, t_alloc(T * d_c));
            store64(LA_ssm_C + L * 8, t_alloc(T * d_c));
            store64(LA_ssm_h + L * 8, t_alloc(T * C * d_c));
            store64(LA_ssm_y + L * 8, t_alloc(TC));
            store64(g_ssm_state + L * 8, t_alloc(C * d_c));
        }
        L = L + 1;
    }

    # gradient temporaries
    D_logits = t_alloc(TV); D_f = t_alloc(TC); D_resid = t_alloc(TC);
    D_xmid = t_alloc(TC); D_a = t_alloc(TC); D_b = t_alloc(TC);
    D_g = t_alloc(TF); D_fc = t_alloc(TF); D_tmp = t_alloc(TC); D_drop = t_alloc(TC);
    if (has_mla == 1) { D_lat1 = t_alloc(T * d_c); D_lat2 = t_alloc(T * d_c); }
    if (pos_kind == 2) { D_qr = t_alloc(T * nh * d_rope); D_kr = t_alloc(T * d_rope); }
    if (num_experts > 1) {
        g_moe_sc = t_alloc(2 * F + 2 * C + 3 * num_experts + topk);
        g_moe_dlaux = t_alloc(T * num_experts);
        g_moe_disp = t_alloc(num_experts);
    }
    if (has_ssm == 1) {                         # shared SSM reverse-scan scratch
        g_ssm_dy = t_alloc(TC); g_ssm_dDlt = t_alloc(TC); g_ssm_sc = t_alloc(TC);
        g_ssm_dBm = t_alloc(T * d_c); g_ssm_dCm = t_alloc(T * d_c); g_ssm_dhc = t_alloc(C * d_c);
    }

    # KV caches + single-row scratch (generation)
    var TKv = T * Ckv;
    KV_K = t_alloc(NL); KV_V = t_alloc(NL);
    L = 0;
    while (L < NL) {
        store64(KV_K + L * 8, t_alloc(TKv));
        store64(KV_V + L * 8, t_alloc(TKv));
        L = L + 1;
    }
    # gated-linear decode state: per-layer nh*hd^2 retention state. Allocated when
    # ANY block is gated-linear — a uniform lin model OR a hybrid with lin layers.
    if (_any_lin() == 1) {
        var hdl = C / nh;
        g_lin_state = t_alloc(NL);
        L = 0;
        while (L < NL) { store64(g_lin_state + L * 8, t_alloc(nh * hdl * hdl)); L = L + 1; }
    }
    R_x = t_alloc(C); R_a = t_alloc(C); R_attn = t_alloc(C); R_xmid = t_alloc(C);
    R_b = t_alloc(C); R_fc = t_alloc(F); R_g = t_alloc(F); R_mlp = t_alloc(C);
    R_f = t_alloc(C); R_q = t_alloc(C); R_concat = t_alloc(C);
    R_mean = t_alloc(1); R_rstd = t_alloc(1);
    R_prow = t_alloc(T); R_logits = t_alloc(V);
    G_win = t_alloc(T);
    if (pos_kind == 2) { R_qr = t_alloc(nh * d_rope); }   # decoupled rope-query row scratch
    return 0;
}

# bytes held by the persistent per-token decode cache. MHA/GQA store full K/V
# (the E2 lever: scales with nkv). MLA (M12.2) stores only the low-rank latent
# `c` (d_c per token per layer), NOT full K/V — the headline compression number.
# Decoupled-RoPE MLA (M12 incr 5) also caches the shared rope key K^R (d_rope per
# token per layer), so the cache is d_c + d_rope per token.
fn kv_cache_bytes(): i64 {
    # per-layer HYBRID (M14 rung c/d): each block's cache is its OWN kind's —
    # mha/gqa store full K/V (2·T·Ckv), lin the constant nh·hd^2 retention state,
    # ssm the constant C·N state, mla the T·d_c latent (hybrids are learned-abs, so
    # no decoupled-RoPE K^R term). Sums over the per-layer kinds.
    if (g_layer_kind != 0) {
        var hd2 = g_C / g_nh;
        var lin_b = g_nh * hd2 * hd2;
        var mha_b = 2 * g_T * _Ckv();
        var ssm_b = g_C * g_latent_dim;
        var mla_b = g_T * g_latent_dim;
        var tot = 0; var L = 0;
        while (L < g_NL) {
            var k = load64(g_layer_kind + L * 8);
            if (k == 2) { tot = tot + lin_b; }
            elif (k == 3) { tot = tot + ssm_b; }
            elif (k == 1) { tot = tot + mla_b; }
            else { tot = tot + mha_b; }
            L = L + 1;
        }
        return tot * 8;
    }
    # gated linear attention (M14): the cache is the per-layer retention STATE
    # (nh·hd^2), CONSTANT in T — the headline vs MHA/MLA's T-growing K/V.
    if (g_attn_kind == 2) { var hd = g_C / g_nh; return g_NL * g_nh * hd * hd * 8; }
    # selective SSM (M14 rung b): the cache is the per-layer C×N state, CONSTANT in T.
    if (g_attn_kind == 3) { return g_NL * g_C * g_latent_dim * 8; }
    if (g_attn_kind == 1) {
        if (g_pos_kind == 2) { return g_NL * g_T * (g_latent_dim + g_rope_dim) * 8; }
        return g_NL * g_T * g_latent_dim * 8;
    }
    return 2 * g_NL * g_T * _Ckv() * 8;
}

# ---- MoE expert-utilization metric (M13, E8) -------------------------------
# Routing entropy over a measured set of forwards: reset the per-expert dispatch
# histogram, run forwards (each accumulates the layer routers' top-K picks via
# moe_disp_accum), then read moe_entropy. Normalized to [0,1]: 1 = perfectly
# balanced expert load (the aux loss's goal), 0 = full collapse to one expert.
fn moe_disp_reset(): i64 {
    if (g_num_experts <= 1) { return 0; }
    var i = 0;
    while (i < g_num_experts) { store64(g_moe_disp + i * 8, 0); i = i + 1; }
    return 0;
}
fn moe_disp_accum(): i64 {
    if (g_num_experts <= 1) { return 0; }
    var L = 0;
    while (L < g_NL) {
        var sel = La(LA_msel, L);
        var n = g_T * g_expert_topk;
        var j = 0;
        while (j < n) {
            var e = load64(sel + j * 8);
            store64(g_moe_disp + e * 8, load64(g_moe_disp + e * 8) + 1);
            j = j + 1;
        }
        L = L + 1;
    }
    return 0;
}
fn moe_entropy(): i64 {
    if (g_num_experts <= 1) { return f64_from(0); }
    var tot = 0;
    var i = 0;
    while (i < g_num_experts) { tot = tot + load64(g_moe_disp + i * 8); i = i + 1; }
    if (tot == 0) { return f64_from(0); }
    var invtot = f64_div(f64_from(1), f64_from(tot));
    var H = f64_from(0);
    i = 0;
    while (i < g_num_experts) {
        var c = load64(g_moe_disp + i * 8);
        if (c > 0) {
            var p = f64_mul(f64_from(c), invtot);
            H = f64_sub(H, f64_mul(p, f64_ln(p)));
        }
        i = i + 1;
    }
    return f64_div(H, f64_ln(f64_from(g_num_experts)));   # normalize by ln(N)
}

# ---- tied LM head ----------------------------------------------------------
# Weight tying — the token embedding is reused as the output projection:
# Press & Wolf (2017) arXiv:1608.05859; Inan et al. (2017) arXiv:1611.01462.
# logits(V) = f_row(C) @ tokemb^T — one row; head_fwd_n loops it, so the
# training path and the cached generation path share the same arithmetic.
fn head_fwd_row(f_row, logits_row): i64 {
    var C = g_C; var V = g_V;
    var emb = P_tokemb();
    var c4 = C - (C % 4);
    var acc[32];                     # 4-lane dot accumulator (M9: SIMD head)
    var v = 0;
    while (v < V) {
        var erow = emb + v * C * 8;
        store64(&acc, f64_from(0)); store64(&acc + 8, f64_from(0));
        store64(&acc + 16, f64_from(0)); store64(&acc + 24, f64_from(0));
        var c = 0;
        while (c < c4) {
            f64v_fmadd(&acc, f_row + c * 8, erow + c * 8, &acc, 4);
            c = c + 4;
        }
        var dot = f64_add(f64_add(load64(&acc), load64(&acc + 8)),
                          f64_add(load64(&acc + 16), load64(&acc + 24)));
        while (c < C) {
            dot = f64_add(dot, f64_mul(load64(f_row + c * 8), load64(erow + c * 8)));
            c = c + 1;
        }
        store64(logits_row + v * 8, dot);
        v = v + 1;
    }
    return 0;
}

# logits(n,V) = f(n,C) @ tokemb^T over the first n rows
fn head_fwd_n(n): i64 {
    var t = 0;
    while (t < n) {
        head_fwd_row(A_f + t * g_C * 8, A_logits + t * g_V * 8);
        t = t + 1;
    }
    return 0;
}
fn head_fwd(): i64 { return head_fwd_n(g_T); }

# dlogits(T,V) -> df(T,C); accumulate dtokemb (head part)
fn head_bwd(): i64 {
    var T = g_T; var C = g_C; var V = g_V;
    var emb = P_tokemb(); var gemb = G_tokemb();
    var t = 0;
    while (t < T) {
        var c = 0;
        while (c < C) {
            var acc = f64_from(0);
            var v = 0;
            while (v < V) {
                acc = f64_add(acc, f64_mul(load64(D_logits + (t * V + v) * 8),
                                           load64(emb + (v * C + c) * 8)));
                v = v + 1;
            }
            store64(D_f + (t * C + c) * 8, acc);
            c = c + 1;
        }
        t = t + 1;
    }
    var v2 = 0;
    while (v2 < V) {
        var c = 0;
        while (c < C) {
            var acc = f64_from(0);
            var tt = 0;
            while (tt < T) {
                acc = f64_add(acc, f64_mul(load64(D_logits + (tt * V + v2) * 8),
                                           load64(A_f + (tt * C + c) * 8)));
                tt = tt + 1;
            }
            var gi = gemb + (v2 * C + c) * 8;
            store64(gi, f64_add(load64(gi), acc));
            c = c + 1;
        }
        v2 = v2 + 1;
    }
    return 0;
}

# ---- embedding -------------------------------------------------------------
# over the first n rows (n = g_T for training; n < g_T for eval windows)
fn embed_fwd_n(n): i64 {
    var T = n; var C = g_C;
    var emb = P_tokemb(); var pos = P_posemb(); var x0 = La(LA_resid, 0);
    # RoPE (g_pos_kind != 0) carries position inside attention (relative), so the
    # learned ABSOLUTE posemb is not added here — the two schemes are mutually
    # exclusive (ADR 0007). The posemb parameters stay allocated (layout-stable)
    # but unused/untrained under RoPE.
    var add_pos = 1;
    if (g_pos_kind != 0) { add_pos = 0; }
    # M15 diffusion: a masked position's input is the learned [MASK] embedding, not
    # the token lookup. memb's address is computed unconditionally (cheap) but read
    # only when masked == 1 — which is always 0 under AR (g_objective 0), so the AR
    # path is byte-identical and never touches the (AR: nonexistent) mask_emb slot.
    var memb = P_maskemb();
    var t = 0;
    while (t < T) {
        var tok = load64(A_tokens + t * 8);
        var masked = 0;
        if (g_objective == 1) { if (load64(A_mask + t * 8) != 0) { masked = 1; } }
        var c = 0;
        while (c < C) {
            var e = load64(emb + (tok * C + c) * 8);
            if (masked == 1) { e = load64(memb + c * 8); }
            if (add_pos == 1) { e = f64_add(e, load64(pos + (t * C + c) * 8)); }
            store64(x0 + (t * C + c) * 8, e);
            c = c + 1;
        }
        t = t + 1;
    }
    return 0;
}
fn embed_fwd(): i64 { return embed_fwd_n(g_T); }

# d(resid[0]) -> accumulate dtokemb (lookup part) and dposemb. Under RoPE the
# posemb is not on the forward path, so no gradient flows to it (mirrors
# embed_fwd_n's add_pos skip) — leaving dposemb untouched keeps it at zero.
fn embed_bwd(dx0): i64 {
    var T = g_T; var C = g_C;
    var gemb = G_tokemb(); var gpos = G_posemb();
    var add_pos = 1;
    if (g_pos_kind != 0) { add_pos = 0; }
    # M15 diffusion: a masked position fed the [MASK] embedding (not tokemb[tok]),
    # so its input-side gradient routes to G_maskemb(), NOT gemb[tok]. tokemb still
    # receives the tied-HEAD gradient at every position (head_bwd) — so tokemb gets
    # head-grad (all) + lookup-grad (given only); mask_emb gets it at masked only.
    # The posemb gradient is unchanged (a masked position still has a position).
    # Under AR (masked always 0) this is byte-identical to before.
    var gmemb = G_maskemb();
    var t = 0;
    while (t < T) {
        var tok = load64(A_tokens + t * 8);
        var masked = 0;
        if (g_objective == 1) { if (load64(A_mask + t * 8) != 0) { masked = 1; } }
        var c = 0;
        while (c < C) {
            var d = load64(dx0 + (t * C + c) * 8);
            if (masked == 1) {
                var me = gmemb + c * 8;
                store64(me, f64_add(load64(me), d));
            } else {
                var te = gemb + (tok * C + c) * 8;
                store64(te, f64_add(load64(te), d));
            }
            if (add_pos == 1) {
                var pe = gpos + (t * C + c) * 8;
                store64(pe, f64_add(load64(pe), d));
            }
            c = c + 1;
        }
        t = t + 1;
    }
    return 0;
}

# ---- full forward: returns mean loss (f64) ---------------------------------
# ---- attention-sublayer mixer dispatch (1.4.1) ------------------------------
# ONE branch point each on the mixer kind (0 = mha/gqa, 1 = mla [× g_pos_kind],
# 2 = gated-linear, 3 = selective-SSM): the batch forward (shared by
# model_forward and model_eval_window), the batch backward, and the cached
# single-row decode. A new mixer adds one case in each of these three, not in
# four functions. The M14 rung-c per-layer HYBRID (1.4.3) reads the kind via
# `_lk(L)` HERE and nowhere else — uniform models (g_layer_kind == 0) get
# g_attn_kind back unchanged, so this is byte-identical until a hybrid is built.
fn _attn_block_fwd(L, rows): i64 {
    var a = La(LA_a, L);
    var ak = _lk(L);
    if (ak == 2) {
        attn_lin_fwd(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wk()), P_bk(L),
                     PL(L, _o_Wv()), P_bv(L), PL(L, _o_Wo()), P_bo(L),
                     a, A_attn, La(LA_arena, L), rows, g_C, g_nh);
    } elif (ak == 3) {
        ssm_fwd(a, PL(L, _o_Wq()), P_bq(L), PL(L, _o_ssmA()), PL(L, _o_ssmWB()), PL(L, _o_ssmWC()),
                PL(L, _o_ssmD()), PL(L, _o_Wo()), P_bo(L), A_attn,
                La(LA_ssm_dlt, L), La(LA_ssm_B, L), La(LA_ssm_C, L), La(LA_ssm_h, L), La(LA_ssm_y, L),
                rows, g_C, g_latent_dim);
    } elif (ak == 1) {
        if (g_pos_kind == 2) {
            attn_mla_dec_fwd(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wdkv()), PL(L, _o_Wuk()), P_bk(L),
                             PL(L, _o_Wuv()), P_bv(L), PL(L, _o_Wqr()), PL(L, _o_Wkr()), PL(L, _o_Wo()), P_bo(L),
                             a, A_attn, La(LA_arena, L), La(LA_c, L), La(LA_qr, L), La(LA_kr, L),
                             rows, g_C, g_nh, g_latent_dim, g_rope_dim);
        } else {
            attn_mla_fwd(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wdkv()), PL(L, _o_Wuk()), P_bk(L),
                         PL(L, _o_Wuv()), P_bv(L), PL(L, _o_Wo()), P_bo(L),
                         a, A_attn, La(LA_arena, L), La(LA_c, L), rows, g_C, g_nh, g_latent_dim);
        }
    } else {
        attn_fwd(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wk()), P_bk(L),
                 PL(L, _o_Wv()), P_bv(L), PL(L, _o_Wo()), P_bo(L),
                 a, A_attn, La(LA_arena, L), rows, g_C, g_nh, g_nkv, g_pos_kind);
    }
    return 0;
}
fn _attn_block_bwd(L): i64 {
    var ak = _lk(L);
    if (ak == 2) {
        attn_lin_bwd(PL(L, _o_Wq()), PL(L, _o_Wk()), PL(L, _o_Wv()), PL(L, _o_Wo()),
                     La(LA_a, L), D_drop, D_a,
                     GL(L, _o_Wq()), G_bq(L), GL(L, _o_Wk()), G_bk(L),
                     GL(L, _o_Wv()), G_bv(L), GL(L, _o_Wo()), G_bo(L),
                     La(LA_arena, L), g_T, g_C, g_nh);
    } elif (ak == 3) {
        ssm_bwd(La(LA_a, L), PL(L, _o_Wq()), PL(L, _o_ssmA()), PL(L, _o_ssmWB()), PL(L, _o_ssmWC()),
                PL(L, _o_ssmD()), PL(L, _o_Wo()), D_drop, D_a,
                GL(L, _o_Wq()), G_bq(L), GL(L, _o_ssmA()), GL(L, _o_ssmWB()), GL(L, _o_ssmWC()),
                GL(L, _o_ssmD()), GL(L, _o_Wo()), G_bo(L),
                La(LA_ssm_dlt, L), La(LA_ssm_B, L), La(LA_ssm_C, L), La(LA_ssm_h, L), La(LA_ssm_y, L),
                g_ssm_dy, g_ssm_dDlt, g_ssm_dBm, g_ssm_dCm, g_ssm_dhc, g_ssm_sc, g_T, g_C, g_latent_dim);
    } elif (ak == 1) {
        if (g_pos_kind == 2) {
            attn_mla_dec_bwd(PL(L, _o_Wq()), PL(L, _o_Wdkv()), PL(L, _o_Wuk()), PL(L, _o_Wuv()),
                             PL(L, _o_Wqr()), PL(L, _o_Wkr()), PL(L, _o_Wo()),
                             La(LA_a, L), D_drop, D_a,
                             GL(L, _o_Wq()), G_bq(L), GL(L, _o_Wdkv()), GL(L, _o_Wuk()), G_bk(L),
                             GL(L, _o_Wuv()), G_bv(L), GL(L, _o_Wqr()), GL(L, _o_Wkr()), GL(L, _o_Wo()), G_bo(L),
                             La(LA_arena, L), La(LA_c, L), La(LA_qr, L), La(LA_kr, L), D_lat1, D_lat2, D_qr, D_kr,
                             g_T, g_C, g_nh, g_latent_dim, g_rope_dim);
        } else {
            attn_mla_bwd(PL(L, _o_Wq()), PL(L, _o_Wdkv()), PL(L, _o_Wuk()), PL(L, _o_Wuv()), PL(L, _o_Wo()),
                         La(LA_a, L), D_drop, D_a,
                         GL(L, _o_Wq()), G_bq(L), GL(L, _o_Wdkv()), GL(L, _o_Wuk()), G_bk(L),
                         GL(L, _o_Wuv()), G_bv(L), GL(L, _o_Wo()), G_bo(L),
                         La(LA_arena, L), La(LA_c, L), D_lat1, D_lat2, g_T, g_C, g_nh, g_latent_dim);
        }
    } else {
        attn_bwd(PL(L, _o_Wq()), PL(L, _o_Wk()), PL(L, _o_Wv()), PL(L, _o_Wo()),
                 La(LA_a, L), D_drop, D_a,
                 GL(L, _o_Wq()), G_bq(L), GL(L, _o_Wk()), G_bk(L),
                 GL(L, _o_Wv()), G_bv(L), GL(L, _o_Wo()), G_bo(L),
                 La(LA_arena, L), g_T, g_C, g_nh, g_nkv, g_pos_kind);
    }
    return 0;
}
fn _attn_block_fwd_row(L, pos): i64 {
    var ak = _lk(L);
    if (ak == 2) {
        attn_lin_fwd_row(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wk()), P_bk(L),
                         PL(L, _o_Wv()), P_bv(L), PL(L, _o_Wo()), P_bo(L),
                         R_a, R_attn, La(LA_arena, L), La(g_lin_state, L), pos, g_C, g_nh);
    } elif (ak == 3) {
        ssm_fwd_row(R_a, PL(L, _o_Wq()), P_bq(L), PL(L, _o_ssmA()), PL(L, _o_ssmWB()), PL(L, _o_ssmWC()),
                    PL(L, _o_ssmD()), PL(L, _o_Wo()), P_bo(L), R_attn, La(g_ssm_state, L),
                    R_q, R_fc, R_g, R_concat, pos, g_C, g_latent_dim);
    } elif (ak == 1) {
        var ar = La(LA_arena, L);
        if (g_pos_kind == 2) {
            attn_mla_dec_fwd_row(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wdkv()), PL(L, _o_Wuk()), P_bk(L),
                                 PL(L, _o_Wuv()), P_bv(L), PL(L, _o_Wqr()), PL(L, _o_Wkr()),
                                 PL(L, _o_Wo()), P_bo(L),
                                 R_a, R_attn, La(LA_c, L), La(LA_kr, L),
                                 _at_Kc(ar, g_T, g_C), _at_Vc(ar, g_T, g_C, g_C),
                                 R_qr, R_prow, R_concat, R_q, pos, g_C, g_nh, g_latent_dim, g_rope_dim);
        } else {
            attn_mla_fwd_row(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wdkv()), PL(L, _o_Wuk()), P_bk(L),
                             PL(L, _o_Wuv()), P_bv(L), PL(L, _o_Wo()), P_bo(L),
                             R_a, R_attn, La(LA_c, L), _at_Kc(ar, g_T, g_C), _at_Vc(ar, g_T, g_C, g_C),
                             R_prow, R_concat, R_q, pos, g_C, g_nh, g_latent_dim);
        }
    } else {
        attn_fwd_row(PL(L, _o_Wq()), P_bq(L), PL(L, _o_Wk()), P_bk(L),
                     PL(L, _o_Wv()), P_bv(L), PL(L, _o_Wo()), P_bo(L),
                     R_a, R_attn, La(KV_K, L), La(KV_V, L), R_prow, R_concat,
                     R_q, pos, g_C, g_nh, g_nkv, g_pos_kind);
    }
    return 0;
}

fn model_forward(): i64 {
    var T = g_T; var C = g_C; var F = g_F; var V = g_V;
    var TC = T * C;
    g_aux_loss = f64_from(0);   # accumulated across the MoE blocks below (0 if dense)
    embed_fwd();
    var L = 0;
    while (L < g_NL) {
        var xin = La(LA_resid, L);
        var a = La(LA_a, L);
        ln_fwd(xin, PL(L, _o_ln1g()), PL(L, _o_ln1b()), a, La(LA_m1, L), La(LA_r1, L), T, C);
        _attn_block_fwd(L, T);
        # residual dropout on the attention branch
        dropout_gen_mask(La(LA_dmask_attn, L), TC, g_dropout, g_training);
        dropout_apply(A_attn, La(LA_dmask_attn, L), A_attn, TC);
        var xmid = La(LA_xmid, L);
        var i = 0;
        while (i < TC) { store64(xmid + i * 8, f64_add(load64(xin + i * 8), load64(A_attn + i * 8))); i = i + 1; }
        var b = La(LA_b, L);
        ln_fwd(xmid, PL(L, _o_ln2g()), PL(L, _o_ln2b()), b, La(LA_m2, L), La(LA_r2, L), T, C);
        if (g_num_experts > 1) {
            # MoE: route b through the top-K experts into A_mlp, accumulate the
            # block's load-balance aux loss (router is position-independent, so
            # the cached decode path runs the same kernel — see model_fwd_row).
            moe_fwd(b, PL(L, _o_Wgate()), PL(L, _o_expert(0)), A_mlp,
                    La(LA_mlogits, L), La(LA_msel, L), La(LA_mgate, L), La(LA_mefc, L), La(LA_megg, L),
                    g_moe_sc, T, C, F, g_num_experts, g_expert_topk);
            g_aux_loss = f64_add(g_aux_loss,
                moe_aux_fwd(La(LA_mlogits, L), La(LA_msel, L), g_aux_alpha, g_moe_sc, T, g_num_experts, g_expert_topk));
        } else {
            var fc = La(LA_fc, L); var gg = La(LA_g, L);
            qlinear_fwd(b, PL(L, _o_Wfc()), PL(L, _o_bfc()), fc, T, C, F);
            gelu_fwd(fc, gg, T * F);
            qlinear_fwd(gg, PL(L, _o_Wproj()), PL(L, _o_bproj()), A_mlp, T, F, C);
        }
        # residual dropout on the MLP branch
        dropout_gen_mask(La(LA_dmask_mlp, L), TC, g_dropout, g_training);
        dropout_apply(A_mlp, La(LA_dmask_mlp, L), A_mlp, TC);
        var xout = La(LA_resid, L + 1);
        i = 0;
        while (i < TC) { store64(xout + i * 8, f64_add(load64(xmid + i * 8), load64(A_mlp + i * 8))); i = i + 1; }
        L = L + 1;
    }
    ln_fwd(La(LA_resid, g_NL), P_lnfg(), P_lnfb(), A_f, A_meanf, A_rstdf, T, C);
    head_fwd();
    # M15 masked diffusion: the loss is CE over the MASKED positions only (the
    # model is bidirectional via g_bidir; no MoE aux term — MoE is disallowed with
    # diffusion). g_nmask records the masked count for the training log / eval.
    if (g_objective == 1) {
        var nm = 0; var ti = 0;
        while (ti < T) { if (load64(A_mask + ti * 8) != 0) { nm = nm + 1; } ti = ti + 1; }
        g_nmask = nm;
        return softmax_xent_masked_fwd(A_logits, A_targets, A_probs, A_mask, T, V);
    }
    # AR training objective = cross-entropy + Σ_blocks load-balance aux loss
    # (g_aux_loss is exactly 0 in the dense path, so a no-flag run is unchanged).
    return f64_add(softmax_xent_fwd(A_logits, A_targets, A_probs, T, V), g_aux_loss);
}

# ---- cached single-row forward (inference, E1) ------------------------------
# Process ONE token at window position `pos` against the per-layer K/V caches
# (which must already hold positions 0..pos-1). Appends this position's K/V to
# the caches and leaves its logits in R_logits. Eval-only: no backward caches,
# no dropout (eval dropout is the identity, so skipping it is bit-neutral).
# Per-row arithmetic is identical to the batch forward's — each op here is the
# same kernel the T-row path runs, on one row — so a position's logits are
# bit-identical to a full forward over the same window (pinned in tests).
fn model_fwd_row(tok, pos): i64 {
    var C = g_C; var F = g_F;
    var emb = P_tokemb(); var posb = P_posemb();
    # under RoPE the learned posemb is off the path (positions enter inside
    # attention); mirror embed_fwd_n so the cached row matches the uncached path.
    var add_pos = 1;
    if (g_pos_kind != 0) { add_pos = 0; }
    var c = 0;
    while (c < C) {
        var e = load64(emb + (tok * C + c) * 8);
        if (add_pos == 1) { e = f64_add(e, load64(posb + (pos * C + c) * 8)); }
        store64(R_x + c * 8, e);
        c = c + 1;
    }
    var L = 0;
    while (L < g_NL) {
        ln_fwd(R_x, PL(L, _o_ln1g()), PL(L, _o_ln1b()), R_a, R_mean, R_rstd, 1, C);
        _attn_block_fwd_row(L, pos);
        c = 0;
        while (c < C) {
            store64(R_xmid + c * 8, f64_add(load64(R_x + c * 8), load64(R_attn + c * 8)));
            c = c + 1;
        }
        ln_fwd(R_xmid, PL(L, _o_ln2g()), PL(L, _o_ln2b()), R_b, R_mean, R_rstd, 1, C);
        if (g_num_experts > 1) {
            # MoE is position-independent: the cached single row runs the SAME
            # moe_fwd kernel on one row as training runs on T — so a token's MLP
            # output is bit-identical to the batch path (test_kv_moe). The LA_m*
            # caches are reused as eval scratch (no backward in decode).
            moe_fwd(R_b, PL(L, _o_Wgate()), PL(L, _o_expert(0)), R_mlp,
                    La(LA_mlogits, L), La(LA_msel, L), La(LA_mgate, L), La(LA_mefc, L), La(LA_megg, L),
                    g_moe_sc, 1, C, F, g_num_experts, g_expert_topk);
        } else {
            qlinear_fwd(R_b, PL(L, _o_Wfc()), PL(L, _o_bfc()), R_fc, 1, C, F);
            gelu_fwd(R_fc, R_g, F);
            qlinear_fwd(R_g, PL(L, _o_Wproj()), PL(L, _o_bproj()), R_mlp, 1, F, C);
        }
        c = 0;
        while (c < C) {
            store64(R_x + c * 8, f64_add(load64(R_xmid + c * 8), load64(R_mlp + c * 8)));
            c = c + 1;
        }
        L = L + 1;
    }
    ln_fwd(R_x, P_lnfg(), P_lnfb(), R_f, R_mean, R_rstd, 1, C);
    head_fwd_row(R_f, R_logits);
    return 0;
}

# ---- uncached eval-window forward (generation reference path) ---------------
# Full forward over the first n window rows (positions 0..n-1, tokens already
# in A_tokens), logits into A_logits rows 0..n-1. No loss, no dropout (eval),
# no backward caches needed — but it reuses the training activation buffers
# and the attention arena (an n-row layout fits inside the T-row arena).
fn model_eval_window(n): i64 {
    var C = g_C; var F = g_F;
    var nC = n * C;
    embed_fwd_n(n);
    var L = 0;
    while (L < g_NL) {
        var xin = La(LA_resid, L);
        var a = La(LA_a, L);
        ln_fwd(xin, PL(L, _o_ln1g()), PL(L, _o_ln1b()), a, La(LA_m1, L), La(LA_r1, L), n, C);
        _attn_block_fwd(L, n);
        var xmid = La(LA_xmid, L);
        var i = 0;
        while (i < nC) { store64(xmid + i * 8, f64_add(load64(xin + i * 8), load64(A_attn + i * 8))); i = i + 1; }
        var b = La(LA_b, L);
        ln_fwd(xmid, PL(L, _o_ln2g()), PL(L, _o_ln2b()), b, La(LA_m2, L), La(LA_r2, L), n, C);
        if (g_num_experts > 1) {
            moe_fwd(b, PL(L, _o_Wgate()), PL(L, _o_expert(0)), A_mlp,
                    La(LA_mlogits, L), La(LA_msel, L), La(LA_mgate, L), La(LA_mefc, L), La(LA_megg, L),
                    g_moe_sc, n, C, F, g_num_experts, g_expert_topk);
        } else {
            var fc = La(LA_fc, L); var gg = La(LA_g, L);
            qlinear_fwd(b, PL(L, _o_Wfc()), PL(L, _o_bfc()), fc, n, C, F);
            gelu_fwd(fc, gg, n * F);
            qlinear_fwd(gg, PL(L, _o_Wproj()), PL(L, _o_bproj()), A_mlp, n, F, C);
        }
        var xout = La(LA_resid, L + 1);
        i = 0;
        while (i < nC) { store64(xout + i * 8, f64_add(load64(xmid + i * 8), load64(A_mlp + i * 8))); i = i + 1; }
        L = L + 1;
    }
    ln_fwd(La(LA_resid, g_NL), P_lnfg(), P_lnfb(), A_f, A_meanf, A_rstdf, n, C);
    head_fwd_n(n);
    return 0;
}

# ---- full backward: fills g_grads (assumes grads already zeroed) -----------
fn model_backward(): i64 {
    var T = g_T; var C = g_C; var F = g_F; var V = g_V;
    var TC = T * C;
    # M15: masked-CE backward (gradient only at masked positions) under diffusion;
    # the byte-identical AR softmax-CE backward otherwise.
    if (g_objective == 1) {
        softmax_xent_masked_bwd(A_probs, A_targets, A_mask, D_logits, T, V);
    } else {
        softmax_xent_bwd(A_probs, A_targets, D_logits, T, V);
    }
    head_bwd();                                   # -> D_f ; accum G_tokemb (head)
    # through final LN: D_f -> D_resid (= d resid[NL])
    ln_bwd(La(LA_resid, g_NL), P_lnfg(), D_f, A_meanf, A_rstdf, D_resid, G_lnfg(), G_lnfb(), T, C);
    var L = g_NL - 1;
    while (L >= 0) {
        var xin = La(LA_resid, L);
        var xmid = La(LA_xmid, L);
        # D_resid currently holds d_xout for layer L.
        # MLP: d(mlp branch output) = D_resid; back through its dropout first.
        dropout_bwd(La(LA_dmask_mlp, L), D_resid, D_drop, TC);
        if (g_num_experts > 1) {
            # MoE: combine backward (-> D_b = d ln2-out, accumulate expert + gate
            # grads), then the load-balance aux backward, which ADDS its router
            # gradient through the gate into D_b (the aux is off the dropout path —
            # it is a loss term on the router logits, not on the combine output).
            moe_bwd(La(LA_b, L), PL(L, _o_Wgate()), PL(L, _o_expert(0)), D_drop, D_b,
                    GL(L, _o_Wgate()), GL(L, _o_expert(0)),
                    La(LA_msel, L), La(LA_mgate, L), La(LA_mefc, L), La(LA_megg, L),
                    g_moe_sc, T, C, F, g_num_experts, g_expert_topk);
            moe_aux_bwd(La(LA_mlogits, L), La(LA_msel, L), g_aux_alpha, La(LA_b, L), PL(L, _o_Wgate()),
                        D_b, GL(L, _o_Wgate()), g_moe_dlaux, g_moe_sc, T, C, g_num_experts, g_expert_topk);
        } else {
            qlinear_bwd(La(LA_g, L), PL(L, _o_Wproj()), D_drop, D_g, GL(L, _o_Wproj()), GL(L, _o_bproj()), T, F, C);
            gelu_bwd(La(LA_fc, L), D_g, D_fc, T * F);
            qlinear_bwd(La(LA_b, L), PL(L, _o_Wfc()), D_fc, D_b, GL(L, _o_Wfc()), GL(L, _o_bfc()), T, C, F);
        }
        ln_bwd(xmid, PL(L, _o_ln2g()), D_b, La(LA_m2, L), La(LA_r2, L), D_tmp,
               GL(L, _o_ln2g()), GL(L, _o_ln2b()), T, C);
        # d_xmid = D_resid (residual) + D_tmp (ln2 path)
        t_copy(D_xmid, D_resid, TC);
        t_add_into(D_xmid, D_tmp, TC);
        # attention: d(attn branch output) = D_xmid; back through its dropout, then attn.
        dropout_bwd(La(LA_dmask_attn, L), D_xmid, D_drop, TC);
        _attn_block_bwd(L);
        ln_bwd(xin, PL(L, _o_ln1g()), D_a, La(LA_m1, L), La(LA_r1, L), D_tmp, GL(L, _o_ln1g()), GL(L, _o_ln1b()), T, C);
        # d_xin = d_xmid (residual) + D_tmp (ln1 path) ; becomes next D_resid
        t_copy(D_resid, D_xmid, TC);
        t_add_into(D_resid, D_tmp, TC);
        L = L - 1;
    }
    embed_bwd(D_resid);
    return 0;
}

fn model_zero_grads(): i64 { t_zero(g_grads, g_NP); return 0; }

# ---- gradient clipping (global L2 norm) ------------------------------------
# If ||grads|| > clip, scale all grads by clip/||grads||. Returns the norm (f64).
# Source: Pascanu, Mikolov, Bengio (2013), arXiv:1211.5063.
fn model_clip_grads(clip): i64 {
    var n2 = f64_from(0);
    var i = 0;
    while (i < g_NP) {
        var g = load64(g_grads + i * 8);
        n2 = f64_add(n2, f64_mul(g, g));
        i = i + 1;
    }
    var norm = f64_sqrt(n2);
    if (f64_gt(norm, clip) == 1) {
        t_scale(g_grads, g_NP, f64_div(clip, norm));
    }
    return norm;
}

# ---- Adam ------------------------------------------------------------------
# Source: Kingma & Ba (2015), "Adam", arXiv:1412.6980 — bias-corrected 1st/2nd
# moments; defaults b1=0.9, b2=0.999, eps=1e-8 are the paper's.
# lr is an f64 bit pattern; step is the 1-based update count.
fn model_adam_step(lr, step): i64 {
    var b1 = f64_div(f64_from(9), f64_from(10));        # 0.9
    var b2 = f64_div(f64_from(999), f64_from(1000));    # 0.999
    var om1 = f64_div(f64_from(1), f64_from(10));       # 1-b1
    var om2 = f64_div(f64_from(1), f64_from(1000));     # 1-b2
    var eps = f64_div(f64_from(1), f64_from(100000000)); # 1e-8
    var one = f64_from(1);
    var bc1 = f64_sub(one, f64_pow(b1, f64_from(step)));
    var bc2 = f64_sub(one, f64_pow(b2, f64_from(step)));
    var i = 0;
    while (i < g_NP) {
        var g = load64(g_grads + i * 8);
        var m = f64_add(f64_mul(b1, load64(g_adam_m + i * 8)), f64_mul(om1, g));
        var v = f64_add(f64_mul(b2, load64(g_adam_v + i * 8)), f64_mul(om2, f64_mul(g, g)));
        store64(g_adam_m + i * 8, m);
        store64(g_adam_v + i * 8, v);
        var mhat = f64_div(m, bc1);
        var vhat = f64_div(v, bc2);
        var upd = f64_div(mhat, f64_add(f64_sqrt(vhat), eps));
        var pi = g_params + i * 8;
        store64(pi, f64_sub(load64(pi), f64_mul(lr, upd)));
        i = i + 1;
    }
    return 0;
}
