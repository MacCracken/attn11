# tests/gpu_adam.cyr — M18 1.8.5 GPU Adam validation (BIT-EXACT, plain --gpu).
#
# Validates `gpu_adam_step` (src/gpu.cyr) against an inline CPU replica identical to
# src/model.cyr `model_adam_step`, BIT-FOR-BIT (in-shader f64 sqrt + FDiv are correctly-rounded
# on this hardware, verified). So a --gpu training run's checkpoint stays byte-identical to the
# CPU's — Adam rides plain --gpu, never --gpu-tc. Exercises the >65535 grid-tiling path. Engagement
# proven (non-zero return = silent fallback = failure). Device-dependent → SKIPS cleanly (exit 0)
# where no AMD f64 GPU exists; build-verified everywhere, NOT in the CI gate.
#
# Build:  cyrius build tests/gpu_adam.cyr build/gpu_adam && ./build/gpu_adam
# Exit:   0 = all shapes bit-exact (or cleanly skipped); 1 = any bit difference / fallback.

include "lib/mabda.cyr"
include "src/gpu.cyr"

# gpu_adam_step reads these (defined in model.cyr in the real build; standalone here).
var g_params = 0; var g_grads = 0; var g_adam_m = 0; var g_adam_v = 0; var g_NP = 0;

fn print_cstr(s): i64 { syscall(1, 1, s, strlen(s)); return 0; }
fn print_i64(n): i64 { var b[32]; memset(&b, 0, 32); var l = fmt_int_buf(n, &b); syscall(1, 1, &b, l); return 0; }

fn frand(i, seed): i64 {
    var x = ((i * 2654435761) + (seed * 40503)) % 100000; if (x < 0) { x = x + 100000; }
    return f64_div(f64_from(x - 50000), f64_from(7000));
}

# CPU reference — identical arithmetic to src/model.cyr model_adam_step.
fn cpu_adam(params, grads, m, v, NP, lr, step): i64 {
    var b1 = f64_div(f64_from(9), f64_from(10));
    var b2 = f64_div(f64_from(999), f64_from(1000));
    var om1 = f64_div(f64_from(1), f64_from(10));
    var om2 = f64_div(f64_from(1), f64_from(1000));
    var eps = f64_div(f64_from(1), f64_from(100000000));
    var one = f64_from(1);
    var bc1 = f64_sub(one, f64_pow(b1, f64_from(step)));
    var bc2 = f64_sub(one, f64_pow(b2, f64_from(step)));
    var i = 0;
    while (i < NP) {
        var g = load64(grads + i*8);
        var mm = f64_add(f64_mul(b1, load64(m + i*8)), f64_mul(om1, g));
        var vv = f64_add(f64_mul(b2, load64(v + i*8)), f64_mul(om2, f64_mul(g, g)));
        store64(m + i*8, mm); store64(v + i*8, vv);
        var mhat = f64_div(mm, bc1); var vhat = f64_div(vv, bc2);
        var upd = f64_div(mhat, f64_add(f64_sqrt(vhat), eps));
        var pi = params + i*8;
        store64(pi, f64_sub(load64(pi), f64_mul(lr, upd)));
        i = i + 1;
    }
    return 0;
}

fn run_shape(NP, step): i64 {
    g_NP = NP;
    var lr = f64_div(f64_from(1), f64_from(1000));   # 1e-3
    g_grads = alloc(NP*8); g_params = alloc(NP*8); g_adam_m = alloc(NP*8); g_adam_v = alloc(NP*8);
    var cp = alloc(NP*8); var cm = alloc(NP*8); var cv = alloc(NP*8);  # CPU copies
    var i = 0;
    while (i < NP) {
        var g = frand(i, 4); var p = frand(i, 5); var mo = f64_abs(frand(i, 6)); var vo = f64_abs(frand(i, 7));
        store64(g_grads + i*8, g);
        store64(g_params + i*8, p); store64(cp + i*8, p);
        store64(g_adam_m + i*8, mo); store64(cm + i*8, mo);
        store64(g_adam_v + i*8, vo); store64(cv + i*8, vo);
        i = i + 1;
    }
    cpu_adam(cp, g_grads, cm, cv, NP, lr, step);
    var rc = gpu_adam_step(lr, step);
    print_cstr("  NP="); print_i64(NP); print_cstr(" step="); print_i64(step); print_cstr(": ");
    if (rc != 0) { print_cstr("GPU FALLBACK (rc="); print_i64(rc); print_cstr(")\n"); return 0; }
    var pf = 0; var mf = 0; var vf = 0; i = 0;
    while (i < NP) {
        if (load64(g_params + i*8) != load64(cp + i*8)) { pf = pf + 1; }
        if (load64(g_adam_m + i*8) != load64(cm + i*8)) { mf = mf + 1; }
        if (load64(g_adam_v + i*8) != load64(cv + i*8)) { vf = vf + 1; }
        i = i + 1;
    }
    if ((pf == 0) && (mf == 0) && (vf == 0)) { print_cstr("BIT-EXACT ("); print_i64(NP); print_cstr(" params)\n"); return 1; }
    print_cstr("BIT DIFF (params "); print_i64(pf); print_cstr(", m "); print_i64(mf); print_cstr(", v "); print_i64(vf); print_cstr(")\n");
    return 0;
}

fn main(): i64 {
    alloc_init();
    print_cstr("attn11 GPU Adam validation (M18 1.8.5) — gpu_adam_step vs model_adam_step, BIT-EXACT\n");
    if (_gpu_init() == 0) {
        print_cstr("no native AMD GPU — SKIPPED (CPU oracle unaffected; build verified)\n");
        return 0;
    }
    print_cstr("native AMD f64 GPU online — validating bit-exactness across param counts:\n");
    var ok = 1;
    if (run_shape(1000, 1) == 0) { ok = 0; }        # tiny, step 1 (bc near 1-b)
    if (run_shape(39488, 7) == 0) { ok = 0; }       # default model NP
    if (run_shape(100000, 50) == 0) { ok = 0; }     # > MABDA_MAX_DISPATCH_DIM → grid-tiled (2 chunks)
    print_cstr("GPU Adam steps dispatched on-device: "); print_i64(gpu_adam_count()); print_cstr("\n");
    if (ok == 0) { print_cstr("\nFAIL: GPU Adam diverged from the CPU oracle\n"); return 1; }
    print_cstr("\nOK — gpu_adam_step BIT-EXACT to model_adam_step across all shapes (incl. grid-tiling)\n");
    return 0;
}

var exit_code = main();
sys_exit(exit_code);
