# tests/gpu_rope.cyr — M19 1.9.1 GPU RoPE-rotation validation (BIT-EXACT, plain --gpu).
#
# Validates `gpu_rope_apply` (src/gpu.cyr) — the on-device Q/K rotation — against an inline CPU
# replica using the SAME cos/sin table + the SAME rotation arithmetic as src/attn.cyr rope_apply_*.
# The cos/sin are data-independent (host-precomputed), so the GPU does only the rotation (f64
# mul/add/sub, correctly-rounded) → BIT-EXACT → it rides plain --gpu and keeps the checkpoint
# byte-identical. Tests forward (R) + backward (Rᵀ) across default / preset / wide-head shapes, plus
# the rows=1 (decode) self-fallback. Device-dependent → SKIPS cleanly (exit 0) where no AMD f64 GPU.
#
# Build:  cyrius build tests/gpu_rope.cyr build/gpu_rope && ./build/gpu_rope
# Exit:   0 = bit-exact (or cleanly skipped); 1 = any bit difference / unexpected fallback.

include "lib/mabda.cyr"
include "lib/rosnet-gpu.cyr"

fn print_cstr(s): i64 { syscall(1, 1, s, strlen(s)); return 0; }
fn print_i64(n): i64 { var b[32]; memset(&b, 0, 32); var l = fmt_int_buf(n, &b); syscall(1, 1, &b, l); return 0; }

fn frand(i, seed): i64 {
    var x = ((i * 2654435761) + (seed * 40503)) % 1000; if (x < 0) { x = x + 1000; }
    return f64_div(f64_from(x - 500), f64_from(100));
}

# CPU replica — identical formula + table indexing to _gpu_build_rope. dir 0 = fwd, 1 = bwd.
fn cpu_rope(X, cs, rows, width, num_heads, hdp, dir): i64 {
    var hd = width / num_heads;
    var r = 0;
    while (r < rows) {
        var h = 0;
        while (h < num_heads) {
            var k = 0;
            while (k < hdp) {
                var xb = r * width + h * hd + 2 * k;
                var x0 = load64(X + xb * 8); var x1 = load64(X + (xb + 1) * 8);
                var cb = (r * hdp + k) * 2;
                var c = load64(cs + cb * 8); var s = load64(cs + (cb + 1) * 8);
                var y0 = f64_from(0); var y1 = f64_from(0);
                if (dir == 0) {
                    y0 = f64_sub(f64_mul(x0, c), f64_mul(x1, s));
                    y1 = f64_add(f64_mul(x0, s), f64_mul(x1, c));
                } else {
                    y0 = f64_add(f64_mul(x0, c), f64_mul(x1, s));
                    y1 = f64_sub(f64_mul(x1, c), f64_mul(x0, s));
                }
                store64(X + xb * 8, y0); store64(X + (xb + 1) * 8, y1);
                k = k + 1;
            }
            h = h + 1;
        }
        r = r + 1;
    }
    return 0;
}

# Build a deterministic (arbitrary) cos/sin table — the GPU rotation is bit-exact for ANY table,
# so arbitrary f64 values exercise the kernel's index math + arithmetic without needing real trig.
fn fill_cs(cs, rows, hdp, seed): i64 {
    var i = 0; var n = rows * hdp;
    while (i < n) {
        store64(cs + (i * 2) * 8, frand(i * 2, seed));
        store64(cs + (i * 2 + 1) * 8, frand(i * 2 + 1, seed + 1));
        i = i + 1;
    }
    return 0;
}

fn run_shape(rows, width, num_heads, dir): i64 {
    var hd = width / num_heads; var hdp = hd / 2;
    var Xc = alloc(rows * width * 8); var Xg = alloc(rows * width * 8);
    var cs = alloc(rows * hdp * 2 * 8);
    var i = 0;
    while (i < rows * width) { var v = frand(i, 9); store64(Xc + i * 8, v); store64(Xg + i * 8, v); i = i + 1; }
    fill_cs(cs, rows, hdp, 3);
    cpu_rope(Xc, cs, rows, width, num_heads, hdp, dir);
    var rc = gpu_rope_apply(Xg, cs, rows, width, num_heads, hdp, dir);
    print_cstr("  rows="); print_i64(rows); print_cstr(" width="); print_i64(width);
    print_cstr(" nh="); print_i64(num_heads); print_cstr(" hd="); print_i64(hd);
    print_cstr(" dir="); print_i64(dir); print_cstr(": ");
    if (rc != 0) { print_cstr("GPU FALLBACK (rc="); print_i64(rc); print_cstr(") — expected on-device\n"); return 0; }
    var diff = 0; i = 0;
    while (i < rows * width) { if (load64(Xg + i * 8) != load64(Xc + i * 8)) { diff = diff + 1; } i = i + 1; }
    if (diff == 0) { print_cstr("BIT-EXACT ("); print_i64(rows * width); print_cstr(" elems)\n"); return 1; }
    print_cstr("BIT DIFF ("); print_i64(diff); print_cstr(")\n"); return 0;
}

# rows=1 (decode) must self-fall-back (rc != 0), never run a pointless single-row dispatch.
fn expect_fb(rows, width, num_heads): i64 {
    var hd = width / num_heads; var hdp = hd / 2;
    var X = alloc(rows * width * 8); var cs = alloc(rows * hdp * 2 * 8);
    var i = 0; while (i < rows * width) { store64(X + i * 8, frand(i, 1)); i = i + 1; }
    fill_cs(cs, rows, hdp, 1);
    var rc = gpu_rope_apply(X, cs, rows, width, num_heads, hdp, 0);
    print_cstr("  rows="); print_i64(rows); print_cstr(" width="); print_i64(width); print_cstr(": ");
    if (rc != 0) { print_cstr("CPU fallback (correct — decode not worth a dispatch)\n"); return 1; }
    print_cstr("UNEXPECTED on-device (rows<2 should fall back)\n"); return 0;
}

fn main(): i64 {
    alloc_init();
    print_cstr("attn11 GPU RoPE-rotation validation (M19 1.9.1) — gpu_rope_apply vs the CPU rotation, BIT-EXACT\n");
    if (_gpu_init() == 0) {
        print_cstr("no native AMD GPU — SKIPPED (CPU oracle unaffected; build verified)\n");
        return 0;
    }
    print_cstr("native AMD f64 GPU online — validating bit-exact Q/K rotation (fwd + bwd):\n");
    var ok = 1;
    if (run_shape(16, 32, 4, 0) == 0) { ok = 0; }    # default Q (hd=8, hdp=4) fwd
    if (run_shape(16, 32, 4, 1) == 0) { ok = 0; }    # default Q bwd
    if (run_shape(64, 64, 8, 0) == 0) { ok = 0; }    # preset Q (T=64) fwd
    if (run_shape(64, 64, 8, 1) == 0) { ok = 0; }    # preset Q bwd
    if (run_shape(16, 64, 1, 0) == 0) { ok = 0; }    # wide head (hd=64, hdp=32) fwd
    if (run_shape(64, 32, 4, 1) == 0) { ok = 0; }    # preset-T, narrow width, bwd
    if (expect_fb(1, 32, 4) == 0) { ok = 0; }        # rows=1 (decode) → CPU fallback
    print_cstr("GPU rope rotations dispatched on-device: "); print_i64(gpu_rope_count()); print_cstr("\n");
    if (ok == 0) { print_cstr("\nFAIL: GPU rope diverged from the CPU rotation\n"); return 1; }
    print_cstr("\nOK — gpu_rope_apply BIT-EXACT to the CPU rotation (fwd + bwd); clean rows=1 fallback\n");
    return 0;
}

var exit_code = main();
sys_exit(exit_code);
