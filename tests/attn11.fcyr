# attn11 fuzz harness — hostile inputs to the loaders must never crash.
#
# Covers the untrusted-input paths (M2 loaders + the M7 BPE surface):
#   * ckpt_load_buf  — fed truncated / bit-flipped / wild-config / random bytes,
#                      on BOTH a byte-level and a BPE reference image; BPE
#                      rounds add merge-slot clobbers, inconsistent (V,Vb,K)
#                      triples, and expansion-bomb merge chains
#   * corpus_set     — fed random byte buffers of random length; bpe_learn
#                      over each must round-trip (decode reconstructs input)
# Property: the loader always returns (a negative error or a sane success),
# never reads out of bounds or over-allocates. Validation happens before any
# allocation/copy, so a malformed buffer is rejected, not trusted.
#
# Uses its OWN PRNG (model_init reseeds the global _rng_state, so we can't
# share it). Deterministic seed -> reproducible. Run by `cyrius test`.

include "lib/tyche.cyr"          # extracted PRNG (rng_*, _rng_state)
include "lib/rosnet.cyr"         # extracted tensor/BLAS-1/matmul (+ gradient)
include "lib/rupantara.cyr"      # ru_* forward leaf ops (M1 re-fold)
# mabda (Linux-only GPU dep) auto-prepends from [deps.mabda] on all targets; on AGNOS it is
# dead code but still references SYS_IOCTL (absent from the agnos syscall peer) — define it so
# the auto-prepended dep compiles. The GPU backend (rosnet's [lib.gpu] bundle, also auto-prepended)
# consumes it; g_gpu==0 here regardless → the CPU oracle path, byte-identical.
#ifdef CYRIUS_TARGET_AGNOS
var SYS_IOCTL = 16;
#endif
# 1.10.0 (ADR 0017): the GPU backend is rosnet's dist/rosnet-gpu.cyr, auto-prepended from
# [deps.rosnet]; no manual include. The gpu_* CALLS stay AGNOS-gated in src/.
include "src/tensor.cyr"
include "src/fileio.cyr"
include "lib/akshara.cyr"
include "src/ops.cyr"
include "src/attn.cyr"
include "src/attn_linear.cyr"
include "src/attn_ssm.cyr"
include "src/model.cyr"
include "src/train.cyr"
include "src/persist.cyr"
include "src/stream.cyr"

var _fz = 0;
fn fz_seed(s): i64 { _fz = s; return 0; }
fn fz_next(): i64 {
    var x = _fz;
    x = x ^ (x << 13);
    x = x ^ (x >> 7);
    x = x ^ (x << 17);
    _fz = x;
    return x;
}
fn fz_pos(): i64 { var v = fz_next(); if (v < 0) { return 0 - v - 1; } return v; }

fn main(): i64 {
    alloc_init();
    fz_seed(0x00C0FFEE);

    # ---- a valid reference checkpoint (tiny model) ----
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 5);
    var sz = ckpt_size();
    var good = alloc(sz);
    ckpt_serialize(good);
    var work = alloc(sz);

    var rounds = 0; var rejected = 0; var accepted = 0;
    while (rounds < 500) {
        t_copy(work, good, sz / 8);          # fresh copy of the valid checkpoint
        var mode = fz_pos() % 6;
        var mlen = sz;
        if (mode == 0) {                      # flip a random byte
            var off = fz_pos() % sz;
            store8(work + off, (load8(work + off) ^ (fz_pos() & 0xFF)) & 0xFF);
        } elif (mode == 1) {                  # truncate to a random length
            mlen = fz_pos() % (sz + 1);
        } elif (mode == 2) {                  # wild value into a header field (2..CKPT_HDR()-1, incl. v4 descriptor)
            var fld = 2 + (fz_pos() % (CKPT_HDR() - 2));
            store64(work + fld * 8, fz_next());
        } elif (mode == 3) {                  # clobber the magic
            store64(work, fz_next());
        } elif (mode == 4) {                  # boundary-combination: every size field at/over its cap
            store64(work + 2 * 8, 768 + (fz_pos() % 3));    # V  (cap BPE_VMAX 768)
            store64(work + 3 * 8, 4096 + (fz_pos() % 3));   # C  (cap 4096)
            store64(work + 4 * 8, 8192 + (fz_pos() % 3));   # T  (cap 8192)
            store64(work + 6 * 8, 128 + (fz_pos() % 3));    # NL (cap 128)
            store64(work + 9 * 8, 4194304 + (fz_pos() % 3));# np (cap 4M) — stresses size arithmetic + check order
            store64(work + 20 * 8, 256 + (fz_pos() % 3));   # num_experts (cap 256) — stresses N*(2CF+...) arithmetic
        } else {                              # fully random header
            var k = 0;
            while (k < CKPT_HDR()) { store64(work + k * 8, fz_next()); k = k + 1; }
        }
        var rc = ckpt_load_buf(work, mlen);
        if (rc < 0) { rejected = rejected + 1; }
        else { accepted = accepted + 1; }     # valid by format (e.g. payload-only flip)
        rounds = rounds + 1;
    }

    # ---- a valid BPE reference checkpoint: merge-table mutations ----
    # tok_kind=1 images exercise the merge-table scan (-37/-38), the
    # (V, Vb, K) triple checks, and the install/rebuild path on accepts.
    build_corpus();
    var Vb2 = bpe_learn(8);
    model_init(Vb2, 8, 4, 2, 2, 1, 0, f64_from(0), 5);
    var bsz = ckpt_size();
    var bgood = alloc(bsz);
    ckpt_serialize(bgood);
    var bwork = alloc(bsz);
    var Bb = load64(bgood + 14 * 8);          # base vocab
    var Kb = load64(bgood + 15 * 8);          # merge count
    var brejected = 0; var baccepted = 0;
    var br = 0;
    while (br < 500) {
        t_copy(bwork, bgood, bsz / 8);
        var bmode = fz_pos() % 8;
        var bmlen = bsz;
        if (bmode == 0) {                     # flip a random byte
            var boff = fz_pos() % bsz;
            store8(bwork + boff, (load8(bwork + boff) ^ (fz_pos() & 0xFF)) & 0xFF);
        } elif (bmode == 1) {                 # truncate
            bmlen = fz_pos() % (bsz + 1);
        } elif (bmode == 2) {                 # wild config/tokenizer/descriptor field
            var bfld = 2 + (fz_pos() % (CKPT_HDR() - 2));
            store64(bwork + bfld * 8, fz_next());
        } elif (bmode == 3) {                 # clobber the magic
            store64(bwork, fz_next());
        } elif (bmode == 4) {                 # fully random header
            var bk = 0;
            while (bk < CKPT_HDR()) { store64(bwork + bk * 8, fz_next()); bk = bk + 1; }
        } elif (bmode == 5) {                 # clobber one merge slot
            var slot = fz_pos() % (2 * Kb);
            store64(bwork + (CKPT_HDR() + Bb + slot) * 8, fz_next());
        } elif (bmode == 6) {                 # inconsistent OR max-boundary (V, Vb, K) triple
            var pick = fz_pos() % 4;
            if (pick == 0) { store64(bwork + 2 * 8, 1 + (fz_pos() % 1024)); }
            elif (pick == 1) { store64(bwork + 14 * 8, fz_pos() % 300); }
            elif (pick == 2) { store64(bwork + 15 * 8, fz_pos() % 600); }
            else {                            # the extreme VALID triple: V=768, Vb=256, K=512
                store64(bwork + 2 * 8, 768);  # = BPE_VMAX, the lens[6144] boundary
                store64(bwork + 14 * 8, 256); # passes -4/-33/-34/-35, rejects on -11 (size)
                store64(bwork + 15 * 8, 512);
            }
        } else {                              # expansion-bomb merge chain
            var bj = 0;
            while (bj < Kb) {
                var ref = 0;
                if (bj > 0) { ref = Bb + bj - 1; }
                store64(bwork + (CKPT_HDR() + Bb + 2 * bj) * 8, ref);
                store64(bwork + (CKPT_HDR() + Bb + 2 * bj + 1) * 8, ref);
                bj = bj + 1;
            }
        }
        var brc = ckpt_load_buf(bwork, bmlen);
        if (brc < 0) { brejected = brejected + 1; }
        else { baccepted = baccepted + 1; }
        br = br + 1;
    }
    if (brejected < 1) { sys_write(2, "FAIL: no BPE image rejected\n", 28); sys_exit(4); }

    # ---- a valid v7 (M15 char-diffusion) reference: objective-field mutations ----
    # v7 carries the objective at [22] and a +C mask_emb in NP. Hostile v7 headers
    # (objective out of {0,1}, diffusion paired with a causal mixer / rope / MoE,
    # bit-flips) must reject cleanly (-47/-10/...), never crash or over-read.
    var dV = build_corpus();
    model_init_full(dV, 8, 4, 2, 2, 1, 0, f64_from(0), 5, 0, 0, 0, 0, 1, 1, 0, 1);   # diffusion
    var dsz = ckpt_size();
    var dgood = alloc(dsz);
    ckpt_serialize(dgood);
    var dwork = alloc(dsz);
    var drej = 0; var dacc = 0;
    var dr = 0;
    while (dr < 500) {
        t_copy(dwork, dgood, dsz / 8);
        var dmode = fz_pos() % 5;
        var dmlen = dsz;
        if (dmode == 0) { store64(dwork + 22 * 8, fz_next()); }              # wild objective field
        elif (dmode == 1) { store64(dwork + 16 * 8, fz_pos() % 4); }         # attn_kind vs diffusion
        elif (dmode == 2) { store64(dwork + 17 * 8, fz_pos() % 3); }         # pos_kind vs diffusion
        elif (dmode == 3) {                                                  # wild header field 2..22
            var dfld = 2 + (fz_pos() % (CKPT_HDR_V7() - 2));
            store64(dwork + dfld * 8, fz_next());
        } else {                                                            # flip a random byte
            var doff = fz_pos() % dsz;
            store8(dwork + doff, (load8(dwork + doff) ^ (fz_pos() & 0xFF)) & 0xFF);
        }
        var drc = ckpt_load_buf(dwork, dmlen);
        if (drc < 0) { drej = drej + 1; } else { dacc = dacc + 1; }
        dr = dr + 1;
    }
    if (drej < 1) { sys_write(2, "FAIL: no v7 image rejected\n", 27); sys_exit(7); }

    # ---- token-shard metadata loader (1.6.x): hostile shards must reject ----
    # shard_validate_buf is the single authority shard_open routes through; it must
    # bound every read against the buffer length and reject any malformed header /
    # tokenizer (wild triple, clobbered merge slot, expansion bomb, flipped bytes)
    # with a negative -60.. code, never crash or over-read. Built on a BPE shard so
    # the vocab AND merge-DAG paths are both exercised.
    var sV = build_corpus();
    var sKv = bpe_learn(16);
    var sVb = g_bpe_base; var sK = g_bpe_nmerges;
    var sneed = (SHARD_HDR() + sVb + 2 * sK) * 8;
    var sgood = alloc(sneed);
    store64(sgood + 0 * 8, SHARD_MAGIC()); store64(sgood + 1 * 8, 1);
    store64(sgood + 2 * 8, 1);                                   # tok_kind BPE
    store64(sgood + 3 * 8, sVb); store64(sgood + 4 * 8, sK); store64(sgood + 5 * 8, sVb + sK);
    store64(sgood + 6 * 8, 2); store64(sgood + 7 * 8, 1000);     # width 2, ntok 1000
    var svi = 0;
    while (svi < sVb) { store64(sgood + (SHARD_HDR() + svi) * 8, load64(g_vocab + svi * 8)); svi = svi + 1; }
    svi = 0;
    while (svi < 2 * sK) { store64(sgood + (SHARD_HDR() + sVb + svi) * 8, load64(g_merges + svi * 8)); svi = svi + 1; }
    if (shard_validate_buf(sgood, sneed) != 0) { sys_write(2, "FAIL: valid shard rejected\n", 27); sys_exit(8); }
    var swork = alloc(sneed);
    var srej = 0; var sacc = 0;
    var sr = 0;
    while (sr < 500) {
        t_copy(swork, sgood, sneed / 8);
        var smode = fz_pos() % 6;
        var slen = sneed;
        if (smode == 0) { var so = fz_pos() % sneed; store8(swork + so, (load8(swork + so) ^ (fz_pos() & 0xFF)) & 0xFF); }  # flip byte
        elif (smode == 1) { slen = 1 + (fz_pos() % sneed); }                                   # truncate
        elif (smode == 2) { var sf = 2 + (fz_pos() % 6); store64(swork + sf * 8, fz_next()); } # wild header field 2..7
        elif (smode == 3) { store64(swork + 0 * 8, fz_next()); }                               # clobber magic
        elif (smode == 4) { store64(swork + (SHARD_HDR() + sVb + (fz_pos() % (2 * sK))) * 8, fz_next()); }  # clobber a merge id
        else { var k2 = 0; while (k2 < SHARD_HDR()) { store64(swork + k2 * 8, fz_next()); k2 = k2 + 1; } }   # random header
        var src = shard_validate_buf(swork, slen);
        if (src < 0) { srej = srej + 1; } else { sacc = sacc + 1; }
        sr = sr + 1;
    }
    if (srej < 1) { sys_write(2, "FAIL: no shard rejected\n", 24); sys_exit(8); }

    # ---- corpus tokenizer on random byte buffers (+ BPE round-trip) ----
    var cb = alloc(2048);
    var cr = 0;
    while (cr < 100) {
        var clen = 1 + (fz_pos() % 2048);
        var j = 0;
        while (j < clen) { store8(cb + j, fz_pos() & 0xFF); j = j + 1; }
        var vv = corpus_set(cb, clen);
        if (vv < 1) { sys_write(2, "FAIL: corpus vocab < 1\n", 23); sys_exit(1); }
        if (vv > 256) { sys_write(2, "FAIL: corpus vocab > 256\n", 25); sys_exit(2); }
        # BPE over random bytes: whatever it learns, expanding the encoded
        # stream must reconstruct the input byte-exactly
        if (clen >= 2) {
            var bV = bpe_learn(1 + (fz_pos() % 32));
            if (bV < vv) { sys_write(2, "FAIL: bpe V < base\n", 19); sys_exit(5); }
            var pos = 0; var ei = 0; var bad = 0;
            while (ei < g_datalen) {
                var id = gd_ld(ei);
                var tl = load64(g_tok_len + id * 8);
                var sp = g_tok_bytes + id * BPE_MAX_TOKLEN();
                var bj2 = 0;
                while (bj2 < tl) {
                    if (pos >= clen) { bad = 1; }
                    elif (load8(sp + bj2) != load8(cb + pos)) { bad = 1; }
                    pos = pos + 1;
                    bj2 = bj2 + 1;
                }
                ei = ei + 1;
            }
            if ((bad == 1) || (pos != clen)) { sys_write(2, "FAIL: bpe roundtrip\n", 20); sys_exit(6); }
        }
        cr = cr + 1;
    }

    # ensure the malformed inputs were actually exercised (most must reject)
    if (rejected < 1) { sys_write(2, "FAIL: nothing rejected\n", 23); sys_exit(3); }

    puts("fuzz: ok  ("); fmt_int(rounds); puts(" ckpt rounds, ");
    fmt_int(rejected); puts(" rejected / "); fmt_int(accepted);
    puts(" accepted; "); fmt_int(br); puts(" bpe rounds, ");
    fmt_int(brejected); puts(" rejected / "); fmt_int(baccepted);
    puts(" accepted; "); fmt_int(dr); puts(" v7 rounds, ");
    fmt_int(drej); puts(" rejected / "); fmt_int(dacc);
    puts(" accepted; "); fmt_int(sr); puts(" shard rounds, ");
    fmt_int(srej); puts(" rejected / "); fmt_int(sacc);
    puts(" accepted; 100 random corpora + bpe roundtrip)\n");
    return 0;
}

# Statement-call epilogue (not a `var` initializer) — see docs/architecture/002.
var r = 0;
r = main();
sys_exit(r);
