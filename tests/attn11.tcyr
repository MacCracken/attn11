# attn11 test suite — finite-difference gradient checks + resume determinism.
#
# Hand-derived backward passes are only as trustworthy as their grad checks.
# Every op (and the full model) is verified against central finite differences.
# The checkpoint round-trip is verified to reproduce training bit-for-bit.
# Stdlib (assert/math/...) auto-included via cyrius.cyml.

include "lib/tyche.cyr"          # extracted PRNG (rng_*, _rng_state)
include "lib/rosnet.cyr"         # extracted tensor/BLAS-1/matmul (+ gradient)
# mabda (Linux-only GPU dep) auto-prepends from [deps.mabda] on all targets; on AGNOS it is
# dead code but still references SYS_IOCTL (absent from the agnos syscall peer) — define it so
# the auto-prepended dep compiles. The GPU backend (rosnet's [lib.gpu] bundle, also auto-prepended)
# consumes it; g_gpu==0 here regardless → the CPU oracle path, byte-identical.
#ifdef CYRIUS_TARGET_AGNOS
var SYS_IOCTL = 16;
#endif
# 1.10.0 (ADR 0017): the GPU backend is rosnet's dist/rosnet-gpu.cyr, auto-prepended from
# [deps.rosnet]; no manual include. The gpu_* CALLS stay AGNOS-gated in src/.
include "src/tensor.cyr"
include "src/fileio.cyr"
include "lib/akshara.cyr"
include "src/ops.cyr"
include "src/attn.cyr"
include "src/attn_linear.cyr"
include "src/attn_ssm.cyr"
include "src/model.cyr"
include "src/train.cyr"
include "src/persist.cyr"
include "src/stream.cyr"

fn _eps(): i64 { return f64_div(f64_from(1), f64_from(10000)); }     # 1e-4
fn dotsum(a, b, n): i64 {
    var acc = f64_from(0); var i = 0;
    while (i < n) { acc = f64_add(acc, f64_mul(load64(a + i * 8), load64(b + i * 8))); i = i + 1; }
    return acc;
}

# max relative error between analytic and numeric gradient arrays
fn maxrel(analytic, numeric, n): i64 {
    var mr = f64_from(0);
    var tiny = f64_div(f64_from(1), f64_from(1000000000));
    var i = 0;
    while (i < n) {
        var a = load64(analytic + i * 8); var b = load64(numeric + i * 8);
        var rel = f64_div(f64_abs(f64_sub(a, b)),
        f64_add(f64_add(f64_abs(a), f64_abs(b)), tiny));
        if (f64_gt(rel, mr) == 1) { mr = rel; }
        i = i + 1;
    }
    return mr;
}

# assert max-rel-err < tol; tol = 1/tol_inv
fn check(name, analytic, numeric, n, tol_inv): i64 {
    var mr = maxrel(analytic, numeric, n);
    print(name, strlen(name)); print(" maxrel=", 8); f_print(mr, 9); _putc(10);
    assert(f64_lt(mr, f64_div(f64_from(1), f64_from(tol_inv))) == 1, name);
    return 0;
}

# ===========================================================================
fn lin_loss(x, W, b, y, dy, M, K, N): i64 { linear_fwd(x, W, b, y, M, K, N); return dotsum(dy, y, M * N); }

fn test_linear(): i64 {
    var M = 3; var K = 4; var N = 5;
    var x = t_alloc(M * K); var W = t_alloc(K * N); var b = t_alloc(N);
    var y = t_alloc(M * N); var dy = t_alloc(M * N);
    t_randn(x, M * K, f64_from(1)); t_randn(W, K * N, f64_from(1));
    t_randn(b, N, f64_from(1)); t_randn(dy, M * N, f64_from(1));
    var dx = t_alloc(M * K); var dW = t_alloc(K * N); var db = t_alloc(N);
    linear_fwd(x, W, b, y, M, K, N);
    linear_bwd(x, W, dy, dx, dW, db, M, K, N);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var ndx = t_alloc(M * K); var i = 0;
    while (i < M * K) {
        var o = load64(x + i * 8);
        store64(x + i * 8, f64_add(o, eps)); var lp = lin_loss(x, W, b, y, dy, M, K, N);
        store64(x + i * 8, f64_sub(o, eps)); var lm = lin_loss(x, W, b, y, dy, M, K, N);
        store64(x + i * 8, o); store64(ndx + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    var ndW = t_alloc(K * N); i = 0;
    while (i < K * N) {
        var o = load64(W + i * 8);
        store64(W + i * 8, f64_add(o, eps)); var lp = lin_loss(x, W, b, y, dy, M, K, N);
        store64(W + i * 8, f64_sub(o, eps)); var lm = lin_loss(x, W, b, y, dy, M, K, N);
        store64(W + i * 8, o); store64(ndW + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    var ndb = t_alloc(N); i = 0;
    while (i < N) {
        var o = load64(b + i * 8);
        store64(b + i * 8, f64_add(o, eps)); var lp = lin_loss(x, W, b, y, dy, M, K, N);
        store64(b + i * 8, f64_sub(o, eps)); var lm = lin_loss(x, W, b, y, dy, M, K, N);
        store64(b + i * 8, o); store64(ndb + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("linear dx", dx, ndx, M * K, 100000);
    check("linear dW", dW, ndW, K * N, 100000);
    check("linear db", db, ndb, N, 100000);
    return 0;
}

fn ln_loss(x, g, be, y, mean, rstd, dy, M, C): i64 { ln_fwd(x, g, be, y, mean, rstd, M, C); return dotsum(dy, y, M * C); }
fn test_layernorm(): i64 {
    var M = 3; var C = 6;
    var x = t_alloc(M * C); var g = t_alloc(C); var be = t_alloc(C);
    var y = t_alloc(M * C); var dy = t_alloc(M * C);
    var mean = t_alloc(M); var rstd = t_alloc(M);
    t_randn(x, M * C, f64_from(1)); t_randn(g, C, f64_from(1));
    t_randn(be, C, f64_from(1)); t_randn(dy, M * C, f64_from(1));
    var dx = t_alloc(M * C); var dg = t_alloc(C); var dbe = t_alloc(C);
    ln_fwd(x, g, be, y, mean, rstd, M, C);
    ln_bwd(x, g, dy, mean, rstd, dx, dg, dbe, M, C);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var ndx = t_alloc(M * C); var i = 0;
    while (i < M * C) {
        var o = load64(x + i * 8);
        store64(x + i * 8, f64_add(o, eps)); var lp = ln_loss(x, g, be, y, mean, rstd, dy, M, C);
        store64(x + i * 8, f64_sub(o, eps)); var lm = ln_loss(x, g, be, y, mean, rstd, dy, M, C);
        store64(x + i * 8, o); store64(ndx + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    var ndg = t_alloc(C); i = 0;
    while (i < C) {
        var o = load64(g + i * 8);
        store64(g + i * 8, f64_add(o, eps)); var lp = ln_loss(x, g, be, y, mean, rstd, dy, M, C);
        store64(g + i * 8, f64_sub(o, eps)); var lm = ln_loss(x, g, be, y, mean, rstd, dy, M, C);
        store64(g + i * 8, o); store64(ndg + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    var ndbe = t_alloc(C); i = 0;
    while (i < C) {
        var o = load64(be + i * 8);
        store64(be + i * 8, f64_add(o, eps)); var lp = ln_loss(x, g, be, y, mean, rstd, dy, M, C);
        store64(be + i * 8, f64_sub(o, eps)); var lm = ln_loss(x, g, be, y, mean, rstd, dy, M, C);
        store64(be + i * 8, o); store64(ndbe + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("layernorm dx", dx, ndx, M * C, 100000);
    check("layernorm dgamma", dg, ndg, C, 100000);
    check("layernorm dbeta", dbe, ndbe, C, 100000);
    return 0;
}

fn gelu_loss(x, y, dy, n): i64 { gelu_fwd(x, y, n); return dotsum(dy, y, n); }
fn test_gelu(): i64 {
    var n = 12;
    var x = t_alloc(n); var y = t_alloc(n); var dy = t_alloc(n);
    t_randn(x, n, f64_from(1)); t_randn(dy, n, f64_from(1));
    var dx = t_alloc(n);
    gelu_fwd(x, y, n); gelu_bwd(x, dy, dx, n);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var ndx = t_alloc(n); var i = 0;
    while (i < n) {
        var o = load64(x + i * 8);
        store64(x + i * 8, f64_add(o, eps)); var lp = gelu_loss(x, y, dy, n);
        store64(x + i * 8, f64_sub(o, eps)); var lm = gelu_loss(x, y, dy, n);
        store64(x + i * 8, o); store64(ndx + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("gelu dx", dx, ndx, n, 100000);
    return 0;
}

fn test_softmax_xent(): i64 {
    var M = 4; var V = 5;
    var logits = t_alloc(M * V); var probs = t_alloc(M * V); var targets = t_alloc(M);
    t_randn(logits, M * V, f64_from(1));
    store64(targets + 0, 2); store64(targets + 8, 0); store64(targets + 16, 4); store64(targets + 24, 1);
    var dlogits = t_alloc(M * V);
    softmax_xent_fwd(logits, targets, probs, M, V);
    softmax_xent_bwd(probs, targets, dlogits, M, V);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var nd = t_alloc(M * V); var i = 0;
    while (i < M * V) {
        var o = load64(logits + i * 8);
        store64(logits + i * 8, f64_add(o, eps)); var lp = softmax_xent_fwd(logits, targets, probs, M, V);
        store64(logits + i * 8, f64_sub(o, eps)); var lm = softmax_xent_fwd(logits, targets, probs, M, V);
        store64(logits + i * 8, o); store64(nd + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("softmax_xent dlogits", dlogits, nd, M * V, 100000);
    return 0;
}

# M15: masked cross-entropy (the diffusion objective's loss). The fwd returns the
# scalar masked-mean loss directly, so the grad-check is a direct central-FD over
# logits (like a loss layer). Mixed mask (rows 0,2 masked; 1,3 given) exercises the
# zeroed-gradient path at given rows AND the 1/nmask normalizer. Two regression
# pins: an all-ones mask must equal the plain softmax_xent (byte-for-byte), and an
# all-zeros mask must give zero loss + zero dlogits.
fn test_masked_ce(): i64 {
    var M = 4; var V = 5;
    var logits = t_alloc(M * V); var probs = t_alloc(M * V); var targets = t_alloc(M);
    var mask = t_alloc(M);
    t_randn(logits, M * V, f64_from(1));
    store64(targets + 0, 2); store64(targets + 8, 0); store64(targets + 16, 4); store64(targets + 24, 1);
    store64(mask + 0, 1); store64(mask + 8, 0); store64(mask + 16, 1); store64(mask + 24, 0);
    var dlogits = t_alloc(M * V);
    softmax_xent_masked_fwd(logits, targets, probs, mask, M, V);
    softmax_xent_masked_bwd(probs, targets, mask, dlogits, M, V);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var nd = t_alloc(M * V); var i = 0;
    while (i < M * V) {
        var o = load64(logits + i * 8);
        store64(logits + i * 8, f64_add(o, eps)); var lp = softmax_xent_masked_fwd(logits, targets, probs, mask, M, V);
        store64(logits + i * 8, f64_sub(o, eps)); var lm = softmax_xent_masked_fwd(logits, targets, probs, mask, M, V);
        store64(logits + i * 8, o); store64(nd + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("masked-ce dlogits", dlogits, nd, M * V, 100000);
    # pin: an all-ones mask must reproduce the plain softmax_xent bit-for-bit
    store64(mask + 8, 1); store64(mask + 24, 1);
    var probs2 = t_alloc(M * V);
    var l_masked = softmax_xent_masked_fwd(logits, targets, probs, mask, M, V);
    var l_plain = softmax_xent_fwd(logits, targets, probs2, M, V);
    assert(f64_eq(l_masked, l_plain) == 1, "all-ones mask == plain CE");
    # pin: an all-zeros mask -> zero loss and zero dlogits
    store64(mask + 0, 0); store64(mask + 8, 0); store64(mask + 16, 0); store64(mask + 24, 0);
    var l_zero = softmax_xent_masked_fwd(logits, targets, probs, mask, M, V);
    assert(f64_eq(l_zero, f64_from(0)) == 1, "all-zeros mask -> zero loss");
    softmax_xent_masked_bwd(probs, targets, mask, dlogits, M, V);
    var allzero = 1; var z = 0;
    while (z < M * V) { if (f64_eq(load64(dlogits + z * 8), f64_from(0)) == 0) { allzero = 0; } z = z + 1; }
    assert(allzero == 1, "all-zeros mask -> zero dlogits");
    return 0;
}

fn attn_loss(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk): i64 {
    attn_fwd(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, ar, T, C, nh, nkv, pk);
    return dotsum(dout, out, T * C);
}
fn attn_ng(p, np, n, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = attn_loss(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
        store64(p + i * 8, f64_sub(o, eps)); var lm = attn_loss(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
# Parameterized so we can grad-check several head dims: hd = C/nh selects how
# many 4-wide SIMD chunks (+ tail) the attention kernels run. We cover hd=6
# (1 chunk + 2 tail), hd=8 (2 chunks, no tail — the PRODUCTION C=32,nh=4 path),
# and hd=10 (2 chunks + 2 tail), so a second-chunk stride/accumulator bug can't
# hide behind a single-chunk test. nkv < nh exercises the GQA/MQA K/V sharing
# (Ckv-wide K/V projections, grouped dK/dV accumulation). pk: pos_kind — 0 =
# learned-abs, 1 = coupled RoPE (rotation inside attn_fwd/attn_bwd).
fn _attn_check_pos(T, C, nh, nkv, pk): i64 {
    var CC = C * C; var TC = T * C;
    var Ckv = nkv * (C / nh); var CK = C * Ckv;
    var Wq = t_alloc(CC); var Wk = t_alloc(CK); var Wv = t_alloc(CK); var Wo = t_alloc(CC);
    var bq = t_alloc(C); var bk = t_alloc(Ckv); var bv = t_alloc(Ckv); var bo = t_alloc(C);
    var x = t_alloc(TC); var out = t_alloc(TC); var dout = t_alloc(TC);
    var std = f64_div(f64_from(1), f64_from(2));
    t_randn(Wq, CC, std); t_randn(Wk, CK, std); t_randn(Wv, CK, std); t_randn(Wo, CC, std);
    t_randn(bq, C, std); t_randn(bk, Ckv, std); t_randn(bv, Ckv, std); t_randn(bo, C, std);
    t_randn(x, TC, f64_from(1)); t_randn(dout, TC, f64_from(1));
    var ar = t_alloc(attn_arena_size(T, C, nh, nkv));
    var dx = t_alloc(TC);
    var dWq = t_alloc(CC); var dWk = t_alloc(CK); var dWv = t_alloc(CK); var dWo = t_alloc(CC);
    var dbq = t_alloc(C); var dbk = t_alloc(Ckv); var dbv = t_alloc(Ckv); var dbo = t_alloc(C);
    attn_fwd(Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, ar, T, C, nh, nkv, pk);
    attn_bwd(Wq, Wk, Wv, Wo, x, dout, dx, dWq, dbq, dWk, dbk, dWv, dbv, dWo, dbo, ar, T, C, nh, nkv, pk);
    var ndx = t_alloc(TC); attn_ng(x, ndx, TC, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nWq = t_alloc(CC); attn_ng(Wq, nWq, CC, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nWk = t_alloc(CK); attn_ng(Wk, nWk, CK, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nWv = t_alloc(CK); attn_ng(Wv, nWv, CK, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nWo = t_alloc(CC); attn_ng(Wo, nWo, CC, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nbq = t_alloc(C); attn_ng(bq, nbq, C, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nbv = t_alloc(Ckv); attn_ng(bv, nbv, Ckv, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    var nbo = t_alloc(C); attn_ng(bo, nbo, C, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
    # x86 keeps the tight 1e-5 bound. On aarch64 the attention path chains
    # through the f64_exp polyfill, which makes the finite-difference reference
    # noisier (~1.3e-5), so loosen to 1e-4 there only (a real bug is orders of
    # magnitude larger either way). RoPE adds a sin/cos/pow chain, so it also
    # rides the looser 1e-4 bound everywhere.
    var atol = 100000;
    #ifdef CYRIUS_ARCH_AARCH64
    atol = 10000;
    #endif
    if (pk == 1) { atol = 10000; }
    check("attn dx", dx, ndx, TC, atol);
    check("attn dWq", dWq, nWq, CC, atol);
    check("attn dWk", dWk, nWk, CK, atol);
    check("attn dWv", dWv, nWv, CK, atol);
    check("attn dWo", dWo, nWo, CC, atol);
    check("attn dbq", dbq, nbq, C, atol);
    check("attn dbv", dbv, nbv, Ckv, atol);
    check("attn dbo", dbo, nbo, C, atol);
    if (pk == 0) {
        # bk is FD-uncheckable under learned-abs: a constant K-row bias shifts
        # each score row by q_i.bk — constant over j — and softmax is
        # shift-invariant, so the TRUE dbk is identically zero (GPT-2's K bias is
        # a no-op parameter). Both analytic and FD values are pure rounding
        # noise, so maxrel between them is meaningless. Instead pin that the
        # analytic backward RESPECTS the invariance: |dbk| at rounding scale.
        var mxbk = f64_from(0);
        var bi = 0;
        while (bi < Ckv) {
            var av = f64_abs(load64(dbk + bi * 8));
            if (f64_gt(av, mxbk) == 1) { mxbk = av; }
            bi = bi + 1;
        }
        print("attn dbk |max|=", 16); f_print(mxbk, 12); _putc(10);
        assert(f64_lt(mxbk, f64_div(f64_from(1), f64_from(10000000000))) == 1,
        "attn dbk ~ 0 (softmax shift-invariance)");
    } else {
        # Under RoPE the K bias is ROTATED per position (R_j·bk varies with j),
        # so the shift-invariance no longer holds and dbk is a REAL gradient —
        # FD-check it like any other parameter.
        var nbk = t_alloc(Ckv); attn_ng(bk, nbk, Ckv, Wq, bq, Wk, bk, Wv, bv, Wo, bo, x, out, dout, ar, T, C, nh, nkv, pk);
        check("attn rope dbk", dbk, nbk, Ckv, atol);
    }
    return 0;
}
fn _attn_check(T, C, nh, nkv): i64 { return _attn_check_pos(T, C, nh, nkv, 0); }
fn test_attention(): i64 {
    _attn_check(3, 12, 2, 2);   # hd=6: 1 SIMD chunk + 2 tail
    _attn_check(3, 16, 2, 2);   # hd=8: 2 SIMD chunks (production path)
    _attn_check(3, 20, 2, 2);   # hd=10: 2 SIMD chunks + 2 tail
    # GQA/MQA (E2 gate: nkv in {1, 2, nh}; nkv = nh is covered above)
    _attn_check(3, 16, 4, 1);   # hd=4 MQA: 4 query heads share 1 K/V head
    _attn_check(3, 16, 4, 2);   # hd=4 GQA: 2 query heads per K/V head
    _attn_check(4, 16, 2, 1);   # hd=8 MQA: SIMD-chunk head dim, shared K/V
    return 0;
}
# M15: BIDIRECTIONAL (diffusion) attention grad-check. Set g_bidir = 1 so the
# shared core runs the full T×T square, then reuse the FD harness — the SAME
# dx/dW*/db* checks now exercise FUTURE-attending gradients (query 0 attends keys
# 1..T-1), so a causal-range bug in the dotPdP softmax sum (trap: backward not
# matching the forward's range) would blow up dWk/dWv/dx here. T ≥ 3 throughout.
# The explicit future-dependency pin below is ESSENTIAL: if BOTH fwd and bwd were
# wrongly causal they would still AGREE (FD passes) yet not be bidirectional —
# this assertion proves the forward actually attends future positions.
fn test_attn_bidir(): i64 {
    g_bidir = 1;
    _attn_check_pos(3, 16, 2, 2, 0);   # hd=8, full heads
    _attn_check_pos(4, 16, 2, 1, 0);   # hd=8, MQA — grouped dK/dV under bidir
    _attn_check_pos(3, 12, 2, 2, 0);   # hd=6: 1 SIMD chunk + 2 tail
    # explicit future-dependency pin: with bidirectional attention, out[0] MUST
    # depend on a FUTURE input x[T-1] (causal attention would make this change 0).
    var T = 3; var C = 16; var nh = 2; var nkv = 2;
    var CC = C * C; var TC = T * C; var Ckv = nkv * (C / nh); var CK = C * Ckv;
    var Wq = t_alloc(CC); var Wk = t_alloc(CK); var Wv = t_alloc(CK); var Wo = t_alloc(CC);
    var x = t_alloc(TC); var out = t_alloc(TC); var ar = t_alloc(attn_arena_size(T, C, nh, nkv));
    var std = f64_div(f64_from(1), f64_from(2));
    t_randn(Wq, CC, std); t_randn(Wk, CK, std); t_randn(Wv, CK, std); t_randn(Wo, CC, std);
    t_randn(x, TC, f64_from(1));
    attn_fwd(Wq, 0, Wk, 0, Wv, 0, Wo, 0, x, out, ar, T, C, nh, nkv, 0);
    var o0a = load64(out);                          # out[0,0] before touching the future
    var last = (T - 1) * C * 8;
    store64(x + last, f64_add(load64(x + last), f64_from(1)));   # bump x[T-1,0]
    attn_fwd(Wq, 0, Wk, 0, Wv, 0, Wo, 0, x, out, ar, T, C, nh, nkv, 0);
    assert(f64_gt(f64_abs(f64_sub(load64(out), o0a)), f64_div(f64_from(1), f64_from(1000000))) == 1,
    "bidir: out[0] depends on future x[T-1]");
    g_bidir = 0;   # reset so subsequent tests run the causal path
    return 0;
}
# M15: the CENTERPIECE full-model diffusion grad-check — it composes the mask_emb
# input path + bidirectional attention + the tied head + masked-CE in ONE finite
# difference. NL=2 exercises the residual stack. The window has BOTH masked
# (positions 0,2 — supervised) AND given (position 1 — context) positions, so:
#  - mask_emb gets gradient (masked inputs) -> FD-checked,
#  - tokemb gets BOTH the tied-head gradient (all positions) AND the input-lookup
#    gradient (the given position only) -> FD-checked (the double-path trap), and
#  - a mis-routed embed_bwd (masked grad into tokemb, or given grad into mask_emb)
#    would fail one of the two checks.
fn test_model_diffusion(): i64 {
    var V = 5; var C = 4; var T = 3; var nh = 2; var NL = 2;
    # objective = 1 (last arg): mha + learned-abs + dense; sets g_objective/g_bidir.
    model_init_full(V, C, T, nh, nh, NL, 1, f64_from(0), 1, 0, 0, 0, 0, 1, 1, 0, 1);
    assert(g_objective == 1, "diffusion model built");
    assert(g_bidir == 1, "diffusion model is bidirectional");
    # original window (A_tokens), same as targets; mask positions 0 and 2.
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 1); store64(A_targets + 8, 3); store64(A_targets + 16, 0);
    store64(A_mask + 0, 1); store64(A_mask + 8, 0); store64(A_mask + 16, 1);
    model_forward(); model_zero_grads(); model_backward();
    assert(g_nmask == 2, "g_nmask counts masked positions");
    var Cc = C * C; var n_tok = V * C;
    var aMsk = t_alloc(C); t_copy(aMsk, G_maskemb(), C);          # the NEW learned [MASK] emb
    var aTok = t_alloc(n_tok); t_copy(aTok, G_tokemb(), n_tok);   # double-path (head + lookup)
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);     # bidirectional attention block
    var aPos = t_alloc(T * C); t_copy(aPos, G_posemb(), T * C);
    var aLnf = t_alloc(C); t_copy(aLnf, G_lnfg(), C);
    var nMsk = t_alloc(C); model_ng(P_maskemb(), nMsk, C);
    var nTok = t_alloc(n_tok); model_ng(P_tokemb(), nTok, n_tok);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    var nPos = t_alloc(T * C); model_ng(P_posemb(), nPos, T * C);
    var nLnf = t_alloc(C); model_ng(P_lnfg(), nLnf, C);
    var atol = 10000;   # full-model FD tier (1e-4), as test_model
    check("diffusion dmaskemb", aMsk, nMsk, C, atol);
    check("diffusion dtokemb", aTok, nTok, n_tok, atol);
    check("diffusion L0 dWq (bidir)", aWq0, nWq0, Cc, atol);
    check("diffusion dposemb", aPos, nPos, T * C, atol);
    check("diffusion dlnf_g", aLnf, nLnf, C, atol);
    g_objective = 0; g_bidir = 0;   # reset for any later AR-building tests
    return 0;
}

# X043 — MTP backward. One aux head (g_mtp=2, predicts t+2). Verifies, in one FD:
#  - dW_mtp_0 : the aux-head transform's gradient,
#  - dtokemb  : the TIED unembed's TRIPLE path (input lookup + main head + aux head)
#               — a mis-routed aux contribution fails here, and
#  - L0 dWq / dlnf_g : the trunk, reached ONLY through the aux head's dA_f (a dropped
#               or unscaled aux→trunk path fails). g_training=1 + dropout 0 keeps the
#               aux loss in BOTH the analytic gradient and the central FD.
fn test_model_mtp(): i64 {
    var V = 5; var C = 4; var T = 3; var nh = 2; var NL = 2;
    g_mtp = 2;
    model_init(V, C, T, nh, nh, NL, 1, f64_from(0), 1);
    g_training = 1;
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    # aux head 0 (t+2): supervise positions 0,1; position 2 has no t+2 in-window → masked.
    store64(g_mtp_tgt + 0, 2); store64(g_mtp_tgt + 8, 4); store64(g_mtp_tgt + 16, 0);
    store64(g_mtp_mask + 0, 1); store64(g_mtp_mask + 8, 1); store64(g_mtp_mask + 16, 0);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var n_tok = V * C;
    var aMtp = t_alloc(Cc); t_copy(aMtp, G_mtp(0), Cc);
    var aTok = t_alloc(n_tok); t_copy(aTok, G_tokemb(), n_tok);
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);
    var aLnf = t_alloc(C); t_copy(aLnf, G_lnfg(), C);
    var nMtp = t_alloc(Cc); model_ng(P_mtp(0), nMtp, Cc);
    var nTok = t_alloc(n_tok); model_ng(P_tokemb(), nTok, n_tok);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    var nLnf = t_alloc(C); model_ng(P_lnfg(), nLnf, C);
    var atol = 10000;   # 1e-4 full-model FD tier
    check("mtp dW_mtp_0", aMtp, nMtp, Cc, atol);
    check("mtp dtokemb (tied +aux)", aTok, nTok, n_tok, atol);
    check("mtp L0 dWq (trunk via aux dA_f)", aWq0, nWq0, Cc, atol);
    check("mtp dlnf_g", aLnf, nLnf, C, atol);
    g_mtp = 1; g_training = 0;
    return 0;
}
# M15: the confidence-ordered diffusion decoder. It uses NO RNG (greedy + frozen
# lowest-index tie-break), so a second run with the same model/prompt/steps must be
# bit-identical. Also pins that every position is resolved (A_mask all 0) and the
# committed ids are valid — i.e. the iterative-unmask loop terminates correctly.
fn test_diffusion_decode_determinism(): i64 {
    var V = build_corpus();
    model_init_full(V, 16, 16, 4, 4, 2, 1, f64_from(0), 7, 0, 0, 0, 0, 1, 1, 0, 1);
    var T = g_T;
    gen_diffusion("cyrius ", 7, 8, 0, 0);     # 8 steps, cosine schedule, no emit
    var allun = 1; var i = 0;
    while (i < T) { if (load64(A_mask + i * 8) != 0) { allun = 0; } i = i + 1; }
    assert(allun == 1, "diffusion decode unmasks every position");
    var valid = 1; i = 0;
    while (i < T) { var id = load64(A_tokens + i * 8); if ((id < 0) || (id >= V)) { valid = 0; } i = i + 1; }
    assert(valid == 1, "diffusion decode emits valid token ids");
    var out1 = t_alloc(T);
    i = 0; while (i < T) { store64(out1 + i * 8, load64(A_tokens + i * 8)); i = i + 1; }
    gen_diffusion("cyrius ", 7, 8, 0, 0);
    var same = 1; i = 0;
    while (i < T) { if (load64(A_tokens + i * 8) != load64(out1 + i * 8)) { same = 0; } i = i + 1; }
    assert(same == 1, "diffusion decode is deterministic (greedy, no RNG)");
    g_objective = 0; g_bidir = 0;
    return 0;
}
# Coupled RoPE (M12 increment 4): the same attention grad-check at pos_kind=1.
# RoPE rotates Q/K by absolute position before the score, so the rotation's
# backward composes into dWq/dWk/dx (and dbk becomes a real gradient). Even head
# dims only (RoPE pairs (2k,2k+1)): hd ∈ {6,8,10}, plus MQA/GQA K-head sharing.
fn test_attention_rope(): i64 {
    _attn_check_pos(3, 12, 2, 2, 1);   # hd=6: SIMD chunk + tail
    _attn_check_pos(3, 16, 2, 2, 1);   # hd=8: pure SIMD chunks
    _attn_check_pos(3, 20, 2, 2, 1);   # hd=10: SIMD chunks + tail
    _attn_check_pos(4, 16, 2, 1, 1);   # hd=8 MQA: shared K/V head, rotated
    _attn_check_pos(3, 16, 4, 2, 1);   # hd=4 GQA: 2 query heads per K/V head
    return 0;
}

# Isolated grad-check of the RoPE rotation's backward (the ONLY new gradient in
# coupled RoPE — the rotation is parameter-free; roadmap M12 increment 4). With
# loss = <g, rope_fwd(X)>, the gradient w.r.t. X is the transpose rotation applied
# to g, i.e. exactly rope_apply_bwd(g). The rotation is linear, so this matches
# central differences to near machine precision (tight 1e-5). rope_fwd is
# in-place, so the FD reuses a scratch copy.
fn _rope_fwd_dot(X, g, rows, pos0, W, H, scratch): i64 {
    t_copy(scratch, X, rows * W);
    rope_apply_fwd(scratch, rows, pos0, W, H);
    return dotsum(g, scratch, rows * W);
}
fn test_rope_op(): i64 {
    rng_seed(99);
    var rows = 3; var W = 16; var H = 2; var pos0 = 1;   # hd = W/H = 8 (even)
    var n = rows * W;
    var X = t_alloc(n); var g = t_alloc(n); var sc = t_alloc(n);
    t_randn(X, n, f64_from(1)); t_randn(g, n, f64_from(1));
    # analytic dX = R^T g
    var dX = t_alloc(n); t_copy(dX, g, n);
    rope_apply_bwd(dX, rows, pos0, W, H);
    # central-difference dX
    var nd = t_alloc(n);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var i = 0;
    while (i < n) {
        var o = load64(X + i * 8);
        store64(X + i * 8, f64_add(o, eps)); var lp = _rope_fwd_dot(X, g, rows, pos0, W, H, sc);
        store64(X + i * 8, f64_sub(o, eps)); var lm = _rope_fwd_dot(X, g, rows, pos0, W, H, sc);
        store64(X + i * 8, o); store64(nd + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("rope rotation dX", dX, nd, n, 100000);

    # The DEFINING property: (R_m q)·(R_n k) depends only on the offset n-m. Rotate
    # the same (q,k) at positions (2,5) and at (5,8) — both offset 3 — and the dot
    # products must agree (to rounding). A direct pin on RoPE's relative-position
    # semantics, independent of the gradient.
    var hd = 8;
    var q = t_alloc(hd); var k = t_alloc(hd);
    t_randn(q, hd, f64_from(1)); t_randn(k, hd, f64_from(1));
    var qa = t_alloc(hd); var ka = t_alloc(hd); var qb = t_alloc(hd); var kb = t_alloc(hd);
    t_copy(qa, q, hd); rope_apply_fwd(qa, 1, 2, hd, 1);
    t_copy(ka, k, hd); rope_apply_fwd(ka, 1, 5, hd, 1);
    t_copy(qb, q, hd); rope_apply_fwd(qb, 1, 5, hd, 1);
    t_copy(kb, k, hd); rope_apply_fwd(kb, 1, 8, hd, 1);
    var s1 = dotsum(qa, ka, hd);
    var s2 = dotsum(qb, kb, hd);
    var diff = f64_abs(f64_sub(s1, s2));
    var mag = f64_add(f64_add(f64_abs(s1), f64_abs(s2)), f64_from(1));
    var tol = f64_div(f64_from(1), f64_from(1000000000));   # 1e-9
    print("rope rel-pos |s1-s2|=", 21); f_print(diff, 12); _putc(10);
    assert(f64_lt(diff, f64_mul(tol, mag)) == 1, "rope relative-position invariance (m-n only)");
    return 0;
}

# Full-model grad check with coupled RoPE (pos_kind=1, mha + even head dim):
# exercises the rotation backward composed into dWq/dWk/dx through the residual
# stack, the now-REAL K-bias gradient (rotated bias is not shift-invariant), and
# pins that the learned posemb is OFF the RoPE path (exactly zero gradient).
fn test_model_rope(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 2;   # hd = C/nh = 4 (even)
    model_init_arch(V, C, T, nh, nh, NL, 1, f64_from(0), 7, 0, 0, 1, 0);   # mha + rope, biases on
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var n_tok = V * C;
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);
    var aWk1 = t_alloc(Cc); t_copy(aWk1, GL(1, _o_Wk()), Cc);
    var abk0 = t_alloc(C); t_copy(abk0, G_bk(0), C);     # K bias: a REAL gradient under RoPE
    var aWo0 = t_alloc(Cc); t_copy(aWo0, GL(0, _o_Wo()), Cc);
    var aTok = t_alloc(n_tok); t_copy(aTok, G_tokemb(), n_tok);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    var nWk1 = t_alloc(Cc); model_ng(PL(1, _o_Wk()), nWk1, Cc);
    var nbk0 = t_alloc(C); model_ng(P_bk(0), nbk0, C);
    var nWo0 = t_alloc(Cc); model_ng(PL(0, _o_Wo()), nWo0, Cc);
    var nTok = t_alloc(n_tok); model_ng(P_tokemb(), nTok, n_tok);
    # Full-model FD is a composition/wiring check, not the tight gate (that is
    # test_attention_rope at 1e-4 / test_rope_op bit-exact). Here the rotation's
    # sin/cos Maclaurin+pow chain stacks on the f64_exp softmax path, so the FD
    # reference is noisier — especially dbk, a small-magnitude gradient where the
    # rotated K-bias barely moves the loss (x86 ~7e-5, aarch64 ~2.6e-4). Use the
    # 1e-3 bound test_model_mla uses for the same reason; a real wiring bug is
    # orders of magnitude larger.
    check("rope model L0 dWq", aWq0, nWq0, Cc, 1000);
    check("rope model L1 dWk", aWk1, nWk1, Cc, 1000);
    check("rope model L0 dbk", abk0, nbk0, C, 1000);
    check("rope model L0 dWo", aWo0, nWo0, Cc, 1000);
    check("rope model dtokemb", aTok, nTok, n_tok, 1000);
    # posemb is OFF the RoPE path -> exactly zero gradient (bit-for-bit).
    var mxpos = f64_from(0);
    var pi = 0;
    while (pi < T * C) {
        var av = f64_abs(load64(G_posemb() + pi * 8));
        if (f64_gt(av, mxpos) == 1) { mxpos = av; }
        pi = pi + 1;
    }
    assert(mxpos == f64_from(0), "rope: posemb receives exactly zero gradient (off-path)");
    return 0;
}

# Per-op grad check for MLA (ADR 0007), isolating attn_mla_fwd/bwd from
# full-model FD noise. Shallow composition -> the score-path gradients (dWq,
# dW_UK) stay tight (1e-5 x86 / 1e-4 aarch64), unlike the 2-layer full-model FD.
# c is recomputed inside the forward (output, not input), so the FD recompute is
# self-contained. buk (the up-K bias) is the same softmax-shift-invariant no-op
# as MHA's bk (a constant K bias shifts every score row equally), so its true
# gradient is identically zero — pinned by |dbuk| ~ 0, not by maxrel. buv (the
# up-V bias) IS real (it shifts concat by buv since P rows sum to 1).
fn attn_mla_loss(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c): i64 {
    attn_mla_fwd(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, ar, c, T, C, nh, d_c);
    return dotsum(dout, out, T * C);
}
fn attn_mla_ng(p, np, n, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = attn_mla_loss(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
        store64(p + i * 8, f64_sub(o, eps)); var lm = attn_mla_loss(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
fn _attn_mla_check(T, C, nh, d_c): i64 {
    var CC = C * C; var TC = T * C; var Cd = C * d_c; var dC = d_c * C; var Td = T * d_c;
    var Wq = t_alloc(CC); var Wdkv = t_alloc(Cd); var Wuk = t_alloc(dC); var Wuv = t_alloc(dC); var Wo = t_alloc(CC);
    var bq = t_alloc(C); var buk = t_alloc(C); var buv = t_alloc(C); var bo = t_alloc(C);
    var x = t_alloc(TC); var out = t_alloc(TC); var dout = t_alloc(TC); var c = t_alloc(Td);
    var std = f64_div(f64_from(1), f64_from(2));
    t_randn(Wq, CC, std); t_randn(Wdkv, Cd, std); t_randn(Wuk, dC, std); t_randn(Wuv, dC, std); t_randn(Wo, CC, std);
    t_randn(bq, C, std); t_randn(buk, C, std); t_randn(buv, C, std); t_randn(bo, C, std);
    t_randn(x, TC, f64_from(1)); t_randn(dout, TC, f64_from(1));
    var ar = t_alloc(attn_arena_size(T, C, nh, nh));
    var dx = t_alloc(TC); var dlat1 = t_alloc(Td); var dlat2 = t_alloc(Td);
    var dWq = t_alloc(CC); var dWdkv = t_alloc(Cd); var dWuk = t_alloc(dC); var dWuv = t_alloc(dC); var dWo = t_alloc(CC);
    var dbq = t_alloc(C); var dbuk = t_alloc(C); var dbuv = t_alloc(C); var dbo = t_alloc(C);
    attn_mla_fwd(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, ar, c, T, C, nh, d_c);
    attn_mla_bwd(Wq, Wdkv, Wuk, Wuv, Wo, x, dout, dx, dWq, dbq, dWdkv, dWuk, dbuk, dWuv, dbuv, dWo, dbo, ar, c, dlat1, dlat2, T, C, nh, d_c);
    var nWq = t_alloc(CC); attn_mla_ng(Wq, nWq, CC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nWdkv = t_alloc(Cd); attn_mla_ng(Wdkv, nWdkv, Cd, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nWuk = t_alloc(dC); attn_mla_ng(Wuk, nWuk, dC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nWuv = t_alloc(dC); attn_mla_ng(Wuv, nWuv, dC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nWo = t_alloc(CC); attn_mla_ng(Wo, nWo, CC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var ndx = t_alloc(TC); attn_mla_ng(x, ndx, TC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nbq = t_alloc(C); attn_mla_ng(bq, nbq, C, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nbuv = t_alloc(C); attn_mla_ng(buv, nbuv, C, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    var nbo = t_alloc(C); attn_mla_ng(bo, nbo, C, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wo, bo, x, out, dout, ar, c, T, C, nh, d_c);
    # 1e-4 (vs the 1e-5 MHA uses on x86): MLA's K path is one matmul deeper
    # (x -> c -> K), so perturbing W_UK / Wq propagates through an extra linear
    # layer before the softmax score, making the central-difference reference
    # noisier on that path (~2e-5 at d_c=12). The value/down/output gradients
    # still land ~1e-8, and a real bug is orders of magnitude larger. (This is
    # the same bound MHA loosens to on aarch64 for the f64_exp polyfill.)
    var atol = 10000;
    check("mla attn dx", dx, ndx, TC, atol);
    check("mla attn dWq", dWq, nWq, CC, atol);
    check("mla attn dWdkv", dWdkv, nWdkv, Cd, atol);
    check("mla attn dWuk", dWuk, nWuk, dC, atol);
    check("mla attn dWuv", dWuv, nWuv, dC, atol);
    check("mla attn dWo", dWo, nWo, CC, atol);
    check("mla attn dbq", dbq, nbq, C, atol);
    check("mla attn dbuv", dbuv, nbuv, C, atol);
    check("mla attn dbo", dbo, nbo, C, atol);
    # buk is the softmax-shift-invariant no-op (like MHA bk): true gradient is 0
    var mxbk = f64_from(0); var bi = 0;
    while (bi < C) {
        var av = f64_abs(load64(dbuk + bi * 8));
        if (f64_gt(av, mxbk) == 1) { mxbk = av; }
        bi = bi + 1;
    }
    print("mla attn dbuk |max|=", 20); f_print(mxbk, 12); _putc(10);
    assert(f64_lt(mxbk, f64_div(f64_from(1), f64_from(10000000000))) == 1,
    "mla attn dbuk ~ 0 (softmax shift-invariance)");
    return 0;
}
fn test_attention_mla(): i64 {
    _attn_mla_check(3, 16, 4, 8);    # C=16 nh=4 d_c=8 (d_c < C)
    _attn_mla_check(3, 16, 2, 12);   # d_c=12 (non-square, not dividing C)
    _attn_mla_check(4, 8, 2, 6);     # smaller C, d_c=6 (matches full-model config)
    return 0;
}

# Per-op grad check for MLA + decoupled RoPE (pos_kind=2, M12 increment 5;
# ADR 0007). Isolates attn_mla_dec_fwd/bwd: the two-term score (content Qc·Kc +
# rope Qr·Kr, scale 1/sqrt(hd+d_rope)), the SHARED rope key Kr (dKr accumulates
# across heads), and the W_QR/W_KR rope projections (bias-free). dR = d_rope.
fn attn_mla_dec_loss(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR): i64 {
    attn_mla_dec_fwd(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, ar, c, qr, kr, T, C, nh, d_c, dR);
    return dotsum(dout, out, T * C);
}
fn attn_mla_dec_ng(p, np, n, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = attn_mla_dec_loss(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
        store64(p + i * 8, f64_sub(o, eps)); var lm = attn_mla_dec_loss(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
fn _attn_mla_dec_check(T, C, nh, d_c, dR): i64 {
    var CC = C * C; var TC = T * C; var Cd = C * d_c; var dC = d_c * C; var Td = T * d_c;
    var CR = C * nh * dR; var Ckr = C * dR; var Tqr = T * nh * dR; var Tkr = T * dR;
    var Wq = t_alloc(CC); var Wdkv = t_alloc(Cd); var Wuk = t_alloc(dC); var Wuv = t_alloc(dC);
    var Wqr = t_alloc(CR); var Wkr = t_alloc(Ckr); var Wo = t_alloc(CC);
    var bq = t_alloc(C); var buk = t_alloc(C); var buv = t_alloc(C); var bo = t_alloc(C);
    var x = t_alloc(TC); var out = t_alloc(TC); var dout = t_alloc(TC);
    var c = t_alloc(Td); var qr = t_alloc(Tqr); var kr = t_alloc(Tkr);
    var std = f64_div(f64_from(1), f64_from(2));
    t_randn(Wq, CC, std); t_randn(Wdkv, Cd, std); t_randn(Wuk, dC, std); t_randn(Wuv, dC, std);
    t_randn(Wqr, CR, std); t_randn(Wkr, Ckr, std); t_randn(Wo, CC, std);
    t_randn(bq, C, std); t_randn(buk, C, std); t_randn(buv, C, std); t_randn(bo, C, std);
    t_randn(x, TC, f64_from(1)); t_randn(dout, TC, f64_from(1));
    var ar = t_alloc(attn_arena_size(T, C, nh, nh));
    var dx = t_alloc(TC); var dlat1 = t_alloc(Td); var dlat2 = t_alloc(Td);
    var dqr = t_alloc(Tqr); var dkr = t_alloc(Tkr);
    var dWq = t_alloc(CC); var dWdkv = t_alloc(Cd); var dWuk = t_alloc(dC); var dWuv = t_alloc(dC);
    var dWqr = t_alloc(CR); var dWkr = t_alloc(Ckr); var dWo = t_alloc(CC);
    var dbq = t_alloc(C); var dbuk = t_alloc(C); var dbuv = t_alloc(C); var dbo = t_alloc(C);
    attn_mla_dec_fwd(Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, ar, c, qr, kr, T, C, nh, d_c, dR);
    attn_mla_dec_bwd(Wq, Wdkv, Wuk, Wuv, Wqr, Wkr, Wo, x, dout, dx, dWq, dbq, dWdkv, dWuk, dbuk, dWuv, dbuv, dWqr, dWkr, dWo, dbo, ar, c, qr, kr, dlat1, dlat2, dqr, dkr, T, C, nh, d_c, dR);
    var nWq = t_alloc(CC); attn_mla_dec_ng(Wq, nWq, CC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nWdkv = t_alloc(Cd); attn_mla_dec_ng(Wdkv, nWdkv, Cd, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nWuk = t_alloc(dC); attn_mla_dec_ng(Wuk, nWuk, dC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nWuv = t_alloc(dC); attn_mla_dec_ng(Wuv, nWuv, dC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nWqr = t_alloc(CR); attn_mla_dec_ng(Wqr, nWqr, CR, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nWkr = t_alloc(Ckr); attn_mla_dec_ng(Wkr, nWkr, Ckr, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nWo = t_alloc(CC); attn_mla_dec_ng(Wo, nWo, CC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var ndx = t_alloc(TC); attn_mla_dec_ng(x, ndx, TC, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nbq = t_alloc(C); attn_mla_dec_ng(bq, nbq, C, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nbuv = t_alloc(C); attn_mla_dec_ng(buv, nbuv, C, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var nbo = t_alloc(C); attn_mla_dec_ng(bo, nbo, C, Wq, bq, Wdkv, Wuk, buk, Wuv, buv, Wqr, Wkr, Wo, bo, x, out, dout, ar, c, qr, kr, T, C, nh, d_c, dR);
    var atol = 10000;   # same 1e-4 bound as MLA: the K/rope paths are a matmul deep
    check("mla-dec dx", dx, ndx, TC, atol);
    check("mla-dec dWq", dWq, nWq, CC, atol);
    check("mla-dec dWdkv", dWdkv, nWdkv, Cd, atol);
    check("mla-dec dWuk", dWuk, nWuk, dC, atol);
    check("mla-dec dWuv", dWuv, nWuv, dC, atol);
    check("mla-dec dWqr", dWqr, nWqr, CR, atol);
    check("mla-dec dWkr", dWkr, nWkr, Ckr, atol);
    check("mla-dec dWo", dWo, nWo, CC, atol);
    check("mla-dec dbq", dbq, nbq, C, atol);
    check("mla-dec dbuv", dbuv, nbuv, C, atol);
    check("mla-dec dbo", dbo, nbo, C, atol);
    # buk stays softmax-shift-invariant (the rope term doesn't touch it): true dbuk = 0
    var mxbk = f64_from(0); var bi = 0;
    while (bi < C) {
        var av = f64_abs(load64(dbuk + bi * 8));
        if (f64_gt(av, mxbk) == 1) { mxbk = av; }
        bi = bi + 1;
    }
    print("mla-dec dbuk |max|=", 20); f_print(mxbk, 12); _putc(10);
    assert(f64_lt(mxbk, f64_div(f64_from(1), f64_from(10000000000))) == 1,
    "mla-dec dbuk ~ 0 (softmax shift-invariance)");
    return 0;
}
fn test_attention_mla_dec(): i64 {
    _attn_mla_dec_check(3, 16, 2, 8, 4);    # hd=8, d_c=8, d_rope=4
    _attn_mla_dec_check(4, 8, 2, 6, 2);     # hd=4, d_c=6, d_rope=2 (full-model config)
    _attn_mla_dec_check(3, 16, 4, 12, 4);   # hd=4, nh=4 (per-head rope), d_c=12 non-square
    return 0;
}

# Gated linear-attention core grad-check (M14.0). Isolates lin_core_fwd/bwd: the
# causal retention recurrence (per-head decay γ_h) over post-projection Q/K/V.
# Pure multiply/add (no softmax/exp), so a tight 1e-5 holds on both arches; the
# backward recomputes S forward (dq) + accumulates dS in reverse (dk/dv).
fn lin_loss_c(Q, K, V, out, S, dout, T, C, nh): i64 {
    lin_core_fwd(Q, K, V, out, S, T, C, nh);
    return dotsum(dout, out, T * C);
}
fn lin_ng(p, np, n, Q, K, V, out, S, dout, T, C, nh): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = lin_loss_c(Q, K, V, out, S, dout, T, C, nh);
        store64(p + i * 8, f64_sub(o, eps)); var lm = lin_loss_c(Q, K, V, out, S, dout, T, C, nh);
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
fn _lin_check(T, C, nh): i64 {
    var TC = T * C; var hd = C / nh; var hh = hd * hd;
    var Q = t_alloc(TC); var K = t_alloc(TC); var V = t_alloc(TC);
    var out = t_alloc(TC); var dout = t_alloc(TC);
    var S = t_alloc(hh); var dS = t_alloc(hh);
    t_randn(Q, TC, f64_from(1)); t_randn(K, TC, f64_from(1)); t_randn(V, TC, f64_from(1)); t_randn(dout, TC, f64_from(1));
    var dQ = t_alloc(TC); var dK = t_alloc(TC); var dV = t_alloc(TC);
    lin_core_fwd(Q, K, V, out, S, T, C, nh);
    lin_core_bwd(Q, K, V, dout, dQ, dK, dV, S, dS, T, C, nh);
    var nQ = t_alloc(TC); lin_ng(Q, nQ, TC, Q, K, V, out, S, dout, T, C, nh);
    var nK = t_alloc(TC); lin_ng(K, nK, TC, Q, K, V, out, S, dout, T, C, nh);
    var nV = t_alloc(TC); lin_ng(V, nV, TC, Q, K, V, out, S, dout, T, C, nh);
    check("lin dQ", dQ, nQ, TC, 100000);
    check("lin dK", dK, nK, TC, 100000);
    check("lin dV", dV, nV, TC, 100000);
    return 0;
}
fn test_lin_core(): i64 {
    _lin_check(3, 8, 2);    # hd=4
    _lin_check(4, 12, 2);   # hd=6 (scalar; non-power-of-2 head dim)
    _lin_check(3, 16, 4);   # hd=4, 4 heads — exercises the per-head decay spread
    _lin_check(5, 8, 1);    # hd=8, single head
    return 0;
}

# Selective SSM core grad-check (M14 rung b, 1.4.2). Isolates ssm_fwd/ssm_bwd: the
# data-dependent scan (Δ/B/C all functions of the input), the exp(Δ·A)
# discretization, and the BPTT through the per-channel×state recurrence. A is
# inited mostly-negative (stable exp); 1e-4 (the exp+softplus+scan compose, like
# MLA-dec). Verifies dWdt/dA/dWB/dWC/dD/dWo/dbdt/dbo and the input grad da.
fn ssm_loss(a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N): i64 {
    ssm_fwd(a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, T, C, N);
    return dotsum(dout, out, T * C);
}
fn ssm_ng(p, np, n, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = ssm_loss(a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
        store64(p + i * 8, f64_sub(o, eps)); var lm = ssm_loss(a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
fn _ssm_check(T, C, N): i64 {
    var TC = T * C; var CC = C * C; var CN = C * N; var TN = T * N; var TCN = T * C * N;
    var a = t_alloc(TC); var Wdt = t_alloc(CC); var bdt = t_alloc(C); var A = t_alloc(CN);
    var WB = t_alloc(CN); var WC = t_alloc(CN); var D = t_alloc(C); var Wo = t_alloc(CC); var bo = t_alloc(C);
    var out = t_alloc(TC); var dout = t_alloc(TC);
    var Dlt = t_alloc(TC); var Bm = t_alloc(TN); var Cm = t_alloc(TN); var h = t_alloc(TCN); var y = t_alloc(TC);
    var std = f64_div(f64_from(1), f64_from(2));
    t_randn(a, TC, f64_from(1)); t_randn(Wdt, CC, std); t_randn(bdt, C, std);
    t_randn(A, CN, std); var ai = 0;
    while (ai < CN) { store64(A + ai * 8, f64_sub(load64(A + ai * 8), f64_from(1))); ai = ai + 1; }   # mostly negative
    t_randn(WB, CN, std); t_randn(WC, CN, std); t_randn(D, C, std); t_randn(Wo, CC, std); t_randn(bo, C, std);
    t_randn(dout, TC, f64_from(1));
    var da = t_alloc(TC); var dWdt = t_alloc(CC); var dbdt = t_alloc(C); var dA = t_alloc(CN);
    var dWB = t_alloc(CN); var dWC = t_alloc(CN); var dD = t_alloc(C); var dWo = t_alloc(CC); var dbo = t_alloc(C);
    var dy = t_alloc(TC); var dDlt = t_alloc(TC); var dBm = t_alloc(TN); var dCm = t_alloc(TN);
    var dhc = t_alloc(CN); var sc = t_alloc(TC);
    ssm_fwd(a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, T, C, N);
    ssm_bwd(a, Wdt, A, WB, WC, D, Wo, dout, da, dWdt, dbdt, dA, dWB, dWC, dD, dWo, dbo,
    Dlt, Bm, Cm, h, y, dy, dDlt, dBm, dCm, dhc, sc, T, C, N);
    var nWdt = t_alloc(CC); ssm_ng(Wdt, nWdt, CC, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nA = t_alloc(CN); ssm_ng(A, nA, CN, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nWB = t_alloc(CN); ssm_ng(WB, nWB, CN, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nWC = t_alloc(CN); ssm_ng(WC, nWC, CN, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nD = t_alloc(C); ssm_ng(D, nD, C, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nWo = t_alloc(CC); ssm_ng(Wo, nWo, CC, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nbdt = t_alloc(C); ssm_ng(bdt, nbdt, C, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nbo = t_alloc(C); ssm_ng(bo, nbo, C, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var nda = t_alloc(TC); ssm_ng(a, nda, TC, a, Wdt, bdt, A, WB, WC, D, Wo, bo, out, Dlt, Bm, Cm, h, y, dout, T, C, N);
    var atol = 10000;
    check("ssm dWdt", dWdt, nWdt, CC, atol);
    check("ssm dA", dA, nA, CN, atol);
    check("ssm dWB", dWB, nWB, CN, atol);
    check("ssm dWC", dWC, nWC, CN, atol);
    check("ssm dD", dD, nD, C, atol);
    check("ssm dWo", dWo, nWo, CC, atol);
    check("ssm dbdt", dbdt, nbdt, C, atol);
    check("ssm dbo", dbo, nbo, C, atol);
    check("ssm da", da, nda, TC, atol);
    return 0;
}
fn test_ssm_core(): i64 {
    _ssm_check(3, 8, 4);    # C=8, N=4
    _ssm_check(4, 6, 2);    # C=6, N=2 (small state)
    _ssm_check(3, 16, 4);   # C=16, N=4
    return 0;
}

# dropout: verify dropout_bwd matches finite differences of dropout_apply with a
# FIXED mask (the mask is generated once and held constant, so forward is
# deterministic).
fn drop_loss(x, mask, y, dy, n): i64 { dropout_apply(x, mask, y, n); return dotsum(dy, y, n); }
fn test_dropout(): i64 {
    var n = 16;
    var x = t_alloc(n); var mask = t_alloc(n); var y = t_alloc(n); var dy = t_alloc(n);
    t_randn(x, n, f64_from(1)); t_randn(dy, n, f64_from(1));
    dropout_gen_mask(mask, n, f64_div(f64_from(1), f64_from(2)), 1);   # p=0.5, training
    var dx = t_alloc(n);
    dropout_apply(x, mask, y, n);
    dropout_bwd(mask, dy, dx, n);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var ndx = t_alloc(n); var i = 0;
    while (i < n) {
        var o = load64(x + i * 8);
        store64(x + i * 8, f64_add(o, eps)); var lp = drop_loss(x, mask, y, dy, n);
        store64(x + i * 8, f64_sub(o, eps)); var lm = drop_loss(x, mask, y, dy, n);
        store64(x + i * 8, o); store64(ndx + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("dropout dx", dx, ndx, n, 100000);
    return 0;
}

# ---------------------------------------------------------------------------
# Mixture of Experts op grad-check (M13.0). Isolates moe_fwd/moe_bwd: the router
# gate (C->N), the frozen top-K pick, the K-way renormalized softmax combine,
# and the per-expert MLP backward scaled by the gate weight. Inputs are chosen
# with a comfortable top-K margin so the central-difference perturbation never
# flips the discrete selection (the combine is smooth only with the pick fixed).
fn moe_loss(x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K): i64 {
    moe_fwd(x, Wg, We, y, logits, sel, gate, efc, egg, sc, T, C, F, N, K);
    return dotsum(dout, y, T * C);
}
fn moe_ng(p, np, n, x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = moe_loss(x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K);
        store64(p + i * 8, f64_sub(o, eps)); var lm = moe_loss(x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K);
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
fn _moe_check(T, C, F, N, K): i64 {
    var TC = T * C; var CN = C * N; var TN = T * N; var TK = T * K; var TKF = T * K * F;
    var estride = _moe_estride(C, F); var WE = N * estride;
    var x = t_alloc(TC); var Wg = t_alloc(CN); var We = t_alloc(WE);
    var y = t_alloc(TC); var dout = t_alloc(TC);
    var logits = t_alloc(TN); var sel = t_alloc(TK); var gate = t_alloc(TK);
    var efc = t_alloc(TKF); var egg = t_alloc(TKF);
    var sc = t_alloc(2 * F + 2 * C + K + N);
    var std = f64_div(f64_from(1), f64_from(2));
    t_randn(x, TC, f64_from(1)); t_randn(Wg, CN, std); t_randn(We, WE, std); t_randn(dout, TC, f64_from(1));
    var dx = t_alloc(TC); var dWg = t_alloc(CN); var dWe = t_alloc(WE);
    moe_fwd(x, Wg, We, y, logits, sel, gate, efc, egg, sc, T, C, F, N, K);
    moe_bwd(x, Wg, We, dout, dx, dWg, dWe, sel, gate, efc, egg, sc, T, C, F, N, K);
    var nx = t_alloc(TC); moe_ng(x, nx, TC, x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K);
    var nWg = t_alloc(CN); moe_ng(Wg, nWg, CN, x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K);
    var nWe = t_alloc(WE); moe_ng(We, nWe, WE, x, Wg, We, y, logits, sel, gate, efc, egg, sc, dout, T, C, F, N, K);
    # 1e-4: the combine composes the router softmax with each expert's two
    # matmuls + GELU, so the central-difference reference is noisier than a lone
    # linear (1e-5); a real backward bug is orders of magnitude larger.
    var atol = 10000;
    check("moe dx", dx, nx, TC, atol);
    check("moe dWg", dWg, nWg, CN, atol);
    check("moe dWe", dWe, nWe, WE, atol);
    return 0;
}
fn test_moe_op(): i64 {
    _moe_check(3, 8, 32, 4, 2);    # C=8 F=4C N=4 experts, top-2 (typical)
    _moe_check(4, 6, 24, 8, 2);    # N=8 experts, top-2
    _moe_check(3, 8, 32, 4, 1);    # top-1: renorm gate ≡ 1, combine gives zero router grad
    _moe_check(2, 4, 16, 3, 3);    # K = N: every expert selected (full softmax combine)
    return 0;
}

# Load-balance aux loss grad-check (M13.1): verify ∂L_aux/∂logits (moe_aux_dr)
# against finite differences of L_aux (moe_aux_fwd). The dispatch counts f_i are
# held fixed (sel is a constant input, not recomputed), so FD only moves the
# smooth P_i term — exactly the straight-through treatment the analytic encodes.
fn _moe_aux_check(T, N, K): i64 {
    var TN = T * N;
    var logits = t_alloc(TN); var sel = t_alloc(T * K); var sc = t_alloc(3 * N);
    t_randn(logits, TN, f64_from(1));
    # fixed distinct routing per row (K < N): experts (t, t+1, ..., t+K-1) mod N
    var t = 0;
    while (t < T) { var k = 0; while (k < K) { store64(sel + (t * K + k) * 8, (t + k) % N); k = k + 1; } t = t + 1; }
    var alpha = _lrc(1, 100);                 # α = 0.01 (the Switch default)
    var dlogits = t_alloc(TN);                # zeroed; moe_aux_dr accumulates into it
    moe_aux_dr(logits, sel, alpha, dlogits, sc, T, N, K);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var nd = t_alloc(TN); var i = 0;
    while (i < TN) {
        var o = load64(logits + i * 8);
        store64(logits + i * 8, f64_add(o, eps)); var lp = moe_aux_fwd(logits, sel, alpha, sc, T, N, K);
        store64(logits + i * 8, f64_sub(o, eps)); var lm = moe_aux_fwd(logits, sel, alpha, sc, T, N, K);
        store64(logits + i * 8, o); store64(nd + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("moe aux dlogits", dlogits, nd, TN, 100000);   # 1e-5: a lone softmax
    return 0;
}
# Configs with NON-uniform dispatch (N ∤ T·K): a balanced f_i makes f_j − Σf_i·p_i
# collapse to 0 (L_aux constant in logits), which is correct but a degenerate,
# FD-noise-dominated grad-check — these keep the aux gradient well-conditioned.
fn test_moe_aux(): i64 {
    _moe_aux_check(3, 4, 2);   # f = [1,2,2,1]/3 — skewed
    _moe_aux_check(3, 8, 2);   # most experts unrouted
    _moe_aux_check(5, 6, 3);
    return 0;
}

fn model_ng(p, np, n): i64 {
    var eps = _eps(); var te = f64_mul(f64_from(2), eps); var i = 0;
    while (i < n) {
        var o = load64(p + i * 8);
        store64(p + i * 8, f64_add(o, eps)); var lp = model_forward();
        store64(p + i * 8, f64_sub(o, eps)); var lm = model_forward();
        store64(p + i * 8, o); store64(np + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    return 0;
}
# grad-check a deep model (n_layers=2): verify weights in BOTH blocks plus the
# shared embeddings/head, so the per-layer offset math and residual-stream
# backward wiring are all exercised.
fn test_model(): i64 {
    var V = 5; var C = 4; var T = 3; var nh = 2; var NL = 2;
    # attention biases ON, dropout OFF (FD needs a deterministic forward)
    model_init(V, C, T, nh, nh, NL, 1, f64_from(0), 1);
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var n_tok = V * C;
    # full-model finite differences are noisier; tol = 1e-4
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);   # block 0 attention
    var aWp1 = t_alloc(C * g_F); t_copy(aWp1, GL(1, _o_Wproj()), C * g_F);  # block 1 MLP proj
    var abo0 = t_alloc(C); t_copy(abo0, G_bo(0), C);            # block 0 attn output bias
    var aTok = t_alloc(n_tok); t_copy(aTok, G_tokemb(), n_tok);
    var aPos = t_alloc(T * C); t_copy(aPos, G_posemb(), T * C);
    var aLnf = t_alloc(C); t_copy(aLnf, G_lnfg(), C);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    var nWp1 = t_alloc(C * g_F); model_ng(PL(1, _o_Wproj()), nWp1, C * g_F);
    var nbo0 = t_alloc(C); model_ng(P_bo(0), nbo0, C);
    var nTok = t_alloc(n_tok); model_ng(P_tokemb(), nTok, n_tok);
    var nPos = t_alloc(T * C); model_ng(P_posemb(), nPos, T * C);
    var nLnf = t_alloc(C); model_ng(P_lnfg(), nLnf, C);
    check("model L0 dWq", aWq0, nWq0, Cc, 10000);
    check("model L1 dWproj", aWp1, nWp1, C * g_F, 10000);
    check("model L0 dbo", abo0, nbo0, C, 10000);
    check("model dtokemb", aTok, nTok, n_tok, 10000);
    check("model dposemb", aPos, nPos, T * C, 10000);
    check("model dlnf_g", aLnf, nLnf, C, 10000);
    return 0;
}

# Full-model grad check with GQA (nkv < nh): exercises the Ckv-dependent
# per-layer offset math (Wv/Wo/ln2/bias offsets all shift) and the grouped
# dK/dV accumulation through the whole residual stack.
fn test_model_gqa(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 4; var nkv = 2; var NL = 2;
    model_init(V, C, T, nh, nkv, NL, 1, f64_from(0), 11);
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Ckv = _Ckv(); var CK = C * Ckv; var Cc = C * C;
    var aWk0 = t_alloc(CK); t_copy(aWk0, GL(0, _o_Wk()), CK);
    var aWv1 = t_alloc(CK); t_copy(aWv1, GL(1, _o_Wv()), CK);
    var abv0 = t_alloc(Ckv); t_copy(abv0, G_bv(0), Ckv);
    var aWo1 = t_alloc(Cc); t_copy(aWo1, GL(1, _o_Wo()), Cc);
    var nWk0 = t_alloc(CK); model_ng(PL(0, _o_Wk()), nWk0, CK);
    var nWv1 = t_alloc(CK); model_ng(PL(1, _o_Wv()), nWv1, CK);
    var nbv0 = t_alloc(Ckv); model_ng(P_bv(0), nbv0, Ckv);
    var nWo1 = t_alloc(Cc); model_ng(PL(1, _o_Wo()), nWo1, Cc);
    check("gqa model L0 dWk", aWk0, nWk0, CK, 10000);
    check("gqa model L1 dWv", aWv1, nWv1, CK, 10000);
    check("gqa model L0 dbv", abv0, nbv0, Ckv, 10000);
    check("gqa model L1 dWo", aWo1, nWo1, Cc, 10000);
    return 0;
}

# Full-model grad check with MLA (attn_kind=1, ADR 0007): exercises the latent
# down-projection (W_DKV), the two up-projections (W_UK/W_UV) and their biases,
# the dc accumulation (dc = dc_from_K + dc_from_V), and dx = dx_q + dx_c — all
# through the residual stack. d_c (6) != C (8), so the down/up matrices are
# non-square. The new gradient composes from linear_bwd + the shared core, so a
# passing FD check confirms the whole MLA path end to end.
fn test_model_mla(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 4; var NL = 2; var dc = 6;
    model_init_arch(V, C, T, nh, nh, NL, 1, f64_from(0), 11, 1, dc, 0, 0);   # MLA, full heads, biases on
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var Cd = C * dc; var dC = dc * C;
    var aWdkv0 = t_alloc(Cd); t_copy(aWdkv0, GL(0, _o_Wdkv()), Cd);
    var aWuk1 = t_alloc(dC); t_copy(aWuk1, GL(1, _o_Wuk()), dC);
    var aWuv0 = t_alloc(dC); t_copy(aWuv0, GL(0, _o_Wuv()), dC);
    var abk0 = t_alloc(C); t_copy(abk0, G_bk(0), C);     # up-K bias (Ckv == C for MLA)
    var aWo1 = t_alloc(Cc); t_copy(aWo1, GL(1, _o_Wo()), Cc);
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);
    var nWdkv0 = t_alloc(Cd); model_ng(PL(0, _o_Wdkv()), nWdkv0, Cd);
    var nWuk1 = t_alloc(dC); model_ng(PL(1, _o_Wuk()), nWuk1, dC);
    var nWuv0 = t_alloc(dC); model_ng(PL(0, _o_Wuv()), nWuv0, dC);
    var nbk0 = t_alloc(C); model_ng(P_bk(0), nbk0, C);
    var nWo1 = t_alloc(Cc); model_ng(PL(1, _o_Wo()), nWo1, Cc);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    # tol 1e-3 here (vs 1e-4 for MHA/GQA): full-model central differences through
    # the 2-layer MLA composition are noisier on the softmax score path (dQ/dK ->
    # dWq/dW_UK go through the extra down-projection x->c->K). The tight gradient
    # proof is the per-op test_attention_mla (1e-5); this is a composition/wiring
    # sanity check. The value/down/output gradients still land ~1e-7.
    check("mla model L0 dWdkv", aWdkv0, nWdkv0, Cd, 1000);
    check("mla model L1 dWuk", aWuk1, nWuk1, dC, 1000);
    check("mla model L0 dWuv", aWuv0, nWuv0, dC, 1000);
    check("mla model L0 dbk", abk0, nbk0, C, 1000);
    check("mla model L1 dWo", aWo1, nWo1, Cc, 1000);
    check("mla model L0 dWq", aWq0, nWq0, Cc, 1000);
    return 0;
}

# Full-model grad check with MLA + decoupled RoPE (pos_kind=2, M12 incr 5): the
# decoupled rope projections (W_QR per-head, W_KR shared) compose through the
# residual stack with the latent path. dWqr/dWkr are the new gradients; the
# tight proof is the per-op test_attention_mla_dec (1e-4) — this is the
# composition/wiring check (1e-3, like test_model_mla).
fn test_model_mla_dec(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 2; var dc = 6; var dR = 2;
    model_init_arch(V, C, T, nh, nh, NL, 1, f64_from(0), 13, 1, dc, 2, dR);   # MLA + decoupled rope
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var Cd = C * dc; var dC = dc * C; var CR = C * nh * dR; var Ckr = C * dR;
    var aWqr0 = t_alloc(CR); t_copy(aWqr0, GL(0, _o_Wqr()), CR);
    var aWkr1 = t_alloc(Ckr); t_copy(aWkr1, GL(1, _o_Wkr()), Ckr);
    var aWdkv0 = t_alloc(Cd); t_copy(aWdkv0, GL(0, _o_Wdkv()), Cd);
    var aWuk1 = t_alloc(dC); t_copy(aWuk1, GL(1, _o_Wuk()), dC);
    var aWo0 = t_alloc(Cc); t_copy(aWo0, GL(0, _o_Wo()), Cc);
    var aWq1 = t_alloc(Cc); t_copy(aWq1, GL(1, _o_Wq()), Cc);
    var nWqr0 = t_alloc(CR); model_ng(PL(0, _o_Wqr()), nWqr0, CR);
    var nWkr1 = t_alloc(Ckr); model_ng(PL(1, _o_Wkr()), nWkr1, Ckr);
    var nWdkv0 = t_alloc(Cd); model_ng(PL(0, _o_Wdkv()), nWdkv0, Cd);
    var nWuk1 = t_alloc(dC); model_ng(PL(1, _o_Wuk()), nWuk1, dC);
    var nWo0 = t_alloc(Cc); model_ng(PL(0, _o_Wo()), nWo0, Cc);
    var nWq1 = t_alloc(Cc); model_ng(PL(1, _o_Wq()), nWq1, Cc);
    check("mla-dec model L0 dWqr", aWqr0, nWqr0, CR, 1000);
    check("mla-dec model L1 dWkr", aWkr1, nWkr1, Ckr, 1000);
    check("mla-dec model L0 dWdkv", aWdkv0, nWdkv0, Cd, 1000);
    check("mla-dec model L1 dWuk", aWuk1, nWuk1, dC, 1000);
    check("mla-dec model L0 dWo", aWo0, nWo0, Cc, 1000);
    check("mla-dec model L1 dWq", aWq1, nWq1, Cc, 1000);
    return 0;
}

# Full-model grad-check with MoE (M13.2): the dense MLP is replaced by N experts
# + a top-K router, and the total loss is CE + Σ_blocks load-balance aux. This
# composition check verifies the wiring of three things at once: (a) the expert
# weight grads (dWe — no aux term, pure combine/CE path), (b) the gate grad
# (dWgate — combine AND aux contribute), (c) upstream grads (dWq, dtokemb — the
# aux gradient flows back through the router into them). The tight per-op proofs
# are test_moe_op (combine, 1e-4) and test_moe_aux (aux, 1e-5); this is 1e-3, like
# the other full-model checks (softmax-chain + composition FD noise). The init
# router logits are tiny and near-uniform, but perturbing ONE weight by eps moves
# them ~1e4× less than the top-K margin, so the discrete selection stays fixed.
fn test_model_moe(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 2; var NE = 4; var TK = 2;
    var F = 4 * C;
    model_init_moe(V, C, T, nh, nh, NL, 1, f64_from(0), 17, 0, 0, 0, 0, NE, TK);   # MHA + 4 experts, top-2
    assert(g_num_experts == NE, "moe model built");
    assert(g_expert_topk == TK, "moe topk installed");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var CF = C * F; var FC = F * C; var CN = C * NE;
    # expert 0's Wfc (no aux term), expert 1's Wproj, the router gate, an upstream
    # attn weight, and the tied embedding — covers combine, aux, and upstream flow.
    var aWfc0 = t_alloc(CF); t_copy(aWfc0, GL(0, _o_expert(0)), CF);
    var aWproj1 = t_alloc(FC); t_copy(aWproj1, GL(1, _o_expert(1) + C * F + F), FC);
    var aWg0 = t_alloc(CN); t_copy(aWg0, GL(0, _o_Wgate()), CN);
    var aWq1 = t_alloc(Cc); t_copy(aWq1, GL(1, _o_Wq()), Cc);
    var atok = t_alloc(V * C); t_copy(atok, G_tokemb(), V * C);
    var nWfc0 = t_alloc(CF); model_ng(PL(0, _o_expert(0)), nWfc0, CF);
    var nWproj1 = t_alloc(FC); model_ng(PL(1, _o_expert(1) + C * F + F), nWproj1, FC);
    var nWg0 = t_alloc(CN); model_ng(PL(0, _o_Wgate()), nWg0, CN);
    var nWq1 = t_alloc(Cc); model_ng(PL(1, _o_Wq()), nWq1, Cc);
    var ntok = t_alloc(V * C); model_ng(P_tokemb(), ntok, V * C);
    check("moe model L0 dWfc(e0)", aWfc0, nWfc0, CF, 1000);
    check("moe model L1 dWproj(e1)", aWproj1, nWproj1, FC, 1000);
    check("moe model L0 dWgate", aWg0, nWg0, CN, 1000);
    check("moe model L1 dWq", aWq1, nWq1, Cc, 1000);
    check("moe model dtokemb", atok, ntok, V * C, 1000);
    return 0;
}

# Full-model grad-check with the gated linear-attention mixer (M14.1, attn_kind=2):
# the softmax core is replaced by the retention recurrence, reusing the Q/K/V/O
# projections. Verifies the wiring through the residual stack. Unlike softmax
# attention, the K-bias is a REAL gradient here (no shift-invariance — k enters
# the score linearly), so dbk is FD-checked like any other parameter. 1e-3, like
# the other full-model checks; the tight per-op proof is test_lin_core (1e-9).
fn test_model_lin(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 2;
    model_init_arch(V, C, T, nh, nh, NL, 1, f64_from(0), 19, 2, 0, 0, 0);   # gated linear attention
    assert(g_attn_kind == 2, "linear-attention model built");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C;
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);
    var aWk1 = t_alloc(Cc); t_copy(aWk1, GL(1, _o_Wk()), Cc);
    var abk0 = t_alloc(C); t_copy(abk0, G_bk(0), C);
    var aWv0 = t_alloc(Cc); t_copy(aWv0, GL(0, _o_Wv()), Cc);
    var aWo1 = t_alloc(Cc); t_copy(aWo1, GL(1, _o_Wo()), Cc);
    var atok = t_alloc(V * C); t_copy(atok, G_tokemb(), V * C);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    var nWk1 = t_alloc(Cc); model_ng(PL(1, _o_Wk()), nWk1, Cc);
    var nbk0 = t_alloc(C); model_ng(P_bk(0), nbk0, C);
    var nWv0 = t_alloc(Cc); model_ng(PL(0, _o_Wv()), nWv0, Cc);
    var nWo1 = t_alloc(Cc); model_ng(PL(1, _o_Wo()), nWo1, Cc);
    var ntok = t_alloc(V * C); model_ng(P_tokemb(), ntok, V * C);
    check("lin model L0 dWq", aWq0, nWq0, Cc, 1000);
    check("lin model L1 dWk", aWk1, nWk1, Cc, 1000);
    check("lin model L0 dbk", abk0, nbk0, C, 1000);
    check("lin model L0 dWv", aWv0, nWv0, Cc, 1000);
    check("lin model L1 dWo", aWo1, nWo1, Cc, 1000);
    check("lin model dtokemb", atok, ntok, V * C, 1000);
    return 0;
}

# Full-model grad-check with the selective SSM mixer (M14 rung b, attn_kind=3):
# the data-dependent scan composes through the residual stack. The tight per-op
# proof is test_ssm_core (~1e-7); this is the 1e-3 wiring check. W_dt rides the Wq
# slot, the output proj rides Wo; A/W_B/W_C/D are the SSM K/V region; D inits to 1.
fn test_model_ssm(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 2; var N = 4;
    model_init_arch(V, C, T, nh, nh, NL, 1, f64_from(0), 29, 3, N, 0, 0);   # selective SSM
    assert(g_attn_kind == 3, "ssm model built");
    assert(g_latent_dim == N, "ssm state size installed");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var CN = C * N;
    var aWdt0 = t_alloc(Cc); t_copy(aWdt0, GL(0, _o_Wq()), Cc);     # W_dt (Wq slot)
    var aA1 = t_alloc(CN); t_copy(aA1, GL(1, _o_ssmA()), CN);
    var aWB0 = t_alloc(CN); t_copy(aWB0, GL(0, _o_ssmWB()), CN);
    var aWC1 = t_alloc(CN); t_copy(aWC1, GL(1, _o_ssmWC()), CN);
    var aD0 = t_alloc(C); t_copy(aD0, GL(0, _o_ssmD()), C);
    var aWo1 = t_alloc(Cc); t_copy(aWo1, GL(1, _o_Wo()), Cc);
    var atok = t_alloc(V * C); t_copy(atok, G_tokemb(), V * C);
    var nWdt0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWdt0, Cc);
    var nA1 = t_alloc(CN); model_ng(PL(1, _o_ssmA()), nA1, CN);
    var nWB0 = t_alloc(CN); model_ng(PL(0, _o_ssmWB()), nWB0, CN);
    var nWC1 = t_alloc(CN); model_ng(PL(1, _o_ssmWC()), nWC1, CN);
    var nD0 = t_alloc(C); model_ng(PL(0, _o_ssmD()), nD0, C);
    var nWo1 = t_alloc(Cc); model_ng(PL(1, _o_Wo()), nWo1, Cc);
    var ntok = t_alloc(V * C); model_ng(P_tokemb(), ntok, V * C);
    check("ssm model L0 dWdt", aWdt0, nWdt0, Cc, 1000);
    check("ssm model L1 dA", aA1, nA1, CN, 1000);
    check("ssm model L0 dWB", aWB0, nWB0, CN, 1000);
    check("ssm model L1 dWC", aWC1, nWC1, CN, 1000);
    check("ssm model L0 dD", aD0, nD0, C, 1000);
    check("ssm model L1 dWo", aWo1, nWo1, Cc, 1000);
    check("ssm model dtokemb", atok, ntok, V * C, 1000);
    return 0;
}

# Full-model grad-check of a per-layer HYBRID (M14 rung c): layers [mha, lin, mha]
# over the shared {0,2} block layout. The mixed backward — attn_bwd for the MHA
# blocks, attn_lin_bwd for the lin block — must compose through the residual stack
# and the tied head. Grad-checks Wq at an MHA layer, Wk/Wv at the lin layer, Wo at
# the trailing MHA layer, and the shared token embedding. The per-op proofs are
# test_attention_grad / test_lin_core; this pins the per-layer DISPATCH wiring.
fn test_model_hybrid(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 3;
    var kinds[24];   # 3 i64: mha, lin, mha
    store64(&kinds + 0, 0); store64(&kinds + 8, 2); store64(&kinds + 16, 0);
    model_init_full(V, C, T, nh, nh, NL, 1, f64_from(0), 23, 2, 0, 0, 0, 1, 1, &kinds, 0);   # base lin
    assert(g_layer_kind != 0, "hybrid model built");
    assert(_lk(0) == 0, "layer 0 is mha");
    assert(_lk(1) == 2, "layer 1 is lin");
    assert(_lk(2) == 0, "layer 2 is mha");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C;
    var aWq0 = t_alloc(Cc); t_copy(aWq0, GL(0, _o_Wq()), Cc);     # MHA layer
    var aWk1 = t_alloc(Cc); t_copy(aWk1, GL(1, _o_Wk()), Cc);     # lin layer
    var aWv1 = t_alloc(Cc); t_copy(aWv1, GL(1, _o_Wv()), Cc);     # lin layer
    var aWo2 = t_alloc(Cc); t_copy(aWo2, GL(2, _o_Wo()), Cc);     # trailing MHA layer
    var atok = t_alloc(V * C); t_copy(atok, G_tokemb(), V * C);
    var nWq0 = t_alloc(Cc); model_ng(PL(0, _o_Wq()), nWq0, Cc);
    var nWk1 = t_alloc(Cc); model_ng(PL(1, _o_Wk()), nWk1, Cc);
    var nWv1 = t_alloc(Cc); model_ng(PL(1, _o_Wv()), nWv1, Cc);
    var nWo2 = t_alloc(Cc); model_ng(PL(2, _o_Wo()), nWo2, Cc);
    var ntok = t_alloc(V * C); model_ng(P_tokemb(), ntok, V * C);
    check("hybrid model L0(mha) dWq", aWq0, nWq0, Cc, 1000);
    check("hybrid model L1(lin) dWk", aWk1, nWk1, Cc, 1000);
    check("hybrid model L1(lin) dWv", aWv1, nWv1, Cc, 1000);
    check("hybrid model L2(mha) dWo", aWo2, nWo2, Cc, 1000);
    check("hybrid model dtokemb", atok, ntok, V * C, 1000);
    return 0;
}

# M14 rung d: a HYBRID with a DIFFERENT-LAYOUT mixer (SSM) interleaved with MHA.
# The block K/V region pads to the max _kvw; layer 1's MHA Wk/Wv tile the padded
# region, layers 0/2's SSM A/W_B/W_C/D tile their (smaller) part with a zeroed pad.
# The MIXED backward — ssm_bwd for the SSM blocks, attn_bwd for the MHA block —
# must compose. Grad-checks SSM params at an SSM layer, MHA Wk at the MHA layer,
# Wo (after the padded region) at an SSM layer, and the tied embedding. Base ssm.
fn test_model_hybrid_ssm(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 3; var N = 4;
    var kinds[24]; store64(&kinds + 0, 3); store64(&kinds + 8, 0); store64(&kinds + 16, 3);   # ssm, mha, ssm
    model_init_full(V, C, T, nh, nh, NL, 1, f64_from(0), 31, 3, N, 0, 0, 1, 1, &kinds, 0);        # base ssm
    assert(g_layer_kind != 0, "ssm-hybrid model built");
    assert(_lk(0) == 3, "layer 0 ssm"); assert(_lk(1) == 0, "layer 1 mha"); assert(_lk(2) == 3, "layer 2 ssm");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var CN = C * N;
    var aA0 = t_alloc(CN); t_copy(aA0, GL(0, _o_ssmA()), CN);       # SSM layer
    var aWB0 = t_alloc(CN); t_copy(aWB0, GL(0, _o_ssmWB()), CN);
    var aWk1 = t_alloc(Cc); t_copy(aWk1, GL(1, _o_Wk()), Cc);       # MHA layer (padded region)
    var aWo2 = t_alloc(Cc); t_copy(aWo2, GL(2, _o_Wo()), Cc);       # after the padded region
    var atok = t_alloc(V * C); t_copy(atok, G_tokemb(), V * C);
    var nA0 = t_alloc(CN); model_ng(PL(0, _o_ssmA()), nA0, CN);
    var nWB0 = t_alloc(CN); model_ng(PL(0, _o_ssmWB()), nWB0, CN);
    var nWk1 = t_alloc(Cc); model_ng(PL(1, _o_Wk()), nWk1, Cc);
    var nWo2 = t_alloc(Cc); model_ng(PL(2, _o_Wo()), nWo2, Cc);
    var ntok = t_alloc(V * C); model_ng(P_tokemb(), ntok, V * C);
    check("hybrid-ssm L0(ssm) dA", aA0, nA0, CN, 1000);
    check("hybrid-ssm L0(ssm) dWB", aWB0, nWB0, CN, 1000);
    check("hybrid-ssm L1(mha) dWk", aWk1, nWk1, Cc, 1000);
    check("hybrid-ssm L2(ssm) dWo", aWo2, nWo2, Cc, 1000);
    check("hybrid-ssm dtokemb", atok, ntok, V * C, 1000);
    return 0;
}

# M14 rung d: an MLA ⊕ MHA hybrid (base mla). The block region pads to max(_kvw):
# MLA's W_DKV/W_UK/W_UV tile the region, the MHA layer's Wk/Wv tile it. Mixed
# backward (attn_mla_bwd + attn_bwd) composes. Grad-checks MLA Wuk at an MLA layer,
# MHA Wk at the MHA layer, Wo, and the embedding.
fn test_model_hybrid_mla(): i64 {
    var V = 5; var C = 8; var T = 3; var nh = 2; var NL = 3; var dc = 4;
    var kinds[24]; store64(&kinds + 0, 1); store64(&kinds + 8, 0); store64(&kinds + 16, 1);   # mla, mha, mla
    model_init_full(V, C, T, nh, nh, NL, 1, f64_from(0), 37, 1, dc, 0, 0, 1, 1, &kinds, 0);       # base mla
    assert(g_layer_kind != 0, "mla-hybrid model built");
    assert(_lk(1) == 0, "layer 1 mha");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var Cc = C * C; var dcc = dc * C;
    var aWuk0 = t_alloc(dcc); t_copy(aWuk0, GL(0, _o_Wuk()), dcc);   # MLA layer
    var aWk1 = t_alloc(Cc); t_copy(aWk1, GL(1, _o_Wk()), Cc);        # MHA layer
    var aWo2 = t_alloc(Cc); t_copy(aWo2, GL(2, _o_Wo()), Cc);
    var atok = t_alloc(V * C); t_copy(atok, G_tokemb(), V * C);
    var nWuk0 = t_alloc(dcc); model_ng(PL(0, _o_Wuk()), nWuk0, dcc);
    var nWk1 = t_alloc(Cc); model_ng(PL(1, _o_Wk()), nWk1, Cc);
    var nWo2 = t_alloc(Cc); model_ng(PL(2, _o_Wo()), nWo2, Cc);
    var ntok = t_alloc(V * C); model_ng(P_tokemb(), ntok, V * C);
    check("hybrid-mla L0(mla) dWuk", aWuk0, nWuk0, dcc, 1000);
    check("hybrid-mla L1(mha) dWk", aWk1, nWk1, Cc, 1000);
    check("hybrid-mla L2(mla) dWo", aWo2, nWo2, Cc, 1000);
    check("hybrid-mla dtokemb", atok, ntok, V * C, 1000);
    return 0;
}

# The M9 SIMD LM head (head_fwd_row) has a scalar tail for C % 4 != 0 that NO
# other test exercises — every config above uses C ∈ {8,16}. C=6 (% 4 = 2)
# hits it. Compare the vectorized head output to an independent scalar dot
# product: a dropped/short tail would diverge by a whole term, far past tol.
fn test_head_tail(): i64 {
    var V = 5; var C = 6; var T = 4; var nh = 2; var nkv = 2; var NL = 1;
    model_init(V, C, T, nh, nkv, NL, 1, f64_from(0), 7);
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3);
    store64(A_tokens + 16, 0); store64(A_tokens + 24, 2);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0);
    store64(A_targets + 16, 4); store64(A_targets + 24, 1);
    model_forward();                                   # fills A_f + A_logits (SIMD head)
    var emb = P_tokemb();
    var ref = t_alloc(T * V);
    var t = 0;
    while (t < T) {
        var v = 0;
        while (v < V) {
            var acc = f64_from(0);
            var c = 0;
            while (c < C) {
                acc = f64_add(acc, f64_mul(load64(A_f + (t * C + c) * 8),
                load64(emb + (v * C + c) * 8)));
                c = c + 1;
            }
            store64(ref + (t * V + v) * 8, acc);
            v = v + 1;
        }
        t = t + 1;
    }
    check("head SIMD == scalar dot (C=6 tail)", A_logits, ref, T * V, 100000000);
    return 0;
}

# Resume determinism: train(K) in one go must equal train(K1) -> checkpoint
# round-trip -> train(K). The schedule horizon `total` is held fixed across the
# split so the LR/bias-correction match step-for-step. We compare the final
# parameter vector BIT-FOR-BIT.
fn _lrc(n, d): i64 { return f64_div(f64_from(n), f64_from(d)); }
# train(K) == train(K1) -> checkpoint round-trip -> train(K), bit-for-bit.
# `drop` exercises the path with (drop>0) and without (drop==0) the dropout
# PRNG draws, so the save/load RNG alignment is verified for both.
# `nkv` < nh runs the same pin under GQA (Ckv-wide K/V, grouped accumulation).
fn _resume_check(drop, nkv): i64 {
    var V = build_corpus();                 # embedded corpus -> g_data
    var C = 8; var T = 4; var nh = 2; var NL = 2;
    var base = _lrc(3, 1000); var minl = _lrc(3, 10000); var clip = f64_from(1);
    var K = 24; var K1 = 9; var B = 4; var warm = 5; var quiet = 1000000000;

    # Path A: one continuous run to K (horizon = K)
    model_init(V, C, T, nh, nkv, NL, 0, drop, 7);
    train(K, K, B, base, minl, warm, clip, quiet);
    var npA = g_NP;
    var snapA = t_alloc(npA); t_copy(snapA, g_params, npA);

    # Path B: run to K1, checkpoint round-trip, then continue to K (horizon = K)
    model_init(V, C, T, nh, nkv, NL, 0, drop, 7);
    train(K1, K, B, base, minl, warm, clip, quiet);
    var sz = ckpt_size();
    var buf = alloc(sz);
    ckpt_serialize(buf);
    # scramble model state to a different seed to prove load restores everything
    model_init(V, C, T, nh, nkv, NL, 0, drop, 999);
    var rc = ckpt_load_buf(buf, sz);
    train(K, K, B, base, minl, warm, clip, quiet);

    var mism = 0; var i = 0;
    while (i < g_NP) {
        if (load64(g_params + i * 8) != load64(snapA + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(rc == 0, "ckpt_load_buf returns ok");
    assert(g_NP == npA, "resumed param count matches");
    assert(g_step == K, "resumed step counter reaches K");
    assert(mism == 0, "resume reproduces params bit-for-bit");
    return 0;
}
fn test_resume_determinism(): i64 { return _resume_check(f64_from(0), 2); }
fn test_resume_dropout(): i64 { return _resume_check(_lrc(1, 10), 2); }   # p=0.1
fn test_resume_gqa(): i64 { return _resume_check(f64_from(0), 1); }       # MQA

# File-path round-trip: ckpt_save_file -> ckpt_load_file. The resume checks
# above exercise ckpt_load_buf (in-memory) but NEVER the FILE loader, where the
# M8 _file_size(fd, path) dropped-arg bug lived (strlen on a garbage register ->
# crash on every --load under AGNOS, masked on Linux). This drives the fixed
# call end-to-end; on the AGNOS target a dropped path arg fails here.
fn test_ckpt_file_roundtrip(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 7);
    g_step = 5;
    var npA = g_NP;
    var snapA = t_alloc(npA); t_copy(snapA, g_params, npA);

    var p = "/tmp/attn11-ckpt-rt.ckpt";
    assert(ckpt_save_file(p) == 0, "ckpt_save_file writes ok");
    # scramble model state, then reload from the file to prove it restores
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 999);
    var rc = ckpt_load_file(p);
    assert(rc == 0, "ckpt_load_file reads back ok (exercises _file_size path)");
    assert(g_NP == npA, "file round-trip param count matches");
    assert(g_step == 5, "file round-trip restores step");
    var mism = 0; var i = 0;
    while (i < g_NP) {
        if (load64(g_params + i * 8) != load64(snapA + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "file round-trip reproduces params bit-for-bit");
    _unlink(p);
    return 0;
}

# Hostile-checkpoint smoke: a few corrupt buffers must be rejected, not crash.
fn test_ckpt_reject(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 3);
    var sz = ckpt_size();
    var good = alloc(sz); ckpt_serialize(good);
    assert(ckpt_load_buf(good, sz) == 0, "valid checkpoint loads");
    # truncated
    assert(ckpt_load_buf(good, sz - 8) < 0, "truncated rejected");
    assert(ckpt_load_buf(good, 8) < 0, "tiny rejected");
    # bad magic
    var bad = alloc(sz); t_copy(bad, good, sz / 8); store64(bad, 0);
    assert(ckpt_load_buf(bad, sz) < 0, "bad magic rejected");
    # absurd config (huge C)
    var bad2 = alloc(sz); t_copy(bad2, good, sz / 8); store64(bad2 + 3 * 8, 999999);
    assert(ckpt_load_buf(bad2, sz) < 0, "absurd config rejected");
    # NaN dropout (field 8) — would poison training math
    var bad3 = alloc(sz); t_copy(bad3, good, sz / 8); store64(bad3 + 8 * 8, 0x7FF8000000000000);
    assert(ckpt_load_buf(bad3, sz) < 0, "NaN dropout rejected");
    # dropout == 1.0 (1/(1-p) = +Inf)
    var bad4 = alloc(sz); t_copy(bad4, good, sz / 8); store64(bad4 + 8 * 8, 0x3FF0000000000000);
    assert(ckpt_load_buf(bad4, sz) < 0, "dropout=1.0 rejected");
    return 0;
}

# The FD grad checks are structurally blind to parameter-layout aliasing:
# forward and backward index through the same _o_* helpers, so overlapping
# offsets would perturb and accumulate identically and every check would stay
# green while the model silently trained a different architecture. Pin the
# layout directly: each offset must equal the previous tensor's end, and the
# block must tile exactly — at a GQA config where Ckv != C.
fn _lay(off, sz, expect): i64 {
    assert(off == expect, "layout: offset == previous end");
    return off + sz;
}
fn test_param_layout(): i64 {
    model_init(5, 16, 4, 4, 2, 2, 1, f64_from(0), 3);   # C=16 nh=4 nkv=2 -> Ckv=8
    var C = g_C; var F = g_F; var Ckv = _Ckv();
    var p = 0;
    p = _lay(_o_ln1g(), C, p);
    p = _lay(_o_ln1b(), C, p);
    p = _lay(_o_Wq(), C * C, p);
    p = _lay(_o_Wk(), C * Ckv, p);
    p = _lay(_o_Wv(), C * Ckv, p);
    p = _lay(_o_Wo(), C * C, p);
    p = _lay(_o_ln2g(), C, p);
    p = _lay(_o_ln2b(), C, p);
    p = _lay(_o_Wfc(), C * F, p);
    p = _lay(_o_bfc(), F, p);
    p = _lay(_o_Wproj(), F * C, p);
    p = _lay(_o_bproj(), C, p);
    assert(p == _blk_base_size(), "layout: weights tile _blk_base_size exactly");
    p = _lay(_o_bq(), C, p);
    p = _lay(_o_bk(), Ckv, p);
    p = _lay(_o_bv(), Ckv, p);
    p = _lay(_o_bo(), C, p);
    assert(p == _blk(), "layout: biases tile _blk exactly");
    return 0;
}

# Same layout pin for the MLA block (ADR 0007): Wk/Wv are replaced by the
# down-projection W_DKV(C x d_c) and two up-projections W_UK/W_UV(d_c x C). FD
# grad checks are blind to offset aliasing, so the tiling is pinned directly. d_c
# != C and d_c not dividing C exercises a non-square K/V weight region.
fn test_param_layout_mla(): i64 {
    model_init_arch(5, 16, 4, 4, 4, 2, 1, f64_from(0), 3, 1, 6, 0, 0);   # MLA C=16 nh=nkv=4 d_c=6
    var C = g_C; var F = g_F; var dc = g_latent_dim; var Ckv = _Ckv();
    assert(dc == 6, "mla latent dim installed");
    assert(Ckv == C, "mla uses full K/V heads (Ckv == C)");
    var p = 0;
    p = _lay(_o_ln1g(), C, p);
    p = _lay(_o_ln1b(), C, p);
    p = _lay(_o_Wq(), C * C, p);
    p = _lay(_o_Wdkv(), C * dc, p);
    p = _lay(_o_Wuk(), dc * C, p);
    p = _lay(_o_Wuv(), dc * C, p);
    p = _lay(_o_Wo(), C * C, p);
    p = _lay(_o_ln2g(), C, p);
    p = _lay(_o_ln2b(), C, p);
    p = _lay(_o_Wfc(), C * F, p);
    p = _lay(_o_bfc(), F, p);
    p = _lay(_o_Wproj(), F * C, p);
    p = _lay(_o_bproj(), C, p);
    assert(p == _blk_base_size(), "mla layout: weights tile _blk_base_size exactly");
    p = _lay(_o_bq(), C, p);
    p = _lay(_o_bk(), Ckv, p);
    p = _lay(_o_bv(), Ckv, p);
    p = _lay(_o_bo(), C, p);
    assert(p == _blk(), "mla layout: biases tile _blk exactly");
    return 0;
}

# Layout pin for MLA + decoupled RoPE (pos_kind=2): W_QR(C x nh*d_rope) and
# W_KR(C x d_rope) are inserted after W_UV, before Wo. FD is blind to offset
# aliasing, so pin the tiling directly (d_c != C, d_rope = 4).
fn test_param_layout_mla_dec(): i64 {
    model_init_arch(5, 16, 4, 4, 4, 2, 1, f64_from(0), 3, 1, 6, 2, 4);   # MLA+dec C=16 d_c=6 d_rope=4
    var C = g_C; var F = g_F; var dc = g_latent_dim; var dR = g_rope_dim; var nh = g_nh; var Ckv = _Ckv();
    assert(dR == 4, "decoupled rope dim installed");
    var p = 0;
    p = _lay(_o_ln1g(), C, p);
    p = _lay(_o_ln1b(), C, p);
    p = _lay(_o_Wq(), C * C, p);
    p = _lay(_o_Wdkv(), C * dc, p);
    p = _lay(_o_Wuk(), dc * C, p);
    p = _lay(_o_Wuv(), dc * C, p);
    p = _lay(_o_Wqr(), C * nh * dR, p);
    p = _lay(_o_Wkr(), C * dR, p);
    p = _lay(_o_Wo(), C * C, p);
    p = _lay(_o_ln2g(), C, p);
    p = _lay(_o_ln2b(), C, p);
    p = _lay(_o_Wfc(), C * F, p);
    p = _lay(_o_bfc(), F, p);
    p = _lay(_o_Wproj(), F * C, p);
    p = _lay(_o_bproj(), C, p);
    assert(p == _blk_base_size(), "mla-dec layout: weights tile _blk_base_size exactly");
    p = _lay(_o_bq(), C, p);
    p = _lay(_o_bk(), Ckv, p);
    p = _lay(_o_bv(), Ckv, p);
    p = _lay(_o_bo(), C, p);
    assert(p == _blk(), "mla-dec layout: biases tile _blk exactly");
    return 0;
}

# Layout pin for the MoE block (M13.2): the dense Wfc/bfc/Wproj/bproj become N
# experts (each that quad, array-of-structs) + the router gate Wg(C*N). FD is
# blind to offset aliasing, so pin the tiling directly — and that expert 0
# aliases the dense Wfc offset (so the dense path is byte-identical).
fn test_param_layout_moe(): i64 {
    model_init_moe(5, 16, 4, 4, 4, 2, 1, f64_from(0), 3, 0, 0, 0, 0, 4, 2);   # MHA C=16, 4 experts
    var C = g_C; var F = g_F; var NE = g_num_experts; var Ckv = _Ckv();
    var es = _moe_estride_blk();
    assert(NE == 4, "moe experts installed");
    assert(_o_expert(0) == _o_Wfc(), "expert 0 aliases the dense Wfc offset");
    var p = 0;
    p = _lay(_o_ln1g(), C, p);
    p = _lay(_o_ln1b(), C, p);
    p = _lay(_o_Wq(), C * C, p);
    p = _lay(_o_Wk(), C * Ckv, p);
    p = _lay(_o_Wv(), C * Ckv, p);
    p = _lay(_o_Wo(), C * C, p);
    p = _lay(_o_ln2g(), C, p);
    p = _lay(_o_ln2b(), C, p);
    var ei = 0;
    while (ei < NE) { p = _lay(_o_expert(ei), es, p); ei = ei + 1; }   # each expert: Wfc|bfc|Wproj|bproj
    p = _lay(_o_Wgate(), C * NE, p);
    assert(p == _blk_base_size(), "moe layout: experts + gate tile _blk_base_size exactly");
    p = _lay(_o_bq(), C, p);
    p = _lay(_o_bk(), Ckv, p);
    p = _lay(_o_bv(), Ckv, p);
    p = _lay(_o_bo(), C, p);
    assert(p == _blk(), "moe layout: biases tile _blk exactly");
    return 0;
}

# model_alloc_bytes (the checkpoint loader's pre-allocation bound) must
# mirror model_init's actual allocations — pin the two together. Exact when
# every t_alloc size is 16-byte aligned; allow small per-alloc slack.
fn test_alloc_accounting(): i64 {
    var used0 = alloc_used();
    model_init(5, 16, 8, 4, 2, 2, 1, f64_from(0), 4);
    var delta = alloc_used() - used0;
    var predicted = model_alloc_bytes(5, 16, 8, 4, 2, 2, g_NP);
    assert(delta >= predicted, "model_alloc_bytes never under-predicts model_init");
    assert(delta <= predicted + 8192, "model_alloc_bytes tracks model_init (no forgotten buffers)");
    # second pin at a BPE-scale vocab (V > 256): the V-dependent terms
    # (embeddings, logits/probs rows, R_logits) must stay accounted
    used0 = alloc_used();
    model_init(300, 16, 8, 4, 2, 2, 1, f64_from(0), 4);
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes(300, 16, 8, 4, 2, 2, g_NP);
    assert(delta >= predicted, "alloc accounting holds at V=300 (under)");
    assert(delta <= predicted + 8192, "alloc accounting holds at V=300 (over)");
    # MLA pin: the latent buffers (LA_c + D_lat1/D_lat2) must be accounted too
    used0 = alloc_used();
    model_init_arch(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 1, 6, 0, 0);
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_arch(5, 16, 8, 4, 4, 2, g_NP, 1, 6, 0, 0);
    assert(delta >= predicted, "mla alloc accounting (under)");
    assert(delta <= predicted + 8192, "mla alloc accounting (over)");
    # decoupled-RoPE pin: the rope projections (W_QR/W_KR in np) + the LA_qr/LA_kr
    # caches + D_qr/D_kr temporaries must all be accounted (pos_kind=2, d_rope=4)
    used0 = alloc_used();
    model_init_arch(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 1, 6, 2, 4);
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_arch(5, 16, 8, 4, 4, 2, g_NP, 1, 6, 2, 4);
    assert(delta >= predicted, "mla-dec alloc accounting (under)");
    assert(delta <= predicted + 8192, "mla-dec alloc accounting (over)");
    # MoE pin (M13.2): the per-layer router/expert caches (LA_mlogits/msel/mgate/
    # mefc/megg) + the shared scratch (g_moe_sc/g_moe_dlaux) must be accounted too.
    used0 = alloc_used();
    model_init_moe(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 0, 0, 0, 0, 8, 2);
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_moe(5, 16, 8, 4, 4, 2, g_NP, 0, 0, 0, 0, 8, 2);
    assert(delta >= predicted, "moe alloc accounting (under)");
    assert(delta <= predicted + 8192, "moe alloc accounting (over)");
    # gated-linear pin (M14): the per-layer retention state cache (g_lin_state)
    # + the arena's 2*hd^2 lin scratch must be accounted (attn_kind=2).
    used0 = alloc_used();
    model_init_arch(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 2, 0, 0, 0);
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_arch(5, 16, 8, 4, 4, 2, g_NP, 2, 0, 0, 0);
    assert(delta >= predicted, "lin alloc accounting (under)");
    assert(delta <= predicted + 8192, "lin alloc accounting (over)");
    # selective-SSM pin (1.4.2): the per-layer Δ/B/C/h/y caches + the C*N decode
    # state + the shared reverse-scan scratch must be accounted (attn_kind=3, N=4).
    used0 = alloc_used();
    model_init_arch(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 3, 4, 0, 0);
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_arch(5, 16, 8, 4, 4, 2, g_NP, 3, 4, 0, 0);
    assert(delta >= predicted, "ssm alloc accounting (under)");
    assert(delta <= predicted + 8192, "ssm alloc accounting (over)");
    # per-layer HYBRID pin (M14 rung c): the per-layer g_layer_kind array (pl=NL) +
    # the g_lin_state decode cache (held whenever ANY layer is lin) must be accounted
    # by model_alloc_bytes_hyb. Two bases: lin (lin-state via attn_kind==2) and mha
    # (lin-state via lin_extra=1, since a lin layer rides a non-lin base).
    var hkA[16]; store64(&hkA + 0, 0); store64(&hkA + 8, 2);          # mha,lin
    used0 = alloc_used();
    model_init_full(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 2, 0, 0, 0, 1, 1, &hkA, 0);   # base lin
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_hyb(5, 16, 8, 4, 4, 2, g_NP, 2, 0, 0, 0, 1, 1, &hkA);
    assert(delta >= predicted, "hybrid(base lin) alloc accounting (under)");
    assert(delta <= predicted + 8192, "hybrid(base lin) alloc accounting (over)");
    used0 = alloc_used();
    model_init_full(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 0, 0, 0, 0, 1, 1, &hkA, 0);   # base mha
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_hyb(5, 16, 8, 4, 4, 2, g_NP, 0, 0, 0, 0, 1, 1, &hkA);
    assert(delta >= predicted, "hybrid(base mha) alloc accounting (under)");
    assert(delta <= predicted + 8192, "hybrid(base mha) alloc accounting (over)");
    # mla/ssm hybrid alloc pins (M14 rung d): the padded K/V region + the present
    # kinds' per-layer caches (LA_c for mla, the ssm caches) must be accounted. The
    # base is the latent-owning kind (so the shared d_c/N validates); the per-layer
    # array overrides one block to MHA.
    var hkM[16]; store64(&hkM + 0, 0); store64(&hkM + 8, 1);          # mha,mla
    used0 = alloc_used();
    model_init_full(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 1, 6, 0, 0, 1, 1, &hkM, 0);   # base mla, latent 6
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_hyb(5, 16, 8, 4, 4, 2, g_NP, 1, 6, 0, 0, 1, 1, &hkM);
    assert(delta >= predicted, "hybrid(mha/mla) alloc accounting (under)");
    assert(delta <= predicted + 8192, "hybrid(mha/mla) alloc accounting (over)");
    var hkS[16]; store64(&hkS + 0, 0); store64(&hkS + 8, 3);          # mha,ssm
    used0 = alloc_used();
    model_init_full(5, 16, 8, 4, 4, 2, 1, f64_from(0), 4, 3, 4, 0, 0, 1, 1, &hkS, 0);   # base ssm, state N=4
    delta = alloc_used() - used0;
    predicted = model_alloc_bytes_hyb(5, 16, 8, 4, 4, 2, g_NP, 3, 4, 0, 0, 1, 1, &hkS);
    assert(delta >= predicted, "hybrid(mha/ssm) alloc accounting (under)");
    assert(delta <= predicted + 8192, "hybrid(mha/ssm) alloc accounting (over)");
    return 0;
}

# Regression for the M7 --layers heap-OOB (adversarial review, 2026-06-11): the
# fresh-model path takes CLI-supplied dims, so model_config_ok must cap their
# MAGNITUDE the same way the checkpoint loader does (-4/-5/-7/-8). Without the
# NL cap an unbounded --layers makes NL*_blk() overflow i64, wrapping to a
# small positive size that t_alloc accepts — then weight-init writes past the
# undersized buffer (SIGSEGV / heap corruption). model_config_ok is the gate
# model_init checks before any allocation.
fn test_config_caps(): i64 {
    # valid shapes accepted (default, BPE-max preset, NL at the cap boundary)
    assert(model_config_ok(25, 32, 16, 4, 4, 3) == 1, "valid default config accepted");
    assert(model_config_ok(768, 64, 64, 8, 8, 4) == 1, "valid BPE-max preset config accepted");
    assert(model_config_ok(25, 32, 16, 4, 4, 128) == 1, "NL at cap (128) accepted");
    # NL is the exploit vector (CLI --layers); cap mirrors the loader's -8
    assert(model_config_ok(25, 32, 16, 4, 4, 129) == 0, "NL over cap (129) rejected");
    assert(model_config_ok(25, 32, 16, 4, 4, 1000000000) == 0, "huge NL rejected before overflow");
    # the remaining magnitude caps mirror the loader's -4/-5/-7
    assert(model_config_ok(769, 32, 16, 4, 4, 3) == 0, "V over BPE_VMAX (769) rejected");
    assert(model_config_ok(25, 4097, 16, 4, 4, 3) == 0, "C over cap (4097) rejected");
    assert(model_config_ok(25, 32, 8193, 4, 4, 3) == 0, "T over cap (8193) rejected");
    # MLA descriptor (ADR 0007): full heads required, 1 <= d_c <= C, kind in {0,1}
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 0, 0) == 1, "valid MLA config accepted");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 32, 0, 0) == 1, "MLA d_c == C accepted");
    assert(model_config_ok_arch(25, 32, 16, 4, 2, 3, 1, 16, 0, 0) == 0, "MLA with nkv != nh rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 0, 0, 0) == 0, "MLA d_c = 0 rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 33, 0, 0) == 0, "MLA d_c > C rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 4, 16, 0, 0) == 0, "unknown attn_kind (4) rejected");
    # pos_kind descriptor (M12 increment 4): rope (1) on mha with even head dim
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 0, 0, 1, 0) == 1, "rope on mha (hd=8) accepted");
    assert(model_config_ok_arch(25, 16, 16, 2, 1, 3, 0, 0, 1, 0) == 1, "rope on mqa (hd=8) accepted");
    assert(model_config_ok_arch(25, 12, 16, 4, 4, 3, 0, 0, 1, 0) == 0, "rope with odd head dim (hd=3) rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 1, 0) == 0, "coupled rope + mla rejected (use decoupled)");
    # pos_kind descriptor (M12 increment 5): decoupled (2) on MLA with even d_rope
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 2, 4) == 1, "decoupled rope on mla (d_rope=4) accepted");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 0, 0, 2, 4) == 0, "decoupled on mha rejected (mla-only)");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 2, 3) == 0, "decoupled odd d_rope rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 2, 0) == 0, "decoupled d_rope < 2 rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 2, 34) == 0, "decoupled d_rope > C rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 1, 16, 1, 4) == 0, "non-decoupled with rope_dim != 0 rejected");
    # gated linear attention (M14, attn_kind=2): full heads, no latent, learned-abs
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 2, 0, 0, 0) == 1, "linear attention (attn_kind=2) accepted");
    assert(model_config_ok_arch(25, 32, 16, 4, 2, 3, 2, 0, 0, 0) == 0, "linear with nkv != nh rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 2, 8, 0, 0) == 0, "linear with a latent dim rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 2, 0, 1, 0) == 0, "linear + rope rejected (softmax-only)");
    # selective SSM (M14 rung b, attn_kind=3): d_c = state N in 1..C, full heads, learned-abs
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 3, 16, 0, 0) == 1, "ssm (attn_kind=3, N=16) accepted");
    assert(model_config_ok_arch(25, 32, 16, 4, 2, 3, 3, 16, 0, 0) == 0, "ssm with nkv != nh rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 3, 0, 0, 0) == 0, "ssm with N = 0 rejected");
    assert(model_config_ok_arch(25, 32, 16, 4, 4, 3, 3, 16, 1, 0) == 0, "ssm + rope rejected");
    # per-layer HYBRID (M14 rung c+d): any mix of {mha,mla,lin,ssm}; the K/V region
    # pads to the max _kvw. Constraints: full heads (nkv==nh), learned-abs, a valid
    # shared latent in [1,C] iff any mla/ssm layer (else 0). C=32, nh=nkv=4.
    # _hybrid_kinds_ok(kinds, NL, C, nh, nkv, d_c, pos_kind, d_rope).
    var hk[24];
    store64(&hk + 0, 0); store64(&hk + 8, 2); store64(&hk + 16, 0);     # mha,lin,mha
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 0, 0, 0) == 1, "hybrid mha/lin (no latent) accepted");
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 8, 0, 0) == 0, "hybrid {mha,lin} carrying a latent rejected");
    store64(&hk + 8, 1);                                               # mha,mla,mha
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 16, 0, 0) == 1, "hybrid mha/mla with latent accepted (rung d)");
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 0, 0, 0) == 0, "hybrid mha/mla without a latent rejected");
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 2, 16, 0, 0) == 0, "hybrid mha/mla with partial heads rejected");
    store64(&hk + 8, 3);                                               # mha,ssm,mha
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 16, 0, 0) == 1, "hybrid mha/ssm with state accepted (rung d)");
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 33, 0, 0) == 0, "hybrid mha/ssm with state > C rejected");
    store64(&hk + 8, 7);                                               # layer 1 -> bogus kind
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 16, 0, 0) == 0, "hybrid with a bogus per-layer kind rejected");
    store64(&hk + 8, 2);                                               # restore lin
    assert(_hybrid_kinds_ok(&hk, 3, 32, 4, 4, 0, 1, 0) == 0, "hybrid + rope rejected (learned-abs only)");
    # MoE descriptor (M13): 1 <= num_experts <= 256, 1 <= topk <= num_experts.
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 8, 2) == 1, "valid moe (8 experts, top-2) accepted");
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 1, 1) == 1, "moe experts=1 (dense) accepted");
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 256, 2) == 1, "moe experts at cap (256) accepted");
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 257, 2) == 0, "moe experts over cap (257) rejected");
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 0, 1) == 0, "moe experts = 0 rejected");
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 8, 9) == 0, "moe topk > experts rejected");
    assert(model_config_ok_moe(25, 32, 16, 4, 4, 3, 0, 0, 0, 0, 8, 0) == 0, "moe topk = 0 rejected");
    return 0;
}

# A BPE-scale vocab (V > 256) through the generation paths: the cached and
# uncached forwards must stay bit-identical with logits/probs rows, the tied
# head, and sampling all running at V past the old byte-level cap. No corpus
# or vocab table involved (emit off; synthetic ids) — V is just a dimension.
fn test_kv_vocab300(): i64 {
    var V = 300;
    model_init(V, 16, 8, 2, 2, 2, 1, f64_from(0), 29);
    g_training = 0;
    var T = g_T;
    var ids = t_alloc(T);
    var i = 0;
    while (i < T) { store64(ids + i * 8, (i * 37 + 5) % V); i = i + 1; }
    # prefill bit-identity at every prefix
    var mism = 0;
    var m = 1;
    while (m <= T) {
        gen_prime(ids, m, 1);
        var cs = t_alloc(V); t_copy(cs, R_logits, V);
        gen_prime(ids, m, 0);
        var urow = A_logits + (m - 1) * g_V * 8;
        var v = 0;
        while (v < V) {
            if (load64(cs + v * 8) != load64(urow + v * 8)) { mism = mism + 1; }
            v = v + 1;
        }
        m = m + 1;
    }
    assert(mism == 0, "V=300 prefill logits bit-identical at every prefix");
    # decode ids across context-shifts, temperature sampling
    var NG = 2 * T;
    var outA = t_alloc(NG); var outB = t_alloc(NG);
    _rng_state = 31337;
    gen_prime(ids, T, 1);
    gen_decode(NG, _lrc(8, 10), 1, outA, 0);
    _rng_state = 31337;
    gen_prime(ids, T, 0);
    gen_decode(NG, _lrc(8, 10), 0, outB, 0);
    var bad = 0; i = 0;
    while (i < NG) {
        var a = load64(outA + i * 8);
        if (a != load64(outB + i * 8)) { bad = bad + 1; }
        if ((a < 0) || (a >= V)) { bad = bad + 1; }
        i = i + 1;
    }
    assert(bad == 0, "V=300 decode ids identical and in range");
    return 0;
}

# GQA checkpoint round-trip + the new v2 header validations.
fn test_ckpt_gqa_roundtrip(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 4, 2, 1, 1, f64_from(0), 9);   # nh=4, nkv=2, biases on
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    model_init(V, 8, 4, 4, 4, 1, 1, f64_from(0), 31);  # scramble with full MHA
    assert(ckpt_load_buf(ck, sz) == 0, "gqa checkpoint loads");
    assert(g_nkv == 2, "gqa nkv restored");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "gqa load restores params bit-for-bit");
    # invalid nkv values must be rejected (-16)
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 12 * 8, 3);
    assert(ckpt_load_buf(bad, sz) == (0 - 16), "nkv not dividing nh rejected");
    t_copy(bad, ck, sz / 8); store64(bad + 12 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 16), "nkv = 0 rejected");
    t_copy(bad, ck, sz / 8); store64(bad + 12 * 8, 8);
    assert(ckpt_load_buf(bad, sz) == (0 - 16), "nkv > nh rejected");
    # negative step must be rejected (-17)
    t_copy(bad, ck, sz / 8); store64(bad + 10 * 8, 0 - 5);
    assert(ckpt_load_buf(bad, sz) == (0 - 17), "negative step rejected");
    # rng state 0 (the xorshift fixed point) must be rejected (-19)
    t_copy(bad, ck, sz / 8); store64(bad + 11 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 19), "rng state 0 rejected");
    # a SHAPE-valid config whose nh*T*T attention arenas would blow the
    # allocator (np stays tiny — the arena term is independent of np) must be
    # rejected by the pre-allocation bound (-18), before the length check
    t_copy(bad, ck, sz / 8);
    store64(bad + 2 * 8, 2);        # V=2
    store64(bad + 3 * 8, 64);       # C=64
    store64(bad + 4 * 8, 8192);     # T=8192
    store64(bad + 5 * 8, 64);       # nh=64 (hd=1)
    store64(bad + 6 * 8, 1);        # NL=1
    store64(bad + 7 * 8, 0);        # bias off
    store64(bad + 12 * 8, 1);       # nkv=1
    store64(bad + 14 * 8, 2);       # Vb=2 (keep V = Vb + K consistent)
    store64(bad + 9 * 8, ckpt_expected_np(2, 64, 8192, 64, 1, 0, 1));
    assert(ckpt_load_buf(bad, sz) == (0 - 18), "oversized model (arena) rejected pre-alloc");
    return 0;
}

# MLA checkpoint round-trip (v4 descriptor attn_kind=1 + latent_dim): the
# descriptor and the latent-projection params restore bit-for-bit, the model
# rebuilds with full heads, and the descriptor-consistency gates (-42) fire.
fn test_ckpt_mla_roundtrip(): i64 {
    var V = build_corpus();
    model_init_arch(V, 8, 4, 2, 2, 1, 1, f64_from(0), 9, 1, 6, 0, 0);   # MLA d_c=6, biases on
    assert(g_attn_kind == 1, "mla model built");
    assert(g_latent_dim == 6, "mla latent dim set");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 16 * 8) == 1, "checkpoint records attn_kind=mla");
    assert(load64(ck + 18 * 8) == 6, "checkpoint records latent_dim");
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 31);   # scramble to a fresh MHA model
    assert(g_attn_kind == 0, "scramble reset to mha");
    assert(ckpt_load_buf(ck, sz) == 0, "mla checkpoint loads");
    assert(g_attn_kind == 1, "attn_kind restored to mla");
    assert(g_latent_dim == 6, "latent_dim restored");
    assert(g_nkv == g_nh, "mla restored with full heads");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "mla load restores params bit-for-bit");
    # an mha header (attn_kind=0) carrying a non-zero latent dim is inconsistent (-42)
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 16 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 42), "mha header with latent dim rejected (-42)");
    # MLA with d_c out of [1, C] (-42)
    t_copy(bad, ck, sz / 8); store64(bad + 18 * 8, 9);   # d_c=9 > C=8
    assert(ckpt_load_buf(bad, sz) == (0 - 42), "mla d_c > C rejected (-42)");
    t_copy(bad, ck, sz / 8); store64(bad + 18 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 42), "mla d_c = 0 rejected (-42)");
    return 0;
}

# Older checkpoint versions must still load. A byte-kind, default-descriptor v4
# body (vocab + params) is bit-identical to v1/v2/v3's, so older images are pure
# header shifts of the v4 the serializer now emits: v3 (pre-MLA, 16 fields) drops
# the descriptor [16..19]; v2 (pre-BPE, 13 fields) also drops [13..15]; v1
# (pre-GQA, 12 fields) also drops [12] (nkv) and loads as full MHA (nkv = nh,
# under which the parameter layout is identical across all versions). dropped is
# computed off CKPT_HDR() so a future header bump shifts this automatically.
fn _ckpt_compat_check(ver, hdr_fields): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 6);
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var cur = alloc(sz); ckpt_serialize(cur);
    var dropped = CKPT_HDR() - hdr_fields;
    var szo = sz - dropped * 8;
    var old = alloc(szo);
    var i = 0;
    while (i < hdr_fields) { store64(old + i * 8, load64(cur + i * 8)); i = i + 1; }
    store64(old + 1 * 8, ver);
    while (i < szo / 8) { store64(old + i * 8, load64(cur + (i + dropped) * 8)); i = i + 1; }
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 777);  # scramble
    assert(ckpt_load_buf(old, szo) == 0, "old-version checkpoint loads");
    assert(g_nkv == g_nh, "old version loads as full MHA (nkv = nh)");
    assert(g_bpe_on == 0, "old version loads as byte-level tokenizer");
    assert(g_bpe_nmerges == 0, "old version loads with zero merges");
    assert(g_attn_kind == 0, "old version loads as mha (default descriptor)");
    assert(g_pos_kind == 0, "old version loads as learned-abs (default descriptor)");
    var mism = 0; i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "old-version load restores params bit-for-bit");
    return 0;
}
fn test_ckpt_v1_compat(): i64 { return _ckpt_compat_check(1, 12); }
fn test_ckpt_v2_compat(): i64 { return _ckpt_compat_check(2, 13); }
fn test_ckpt_v3_compat(): i64 { return _ckpt_compat_check(3, CKPT_HDR_V3()); }
fn test_ckpt_v4_compat(): i64 { return _ckpt_compat_check(4, CKPT_HDR_V4()); }   # pre-MoE: synthesizes dense

# Checkpoint v5 round-trip + hostile rejections for the MoE descriptor (M13.4):
# a MoE model's router gate + per-expert weights serialize, round-trip bit-for-bit
# (params + the experts/topk fields), and the v5 loader rejects an out-of-range
# num_experts (-44) / topk (-45) and an NP that disagrees with the descriptor (-10).
fn test_ckpt_moe(): i64 {
    var V = build_corpus();
    model_init_moe(V, 8, 4, 2, 2, 1, 1, f64_from(0), 9, 0, 0, 0, 0, 8, 2);   # MHA + 8 experts, top-2
    assert(g_num_experts == 8, "moe model built");
    assert(g_expert_topk == 2, "topk installed");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 1 * 8) == 5, "moe checkpoint is v5");
    assert(load64(ck + 20 * 8) == 8, "num_experts recorded");
    assert(load64(ck + 21 * 8) == 2, "expert_topk recorded");
    # scramble to a dense model, then reload the MoE checkpoint
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 31);
    assert(g_num_experts == 1, "reset to dense");
    assert(ckpt_load_buf(ck, sz) == 0, "moe checkpoint loads");
    assert(g_num_experts == 8, "num_experts restored");
    assert(g_expert_topk == 2, "expert_topk restored");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "moe params restored bit-for-bit");
    # hostile descriptor rejections (bound-before-alloc, codes -44/-45/-10)
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 20 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 44), "num_experts = 0 rejected (-44)");
    t_copy(bad, ck, sz / 8); store64(bad + 20 * 8, 257);
    assert(ckpt_load_buf(bad, sz) == (0 - 44), "num_experts over cap (257) rejected (-44)");
    t_copy(bad, ck, sz / 8); store64(bad + 21 * 8, 9);
    assert(ckpt_load_buf(bad, sz) == (0 - 45), "topk > num_experts rejected (-45)");
    t_copy(bad, ck, sz / 8); store64(bad + 21 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 45), "topk = 0 rejected (-45)");
    # a num_experts that passes its bound but disagrees with NP fails the np gate
    t_copy(bad, ck, sz / 8); store64(bad + 20 * 8, 4);
    assert(ckpt_load_buf(bad, sz) == (0 - 10), "num_experts inconsistent with NP rejected (-10)");
    return 0;
}

# Checkpoint round-trip + hostile rejections for the gated-linear descriptor
# (M14.3, attn_kind=2). Rides the existing v5 attn_kind slot — no format bump
# (linear is parameter-free over the MHA layout, so NP is unchanged). The loader
# rejects a linear image carrying a latent (-42), RoPE (-41), or partial heads (-40).
fn test_ckpt_lin(): i64 {
    var V = build_corpus();
    model_init_arch(V, 8, 4, 2, 2, 1, 1, f64_from(0), 27, 2, 0, 0, 0);   # gated linear
    assert(g_attn_kind == 2, "linear model built");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 16 * 8) == 2, "attn_kind=lin recorded");
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 53);                    # scramble to mha
    assert(g_attn_kind == 0, "reset to mha");
    assert(ckpt_load_buf(ck, sz) == 0, "linear checkpoint loads");
    assert(g_attn_kind == 2, "attn_kind restored");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "linear params restored bit-for-bit");
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 18 * 8, 4);     # d_c != 0 on linear
    assert(ckpt_load_buf(bad, sz) == (0 - 42), "linear + latent rejected (-42)");
    t_copy(bad, ck, sz / 8); store64(bad + 17 * 8, 1);     # pos_kind=1 (rope) on linear
    assert(ckpt_load_buf(bad, sz) == (0 - 41), "linear + rope rejected (-41)");
    t_copy(bad, ck, sz / 8); store64(bad + 12 * 8, 1);     # nkv=1 < nh=2 on linear
    assert(ckpt_load_buf(bad, sz) == (0 - 40), "linear with partial heads rejected (-40)");
    return 0;
}

# Selective-SSM checkpoint round-trip + hostile rejections (1.4.2 b.3). Rides the
# v5 attn_kind slot (value 3) reusing latent_dim as the state size N — no format
# bump. Rejects a missing state size (-42), RoPE on the SSM (-41), partial heads (-40).
fn test_ckpt_ssm(): i64 {
    var V = build_corpus();
    model_init_arch(V, 8, 4, 2, 2, 1, 1, f64_from(0), 33, 3, 4, 0, 0);   # SSM, N=4
    assert(g_attn_kind == 3, "ssm model built");
    assert(g_latent_dim == 4, "ssm state size installed");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 16 * 8) == 3, "attn_kind=ssm recorded");
    assert(load64(ck + 18 * 8) == 4, "state size recorded");
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 61);                    # scramble to mha
    assert(g_attn_kind == 0, "reset to mha");
    assert(ckpt_load_buf(ck, sz) == 0, "ssm checkpoint loads");
    assert(g_attn_kind == 3, "attn_kind restored");
    assert(g_latent_dim == 4, "state size restored");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "ssm params restored bit-for-bit");
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 18 * 8, 0);     # state size 0
    assert(ckpt_load_buf(bad, sz) == (0 - 42), "ssm with N=0 rejected (-42)");
    t_copy(bad, ck, sz / 8); store64(bad + 17 * 8, 1);     # pos_kind=1 (rope) on ssm
    assert(ckpt_load_buf(bad, sz) == (0 - 41), "ssm + rope rejected (-41)");
    t_copy(bad, ck, sz / 8); store64(bad + 12 * 8, 1);     # nkv=1 < nh=2
    assert(ckpt_load_buf(bad, sz) == (0 - 40), "ssm with partial heads rejected (-40)");
    return 0;
}

# M15: char-diffusion checkpoint v7 round-trip + back-compat + hostile rejections.
# Pins: (1) an AR model STILL serializes as v5 (M15 must not bump AR's version);
# (2) a diffusion model serializes as v7 with objective at [22] and round-trips the
# +C mask_emb bit-for-bit; (3) hostile v7 images reject cleanly (-47). v5/v6
# back-compat (objective synthesized 0) is covered by the existing v3/v4/hybrid
# round-trips, which still pass after this milestone.
fn test_ckpt_diffusion(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 5);             # uniform AR
    assert(CKPT_VER() == 5, "AR model still serializes as v5 after M15");
    # diffusion model: mha + learned-abs + dense + uniform, NL=2
    model_init_full(V, 8, 4, 2, 2, 2, 1, f64_from(0), 33, 0, 0, 0, 0, 1, 1, 0, 1);
    assert(g_objective == 1, "diffusion model built");
    assert(g_bidir == 1, "diffusion model is bidirectional");
    assert(CKPT_VER() == 7, "diffusion serializes as v7");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 1 * 8) == 7, "version field = 7");
    assert(load64(ck + 22 * 8) == 1, "objective = diffusion recorded at [22]");
    model_init(V, 8, 4, 2, 2, 2, 1, f64_from(0), 61);            # scramble to AR
    assert(g_objective == 0, "reset to AR");
    assert(g_bidir == 0, "reset to causal");
    assert(ckpt_load_buf(ck, sz) == 0, "v7 diffusion checkpoint loads");
    assert(g_objective == 1, "objective restored");
    assert(g_bidir == 1, "bidirectional restored");
    assert(g_NP == np, "NP restored (incl. +C mask_emb)");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "v7 params (incl. mask_emb) restored bit-for-bit");
    # hostile rejections (-47), each before any allocation:
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 22 * 8, 2);            # objective out of {0,1}
    assert(ckpt_load_buf(bad, sz) == (0 - 47), "objective=2 rejected (-47)");
    t_copy(bad, ck, sz / 8); store64(bad + 17 * 8, 1);            # diffusion + rope (pos_kind=1)
    assert(ckpt_load_buf(bad, sz) == (0 - 47), "diffusion + rope rejected (-47)");
    t_copy(bad, ck, sz / 8); store64(bad + 20 * 8, 2);            # diffusion + MoE (num_experts=2)
    assert(ckpt_load_buf(bad, sz) == (0 - 47), "diffusion + moe rejected (-47)");
    return 0;
}

# Per-layer HYBRID checkpoint round-trip + hostile rejections (M14 rung c, v6,
# ADR 0011). A hybrid is the FIRST model that can't ride the scalar descriptor —
# it serializes as v6 with NL per-layer kinds at [22..22+NL), the vocab shifting
# after. A uniform model still writes v5 (covered elsewhere). The loader rebuilds
# the per-layer pattern, and rejects a v6 image whose per-layer kind breaks the
# uniform-stride invariant (a kind with a different _kvw than the base) with -46.
fn test_ckpt_hybrid(): i64 {
    var V = build_corpus();
    var NL = 3;
    var kinds[24]; store64(&kinds + 0, 0); store64(&kinds + 8, 2); store64(&kinds + 16, 0);   # mha,lin,mha
    model_init_full(V, 8, 4, 2, 2, NL, 1, f64_from(0), 33, 2, 0, 0, 0, 1, 1, &kinds, 0);          # base lin
    assert(g_layer_kind != 0, "hybrid model built");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 1 * 8) == 6, "hybrid serializes as v6");
    assert(load64(ck + 16 * 8) == 2, "base attn_kind=lin recorded");
    assert(load64(ck + 22 * 8) == 0, "layer 0 kind=mha recorded (per-layer region)");
    assert(load64(ck + 23 * 8) == 2, "layer 1 kind=lin recorded");
    assert(load64(ck + 24 * 8) == 0, "layer 2 kind=mha recorded");
    model_init(V, 8, 4, 2, 2, NL, 1, f64_from(0), 71);                  # scramble to uniform mha
    assert(g_layer_kind == 0, "reset to uniform");
    assert(ckpt_load_buf(ck, sz) == 0, "hybrid checkpoint loads");
    assert(g_layer_kind != 0, "per-layer pattern restored");
    assert(_lk(0) == 0, "layer 0 restored mha");
    assert(_lk(1) == 2, "layer 1 restored lin");
    assert(_lk(2) == 0, "layer 2 restored mha");
    var mism = 0; var i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "hybrid params restored bit-for-bit");
    var bad = alloc(sz);
    # base lin carries d_c == 0, so injecting a latent-kind layer (mla/ssm) without a
    # shared latent breaks the invariant (-46); a bogus kind likewise.
    t_copy(bad, ck, sz / 8); store64(bad + 22 * 8, 1);     # layer 0 -> mla, but d_c == 0
    assert(ckpt_load_buf(bad, sz) == (0 - 46), "hybrid mla-layer without a latent rejected (-46)");
    t_copy(bad, ck, sz / 8); store64(bad + 23 * 8, 3);     # layer 1 -> ssm, but d_c == 0
    assert(ckpt_load_buf(bad, sz) == (0 - 46), "hybrid ssm-layer without a latent rejected (-46)");
    t_copy(bad, ck, sz / 8); store64(bad + 23 * 8, 9);     # layer 1 -> bogus kind
    assert(ckpt_load_buf(bad, sz) == (0 - 46), "hybrid bogus per-layer kind rejected (-46)");

    # rung d: a DIFFERENT-LAYOUT hybrid (mha ⊕ ssm, base ssm) round-trips through v6
    # — the per-layer kinds + the padded np must reconstruct exactly. NL=3, N=4.
    var ksm[24]; store64(&ksm + 0, 3); store64(&ksm + 8, 0); store64(&ksm + 16, 3);   # ssm,mha,ssm
    model_init_full(V, 8, 4, 2, 2, 3, 1, f64_from(0), 41, 3, 4, 0, 0, 1, 1, &ksm, 0);    # base ssm, N=4
    assert(g_layer_kind != 0, "ssm-hybrid built");
    var np2 = g_NP;
    var snap2 = t_alloc(np2); t_copy(snap2, g_params, np2);
    var sz2 = ckpt_size();
    var ck2 = alloc(sz2); ckpt_serialize(ck2);
    assert(load64(ck2 + 1 * 8) == 6, "ssm-hybrid serializes as v6");
    assert(load64(ck2 + 16 * 8) == 3, "base attn_kind=ssm recorded");
    assert(load64(ck2 + 22 * 8) == 3, "layer 0 kind=ssm recorded");
    assert(load64(ck2 + 23 * 8) == 0, "layer 1 kind=mha recorded");
    model_init(V, 8, 4, 2, 2, 3, 1, f64_from(0), 73);                  # scramble to uniform mha
    assert(ckpt_load_buf(ck2, sz2) == 0, "ssm-hybrid checkpoint loads");
    assert(_lk(0) == 3, "ssm-hybrid layer 0 restored ssm");
    assert(_lk(1) == 0, "ssm-hybrid layer 1 restored mha");
    var mism2 = 0; var i2 = 0;
    while (i2 < np2) {
        if (load64(g_params + i2 * 8) != load64(snap2 + i2 * 8)) { mism2 = mism2 + 1; }
        i2 = i2 + 1;
    }
    assert(mism2 == 0, "ssm-hybrid params restored bit-for-bit (padded layout)");
    return 0;
}

# With a corpus already loaded, a checkpoint whose vocab differs must be
# rejected (-15) rather than silently mis-indexing g_data.
fn test_ckpt_vocab_mismatch(): i64 {
    var V = build_corpus();                 # sets g_data != 0 with corpus vocab
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 3);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    # corrupt the first vocab entry so it no longer matches the loaded corpus
    var off = CKPT_HDR() * 8;                # header fields, then vocab[0]
    store64(ck + off, (load64(ck + off) + 1) % 256);
    assert(ckpt_load_buf(ck, sz) == (0 - 15), "vocab-mismatch rejected (-15)");
    return 0;
}

# eval_corpus: deterministic, repeatable, RNG-neutral; byte mode counts one
# byte per target, BPE counts each target's expansion (so bits-per-byte is
# comparable across tokenizers).
fn test_eval_bpb(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 19);
    train(4, 4, 2, _lrc(3, 1000), _lrc(3, 10000), 2, f64_from(1), 1000000000);
    var rng0 = _rng_state;
    var n1 = eval_corpus();
    var nats1 = g_eval_nats; var tok1 = g_eval_tokens; var byt1 = g_eval_bytes;
    var n2 = eval_corpus();
    assert((n1 > 0) && (n1 == n2), "eval runs and is repeatable");
    assert(g_eval_nats == nats1, "eval nats bit-identical across passes");
    assert(_rng_state == rng0, "eval is RNG-neutral");
    assert(byt1 == tok1, "byte-level eval: bytes == tokens");
    assert(f64_is_finite(eval_bpb()) == 1, "bits/byte is finite");
    # BPE: merged targets span > 1 byte each, so bytes must exceed tokens
    build_corpus();
    var V2 = bpe_learn(8);
    model_init(V2, 8, 4, 2, 2, 1, 0, f64_from(0), 19);
    assert(eval_corpus() > 0, "bpe eval runs");
    assert(g_eval_bytes > g_eval_tokens, "bpe eval: targets span more bytes than tokens");
    return 0;
}

# v3 BPE checkpoint round-trip: tokenizer state (kind, base, merges, spans)
# and params restore bit-exactly, and the corpus id stream is rebuilt from
# the retained raw bytes through the loaded merges.
fn test_ckpt_v3_roundtrip(): i64 {
    var B = build_corpus();
    var V = bpe_learn(8);
    var nm = g_bpe_nmerges;
    var dl = g_datalen;
    var mer = t_alloc(2 * nm); t_copy(mer, g_merges, 2 * nm);
    # snapshot the packed token stream into an i64 buffer via the width accessor
    var dat = t_alloc(dl); var ci = 0;
    while (ci < dl) { store64(dat + ci * 8, gd_ld(ci)); ci = ci + 1; }
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 13);
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    assert(sz == (CKPT_HDR() + B + 2 * nm + 3 * np) * 8, "checkpoint size accounts header+base+merges+params");
    var ck = alloc(sz); ckpt_serialize(ck);
    # scramble: fresh byte-level corpus state + different-seed model
    build_corpus();
    model_init(B, 8, 4, 2, 2, 1, 1, f64_from(0), 555);
    assert(g_bpe_on == 0, "scramble reset to byte-level");
    assert(ckpt_load_buf(ck, sz) == 0, "v3 BPE checkpoint loads");
    assert(g_bpe_on == 1, "BPE tokenizer restored");
    assert((g_bpe_base == B) && (g_bpe_nmerges == nm), "base/merge counts restored");
    var mism = 0; var i = 0;
    while (i < 2 * nm) {
        if (load64(g_merges + i * 8) != load64(mer + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "merge table restored bit-for-bit");
    assert(g_datalen == dl, "corpus id stream rebuilt to merged length");
    mism = 0; i = 0;
    while (i < dl) {
        if (gd_ld(i) != load64(dat + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "corpus id stream rebuilt bit-for-bit");
    mism = 0; i = 0;
    while (i < np) {
        if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "v3 BPE load restores params bit-for-bit");
    # double-load idempotency: re-encoding from raw bytes must not drift
    assert(ckpt_load_buf(ck, sz) == 0, "v3 BPE checkpoint re-loads");
    assert(g_datalen == dl, "second load leaves the id stream identical");
    return 0;
}

# v3 rejection paths: every new tokenizer-field error code, the forgery
# cascade (a single inconsistent field can never pass all checks), and the
# merge-table scan (well-foundedness -37, expansion bomb -38).
fn test_ckpt_v3_reject(): i64 {
    var B = build_corpus();
    var V = bpe_learn(8);
    var nm = g_bpe_nmerges;
    assert(nm >= 7, "reject setup: corpus sustains >= 7 merges");
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 17);
    var np = g_NP;
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    var bad = alloc(sz);
    # tok_kind out of {0,1}
    t_copy(bad, ck, sz / 8); store64(bad + 13 * 8, 2);
    assert(ckpt_load_buf(bad, sz) == (0 - 32), "tok_kind=2 rejected (-32)");
    # base vocab out of [1,256]
    t_copy(bad, ck, sz / 8); store64(bad + 14 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 33), "Vb=0 rejected (-33)");
    t_copy(bad, ck, sz / 8); store64(bad + 14 * 8, 257);
    assert(ckpt_load_buf(bad, sz) == (0 - 33), "Vb=257 rejected (-33)");
    # merge count out of [0,512] — negative K would alias base ids past V
    t_copy(bad, ck, sz / 8); store64(bad + 15 * 8, 0 - 1);
    assert(ckpt_load_buf(bad, sz) == (0 - 34), "K=-1 rejected (-34)");
    t_copy(bad, ck, sz / 8); store64(bad + 15 * 8, 513);
    assert(ckpt_load_buf(bad, sz) == (0 - 34), "K=513 rejected (-34)");
    # the forgery cascade: V+1 alone -> -35; with K+1 -> -10 (recomputed NP);
    # with NP also patched -> -11 (exact size). A forger must rewrite the
    # whole file consistently — at which point it is a different checkpoint.
    t_copy(bad, ck, sz / 8); store64(bad + 2 * 8, V + 1);
    assert(ckpt_load_buf(bad, sz) == (0 - 35), "V != Vb+K rejected (-35)");
    t_copy(bad, ck, sz / 8); store64(bad + 15 * 8, nm + 1);
    assert(ckpt_load_buf(bad, sz) == (0 - 35), "K+1 alone rejected (-35)");
    t_copy(bad, ck, sz / 8); store64(bad + 2 * 8, V + 1); store64(bad + 15 * 8, nm + 1);
    assert(ckpt_load_buf(bad, sz) == (0 - 10), "K+1,V+1 rejected by recomputed NP (-10)");
    t_copy(bad, ck, sz / 8); store64(bad + 2 * 8, V + 1); store64(bad + 15 * 8, nm + 1);
    store64(bad + 9 * 8, ckpt_expected_np(V + 1, 8, 4, 2, 1, 0, 2));
    assert(ckpt_load_buf(bad, sz) == (0 - 11), "K+1,V+1,np patched rejected by exact size (-11)");
    # byte-level kind cannot carry merges
    t_copy(bad, ck, sz / 8); store64(bad + 13 * 8, 0);
    assert(ckpt_load_buf(bad, sz) == (0 - 36), "tok_kind=0 with K>0 rejected (-36)");
    # merge-table well-foundedness: self, forward, negative refs (the table now
    # follows the v4 header at CKPT_HDR() + B)
    t_copy(bad, ck, sz / 8); store64(bad + (CKPT_HDR() + B) * 8, B);
    assert(ckpt_load_buf(bad, sz) == (0 - 37), "merge 0 self-reference rejected (-37)");
    t_copy(bad, ck, sz / 8); store64(bad + (CKPT_HDR() + B) * 8, B + 3);
    assert(ckpt_load_buf(bad, sz) == (0 - 37), "merge 0 forward reference rejected (-37)");
    t_copy(bad, ck, sz / 8); store64(bad + (CKPT_HDR() + B + 1) * 8, 0 - 2);
    assert(ckpt_load_buf(bad, sz) == (0 - 37), "merge 0 negative reference rejected (-37)");
    # expansion bomb: chained self-doubling merges, header fully consistent —
    # only the length recurrence can catch this (2^(j+1) bytes at merge j)
    t_copy(bad, ck, sz / 8);
    store64(bad + (CKPT_HDR() + B) * 8, 0); store64(bad + (CKPT_HDR() + B + 1) * 8, 0);
    var j = 1;
    while (j < 7) {
        store64(bad + (CKPT_HDR() + B + 2 * j) * 8, B + j - 1);
        store64(bad + (CKPT_HDR() + B + 2 * j + 1) * 8, B + j - 1);
        j = j + 1;
    }
    assert(ckpt_load_buf(bad, sz) == (0 - 38), "expansion bomb rejected (-38)");
    # a v4 header on a buffer too short for it
    assert(ckpt_load_buf(ck, 13 * 8) == (0 - 1), "header on 13-field buffer rejected (-1)");
    # version forged down to 2: the v2 size formula no longer matches
    t_copy(bad, ck, sz / 8); store64(bad + 1 * 8, 2);
    assert(ckpt_load_buf(bad, sz) == (0 - 11), "BPE image forged to v2 rejected by size (-11)");
    return 0;
}

# v4 architecture descriptor (M12, ADR 0007): a byte-level checkpoint records
# the reserved descriptor [16..19] defaulting to mha / learned-abs / 0 / 0, and
# round-trips it. Only the defaults are accepted today — any non-default value
# is rejected pre-allocation (-40..-43), exactly like every other header field.
fn test_ckpt_v4_descriptor(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 23);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    # the serializer emits v5 with the default descriptor + dense MLP
    assert(load64(ck + 1 * 8) == 5, "serializer writes version 5");
    assert(load64(ck + 16 * 8) == 0, "attn_kind defaults to mha (0)");
    assert(load64(ck + 17 * 8) == 0, "pos_kind defaults to learned-abs (0)");
    assert(load64(ck + 18 * 8) == 0, "latent_dim defaults to 0");
    assert(load64(ck + 19 * 8) == 0, "rope_dim defaults to 0");
    assert(load64(ck + 20 * 8) == 1, "num_experts defaults to 1 (dense)");
    assert(load64(ck + 21 * 8) == 1, "expert_topk defaults to 1");
    # round-trip restores the descriptor into the globals
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 47);   # scramble
    assert(ckpt_load_buf(ck, sz) == 0, "v4 default-descriptor checkpoint loads");
    assert(g_attn_kind == 0, "attn_kind restored");
    assert(g_pos_kind == 0, "pos_kind restored");
    assert(g_latent_dim == 0, "latent_dim restored");
    assert(g_rope_dim == 0, "rope_dim restored");
    # reserved / unsupported descriptor values reject before allocating. attn_kind
    # 1 (MLA), 2 (gated-linear), 3 (selective SSM) are now SUPPORTED; pos_kind 1
    # (RoPE) is now SUPPORTED on this even-hd mha image (test_ckpt_rope below). An
    # unknown attn_kind (4) hits -40, a latent dim on mha hits -42, pos_kind 2
    # (rope-decoupled) on mha hits -41, and a nonzero rope_dim hits -43.
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 16 * 8, 4);
    assert(ckpt_load_buf(bad, sz) == (0 - 40), "attn_kind=4 (unknown) rejected (-40)");
    t_copy(bad, ck, sz / 8); store64(bad + 17 * 8, 2);
    assert(ckpt_load_buf(bad, sz) == (0 - 41), "pos_kind=2 (rope-decoupled reserved) rejected (-41)");
    t_copy(bad, ck, sz / 8); store64(bad + 18 * 8, 8);
    assert(ckpt_load_buf(bad, sz) == (0 - 42), "latent_dim on mha rejected (-42)");
    t_copy(bad, ck, sz / 8); store64(bad + 19 * 8, 8);
    assert(ckpt_load_buf(bad, sz) == (0 - 43), "rope_dim != 0 rejected (-43)");
    return 0;
}

# v4 round-trip with coupled RoPE (pos_kind=1) + the rope-specific hostile
# descriptor rejections. RoPE is parameter-free, so the v4 body is byte-identical
# to an mha image — only the descriptor field differs — and the loader must
# accept pos_kind=1 ONLY on a dense (mha) image with an EVEN head dim.
fn test_ckpt_rope(): i64 {
    var V = build_corpus();
    model_init_arch(V, 16, 4, 2, 2, 1, 1, f64_from(0), 31, 0, 0, 1, 0);   # mha + rope, hd=8
    assert(g_pos_kind == 1, "rope model built with pos_kind=1");
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 17 * 8) == 1, "serializer records pos_kind=1");
    model_init(V, 16, 4, 2, 2, 1, 1, f64_from(0), 99);   # scramble to learned-abs
    assert(ckpt_load_buf(ck, sz) == 0, "v4 rope checkpoint loads");
    assert(g_pos_kind == 1, "pos_kind=1 restored");
    # hostile: pos_kind=1 on an ODD head-dim image (C=12, nh=4 -> hd=3) must reject.
    model_init(V, 12, 4, 4, 4, 1, 1, f64_from(0), 7);    # hd=3 (odd), mha/learned
    var sz2 = ckpt_size();
    var ck2 = alloc(sz2); ckpt_serialize(ck2);
    store64(ck2 + 17 * 8, 1);                             # force pos_kind=rope
    assert(ckpt_load_buf(ck2, sz2) == (0 - 41), "rope with odd head dim rejected (-41)");
    # hostile: pos_kind=1 + attn_kind=1 (MLA) must reject (decoupled is a later rung)
    model_init_arch(V, 16, 4, 2, 2, 1, 1, f64_from(0), 5, 1, 8, 0, 0);   # MLA image
    var sz3 = ckpt_size();
    var ck3 = alloc(sz3); ckpt_serialize(ck3);
    store64(ck3 + 17 * 8, 1);                             # force pos_kind=rope on MLA
    assert(ckpt_load_buf(ck3, sz3) == (0 - 41), "rope + mla rejected (-41)");
    return 0;
}

# v4 round-trip with MLA + decoupled RoPE (pos_kind=2, rope_dim>0) + the
# decoupled-specific hostile rejections. The descriptor carries pos_kind=2 and a
# non-zero rope_dim; np includes W_QR/W_KR; the loader accepts pos_kind=2 ONLY on
# an MLA image with an even d_rope in [2, C].
fn test_ckpt_dec(): i64 {
    var V = build_corpus();
    model_init_arch(V, 16, 4, 2, 2, 1, 1, f64_from(0), 41, 1, 8, 2, 4);   # MLA + decoupled, d_rope=4
    assert(g_pos_kind == 2, "decoupled model built with pos_kind=2");
    assert(g_rope_dim == 4, "decoupled rope_dim=4 installed");
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 17 * 8) == 2, "serializer records pos_kind=2");
    assert(load64(ck + 19 * 8) == 4, "serializer records rope_dim=4");
    model_init(V, 16, 4, 2, 2, 1, 1, f64_from(0), 77);   # scramble to mha/learned
    assert(ckpt_load_buf(ck, sz) == 0, "v4 decoupled checkpoint loads");
    assert(g_pos_kind == 2, "pos_kind=2 restored");
    assert(g_rope_dim == 4, "rope_dim restored");
    assert(g_attn_kind == 1, "attn_kind=mla restored");
    # hostile: pos_kind=2 on a non-MLA image must reject (-41).
    model_init(V, 16, 4, 2, 2, 1, 1, f64_from(0), 7);    # mha/learned
    var sz2 = ckpt_size();
    var ck2 = alloc(sz2); ckpt_serialize(ck2);
    store64(ck2 + 17 * 8, 2); store64(ck2 + 19 * 8, 4);  # force decoupled on mha
    assert(ckpt_load_buf(ck2, sz2) == (0 - 41), "decoupled on mha rejected (-41)");
    # hostile: ODD d_rope on the valid decoupled image (ck) must reject (-43).
    var ck3 = alloc(sz); t_copy(ck3, ck, sz / 8); store64(ck3 + 19 * 8, 3);  # odd d_rope
    assert(ckpt_load_buf(ck3, sz) == (0 - 43), "decoupled odd d_rope rejected (-43)");
    # hostile: rope_dim out of range (> C) must reject (-43).
    var ck4 = alloc(sz); t_copy(ck4, ck, sz / 8); store64(ck4 + 19 * 8, 64);  # d_rope > C=16
    assert(ckpt_load_buf(ck4, sz) == (0 - 43), "decoupled d_rope > C rejected (-43)");
    return 0;
}

# BPE resume determinism: train(K) one-shot == train(K1) -> v3 round-trip ->
# train(K), params bit-for-bit — through the corpus rebuild (the loaded
# corpus is re-encoded from raw bytes with the checkpoint's merges).
fn test_resume_bpe(): i64 {
    var base = _lrc(3, 1000); var minl = _lrc(3, 10000); var clip = f64_from(1);
    var K = 24; var K1 = 9; var Bch = 4; var warm = 5; var quiet = 1000000000;
    # Path A: one continuous run
    build_corpus();
    var V = bpe_learn(8);
    model_init(V, 8, 4, 2, 2, 2, 0, f64_from(0), 7);
    train(K, K, Bch, base, minl, warm, clip, quiet);
    var npA = g_NP;
    var snapA = t_alloc(npA); t_copy(snapA, g_params, npA);
    # Path B: split run with a checkpoint round-trip at K1
    build_corpus();
    bpe_learn(8);
    model_init(V, 8, 4, 2, 2, 2, 0, f64_from(0), 7);
    train(K1, K, Bch, base, minl, warm, clip, quiet);
    var sz = ckpt_size();
    var buf = alloc(sz); ckpt_serialize(buf);
    build_corpus();                                       # scramble corpus to byte-level
    model_init(V, 8, 4, 2, 2, 2, 0, f64_from(0), 999);    # scramble model
    assert(ckpt_load_buf(buf, sz) == 0, "bpe resume: checkpoint loads");
    train(K, K, Bch, base, minl, warm, clip, quiet);
    assert(g_step == K, "bpe resume: step counter reaches K");
    var mism = 0; var i = 0;
    while (i < g_NP) {
        if (load64(g_params + i * 8) != load64(snapA + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert((g_NP == npA) && (mism == 0), "bpe resume reproduces params bit-for-bit");
    return 0;
}

# BPE generation: cached and uncached decode agree on ids at a BPE vocab,
# every sampled id is in range, and the prompt path (tok_encode + clamp)
# runs end-to-end.
fn test_bpe_generate(): i64 {
    build_corpus();
    var V = bpe_learn(8);
    model_init(V, 16, 8, 2, 2, 2, 1, f64_from(0), 23);
    train(8, 8, 2, _lrc(3, 1000), _lrc(3, 10000), 2, f64_from(1), 1000000000);
    g_training = 0;
    var T = g_T;
    var ids = t_alloc(T);
    var i = 0;
    while (i < T) { store64(ids + i * 8, (i * 5 + 2) % V); i = i + 1; }
    var NG = 2 * T;
    var outA = t_alloc(NG); var outB = t_alloc(NG);
    _rng_state = 777;
    gen_prime(ids, T, 1);
    gen_decode(NG, _lrc(8, 10), 1, outA, 0);
    _rng_state = 777;
    gen_prime(ids, T, 0);
    gen_decode(NG, _lrc(8, 10), 0, outB, 0);
    var bad = 0; i = 0;
    while (i < NG) {
        var a = load64(outA + i * 8);
        if (a != load64(outB + i * 8)) { bad = bad + 1; }
        if ((a < 0) || (a >= V)) { bad = bad + 1; }
        i = i + 1;
    }
    assert(bad == 0, "bpe decode ids identical (cached vs uncached) and in range");
    # the BPE prompt-encode path end-to-end (emits a short sample)
    generate("cyrius ", 7, 8, f64_from(0));
    return 0;
}

# BPE: pin the exact merge sequence on the classic Sennrich corpus
# "aaabdaaabac" under OUR frozen semantics (overlap counting; row-major
# ascending argmax = ties to smallest left id then smallest right id; greedy
# left-to-right non-overlapping replace). Hand trace: vocab a=0 b=1 d=2 c=3;
# ids [0,0,0,1,2,0,0,0,1,0,3]. Round 1: (0,0) count 4 -> id 4 "aa", stream
# [4,0,1,2,4,0,1,0,3]. Round 2: (0,1) and (4,0) tie at 2; (0,1) scans first
# -> id 5 "ab", stream [4,5,2,4,5,0,3]. Round 3: (4,5) count 2 -> id 6
# "aaab", stream [6,2,6,0,3]. On the aarch64/qemu CI leg this same assert is
# the cross-arch merge-determinism pin.
fn test_bpe_known(): i64 {
    var buf = alloc(32);
    var len = _append(buf, 0, "aaabdaaabac");
    var B = corpus_set(buf, len);
    assert(B == 4, "bpe known: byte vocab a,b,d,c");
    var V = bpe_learn(3);
    assert(V == 7, "bpe known: V = 4 base + 3 merges");
    assert(g_bpe_nmerges == 3, "bpe known: 3 merges learned");
    assert((load64(g_merges + 0) == 0) && (load64(g_merges + 8) == 0), "bpe known: merge 0 = (a,a)");
    assert((load64(g_merges + 16) == 0) && (load64(g_merges + 24) == 1), "bpe known: merge 1 = (a,b)");
    assert((load64(g_merges + 32) == 4) && (load64(g_merges + 40) == 5), "bpe known: merge 2 = (aa,ab)");
    assert(g_datalen == 5, "bpe known: encoded stream length 5");
    var want[40];
    store64(&want + 0, 6); store64(&want + 8, 2); store64(&want + 16, 6);
    store64(&want + 24, 0); store64(&want + 32, 3);
    var mism = 0; var i = 0;
    while (i < 5) {
        if (gd_ld(i) != load64(&want + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "bpe known: encoded stream [aaab,d,aaab,a,c]");
    assert(load64(g_tok_len + 6 * 8) == 4, "bpe known: id 6 expands to 4 bytes");
    var sp = g_tok_bytes + 6 * BPE_MAX_TOKLEN();
    var okb = 0;
    if ((load8(sp) == 97) && (load8(sp + 1) == 97) && (load8(sp + 2) == 97) && (load8(sp + 3) == 98)) { okb = 1; }
    assert(okb == 1, "bpe known: id 6 span is 'aaab'");
    return 0;
}

# BPE round-trip: expanding every encoded id reconstructs the corpus bytes
# exactly, and tok_encode over the raw bytes reproduces the merged stream
# bit-for-bit (the property the checkpoint loader's corpus rebuild relies
# on). Unseen bytes at encode time fall back to id 0 without crashing.
fn test_bpe_roundtrip(): i64 {
    var B = build_corpus();
    var V = bpe_learn(16);
    assert(V == B + g_bpe_nmerges, "bpe roundtrip: V = base + merges");
    assert(g_bpe_nmerges >= 1, "bpe roundtrip: corpus yields at least one merge");
    # (a) decode: expand g_data through the span table, compare to g_text
    var pos = 0; var bad = 0; var i = 0;
    while (i < g_datalen) {
        var id = gd_ld(i);
        var tl = load64(g_tok_len + id * 8);
        var sp = g_tok_bytes + id * BPE_MAX_TOKLEN();
        var j = 0;
        while (j < tl) {
            if (pos >= g_textlen) { bad = bad + 1; }
            elif (load8(sp + j) != load8(g_text + pos)) { bad = bad + 1; }
            pos = pos + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    assert((bad == 0) && (pos == g_textlen), "bpe roundtrip: decode reconstructs corpus byte-exactly");
    # (b) encode: tok_encode(raw bytes) == g_data, bit-for-bit. Re-encode into an
    # i64 buffer (width 8) and compare to the packed g_data via the width accessor.
    var out = t_alloc(g_textlen);
    var n = tok_encode(g_text, g_textlen, out, 8);
    assert(n == g_datalen, "bpe roundtrip: re-encode length matches");
    var mism = 0; i = 0;
    while (i < n) {
        if (load64(out + i * 8) != gd_ld(i)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "bpe roundtrip: re-encode reproduces g_data bit-for-bit");
    # (c) unseen bytes (the corpus has no 'Z'/0xF0) fall back to id 0, in range
    var probe = alloc(8);
    store8(probe, 90); store8(probe + 1, 0xF0); store8(probe + 2, 97);
    var pn = tok_encode(probe, 3, out, 8);
    var oor = 0; i = 0;
    while (i < pn) {
        var pid = load64(out + i * 8);
        if ((pid < 0) || (pid >= V)) { oor = oor + 1; }
        i = i + 1;
    }
    assert(((pn >= 1) && (oor == 0)), "bpe roundtrip: unseen bytes encode in-range (id 0 fallback)");
    return 0;
}

# BPE determinism: two independent corpus_set + bpe_learn runs over the same
# bytes produce bit-identical merge tables and encoded streams.
fn test_bpe_determinism(): i64 {
    var B1 = build_corpus();
    var V1 = bpe_learn(12);
    var m1 = g_bpe_nmerges;
    var n1 = g_datalen;
    var mer1 = t_alloc(2 * m1); t_copy(mer1, g_merges, 2 * m1);
    var dat1 = t_alloc(n1); var ci = 0;
    while (ci < n1) { store64(dat1 + ci * 8, gd_ld(ci)); ci = ci + 1; }
    var B2 = build_corpus();
    var V2 = bpe_learn(12);
    assert((V1 == V2) && (m1 == g_bpe_nmerges) && (n1 == g_datalen), "bpe determinism: same V/merges/length");
    var mism = 0; var i = 0;
    while (i < 2 * m1) {
        if (load64(mer1 + i * 8) != load64(g_merges + i * 8)) { mism = mism + 1; }
        i = i + 1;
    }
    i = 0;
    while (i < n1) {
        if (load64(dat1 + i * 8) != gd_ld(i)) { mism = mism + 1; }
        i = i + 1;
    }
    assert(mism == 0, "bpe determinism: merges + stream bit-identical across runs");
    return 0;
}

# E1 gate: KV-cached generation must be BIT-IDENTICAL to the uncached
# reference (full window forward per token, same semantics). Verified two
# ways: (1) prefill — the cached path's logits match the uncached row at
# EVERY prefix length 1..T, bit-for-bit; (2) decode — over 3T generated
# tokens (crossing several context-shift re-primes), the sampled id
# sequences match exactly (greedy AND temperature, same PRNG stream) and the
# final logits row matches bit-for-bit. Run at nkv = nh and nkv = 1 (MQA).
# Unified cached-vs-uncached bit-identity driver (1.4.1 refactor — was 6
# near-identical 58-line copies, one per mixer/attention variant). Builds a model
# with the given descriptor, trains briefly, then verifies the cached decode
# matches the uncached reference: (1) prefill logits at every prefix 1..T, then
# (2) decode ids + final logits across context-shifts, greedy AND temperature. A
# new mixer adds a thin wrapper below — not another copy of this body.
fn _gen_bits(C, T, nh, nkv, NL, ak, dc, pk, dr, ne, tk, pstep, NG): i64 {
    var V = build_corpus();
    model_init_moe(V, C, T, nh, nkv, NL, 1, f64_from(0), 21, ak, dc, pk, dr, ne, tk);
    return _gen_verify(pstep, NG);
}
# M14 rung c/d hybrid bit-identity driver: same two-way contract as _gen_bits but
# the model is a per-layer hybrid (model_init_full). Each block's decode path (MHA
# K/V cache, lin retention state, ssm C×N state, or mla latent) must match its
# uncached reference, AND the mixed stack must compose bit-for-bit through
# context-shifts. `base`/`latent` set the descriptor (the latent-owning kind for
# mla/ssm hybrids); `kinds` is the NL per-layer array.
fn _gen_bits_hybk(C, T, nh, NL, base, latent, kinds, pstep, NG): i64 {
    var V = build_corpus();
    model_init_full(V, C, T, nh, nh, NL, 1, f64_from(0), 21, base, latent, 0, 0, 1, 1, kinds, 0);
    return _gen_verify(pstep, NG);
}
fn _gen_bits_hyb(C, T, nh, NL, kinds, pstep, NG): i64 {
    return _gen_bits_hybk(C, T, nh, NL, 2, 0, kinds, pstep, NG);   # base lin (rung c)
}
# The shared post-init verification (extracted 1.4.3 so the uniform and hybrid
# drivers share ONE body): train briefly, then (1) prefill logits bit-identical
# at every prefix, (2) cached vs uncached decode ids + final logits across slides.
fn _gen_verify(pstep, NG): i64 {
    var T = g_T; var V = g_V;
    train(8, 8, 2, _lrc(3, 1000), _lrc(3, 10000), 2, f64_from(1), 1000000000);
    g_training = 0;
    var ids = t_alloc(T);
    var i = 0;
    while (i < T) { store64(ids + i * 8, (i * 3 + 1) % V); i = i + 1; }
    # (1) prefill logits bits at prefix lengths 1, 1+pstep, ... and T
    var mism = 0;
    var m = 1;
    while (m <= T) {
        gen_prime(ids, m, 1);
        var cs = t_alloc(V); t_copy(cs, R_logits, V);
        gen_prime(ids, m, 0);
        var urow = A_logits + (m - 1) * g_V * 8;
        var v = 0;
        while (v < V) {
            if (load64(cs + v * 8) != load64(urow + v * 8)) { mism = mism + 1; }
            v = v + 1;
        }
        if ((m < T) && (m + pstep > T)) { m = T; }
        else { m = m + pstep; }
    }
    assert(mism == 0, "gen prefill logits bit-identical at every prefix");
    # (2) decode across slide boundaries, greedy then temp 0.8
    var outA = t_alloc(NG); var outB = t_alloc(NG);
    var fin = t_alloc(V);
    var tt = 0;
    while (tt < 2) {
        var temp = f64_from(0);
        if (tt == 1) { temp = _lrc(8, 10); }
        _rng_state = 424242 + tt;
        gen_prime(ids, T, 1);            # full window: slides immediately
        gen_decode(NG, temp, 1, outA, 0);
        t_copy(fin, R_logits, V);
        _rng_state = 424242 + tt;
        gen_prime(ids, T, 0);
        gen_decode(NG, temp, 0, outB, 0);
        var dm = 0;
        i = 0;
        while (i < NG) {
            if (load64(outA + i * 8) != load64(outB + i * 8)) { dm = dm + 1; }
            i = i + 1;
        }
        assert(dm == 0, "gen decode ids identical (cached vs uncached)");
        var urow2 = A_logits + (G_n - 1) * g_V * 8;
        var lm = 0;
        var v2 = 0;
        while (v2 < V) {
            if (load64(fin + v2 * 8) != load64(urow2 + v2 * 8)) { lm = lm + 1; }
            v2 = v2 + 1;
        }
        assert(lm == 0, "gen final logits bit-identical after slides");
        tt = tt + 1;
    }
    return 0;
}
# Thin per-variant wrappers (configs documented at the call sites in test_kv_*).
fn _gen_bits_cfg(C, T, nh, nkv, NL, pstep, NG): i64 { return _gen_bits(C, T, nh, nkv, NL, 0, 0, 0, 0, 1, 1, pstep, NG); }
# Small-config form: NL=2, every prefix, 3T decode tokens (several shifts).
fn _gen_bits_check(C, T, nh, nkv): i64 {
    return _gen_bits_cfg(C, T, nh, nkv, 2, 1, 3 * T);
}
# Configs chosen so the contract is pinned where it could plausibly break:
# hd=8 (pure SIMD chunks), hd∈{4,6,10} (scalar-tail loops live), nkv=nh /
# 1<nkv<nh / nkv=1 (all three K/V-group mappings), odd T (odd GEN_SHIFT) and
# a degenerate 2-token window.
fn test_kv_generation(): i64 {
    _gen_bits_check(16, 8, 2, 2);   # hd=8, full MHA (production head dim)
    _gen_bits_check(16, 8, 2, 1);   # hd=8, MQA: shared K/V head
    _gen_bits_check(12, 7, 2, 1);   # hd=6: SIMD tail; odd T (shift 3)
    _gen_bits_check(20, 5, 2, 2);   # hd=10: SIMD tail; odd T (shift 2)
    _gen_bits_check(16, 6, 4, 2);   # hd=4: true grouping 1 < nkv < nh
    _gen_bits_check(12, 2, 2, 1);   # degenerate 2-token window (shift 1)
    return 0;
}

# M12.2 gate: the MLA latent KV-cache decode (ADR 0007) must be BIT-IDENTICAL
# to the uncached MLA reference (model_eval_window). Same two-way verification
# as the MHA suite — (1) prefill logits at every prefix 1..T, (2) decode ids +
# final logits across context-shifts, greedy AND temperature — but on the MLA
# cached path: the persistent cache holds the d_c latent, up-projected to full
# K/V on read. Pins that the row-wise down/up-projection matches the uncached
# T-row matmuls bit-for-bit. A separate driver from _gen_bits_cfg because the
# model is built with model_init_arch(...,1,d_c) (MLA, full heads).
fn _gen_bits_mla(C, T, nh, NL, d_c, pstep, NG): i64 { return _gen_bits(C, T, nh, nh, NL, 1, d_c, 0, 0, 1, 1, pstep, NG); }
# Configs mirror test_kv_generation's coverage on the MLA path: hd=8 (pure SIMD),
# hd∈{6,10} (scalar-tail loops), d_c = C/2 / d_c not dividing C / a degenerate
# 2-token window — plus odd T (odd GEN_SHIFT). NL=2, 3T decode tokens.
fn test_kv_mla(): i64 {
    _gen_bits_mla(16, 8, 2, 2, 8, 1, 24);    # hd=8, d_c = C/2
    _gen_bits_mla(16, 8, 2, 2, 12, 1, 24);   # hd=8, d_c not dividing C
    _gen_bits_mla(12, 7, 2, 2, 6, 1, 21);    # hd=6 scalar tail; odd T (shift 3)
    _gen_bits_mla(20, 5, 2, 2, 10, 1, 15);   # hd=10 scalar tail; odd T (shift 2)
    _gen_bits_mla(12, 2, 2, 2, 4, 1, 6);     # degenerate 2-token window (shift 1)
    return 0;
}

# M13.3 gate: MoE cached decode must be BIT-IDENTICAL to the uncached reference.
# The MoE MLP is position-independent (the router + experts depend only on the
# row, no cross-row term in the forward combine — only the aux loss is cross-row,
# and decode computes no loss), so the cached single-row moe_fwd must reproduce
# the batch row exactly. Same two-way verification as the MHA/MLA paths.
fn _gen_bits_moe(C, T, nh, NL, NE, TK, pstep, NG): i64 { return _gen_bits(C, T, nh, nh, NL, 0, 0, 0, 0, NE, TK, pstep, NG); }
# MHA + MoE configs across the SIMD/tail head dims, top-1 / top-2 / top-K=N,
# odd T (odd GEN_SHIFT), and a degenerate 2-token window. NL=2, 3T decode tokens.
fn test_kv_moe(): i64 {
    _gen_bits_moe(16, 8, 2, 2, 4, 2, 1, 24);    # hd=8, 4 experts top-2
    _gen_bits_moe(12, 7, 2, 2, 8, 2, 1, 21);    # hd=6 scalar tail; odd T; 8 experts
    _gen_bits_moe(20, 5, 2, 2, 4, 1, 1, 15);    # hd=10 tail; top-1 (single-expert combine)
    _gen_bits_moe(16, 6, 4, 2, 3, 3, 1, 18);    # hd=4; K = N (every expert active)
    _gen_bits_moe(12, 2, 2, 2, 4, 2, 1, 6);     # degenerate 2-token window (shift 1)
    return 0;
}

# M14.2 gate: gated linear-attention cached decode must be BIT-IDENTICAL to the
# uncached reference. The cached path advances the constant-size per-layer state
# (one recurrence step/token, resetting at pos==0); the uncached path re-scans
# the window. Both run the same recurrence, so they must agree bit-for-bit —
# including across context-shifts (the re-prime rebuilds the state from pos 0).
fn _gen_bits_lin(C, T, nh, NL, pstep, NG): i64 { return _gen_bits(C, T, nh, nh, NL, 2, 0, 0, 0, 1, 1, pstep, NG); }
fn test_kv_lin(): i64 {
    _gen_bits_lin(16, 8, 2, 2, 1, 24);    # hd=8
    _gen_bits_lin(12, 7, 2, 2, 1, 21);    # hd=6 scalar; odd T (odd shift)
    _gen_bits_lin(20, 5, 4, 2, 1, 15);    # hd=5 (odd head dim); 4 heads
    _gen_bits_lin(12, 2, 2, 2, 1, 6);     # degenerate 2-token window
    return 0;
}
# Selective-SSM cached decode (1.4.2 b.2): the per-layer C×N state advances one
# scan step/token; must be bit-identical to the uncached batch scan across
# context-shifts (state resets at pos==0 on each re-prime). N = the state size.
fn _gen_bits_ssm(C, T, nh, NL, N, pstep, NG): i64 { return _gen_bits(C, T, nh, nh, NL, 3, N, 0, 0, 1, 1, pstep, NG); }
fn test_kv_ssm(): i64 {
    _gen_bits_ssm(16, 8, 2, 2, 4, 1, 24);    # C=16, N=4
    _gen_bits_ssm(12, 7, 2, 2, 2, 1, 21);    # odd T; small state N=2
    _gen_bits_ssm(8, 5, 2, 2, 4, 1, 15);     # C=8
    _gen_bits_ssm(12, 2, 2, 2, 4, 1, 6);     # degenerate 2-token window
    return 0;
}

# M14 rung-c gate: a per-layer mha/lin HYBRID's cached decode must be bit-identical
# to the uncached reference. Each block runs ITS OWN kind's decode path — the MHA
# K/V cache for the attention layers, the constant lin retention state for the rest
# — and the mixed stack must stay bit-for-bit across context-shifts (each path
# resets at pos==0 on a re-prime). Two interleavings: attention every-2, and
# attention at the ends only.
fn test_kv_hybrid(): i64 {
    var k4a[32];   # NL=4: mha,lin,mha,lin  (attention every 2)
    store64(&k4a + 0, 0); store64(&k4a + 8, 2); store64(&k4a + 16, 0); store64(&k4a + 24, 2);
    _gen_bits_hyb(16, 8, 2, 4, &k4a, 1, 24);    # hd=8
    _gen_bits_hyb(12, 7, 2, 4, &k4a, 1, 21);    # hd=6 scalar; odd T (odd shift)
    var k4b[32];   # NL=4: mha,lin,lin,mha  (attention at the ends)
    store64(&k4b + 0, 0); store64(&k4b + 8, 2); store64(&k4b + 16, 2); store64(&k4b + 24, 0);
    _gen_bits_hyb(8, 5, 2, 4, &k4b, 1, 15);     # C=8
    _gen_bits_hyb(12, 2, 2, 4, &k4b, 1, 6);     # degenerate 2-token window
    # rung d: different-layout mixers in the hybrid — mha ⊕ ssm and mha ⊕ mla. Each
    # block decodes through ITS kind's cache (KV arena / C×N ssm state / mla latent)
    # within the padded layout, bit-identical to the uncached reference.
    var ks[32];    # NL=4: ssm,mha,ssm,mha  (base ssm, N=4)
    store64(&ks + 0, 3); store64(&ks + 8, 0); store64(&ks + 16, 3); store64(&ks + 24, 0);
    _gen_bits_hybk(16, 8, 2, 4, 3, 4, &ks, 1, 24);    # mha/ssm, hd=8
    _gen_bits_hybk(12, 7, 2, 4, 3, 2, &ks, 1, 21);    # odd T; small state N=2
    var km[32];    # NL=4: mla,mha,mla,mha  (base mla, d_c=8)
    store64(&km + 0, 1); store64(&km + 8, 0); store64(&km + 16, 1); store64(&km + 24, 0);
    _gen_bits_hybk(16, 8, 2, 4, 1, 8, &km, 1, 24);    # mha/mla, d_c=8
    _gen_bits_hybk(12, 2, 2, 4, 1, 6, &km, 1, 6);     # degenerate 2-token window
    return 0;
}

# M12.2/increment-4 gate: coupled RoPE (pos_kind=1) cached decode must be
# BIT-IDENTICAL to the uncached reference. Same two-way verification as the MHA
# suite, on the rope path: the cached row rotates q_row + the appended K row by
# absolute position `pos`; the uncached path rotates every row by its position;
# and the context-shift re-prime re-rotates the kept tokens at their new
# positions — so the two must agree bit-for-bit, including across slides. nkv
# spans nh / GQA / MQA so the rotated K-head sharing is exercised too.
fn _gen_bits_rope(C, T, nh, nkv, NL, pstep, NG): i64 { return _gen_bits(C, T, nh, nkv, NL, 0, 0, 1, 0, 1, 1, pstep, NG); }
# Even head dims only (RoPE pairs): hd=8 (pure SIMD), hd∈{6,10} (scalar tail),
# nkv ∈ {nh, 2, 1} for the rotated K-head sharing, odd T (odd GEN_SHIFT), and a
# degenerate 2-token window. NL=2, 3T decode tokens (several context-shifts).
fn test_kv_rope(): i64 {
    _gen_bits_rope(16, 8, 2, 2, 2, 1, 24);   # hd=8, full MHA
    _gen_bits_rope(16, 8, 2, 1, 2, 1, 24);   # hd=8, MQA: shared rotated K/V
    _gen_bits_rope(12, 7, 2, 2, 2, 1, 21);   # hd=6 scalar tail; odd T (shift 3)
    _gen_bits_rope(20, 5, 2, 2, 2, 1, 15);   # hd=10 scalar tail; odd T (shift 2)
    _gen_bits_rope(16, 6, 4, 2, 2, 1, 18);   # hd=4 GQA: 1 < nkv < nh, rotated
    _gen_bits_rope(12, 2, 2, 2, 2, 1, 6);    # degenerate 2-token window (shift 1)
    return 0;
}

# M12 increment-5 gate: MLA + decoupled RoPE cached decode must be BIT-IDENTICAL
# to the uncached reference. The cache holds the latent c AND the shared rope key
# kr; each is rotated per absolute position on read, the latents up-projected to
# K/V — so cached row `pos` must match uncached row pos bit-for-bit, including
# across context-shift re-primes. Same two-way verification (prefill + decode,
# greedy + temperature) as the MLA/RoPE suites.
fn _gen_bits_dec(C, T, nh, NL, d_c, d_rope, pstep, NG): i64 { return _gen_bits(C, T, nh, nh, NL, 1, d_c, 2, d_rope, 1, 1, pstep, NG); }
# d_rope ∈ {2,4}; hd ∈ {4,8} (incl. content head NOT even — the rotation lives on
# the d_rope channel); odd T (odd GEN_SHIFT); a degenerate 2-token window. NL=2.
fn test_kv_dec(): i64 {
    _gen_bits_dec(16, 8, 2, 2, 8, 4, 1, 24);    # hd=8, d_c=8, d_rope=4
    _gen_bits_dec(16, 4, 4, 2, 12, 2, 1, 12);   # hd=4, nh=4 per-head rope, d_rope=2
    _gen_bits_dec(12, 7, 2, 2, 6, 2, 1, 21);    # hd=6, odd T (shift 3), d_rope=2
    _gen_bits_dec(12, 2, 2, 2, 6, 2, 1, 6);     # degenerate 2-token window (shift 1)
    return 0;
}

# M7 gate: the bit-identity contract at the --preset shape (ctx 64 / d_model
# 64 / 8 heads / 4 layers). The per-row arithmetic (hd=8) is already pinned
# above; this pins the preset's window/shift geometry (T=64, GEN_SHIFT 32) and
# the 4-layer cache wiring at full scale. The uncached reference is expensive
# at T=64, so the prefix sweep is strided (1, 10, ..., 55, 64 — both edges
# hit) and the decode runs T+8 tokens: priming at full T makes the FIRST
# decode token context-shift, and 64+8 more crosses two further shifts.
fn test_kv_preset(): i64 {
    return _gen_bits_cfg(64, 64, 8, 8, 4, 9, 72);
}

# Soak: training must not leak memory and must not blow up. The forward/backward
# paths use only pre-allocated buffers, so alloc_used() must be IDENTICAL across
# many steps; and reaching the target step proves the NaN guard never tripped
# (loss stayed finite throughout).
fn test_soak(): i64 {
    var V = build_corpus();
    model_init(V, 16, 8, 2, 2, 2, 0, f64_from(0), 1);
    var base = _lrc(1, 1000); var minl = _lrc(1, 10000); var clip = f64_from(1);
    train(2, 90, 4, base, minl, 5, clip, 1000000000);   # warm-up
    var used0 = alloc_used();
    train(90, 90, 4, base, minl, 5, clip, 1000000000);  # 88 more steps
    var used1 = alloc_used();
    assert(used1 == used0, "soak: no per-step heap allocation (no leak)");
    assert(g_step == 90, "soak: reached target step (loss stayed finite)");
    return 0;
}

# The NaN guard must HALT training rather than poison weights. Inject a NaN into
# a weight so the loss is non-finite; the guard should stop before stepping.
fn test_nan_guard(): i64 {
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 2);
    store64(P_tokemb(), 0x7FF8000000000000);   # NaN into a weight
    var before = g_step;
    var w1 = load64(P_tokemb() + 8);            # a finite weight (not the NaN'd one)
    var rc = train(5, 5, 2, _lrc(1, 1000), _lrc(1, 10000), 1, f64_from(1), 1000000000);
    assert(rc == (0 - 1), "train returns -1 on non-finite loss");
    assert(g_step == before, "NaN loss halts training (no step completed)");
    assert(load64(P_tokemb() + 8) == w1, "weights not stepped after the guard fires");
    return 0;
}

# relative error between two f64 bit patterns
fn _rel(a, b): i64 {
    var t = f64_div(f64_from(1), f64_from(1000000000));
    return f64_div(f64_abs(f64_sub(a, b)), f64_add(f64_add(f64_abs(a), f64_abs(b)), t));
}
# Pins the SIMD numeric contract: f64v_fmadd computes a*b+c. On x86_64 it lowers
# to mulpd+addpd (two roundings) so it is BIT-IDENTICAL to scalar f64_mul+f64_add
# (tol 0). On aarch64 it is a fused fmla (one rounding) so it matches scalar only
# within rounding (~1e-16); we still pin it tightly (1e-12) to prove it computes
# a*b+c and not garbage. If x86 ever switches to a fused FMA this fails, flagging
# that the axpy paths are no longer bit-identical to scalar.
fn test_simd_contract(): i64 {
    rng_seed(4242);
    var a4[32]; var b4[32]; var c4[32];
    var tol = f64_from(0);
    #ifdef CYRIUS_ARCH_AARCH64
    tol = f64_div(f64_from(1), f64_from(1000000000000));   # 1e-12 (fused FMA)
    #endif
    var bad = 0; var i = 0;
    while (i < 5000) {
        var L = 0;
        while (L < 4) {
            store64(&a4 + L * 8, rng_normal());
            store64(&b4 + L * 8, rng_normal());
            store64(&c4 + L * 8, rng_normal());
            L = L + 1;
        }
        var e0 = f64_add(load64(&c4), f64_mul(load64(&a4), load64(&b4)));
        var e1 = f64_add(load64(&c4 + 8), f64_mul(load64(&a4 + 8), load64(&b4 + 8)));
        var e2 = f64_add(load64(&c4 + 16), f64_mul(load64(&a4 + 16), load64(&b4 + 16)));
        var e3 = f64_add(load64(&c4 + 24), f64_mul(load64(&a4 + 24), load64(&b4 + 24)));
        f64v_fmadd(&c4, &a4, &b4, &c4, 4);
        if (f64_gt(_rel(load64(&c4), e0), tol) == 1) { bad = bad + 1; }
        if (f64_gt(_rel(load64(&c4 + 8), e1), tol) == 1) { bad = bad + 1; }
        if (f64_gt(_rel(load64(&c4 + 16), e2), tol) == 1) { bad = bad + 1; }
        if (f64_gt(_rel(load64(&c4 + 24), e3), tol) == 1) { bad = bad + 1; }
        i = i + 1;
    }
    assert(bad == 0, "f64v_fmadd matches scalar mul+add (bit-exact x86 / within-rounding aarch64)");
    return 0;
}

# ---- token-store packing (1.5.3) -------------------------------------------
# Pins the packed g_data store: the width-generic accessors round-trip token ids
# at u8 (byte-level, vocab <= 256) and u16 (BPE, vocab <= 768); the storage width
# does NOT change the token-id values (the byte-identical-sampling guarantee);
# and bpe_learn self-widens a u8 corpus to u16. RNG-NEUTRAL (corpus_set/bpe_learn/
# gd_* draw nothing), so registered last without disturbing the pinned RNG stream.
fn test_token_packing(): i64 {
    # (a) direct accessor: low-byte store + zero-extended load at each width, incl.
    # the boundary ids (u8 max 255; u16 covers the full BPE range 0..767).
    var scratch = alloc(8);
    var save_data = g_data; var save_w = g_data_w;
    g_data = scratch;
    g_data_w = 1;
    gd_st(0, 255); gd_st(1, 0);
    assert(gd_ld(0) == 255, "pack u8: id 255 round-trips (low byte, zero-extended)");
    assert(gd_ld(1) == 0, "pack u8: id 0 round-trips");
    g_data_w = 2;
    gd_st(0, 767); gd_st(1, 256); gd_st(2, 0);
    assert(gd_ld(0) == 767, "pack u16: id 767 (max BPE vocab) round-trips");
    assert(gd_ld(1) == 256, "pack u16: id 256 round-trips");
    assert(gd_ld(2) == 0, "pack u16: id 0 round-trips");
    g_data = save_data; g_data_w = save_w;

    # (b) byte-level corpus at u8: the packed fill reads back the char2id base ids.
    g_data_w = 1;
    var V = build_corpus();
    var n = g_datalen;
    var ref = t_alloc(n);
    var bad8 = 0; var i = 0;
    while (i < n) {
        var want = load64(g_char2id + load8(g_text + i) * 8);
        store64(ref + i * 8, want);
        if (gd_ld(i) != want) { bad8 = bad8 + 1; }
        i = i + 1;
    }
    assert(bad8 == 0, "pack u8: byte-level corpus reads back the char2id ids");

    # (c) width-invariance: the SAME corpus at u16 yields IDENTICAL ids + counts.
    g_data_w = 2;
    var V2 = build_corpus();
    assert((V2 == V) && (g_datalen == n), "pack u16: same vocab + token count as u8");
    var bad16 = 0; i = 0;
    while (i < n) {
        if (gd_ld(i) != load64(ref + i * 8)) { bad16 = bad16 + 1; }
        i = i + 1;
    }
    assert(bad16 == 0, "pack u16: byte-level corpus reads back ids IDENTICAL to u8");

    # (d) bpe_learn self-widens a u8 corpus to u16; the merged stream stays in range
    # (ids reach base+merges-1 > 255, which only fit u16). Full byte-exact decode
    # round-trip is test_bpe_roundtrip; here we pin the widen + range.
    g_data_w = 1;
    build_corpus();
    var Vb = bpe_learn(16);
    assert(g_data_w == 2, "pack: bpe_learn widened the u8 store to u16");
    assert(Vb == g_bpe_base + g_bpe_nmerges, "pack: bpe vocab consistent after widen");
    var oor = 0; i = 0;
    while (i < g_datalen) {
        var id = gd_ld(i);
        if ((id < 0) || (id >= Vb)) { oor = oor + 1; }
        i = i + 1;
    }
    assert(oor == 0, "pack: widened u16 stream ids all in [0,V)");
    g_data_w = 1;   # restore the byte-level default
    return 0;
}

# Held-out eval core (X019 follow-on): eval_corpus_buf re-encodes an in-memory
# buffer through the LOADED tokenizer, swaps it in as the corpus, evals, restores.
# Pinned invariant: fed the training corpus's OWN raw bytes it must reproduce
# eval_corpus() BIT-FOR-BIT (same bytes + same tokenizer => same id stream => same
# nats/bytes) — the same idempotent re-encode the checkpoint loader relies on —
# for byte-level AND BPE, and a too-short buffer is rejected (not a crash).
# RNG-neutral (eval sets g_training = 0), so it is registered dead-last and leaves
# the shared stream intact.
fn test_eval_held(): i64 {
    g_data_w = 1;
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 19);
    train(4, 4, 2, _lrc(3, 1000), _lrc(3, 10000), 2, f64_from(1), 1000000000);
    var rng0 = _rng_state;
    var n1 = eval_corpus();
    var nats1 = g_eval_nats; var byt1 = g_eval_bytes;
    var dl = g_datalen; var dat = g_data;
    var nh = eval_corpus_buf(g_text, g_textlen);
    assert(nh == n1, "held-out of own bytes: same token count as eval_corpus");
    assert(g_eval_nats == nats1, "held-out of own bytes: nats bit-identical (byte-level)");
    assert(g_eval_bytes == byt1, "held-out of own bytes: byte count identical (byte-level)");
    assert((g_datalen == dl) && (g_data == dat), "held-out restores g_data/g_datalen");
    assert(_rng_state == rng0, "held-out eval is RNG-neutral");

    # BPE: the idempotent merge-replay must reproduce the merged-stream eval too
    g_data_w = 1;
    var Vb = bpe_learn(8);
    model_init(Vb, 8, 4, 2, 2, 1, 0, f64_from(0), 19);
    var nb = eval_corpus();
    var natsb = g_eval_nats; var bytb = g_eval_bytes;
    var nhb = eval_corpus_buf(g_text, g_textlen);
    assert(nhb == nb, "held-out (bpe) of own bytes: same token count");
    assert(g_eval_nats == natsb, "held-out (bpe) of own bytes: nats bit-identical");
    assert(g_eval_bytes == bytb, "held-out (bpe) of own bytes: byte count identical");

    # a buffer shorter than ctx+1 is rejected cleanly, never indexed out of bounds
    assert(eval_corpus_buf(g_text, 4) == (0 - 1), "held-out rejects a too-short corpus");
    g_data_w = 1;
    return 0;
}

# ---- M16 ternary (BitNet b1.58) grad-checks (E6, ADR 0014) -----------------
# The STE means the QUANTIZED weight gradient is deliberately NOT the finite
# difference of the piecewise-constant quantized forward (round/clip are treated
# as identity in backward). So we grad-check where the function IS differentiable
# (the dx path through the fixed W_eff, and the full-precision biases), and PIN
# the weight gradient by its STE definition (bit-exact pass-through) — mirroring
# the existing exact-zero/exact-equality pins (rope dX, posemb off-path).
fn qlin_loss(x, W, b, y, dy, M, K, N): i64 { qlinear_fwd(x, W, b, y, M, K, N); return dotsum(dy, y, M * N); }
fn test_ternary_quant(): i64 {
    var M = 3; var K = 4; var N = 5;
    var x = t_alloc(M * K); var W = t_alloc(K * N); var b = t_alloc(N);
    var y = t_alloc(M * N); var dy = t_alloc(M * N);
    t_randn(x, M * K, f64_from(1)); t_randn(W, K * N, f64_from(1));
    t_randn(b, N, f64_from(1)); t_randn(dy, M * N, f64_from(1));
    var dx = t_alloc(M * K); var dW = t_alloc(K * N); var db = t_alloc(N);
    # --- structural pins: gamma = absmean(W) > 0, W_eff in {-gamma, 0, +gamma} ---
    var Weff = t_alloc(K * N);
    ternary_quant(W, Weff, K, N);
    var s = f64_from(0); var i = 0;
    while (i < K * N) { s = f64_add(s, f64_abs(load64(W + i * 8))); i = i + 1; }
    var gamma = f64_div(s, f64_from(K * N));
    assert(f64_gt(gamma, f64_from(0)) == 1, "ternary gamma (absmean) > 0");
    # |W_eff| is gamma or 0 — sign-agnostic so a -0.0 (round of a small negative)
    # counts as the zero bucket. The value set is {-gamma, 0, +gamma}.
    var ok = 1; i = 0;
    while (i < K * N) {
        var av = f64_abs(load64(Weff + i * 8));
        if ((av != gamma) && (av != f64_from(0))) { ok = 0; }
        i = i + 1;
    }
    assert(ok == 1, "ternary |W_eff| in {gamma, 0}");
    # --- ternary ON: the quantizing wrappers ---
    g_ternary = 1; g_qscratch = t_alloc(K * N);
    qlinear_fwd(x, W, b, y, M, K, N);
    qlinear_bwd(x, W, dy, dx, dW, db, M, K, N);
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    # dx FD-check: the quantized forward is SMOOTH in x (W_eff is fixed as x varies),
    # so dx through W_eff matches central differences — the real grad-check.
    var ndx = t_alloc(M * K); i = 0;
    while (i < M * K) {
        var o = load64(x + i * 8);
        store64(x + i * 8, f64_add(o, eps)); var lp = qlin_loss(x, W, b, y, dy, M, K, N);
        store64(x + i * 8, f64_sub(o, eps)); var lm = qlin_loss(x, W, b, y, dy, M, K, N);
        store64(x + i * 8, o); store64(ndx + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("ternary dx (FD through W_eff)", dx, ndx, M * K, 100000);
    # db FD-check: the bias is full precision (qlinear passes it through unquantized).
    var ndb = t_alloc(N); i = 0;
    while (i < N) {
        var o = load64(b + i * 8);
        store64(b + i * 8, f64_add(o, eps)); var lp = qlin_loss(x, W, b, y, dy, M, K, N);
        store64(b + i * 8, f64_sub(o, eps)); var lm = qlin_loss(x, W, b, y, dy, M, K, N);
        store64(b + i * 8, o); store64(ndb + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("ternary db (full precision)", db, ndb, N, 100000);
    # dW STE pin: round/clip act as identity, so dW is EXACTLY linear_bwd's dW
    # (which never reads W) — pinned bit-for-bit against a plain linear backward. A
    # naive FD of dW through the quantized forward would be ~0 with spikes at the
    # quantization steps, NOT the STE gradient — which is exactly why it is a pin.
    g_ternary = 0;
    var dxp = t_alloc(M * K); var dWp = t_alloc(K * N); var dbp = t_alloc(N);
    linear_bwd(x, W, dy, dxp, dWp, dbp, M, K, N);
    var bitok = 1; i = 0;
    while (i < K * N) { if (load64(dW + i * 8) != load64(dWp + i * 8)) { bitok = 0; } i = i + 1; }
    assert(bitok == 1, "ternary dW == STE pass-through (bit-exact)");
    return 0;
}

# Full-model grad-check under ternary: the SMOOTH parameters (embeddings, final
# LN, biases) are differentiable through the FIXED W_eff, so their gradients
# FD-check normally — exercising the whole quantized fwd/bwd composition (the
# quantized weight gradients are pinned in test_ternary_quant, not FD'd here).
fn test_model_ternary(): i64 {
    var V = 5; var C = 4; var T = 3; var nh = 2; var NL = 2;
    g_ternary = 1;                                  # set BEFORE model_init (sizes g_qscratch)
    model_init(V, C, T, nh, nh, NL, 1, f64_from(0), 1);   # mha + dense + uniform + AR
    assert(g_ternary == 1, "ternary model active");
    assert(g_qscratch != 0, "ternary qscratch allocated");
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    model_forward(); model_zero_grads(); model_backward();
    var n_tok = V * C;
    var aTok = t_alloc(n_tok); t_copy(aTok, G_tokemb(), n_tok);
    var aPos = t_alloc(T * C); t_copy(aPos, G_posemb(), T * C);
    var aLnf = t_alloc(C); t_copy(aLnf, G_lnfg(), C);
    var abo0 = t_alloc(C); t_copy(abo0, G_bo(0), C);
    var nTok = t_alloc(n_tok); model_ng(P_tokemb(), nTok, n_tok);
    var nPos = t_alloc(T * C); model_ng(P_posemb(), nPos, T * C);
    var nLnf = t_alloc(C); model_ng(P_lnfg(), nLnf, C);
    var nbo0 = t_alloc(C); model_ng(P_bo(0), nbo0, C);
    check("ternary model dtokemb", aTok, nTok, n_tok, 10000);
    check("ternary model dposemb", aPos, nPos, T * C, 10000);
    check("ternary model dlnf_g", aLnf, nLnf, C, 10000);
    check("ternary model L0 dbo", abo0, nbo0, C, 10000);
    g_ternary = 0;                                  # restore (no later test expects ternary)
    return 0;
}

# Ternary checkpoint round-trip (v8) + hostile rejections. A ternary model is
# uniform AR MHA dense — it serializes as v8 (objective [22] + ternary [23]); a
# non-ternary model still writes v5. The loader restores g_ternary and rejects a
# hostile v8 (ternary out of {0,1} -> -48; ternary + a non-scope axis -> -49).
fn test_ckpt_ternary(): i64 {
    var V = build_corpus();
    g_ternary = 0;
    model_init(V, 8, 4, 2, 2, 1, 1, f64_from(0), 5);
    assert(CKPT_VER() == 5, "non-ternary AR still serializes as v5 after M16");
    g_ternary = 1;
    model_init(V, 8, 4, 2, 2, 2, 1, f64_from(0), 33);            # ternary, NL=2
    assert(g_ternary == 1, "ternary model built");
    assert(CKPT_VER() == 8, "ternary serializes as v8");
    var np = g_NP;
    var snap = t_alloc(np); t_copy(snap, g_params, np);
    var sz = ckpt_size();
    var ck = alloc(sz); ckpt_serialize(ck);
    assert(load64(ck + 1 * 8) == 8, "version field = 8");
    assert(load64(ck + 22 * 8) == 0, "objective = AR recorded at [22]");
    assert(load64(ck + 23 * 8) == 1, "ternary recorded at [23]");
    g_ternary = 0;
    model_init(V, 8, 4, 2, 2, 2, 1, f64_from(0), 61);            # scramble to non-ternary
    assert(g_ternary == 0, "reset to non-ternary");
    assert(ckpt_load_buf(ck, sz) == 0, "v8 ternary checkpoint loads");
    assert(g_ternary == 1, "ternary restored");
    assert(g_NP == np, "NP restored");
    var mism = 0; var i = 0;
    while (i < np) { if (load64(g_params + i * 8) != load64(snap + i * 8)) { mism = mism + 1; } i = i + 1; }
    assert(mism == 0, "v8 params restored bit-for-bit");
    var bad = alloc(sz);
    t_copy(bad, ck, sz / 8); store64(bad + 23 * 8, 2);          # ternary out of {0,1}
    assert(ckpt_load_buf(bad, sz) == (0 - 48), "ternary=2 rejected (-48)");
    t_copy(bad, ck, sz / 8); store64(bad + 17 * 8, 1);          # ternary + rope (pos_kind=1)
    assert(ckpt_load_buf(bad, sz) == (0 - 49), "ternary + rope rejected (-49)");
    g_ternary = 0;
    return 0;
}

# M16 increment 2: the i64-add ternary matmul kernel (E6, ADR 0014). x·W_eff =
# γ·(x·t), t∈{−1,0,+1} — the multiply collapses to add/subtract/skip plus ONE
# γ-scale per output. Triangulated: (a) the collapse forward equals the SIMD-f64
# W_eff matmul (same math, different rounding), (b) the collapse dx equals the
# W_eff dx, and (c) dx FD-checks through the collapse forward. dW is the unchanged
# STE pass-through already pinned in test_ternary_quant.
fn tmm_loss(x, t, gamma, b, y, dy, M, K, N): i64 {
    ternary_matmul_fwd(x, t, gamma, b, y, M, K, N); return dotsum(dy, y, M * N);
}
fn test_ternary_matmul(): i64 {
    var M = 3; var K = 4; var N = 5;
    var x = t_alloc(M * K); var W = t_alloc(K * N); var b = t_alloc(N);
    var y = t_alloc(M * N); var yr = t_alloc(M * N); var dy = t_alloc(M * N);
    t_randn(x, M * K, f64_from(1)); t_randn(W, K * N, f64_from(1));
    t_randn(b, N, f64_from(1)); t_randn(dy, M * N, f64_from(1));
    var t = t_alloc(K * N); var Weff = t_alloc(K * N);
    var gamma = ternary_signs(W, t, K, N);
    ternary_quant(W, Weff, K, N);
    # γ·t reproduces W_eff (same absmean + round/clamp as the wrapper). Value-exact,
    # not bit-pattern: a weight whose round gives −0.0 yields W_eff = γ·(−0.0) = −0.0,
    # which the sign-bucket treats as the +0.0 zero — equal in value, not in bits.
    var bitok = 1; var i = 0;
    while (i < K * N) {
        var ti = load64(t + i * 8); var ev = f64_from(0);
        if (ti == 1) { ev = gamma; }
        if (ti == (0 - 1)) { ev = f64_mul(gamma, f64_from(0 - 1)); }
        if (f64_abs(f64_sub(load64(Weff + i * 8), ev)) != f64_from(0)) { bitok = 0; }
        i = i + 1;
    }
    assert(bitok == 1, "ternary signs * gamma == W_eff (value-exact)");
    # (a) collapse forward == SIMD-f64 W_eff matmul. The two sides are INDEPENDENT
    # implementations — ternary_matmul_fwd (scalar add/sub/skip, γ factored out) vs
    # rosnet linear_fwd (4-wide f64v_fmadd over an independently-built W_eff) — so this
    # is a real cross-check, not a tautology. They agree to maxrel 0 here only because
    # γ·(Σx·t) and Σx·(γ·t) coincide to sub-ULP at this small shape; (c)'s FD remains the
    # independent gradient oracle regardless.
    ternary_matmul_fwd(x, t, gamma, b, y, M, K, N);
    linear_fwd(x, Weff, b, yr, M, K, N);
    check("ternary-matmul fwd == W_eff", y, yr, M * N, 1000000);
    # (b) collapse dx == SIMD-f64 W_eff dx — again two independent paths (an FD-free pin)
    var dx = t_alloc(M * K); var dxr = t_alloc(M * K);
    var dWr = t_alloc(K * N); var dbr = t_alloc(N);
    ternary_matmul_dx(t, gamma, dy, dx, M, K, N);
    linear_bwd(x, Weff, dy, dxr, dWr, dbr, M, K, N);
    check("ternary-matmul dx == W_eff dx", dx, dxr, M * K, 1000000);
    # (c) dx FD through the collapse forward (smooth in x — the real grad-check)
    var eps = _eps(); var te = f64_mul(f64_from(2), eps);
    var ndx = t_alloc(M * K); i = 0;
    while (i < M * K) {
        var o = load64(x + i * 8);
        store64(x + i * 8, f64_add(o, eps)); var lp = tmm_loss(x, t, gamma, b, y, dy, M, K, N);
        store64(x + i * 8, f64_sub(o, eps)); var lm = tmm_loss(x, t, gamma, b, y, dy, M, K, N);
        store64(x + i * 8, o); store64(ndx + i * 8, f64_div(f64_sub(lp, lm), te)); i = i + 1;
    }
    check("ternary-matmul dx (FD)", dx, ndx, M * K, 100000);
    return 0;
}

# Streaming token-shard ingestion (1.6.x). Pins the gate: a model trained from a
# STREAMED shard is BIT-FOR-BIT identical to one trained on the same corpus
# in-memory (gd_ld is the only token reader, so the chunk cache returning the same
# ids leaves every sampling/eval path unchanged), and a shard round-trips its token
# stream byte-exactly at byte + BPE width. Uses real /tmp shard files — the genuine
# open/lseek/read path, like test_ckpt_file_roundtrip — and forces a tiny chunk cap
# to exercise multi-chunk reloads + offset seeks across the corpus. RNG-consuming
# (it trains) and reseeds via model_init, so registered DEAD-LAST (X019/X015).
fn test_stream_ingest(): i64 {
    g_stream = 0; g_data_w = 1;
    var sp = "/tmp/attn11-stream-rt.tsh";

    # (a) byte-identity: in-memory train vs streamed train, same corpus + seed.
    var V = build_corpus();
    model_init(V, 8, 4, 2, 2, 1, 0, f64_from(0), 7);
    train(20, 20, 4, _lrc(3, 1000), _lrc(3, 10000), 5, f64_from(1), 1000000000);
    var npA = g_NP;
    var snapA = t_alloc(npA); t_copy(snapA, g_params, npA);
    # write a shard from the (still-intact) in-memory corpus, then stream from it
    assert(shard_save_file(sp, V) == 0, "shard_save_file writes ok");
    var Vs = shard_open(sp);
    assert(Vs == V, "shard_open returns the same vocab size");
    assert((g_stream == 1) && (g_data == 0), "shard_open enters streaming (tokens not in RAM)");
    model_init(Vs, 8, 4, 2, 2, 1, 0, f64_from(0), 7);
    train(20, 20, 4, _lrc(3, 1000), _lrc(3, 10000), 5, f64_from(1), 1000000000);
    var mism = 0; var i = 0;
    while (i < g_NP) { if (load64(g_params + i * 8) != load64(snapA + i * 8)) { mism = mism + 1; } i = i + 1; }
    assert(g_NP == npA, "streamed param count matches");
    assert(mism == 0, "streamed training reproduces in-memory params BIT-FOR-BIT");
    file_close(g_stream_fd); g_stream = 0;

    # (b) round-trip fidelity, byte-level, ACROSS CHUNK BOUNDARIES: capture the
    # in-memory ids, encode, reopen with a tiny chunk cap, compare every streamed id.
    g_data_w = 1;
    var V2 = build_corpus();
    var n = g_datalen;
    var ref = t_alloc(n);
    i = 0; while (i < n) { store64(ref + i * 8, gd_ld(i)); i = i + 1; }
    assert(shard_save_file(sp, V2) == 0, "shard_save_file (fidelity) writes ok");
    assert(shard_open(sp) == V2, "shard_open (fidelity) ok");
    g_stream_cap = 7; g_stream_lo = 0 - 1; g_stream_clen = 0;   # force multi-chunk reloads
    var bad = 0; i = 0;
    while (i < n) { if (gd_ld(i) != load64(ref + i * 8)) { bad = bad + 1; } i = i + 1; }
    assert(bad == 0, "streamed byte ids match in-memory across chunk boundaries");
    file_close(g_stream_fd); g_stream = 0; g_stream_cap = STREAM_CHUNK();

    # (c) round-trip fidelity, BPE (u16) width.
    g_data_w = 1;
    build_corpus();
    var Vb = bpe_learn(16);
    var nb = g_datalen;
    var refb = t_alloc(nb);
    i = 0; while (i < nb) { store64(refb + i * 8, gd_ld(i)); i = i + 1; }
    assert(shard_save_file(sp, Vb) == 0, "shard_save_file (bpe) writes ok");
    assert(shard_open(sp) == Vb, "shard_open (bpe) ok");
    assert(g_data_w == 2, "bpe shard streams at u16 width");
    g_stream_cap = 5; g_stream_lo = 0 - 1; g_stream_clen = 0;
    var badb = 0; i = 0;
    while (i < nb) { if (gd_ld(i) != load64(refb + i * 8)) { badb = badb + 1; } i = i + 1; }
    assert(badb == 0, "streamed bpe ids match in-memory across chunk boundaries");
    file_close(g_stream_fd); g_stream = 0; g_stream_cap = STREAM_CHUNK();

    # (d) hostile metadata: shard_validate_buf rejects cleanly, no crash/alloc.
    var meta = t_alloc(16);
    store64(meta + 0 * 8, SHARD_MAGIC()); store64(meta + 1 * 8, 1);
    store64(meta + 2 * 8, 0); store64(meta + 3 * 8, 3);    # tok_kind byte, Vb 3
    store64(meta + 4 * 8, 0); store64(meta + 5 * 8, 3);    # K 0, V 3
    store64(meta + 6 * 8, 1); store64(meta + 7 * 8, 100);  # width 1, ntok 100
    store64(meta + 8 * 8, 97); store64(meta + 9 * 8, 98); store64(meta + 10 * 8, 99);  # vocab bytes
    assert(shard_validate_buf(meta, 11 * 8) == 0, "valid shard metadata accepted");
    store64(meta + 0 * 8, SHARD_MAGIC() + 1);
    assert(shard_validate_buf(meta, 11 * 8) == (0 - 60), "bad magic rejected (-60)");
    store64(meta + 0 * 8, SHARD_MAGIC());
    store64(meta + 1 * 8, 2);
    assert(shard_validate_buf(meta, 11 * 8) == (0 - 61), "bad version rejected (-61)");
    store64(meta + 1 * 8, 1);
    store64(meta + 5 * 8, 4);
    assert(shard_validate_buf(meta, 11 * 8) == (0 - 65), "V != Vb+K rejected (-65)");
    store64(meta + 5 * 8, 3);
    store64(meta + 6 * 8, 2);            # byte-level shard must be width 1
    assert(shard_validate_buf(meta, 11 * 8) == (0 - 66), "byte-level width!=1 rejected (-66)");
    store64(meta + 6 * 8, 1);
    assert(shard_validate_buf(meta, 4 * 8) == (0 - 60), "too-short metadata rejected (-60)");

    _unlink(sp);
    g_stream = 0; g_data_w = 1;          # restore defaults
    return 0;
}

# Resume-from-stream (1.6.3): a checkpoint saved mid-stream, reloaded against the
# SAME shard, must continue BIT-FOR-BIT — train(K) continuous == train(K1) ->
# checkpoint round-trip -> train(K), all streamed. Mirrors test_resume_determinism
# but with the corpus on disk (g_data == 0, g_stream == 1): the loader verifies the
# shard's full tokenizer against the checkpoint's (g_stream branch in ckpt_load_buf)
# and resumes without re-encoding. Also pins the mismatch rejection (-15). Uses a
# real /tmp shard; RNG-consuming + model_init-reseeding, so registered DEAD-LAST.
fn test_resume_stream(): i64 {
    g_stream = 0; g_data_w = 1;
    var sp = "/tmp/attn11-resume-stream.tsh";
    var V = build_corpus();
    assert(shard_save_file(sp, V) == 0, "resume-stream: shard written");
    assert(shard_open(sp) == V, "resume-stream: shard opened");
    var C = 8; var T = 4; var nh = 2; var nkv = 2; var NL = 2;
    var base = _lrc(3, 1000); var minl = _lrc(3, 10000); var clip = f64_from(1);
    var K = 24; var K1 = 9; var B = 4; var warm = 5; var quiet = 1000000000;

    # Path A: one continuous streamed run to K (horizon = K)
    model_init(V, C, T, nh, nkv, NL, 0, f64_from(0), 7);
    train(K, K, B, base, minl, warm, clip, quiet);
    var npA = g_NP;
    var snapA = t_alloc(npA); t_copy(snapA, g_params, npA);

    # Path B: streamed to K1, in-memory checkpoint round-trip, then continue to K
    model_init(V, C, T, nh, nkv, NL, 0, f64_from(0), 7);
    train(K1, K, B, base, minl, warm, clip, quiet);
    var sz = ckpt_size();
    var buf = alloc(sz);
    ckpt_serialize(buf);
    model_init(V, C, T, nh, nkv, NL, 0, f64_from(0), 999);   # scramble to a different seed
    var rc = ckpt_load_buf(buf, sz);                         # resume-from-stream (g_stream != 0)
    train(K, K, B, base, minl, warm, clip, quiet);
    var mism = 0; var i = 0;
    while (i < g_NP) { if (load64(g_params + i * 8) != load64(snapA + i * 8)) { mism = mism + 1; } i = i + 1; }
    assert(rc == 0, "resume-stream: ckpt_load_buf ok under streaming");
    assert(g_NP == npA, "resume-stream: param count matches");
    assert(g_step == K, "resume-stream: step counter reaches K");
    assert(mism == 0, "resume-stream: reproduces params BIT-FOR-BIT");

    # mismatch: flip the checkpoint's FIRST base-vocab byte (slot CKPT_HDR(); this
    # uniform byte image is v5, no per-layer region) to a different valid 0..255
    # value. np/size stay valid, so the streaming branch's vocab check fires (-15) —
    # a shard whose tokenizer differs from the checkpoint's must not load.
    var vorig = load64(buf + CKPT_HDR() * 8);
    var valt = 0; if (vorig == 0) { valt = 1; }
    store64(buf + CKPT_HDR() * 8, valt);
    assert(ckpt_load_buf(buf, sz) == (0 - 15), "resume-stream: tokenizer mismatch rejected (-15)");

    file_close(g_stream_fd); g_stream = 0;
    _unlink(sp);
    g_data_w = 1;
    return 0;
}

# Streaming BPE encode (1.6.4): a shard produced by the chunked, carry-based
# streaming encoder must be byte-identical to a whole-corpus in-RAM encode through
# the same merges. Uses a ~6 KB synthetic corpus and a TINY forced chunk (7 bytes)
# so the carry runs across hundreds of boundaries — the strongest exactness stress
# for the "greedy-LTR BPE is prefix-stable except within one token of the edge"
# property the carry relies on. RNG-neutral (no model/RNG); dead-last by convention.
fn test_stream_bpe_encode(): i64 {
    g_stream = 0; g_data_w = 1;
    var cpath = "/tmp/attn11-se-in.txt";
    var spath = "/tmp/attn11-se.tsh";
    # a repetitive synthetic corpus (BPE finds real merges; repetition stresses the
    # parity / boundary cases that naive chunking would get wrong)
    var n = 6000;
    var txt = alloc(n);
    var src = "the quick brown fox jumps over the lazy dog and then runs away . ";
    var sl = strlen(src);
    var k = 0;
    while (k < n) { store8(txt + k, load8(src + (k % sl))); k = k + 1; }
    var V = corpus_set(txt, n);
    var Vb = bpe_learn(24);
    var nref = g_datalen;
    var ref = t_alloc(nref);
    var i = 0; while (i < nref) { store64(ref + i * 8, gd_ld(i)); i = i + 1; }
    assert(secure_write_atomic(cpath, txt, n) == n, "se: wrote input file");
    g_stream_enc_chunk = 7;                       # tiny chunk -> hundreds of carry boundaries
    var nt = shard_stream_encode(cpath, spath, 24);
    g_stream_enc_chunk = 0;
    assert(nt == nref, "se: streamed token count == whole-corpus encode");
    assert(shard_open(spath) == Vb, "se: streamed shard opens with the same vocab");
    g_stream_cap = 5; g_stream_lo = 0 - 1; g_stream_clen = 0;
    var bad = 0; i = 0;
    while (i < nref) { if (gd_ld(i) != load64(ref + i * 8)) { bad = bad + 1; } i = i + 1; }
    assert(bad == 0, "se: streamed BPE ids byte-identical to whole-corpus encode across chunks");
    file_close(g_stream_fd); g_stream = 0; g_stream_cap = STREAM_CHUNK();
    # byte-level streaming encode (no merges, no carry) is exact too
    g_data_w = 1;
    corpus_set(txt, n);
    var nbyte = g_datalen;
    g_stream_enc_chunk = 13;
    var ntb = shard_stream_encode(cpath, spath, 0);
    g_stream_enc_chunk = 0;
    assert(ntb == nbyte, "se: byte-level streamed token count == corpus length");
    assert(shard_open(spath) == V, "se: byte-level streamed shard vocab matches");
    file_close(g_stream_fd); g_stream = 0;
    _unlink(cpath); _unlink(spath);
    g_data_w = 1;
    return 0;
}

# REINFORCE policy-gradient backward (M17). The RL gradient is the softmax-CE
# backward over a FIXED rollout SCALED by the advantage (R - b) = g_reinforce_scale,
# injected at D_logits in model_backward (gated on g_rl). Pins: (a) the RL gradient
# equals advantage * the AR gradient element-wise (to rounding) — the scale is exact
# and linear; (b) the full chain finite-difference-checks against the numeric
# gradient of (advantage * CE); (c) a negative advantage flips the sign and a zero
# advantage gives a zero gradient. Dense model (no MoE aux), fixed A_tokens/A_targets.
fn test_rl_op(): i64 {
    var V = 5; var C = 4; var T = 3; var nh = 2; var NL = 2;
    model_init(V, C, T, nh, nh, NL, 1, f64_from(0), 1);   # mha + dense + uniform + AR
    g_training = 0;
    store64(A_tokens + 0, 1); store64(A_tokens + 8, 3); store64(A_tokens + 16, 0);
    store64(A_targets + 0, 3); store64(A_targets + 8, 0); store64(A_targets + 16, 4);
    var nTok = V * C;
    var c = f64_div(f64_from(3), f64_from(2));            # advantage +1.5

    # (a) RL gradient == advantage * AR gradient (one forward, two backwards)
    model_forward();
    g_rl = 0; model_zero_grads(); model_backward();
    var arTok = t_alloc(nTok); t_copy(arTok, G_tokemb(), nTok);
    var arLnf = t_alloc(C); t_copy(arLnf, G_lnfg(), C);
    g_rl = 1; g_reinforce_scale = c; model_zero_grads(); model_backward();
    var expTok = t_alloc(nTok); t_copy(expTok, arTok, nTok); t_scale(expTok, nTok, c);
    var expLnf = t_alloc(C); t_copy(expLnf, arLnf, C); t_scale(expLnf, C, c);
    check("rl grad == adv*AR (dtokemb)", G_tokemb(), expTok, nTok, 1000000);
    check("rl grad == adv*AR (dlnf_g)", G_lnfg(), expLnf, C, 1000000);

    # (b) FD: RL gradient == numeric gradient of (advantage * CE)
    g_rl = 1; g_reinforce_scale = c;
    model_forward(); model_zero_grads(); model_backward();
    var aTok = t_alloc(nTok); t_copy(aTok, G_tokemb(), nTok);
    var aLnf = t_alloc(C); t_copy(aLnf, G_lnfg(), C);
    g_rl = 0;                                             # model_ng FDs the raw CE; scale by c
    var nTokn = t_alloc(nTok); model_ng(P_tokemb(), nTokn, nTok); t_scale(nTokn, nTok, c);
    var nLnfn = t_alloc(C); model_ng(P_lnfg(), nLnfn, C); t_scale(nLnfn, C, c);
    check("rl grad FD (dtokemb)", aTok, nTokn, nTok, 10000);
    check("rl grad FD (dlnf_g)", aLnf, nLnfn, C, 10000);

    # (c) negative advantage negates the gradient (IEEE negation of the seed is
    # exact + linear, so -adv gives the exact negation of the +adv gradient aTok)
    g_rl = 1; g_reinforce_scale = f64_neg(c);
    model_forward(); model_zero_grads(); model_backward();
    var negTok = t_alloc(nTok); t_copy(negTok, aTok, nTok); t_scale(negTok, nTok, f64_neg(f64_from(1)));
    check("rl grad: -adv negates (dtokemb)", G_tokemb(), negTok, nTok, 1000000);
    # zero advantage -> zero gradient
    g_rl = 1; g_reinforce_scale = f64_from(0);
    model_forward(); model_zero_grads(); model_backward();
    var zsum = f64_from(0); var zi = 0;
    while (zi < nTok) { zsum = f64_add(zsum, f64_abs(load64(G_tokemb() + zi * 8))); zi = zi + 1; }
    assert(zsum == f64_from(0), "rl: zero advantage -> zero gradient");
    g_rl = 0; g_reinforce_scale = f64_from(0);
    return 0;
}

# REINFORCE rollout sampler (M17): rl_rollout autoregressively samples T actions
# and lays them out as AR (A_tokens[t]=x_t, A_targets[t]=x_{t+1}) so softmax-CE over
# them is -log pi of the rollout. Pins the layout consistency, that actions are
# in-vocab, and that rl_reward / rl_prompt behave. RNG-consuming (sampling).
fn test_rl_rollout(): i64 {
    g_stream = 0; g_data_w = 1;
    var V = build_corpus();
    model_init(V, 8, 6, 2, 2, 2, 1, f64_from(0), 5);     # small AR model, ctx 6
    g_training = 0;
    rl_rollout(1, f64_from(1));                           # prompt token 1 (in vocab)
    var T = g_T;
    assert(load64(A_tokens) == 1, "rl_rollout: A_tokens[0] == prompt");
    var consist = 1; var t = 0;
    while (t < T - 1) { if (load64(A_tokens + (t + 1) * 8) != load64(A_targets + t * 8)) { consist = 0; } t = t + 1; }
    assert(consist == 1, "rl_rollout: A_tokens[t+1] == A_targets[t]");
    var oor = 0; t = 0;
    while (t < T) { var a = load64(A_targets + t * 8); if ((a < 0) || (a >= V)) { oor = oor + 1; } t = t + 1; }
    assert(oor == 0, "rl_rollout: all sampled actions in [0,V)");
    var tgt = load64(A_targets);
    var manual = 0; t = 0;
    while (t < T) { if (load64(A_targets + t * 8) == tgt) { manual = manual + 1; } t = t + 1; }
    assert(rl_reward(tgt) == f64_from(manual), "rl_reward: counts target occurrences");
    var p = rl_prompt();
    assert((p >= 0) && (p < V), "rl_prompt: returns a valid corpus token id");
    g_data_w = 1;
    return 0;
}

fn main(): i64 {
    alloc_init();
    rng_seed(123);
    test_group("ops grad-check");
    test_linear();
    test_layernorm();
    test_gelu();
    test_softmax_xent();
    test_dropout();
    test_moe_op();
    test_moe_aux();
    test_simd_contract();
    test_group("attention grad-check");
    test_attention();
    test_attention_mla();
    test_attention_mla_dec();
    test_lin_core();
    test_ssm_core();
    test_rope_op();
    test_attention_rope();
    test_group("full-model grad-check");
    test_model();
    test_model_gqa();
    test_model_mla();
    test_model_rope();
    test_model_mla_dec();
    test_model_moe();
    test_model_lin();
    test_model_ssm();
    test_model_hybrid();
    test_model_hybrid_ssm();
    test_model_hybrid_mla();
    test_head_tail();
    test_group("persistence");
    test_resume_determinism();
    test_resume_dropout();
    test_resume_gqa();
    test_ckpt_file_roundtrip();
    test_param_layout();
    test_param_layout_mla();
    test_param_layout_mla_dec();
    test_param_layout_moe();
    test_alloc_accounting();
    test_config_caps();
    test_ckpt_reject();
    test_ckpt_gqa_roundtrip();
    test_ckpt_mla_roundtrip();
    test_ckpt_rope();
    test_ckpt_dec();
    test_ckpt_v1_compat();
    test_ckpt_v2_compat();
    test_ckpt_v3_compat();
    test_ckpt_v4_compat();
    test_ckpt_v4_descriptor();
    test_ckpt_moe();
    test_ckpt_lin();
    test_ckpt_ssm();
    test_ckpt_hybrid();
    test_ckpt_vocab_mismatch();
    test_group("bpe tokenizer");
    test_bpe_known();
    test_bpe_roundtrip();
    test_bpe_determinism();
    test_eval_bpb();
    test_ckpt_v3_roundtrip();
    test_ckpt_v3_reject();
    test_resume_bpe();
    test_bpe_generate();
    test_group("kv-cached generation");
    test_kv_generation();
    test_kv_preset();
    test_kv_vocab300();
    test_kv_mla();
    test_kv_moe();
    test_kv_lin();
    test_kv_ssm();
    test_kv_hybrid();
    test_kv_rope();
    test_kv_dec();
    test_group("robustness");
    test_soak();
    test_nan_guard();
    # M15 char-diffusion — registered LAST so the shared RNG stream the earlier
    # tests are tuned to (e.g. the MoE op test's comfortable top-K margin) is
    # byte-for-byte unchanged from before this milestone.
    test_group("char-diffusion (M15)");
    test_masked_ce();
    test_attn_bidir();
    test_model_diffusion();
    test_model_mtp();
    test_diffusion_decode_determinism();
    test_ckpt_diffusion();
    # RNG-neutral, so dead-last is safe and keeps the diffusion group's stream intact
    test_group("token packing (1.5.3)");
    test_token_packing();
    # RNG-neutral (g_training = 0 during eval), so dead-last keeps every earlier
    # test's shared-stream position byte-for-byte unchanged (X019 follow-on).
    test_group("held-out eval (1.5.x)");
    test_eval_held();
    # M16 ternary (E6) — registered LAST. model_init reseeds the RNG, but the op
    # test consumes the ambient stream, so dead-last keeps every earlier test's
    # shared-stream position byte-for-byte unchanged (the X019/X015 discipline).
    test_group("ternary / BitNet (M16)");
    test_ternary_quant();
    test_model_ternary();
    test_ckpt_ternary();
    test_ternary_matmul();
    # Streaming token-shard ingestion (1.6.x) — RNG-consuming + model_init-reseeding,
    # so dead-last keeps every earlier test's shared-stream position byte-for-byte
    # unchanged (the X019/X015 discipline).
    test_group("streaming token-shard (1.6.x)");
    test_stream_ingest();
    # resume-from-stream (1.6.3) — also RNG-consuming + model_init-reseeding, dead-last.
    test_resume_stream();
    # streaming BPE encode (1.6.4) — RNG-neutral (tokenizer only), dead-last by convention.
    test_stream_bpe_encode();
    # REINFORCE policy gradient (M17, E9) — RNG-consuming + model_init-reseeding, dead-last.
    test_group("reinforcement learning (M17)");
    test_rl_op();
    test_rl_rollout();
    return assert_summary();
}

# Statement-call epilogue (not a `var` initializer) — see docs/architecture/002.
var exit_code = 0;
exit_code = main();
sys_exit(exit_code);
