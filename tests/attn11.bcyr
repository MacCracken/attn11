# attn11 benchmarks — model hot paths.
#
# Measures the real training-step cost (matmul-dominated) so SIMD work can be
# tracked before/after. Uses now_ns() (clock_gettime CLOCK_MONOTONIC_RAW)
# deltas around N-iteration loops; the ~120 ns/call clock overhead amortizes to
# nothing against the ms-scale ops measured.

include "lib/tyche.cyr"          # extracted PRNG (rng_*, _rng_state)
include "lib/rosnet.cyr"         # extracted tensor/BLAS-1/matmul (+ gradient)
include "lib/rupantara.cyr"      # ru_* forward leaf ops (M1 re-fold)
# mabda (Linux-only GPU dep) auto-prepends from [deps.mabda] on all targets; on AGNOS it is
# dead code but still references SYS_IOCTL (absent from the agnos syscall peer) — define it so
# the auto-prepended dep compiles. The GPU backend (rosnet's [lib.gpu] bundle, also auto-prepended)
# consumes it; g_gpu==0 here regardless → the CPU oracle path, byte-identical.
#ifdef CYRIUS_TARGET_AGNOS
var SYS_IOCTL = 16;
#endif
# 1.10.0 (ADR 0017): the GPU backend is rosnet's dist/rosnet-gpu.cyr, auto-prepended from
# [deps.rosnet]; no manual include. The gpu_* CALLS stay AGNOS-gated in src/.
include "src/tensor.cyr"
include "src/fileio.cyr"
include "lib/akshara.cyr"
include "src/ops.cyr"
include "src/attn.cyr"
include "src/attn_linear.cyr"
include "src/attn_ssm.cyr"
include "src/model.cyr"
include "src/train.cyr"

# print "<label>: <ns/op> ns/op" given total ns over `iters`
fn _report(label, total, iters): i64 {
    print(label, strlen(label));
    print(": ", 2);
    fmt_int(total / iters);
    print(" ns/op\n", 7);
    return 0;
}

fn main(): i64 {
    alloc_init();
    var V = build_corpus();
    model_init(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337);
    var C = g_C; var F = g_F; var T = g_T;

    # prime caches
    model_forward(); model_zero_grads(); model_backward();

    # ---- isolated linear (MLP fc size: T x C x F) ----
    var x = t_alloc(T * C); var W = t_alloc(C * F); var bvec = t_alloc(F); var y = t_alloc(T * F);
    t_randn(x, T * C, f64_from(1)); t_randn(W, C * F, f64_from(1)); t_randn(bvec, F, f64_from(1));
    var NL1 = 2000;
    var s = now_ns(); var i = 0;
    while (i < NL1) { linear_fwd(x, W, bvec, y, T, C, F); i = i + 1; }
    var e = now_ns();
    _report("linear_fwd TxCxF ", e - s, NL1);

    # ---- TERNARY i64-add matmul (M16 increment 2, E6): the BitNet collapse
    # x·W_eff = γ·(x·t), t∈{−1,0,+1}, benched HEAD-TO-HEAD against the SIMD-f64
    # W_eff path (the 1.6.0 ternary forward) at the SAME T×C×F shape. Two surfaces:
    #   matmul-only  — linear_fwd(W_eff)         vs ternary_matmul_fwd(signs)
    #   end-to-end   — quant + linear_fwd        vs signs + ternary_matmul_fwd
    # The end-to-end is the decision-relevant number (which path the forward should
    # use). f64v_fmadd is 4-wide; the collapse is scalar add/sub/skip — see X023.
    var tsig = t_alloc(C * F); var Weff = t_alloc(C * F);
    var gam = ternary_signs(W, tsig, C, F);          # γ + i64 signs of W
    ternary_quant(W, Weff, C, F);                     # the 1.6.0 W_eff
    s = now_ns(); i = 0; while (i < NL1) { linear_fwd(x, Weff, bvec, y, T, C, F); i = i + 1; } e = now_ns();
    var sf_mm = (e - s) / NL1;
    _report("  ternary SIMD-f64 mm ", e - s, NL1);
    s = now_ns(); i = 0; while (i < NL1) { ternary_matmul_fwd(x, tsig, gam, bvec, y, T, C, F); i = i + 1; } e = now_ns();
    var ia_mm = (e - s) / NL1;
    _report("  ternary i64-add  mm ", e - s, NL1);
    puts("  i64-add / SIMD-f64 matmul (x100): "); fmt_int(ia_mm * 100 / sf_mm); _putc(10);
    s = now_ns(); i = 0; while (i < NL1) { ternary_quant(W, Weff, C, F); linear_fwd(x, Weff, bvec, y, T, C, F); i = i + 1; } e = now_ns();
    var sf_e2e = (e - s) / NL1;
    _report("  ternary SIMD-f64 e2e", e - s, NL1);
    s = now_ns(); i = 0; while (i < NL1) { ternary_signs(W, tsig, C, F); ternary_matmul_fwd(x, tsig, gam, bvec, y, T, C, F); i = i + 1; } e = now_ns();
    var ia_e2e = (e - s) / NL1;
    _report("  ternary i64-add  e2e", e - s, NL1);
    puts("  i64-add / SIMD-f64 end-to-end (x100): "); fmt_int(ia_e2e * 100 / sf_e2e); _putc(10);

    # ---- forward / backward / full step ----
    var N = 200;
    s = now_ns(); i = 0; while (i < N) { model_forward(); i = i + 1; } e = now_ns();
    _report("model_forward    ", e - s, N);

    s = now_ns(); i = 0; while (i < N) { model_backward(); i = i + 1; } e = now_ns();
    _report("model_backward   ", e - s, N);

    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    var step_ns = (e - s) / N;
    _report("fwd+bwd step     ", e - s, N);

    # ---- Adam step (once per optimizer step over NP params) ----
    var NA = 500;
    var lr = f64_div(f64_from(1), f64_from(1000));
    s = now_ns(); i = 0; while (i < NA) { model_adam_step(lr, i + 1); i = i + 1; } e = now_ns();
    _report("adam_step (NP)   ", e - s, NA);

    # ---- derived: tokens/sec for a batch=16 optimizer step ----
    # one optimizer step ~= 16*(fwd+bwd); tokens = batch*T = 16*T
    var opt_ns = 16 * step_ns;
    var toks = 16 * T;
    # tok/s = toks / (opt_ns / 1e9) = toks * 1e9 / opt_ns
    print("tokens/sec (b=16): ", 19);
    fmt_int(toks * 1000000000 / opt_ns);
    _putc(10);

    # ---- generation: uncached window-forward vs KV-cached decode (E1) ----
    # Both paths share semantics (and are bit-identical — see tests); the
    # uncached path recomputes the whole window per token, the cached path
    # runs one row per token plus a re-prime every GEN_SHIFT() tokens.
    g_training = 0;
    var NGEN = 500;
    var pids = t_alloc(1); store64(pids, 1);
    s = now_ns();
    gen_prime(pids, 1, 0);
    gen_decode(NGEN, f64_from(0), 0, 0, 0);
    e = now_ns();
    var un_ns = (e - s) / NGEN;
    _report("gen uncached     ", e - s, NGEN);
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    var ca_ns = (e - s) / NGEN;
    _report("gen kv-cached    ", e - s, NGEN);
    print("gen tokens/sec uncached: ", 25); fmt_int(1000000000 / un_ns); _putc(10);
    print("gen tokens/sec cached:   ", 25); fmt_int(1000000000 / ca_ns); _putc(10);
    print("gen speedup (x100):      ", 25); fmt_int(un_ns * 100 / ca_ns); _putc(10);

    # ---- KV-cache bytes vs nkv (the E2 lever; default config above) ----
    var nkv = 1;
    while (nkv <= g_nh) {
        print("kv cache bytes (nkv=", 20); fmt_int(nkv); print("): ", 3);
        fmt_int(2 * g_NL * g_T * (nkv * (g_C / g_nh)) * 8); _putc(10);
        nkv = nkv * 2;
    }

    # ---- GQA: training step + cached generation at nkv=1 (MQA) ----
    model_init(V, 32, 16, 4, 1, 3, 1, f64_from(0), 1337);
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step MQA ", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached MQA", e - s, NGEN);

    # ---- the --preset config (M7): ctx 64 / d_model 64 / 8 heads / 4 layers.
    # The context-shift re-prime amortizes over GEN_SHIFT()=32 tokens here
    # (vs 8 at the default), so the cached-vs-uncached ratio should widen.
    model_init(V, 64, 64, 8, 8, 4, 1, f64_from(0), 1337);
    model_forward(); model_zero_grads(); model_backward();   # prime
    var NP2 = 50;
    s = now_ns(); i = 0;
    while (i < NP2) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    var pstep_ns = (e - s) / NP2;
    _report("fwd+bwd preset   ", e - s, NP2);
    print("tokens/sec preset (b=16): ", 26);
    fmt_int(16 * g_T * 1000000000 / (16 * pstep_ns));
    _putc(10);
    g_training = 0;
    var NGP = 200;
    s = now_ns();
    gen_prime(pids, 1, 0);
    gen_decode(NGP, f64_from(0), 0, 0, 0);
    e = now_ns();
    var pun_ns = (e - s) / NGP;
    _report("gen uncached pre ", e - s, NGP);
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGP, f64_from(0), 1, 0, 0);
    e = now_ns();
    var pca_ns = (e - s) / NGP;
    _report("gen kv-cached pre", e - s, NGP);
    print("gen preset tokens/sec uncached: ", 32); fmt_int(1000000000 / pun_ns); _putc(10);
    print("gen preset tokens/sec cached:   ", 32); fmt_int(1000000000 / pca_ns); _putc(10);
    print("gen preset speedup (x100):      ", 32); fmt_int(pun_ns * 100 / pca_ns); _putc(10);

    # ---- MLA latent KV-cache decode (M12.2): default config (C=32 T=16 nh=4
    # NL=3), d_c = C/2 = 16. The cached path stores ONE d_c latent per token and
    # up-projects to full K/V on read; bit-identical to the uncached reference
    # (pinned in the tests). The headline is the cache-bytes table below, not
    # speed — the reference re-up-projects the context each step (compute parity
    # with MHA-cached is the absorption optimization, future work).
    model_init_arch(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 1, 16, 0, 0);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 0);
    gen_decode(NGEN, f64_from(0), 0, 0, 0);
    e = now_ns();
    var mun_ns = (e - s) / NGEN;
    _report("gen uncached MLA ", e - s, NGEN);
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    var mca_ns = (e - s) / NGEN;
    _report("gen latent-cache ", e - s, NGEN);
    print("gen MLA tokens/sec uncached: ", 29); fmt_int(1000000000 / mun_ns); _putc(10);
    print("gen MLA tokens/sec cached:   ", 29); fmt_int(1000000000 / mca_ns); _putc(10);
    # cache-bytes table: MLA latent vs the MHA/MQA full-K/V baselines at the same
    # C/T/nh/NL. d_c=16 -> NL*T*d_c*8; MHA nkv=4 -> 2*NL*T*C*8; MQA nkv=1.
    print("mla latent cache bytes (d_c=16): ", 33); fmt_int(kv_cache_bytes()); _putc(10);
    print("  vs MHA full K/V (nkv=4):       ", 33); fmt_int(2 * 3 * 16 * 32 * 8); _putc(10);
    print("  vs MQA full K/V (nkv=1):       ", 33); fmt_int(2 * 3 * 16 * (1 * (32 / 4)) * 8); _putc(10);

    # ---- coupled RoPE (M12 increment 4): training step + cached generation at
    # the default config vs the learned-abs baseline above. RoPE adds a per-pair
    # rotation (a Maclaurin cos/sin of the base angle + a binary-exponentiation
    # to the position) to Q/K in every attention; the question is the overhead.
    model_init_arch(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 0, 0, 1, 0);   # mha + rope
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step rope", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached rope", e - s, NGEN);

    # ---- decoupled RoPE (M12 increment 5): MLA + a separate d_rope channel.
    # The persistent cache is the latent c (d_c) PLUS the shared rope key K^R
    # (d_rope) per token — still far under full K/V. Default config, d_c=16,
    # d_rope=4.
    model_init_arch(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 1, 16, 2, 4);   # mla + decoupled
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen mla-dec cached", e - s, NGEN);
    print("mla-dec cache bytes (d_c=16,d_rope=4): ", 39); fmt_int(kv_cache_bytes()); _putc(10);
    print("  = latent NL*T*d_c*8 + rope NL*T*d_rope*8: ", 43);
    fmt_int(3 * 16 * 16 * 8); print(" + ", 3); fmt_int(3 * 16 * 4 * 8); _putc(10);
    print("  vs MHA full K/V (nkv=4):                  ", 43); fmt_int(2 * 3 * 16 * 32 * 8); _putc(10);

    # ---- MoE (M13, E8): training step + cached generation at N=8 experts,
    # top-2, vs the dense baseline (fwd+bwd step above). Only top-2 experts
    # compute per token (active FLOPs ~ 2 dense MLPs + the C->N router), but the
    # parameter count scales with N — the density knob. The router + per-expert
    # MLP backward are hand-derived + grad-checked (test_moe_op / test_model_moe).
    model_init_moe(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 0, 0, 0, 0, 8, 2);   # 8 experts, top-2
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step moe8", e - s, N);
    print("moe8 params (vs dense 39488): ", 30); fmt_int(g_NP); _putc(10);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached moe8", e - s, NGEN);

    # ---- gated linear attention (M14, E4): training step + cached generation at
    # the default config. Parameter-free over the MHA projections (same g_NP as
    # the dense baseline), and the decode cache is the CONSTANT per-layer state
    # (nh*hd^2), independent of T — the headline vs MHA/MLA's T-growing K/V.
    model_init_arch(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 2, 0, 0, 0);   # gated linear
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step lin ", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached lin", e - s, NGEN);
    print("lin state cache bytes (constant in T): ", 40); fmt_int(kv_cache_bytes()); _putc(10);
    print("  vs MHA full K/V at this config:       ", 40); fmt_int(2 * 3 * 16 * 32 * 8); _putc(10);

    # ---- selective SSM (M14 rung b): training step + cached generation at the
    # default config, state N=16. The data-dependent scan (Δ/B/C from the input,
    # the exp(Δ·A) discretization); the decode cache is the constant C×N state.
    model_init_arch(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 3, 16, 0, 0);   # selective SSM
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step ssm ", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached ssm", e - s, NGEN);
    print("ssm state cache bytes (constant in T): ", 40); fmt_int(kv_cache_bytes()); _putc(10);

    # ---- per-layer HYBRID (M14 rung c): a mha/lin hybrid (attention at layer 0,
    # gated-linear elsewhere) at the default config. The fwd+bwd cost is the mix of
    # the two mixers' steps; the decode cache is the SUM of per-layer caches — the
    # attention layers' T-growing K/V + the constant lin state — so it scales with
    # the attention fraction (here 1/3), trading cache for full attention.
    var hk[24]; store64(&hk + 0, 0); store64(&hk + 8, 2); store64(&hk + 16, 2);   # mha,lin,lin
    model_init_full(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 2, 0, 0, 0, 1, 1, &hk, 0);   # base lin
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step hyb ", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached hyb", e - s, NGEN);
    puts("hyb(1/3 mha) cache bytes (mixed): "); fmt_int(kv_cache_bytes()); _putc(10);
    puts("hyb(mha/lin) params (vs dense 39488, no pad — shared layout): "); fmt_int(g_NP); _putc(10);

    # ---- per-layer HYBRID, rung d (M14): a mha ⊕ SSM hybrid (full attention at
    # layer 0, selective-SSM elsewhere; base ssm, N=16) at the default config. The
    # block K/V region pads to the max kind size; the decode cache sums the one
    # attention layer's T-growing K/V + the SSM layers' constant C×N state.
    var hks[24]; store64(&hks + 0, 0); store64(&hks + 8, 3); store64(&hks + 16, 3);   # mha,ssm,ssm
    model_init_full(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 3, 16, 0, 0, 1, 1, &hks, 0);   # base ssm
    model_forward(); model_zero_grads(); model_backward();   # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step hyb-ssm", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_prime(pids, 1, 1);
    gen_decode(NGEN, f64_from(0), 1, 0, 0);
    e = now_ns();
    _report("gen kv-cached hyb-ssm", e - s, NGEN);
    puts("hyb-ssm(1/3 mha) cache bytes (mixed): "); fmt_int(kv_cache_bytes()); _putc(10);
    puts("hyb-ssm params (vs pure ssm 38048 — padding to MHA's region): "); fmt_int(g_NP); _putc(10);

    # ---- masked DIFFUSION (M15, E5): the bidirectional fwd+bwd step (full O(T^2)
    # attention vs causal's O(T^2/2)) over sample_window_diffusion, then the
    # confidence-ordered PARALLEL decode (uncached bidirectional, T rounds). The
    # decode is NOT KV-cached — diffusion denoises the whole window each round.
    model_init_full(V, 32, 16, 4, 4, 3, 1, f64_from(0), 1337, 0, 0, 0, 0, 1, 1, 0, 1);   # diffusion (bidir)
    sample_window_diffusion(); model_forward(); model_zero_grads(); model_backward();    # prime
    s = now_ns(); i = 0;
    while (i < N) {
        model_zero_grads(); sample_window_diffusion(); model_forward(); model_backward();
        i = i + 1;
    }
    e = now_ns();
    _report("fwd+bwd step diffusion", e - s, N);
    g_training = 0;
    s = now_ns();
    gen_diffusion("cyrius ", 7, g_T, 0, 0);   # T-round cosine unmask, no emit
    e = now_ns();
    _report("gen diffusion (T-round unmask)", e - s, g_T);
    puts("diffusion params (vs dense 39488, +C mask_emb): "); fmt_int(g_NP); _putc(10);

    # ---- isolated tied LM head at BPE-scale vocab (V=768): the M9 lever-1
    # target. head_fwd_row is O(V*C) per row and runs in every training forward
    # and every generated token; its share grows with the vocab, so bench it
    # where it bites (BPE can push V to 768), not at the V=25 default.
    model_init(768, 64, 64, 8, 8, 4, 1, f64_from(0), 1337);
    sample_window(); model_forward();            # populate A_f (the head input)
    var NHD = 2000;
    s = now_ns(); i = 0; while (i < NHD) { head_fwd_n(g_T); i = i + 1; } e = now_ns();
    _report("head_fwd V768 C64", e - s, NHD);

    # ---- BPE merge training (one-shot, pre-training cost; M7) ----
    # 256 KB of repeated corpus text — content quality is irrelevant to the
    # count/argmax/replace loop cost being measured.
    var seg = alloc(256);
    var slen = corpus_build(seg);
    var big = alloc(262144);
    var bl = 0;
    while (bl + slen < 262144) {
        var si = 0;
        while (si < slen) { store8(big + bl + si, load8(seg + si)); si = si + 1; }
        bl = bl + slen;
    }
    corpus_set(big, bl);
    s = now_ns();
    var bv = bpe_learn(128);
    e = now_ns();
    print("bpe_learn 256KB K=128: ", 23); fmt_int((e - s) / 1000000);
    print(" ms (V=", 7); fmt_int(bv); print(")\n", 2);
    return 0;
}

# Statement-call epilogue (not a `var` initializer) — see docs/architecture/002.
var r = 0;
r = main();
sys_exit(r);
